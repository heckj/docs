  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/actor-isolated-mutating-async"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Calling a mutating async actor-isolated method (ActorIsolatedMutatingAsync)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Calling a mutating async method on actor-isolated state allows concurrent access to that state during mutation, risking data races. To resolve this error, copy the state to a local variable, call the mutating async method on the copy, then write it back. This will overwrite concurrent changes.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "For example:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "struct Backpack {",
            "  var snacks = 5",
            "  mutating func refill() async {",
            "    snacks += await purchaseSnacks(current: snacks)",
            "  }",
            "}",
            "",
            "@MainActor",
            "class Hiker {",
            "  var backpack = Backpack()",
            "",
            "  func getReady() async {",
            "    await backpack.refill()",
            "  }",
            "",
            "  func eatSnack() {",
            "    backpack.snacks -= 1",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Building the above code produces an error about calling a mutating async function on an actor-isolated property:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "|   func getReady() async {",
            "|     await backpack.refill()",
            "|           |        `- error: cannot call mutating async function 'refill()' on actor-isolated property 'backpack' [#ActorIsolatedMutatingAsync]",
            "|           `- note: 'backpack' can be concurrently accessed during mutation, risking data races",
            "|   }"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "A ",
              "type" : "text"
            },
            {
              "code" : "mutating async",
              "type" : "codeVoice"
            },
            {
              "text" : " function takes ",
              "type" : "text"
            },
            {
              "code" : "self",
              "type" : "codeVoice"
            },
            {
              "text" : " as ",
              "type" : "text"
            },
            {
              "code" : "inout",
              "type" : "codeVoice"
            },
            {
              "text" : ". This means that the value of ",
              "type" : "text"
            },
            {
              "code" : "backpack",
              "type" : "codeVoice"
            },
            {
              "text" : " will be copied into ",
              "type" : "text"
            },
            {
              "code" : "refill",
              "type" : "codeVoice"
            },
            {
              "text" : ", then copied out when the method returns. ",
              "type" : "text"
            },
            {
              "code" : "inout",
              "type" : "codeVoice"
            },
            {
              "text" : " requires exclusive access for the duration of the call. While ",
              "type" : "text"
            },
            {
              "code" : "refill",
              "type" : "codeVoice"
            },
            {
              "text" : " is suspended, the main actor is free to do other work. This is a data race, since ",
              "type" : "text"
            },
            {
              "code" : "refill",
              "type" : "codeVoice"
            },
            {
              "text" : " is still mutating ",
              "type" : "text"
            },
            {
              "code" : "backpack",
              "type" : "codeVoice"
            },
            {
              "text" : ". If ",
              "type" : "text"
            },
            {
              "code" : "eatSnack",
              "type" : "codeVoice"
            },
            {
              "text" : " ran before ",
              "type" : "text"
            },
            {
              "code" : "refill",
              "type" : "codeVoice"
            },
            {
              "text" : " finished, it would decrement ",
              "type" : "text"
            },
            {
              "code" : "snacks",
              "type" : "codeVoice"
            },
            {
              "text" : ", but the eaten snack reappears when ",
              "type" : "text"
            },
            {
              "code" : "refill",
              "type" : "codeVoice"
            },
            {
              "text" : " writes back the stale copy.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "\/\/ Task 1: getReady()                  | \/\/ Task 2",
            "await backpack.refill()",
            "\/\/ copies backpack (snacks: 5)         |",
            "\/\/ suspends...                         |",
            "                                         eatSnack()",
            "\/\/                                     | \/\/ backpack.snacks is now 4",
            "\/\/ resumes                             |",
            "\/\/ purchaseSnacks returns 0            |",
            "\/\/ writes back backpack (snacks: 5)    |",
            "\/\/ backpack.snacks is 5                |",
            "\/\/ eatSnack() was silently lost!       |"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "When possible, you can structure code to avoid the need for mutating async functions by separating async computation and mutation:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func getReady() async {",
            "  \/\/ await the asynchronous computation",
            "  let refill = await backpack.computeRefill()",
            "  \/\/ apply the mutation synchronously",
            "  backpack.apply(refill)",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Because the mutation is synchronous, no concurrent changes can occur between reading and writing ",
              "type" : "text"
            },
            {
              "code" : "backpack",
              "type" : "codeVoice"
            },
            {
              "text" : " as part of ",
              "type" : "text"
            },
            {
              "code" : "apply",
              "type" : "codeVoice"
            },
            {
              "text" : ". If ",
              "type" : "text"
            },
            {
              "code" : "eatSnack",
              "type" : "codeVoice"
            },
            {
              "text" : " is called concurrently while ",
              "type" : "text"
            },
            {
              "code" : "computeRefill",
              "type" : "codeVoice"
            },
            {
              "text" : " is suspended, the ",
              "type" : "text"
            },
            {
              "code" : "Hiker",
              "type" : "codeVoice"
            },
            {
              "text" : " may purchase too few snacks, but the decrement from eating a snack won’t be lost.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "If restructuring isn’t appropriate, copy ",
              "type" : "text"
            },
            {
              "code" : "backpack",
              "type" : "codeVoice"
            },
            {
              "text" : " to a local variable to make the potential overwrite explicit at the call site. This way, the call site shows that ",
              "type" : "text"
            },
            {
              "code" : "backpack",
              "type" : "codeVoice"
            },
            {
              "text" : " is overwritten after ",
              "type" : "text"
            },
            {
              "code" : "await",
              "type" : "codeVoice"
            },
            {
              "text" : ", rather than happening implicitly due to ",
              "type" : "text"
            },
            {
              "code" : "inout",
              "type" : "codeVoice"
            },
            {
              "text" : ". Because ",
              "type" : "text"
            },
            {
              "code" : "copy",
              "type" : "codeVoice"
            },
            {
              "text" : " is a local variable, it is not shared with other tasks and can be safely mutated.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func getReady() async {",
            "  var copy = backpack",
            "  await copy.refill()",
            "  backpack = copy",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "See-also",
          "level" : 2,
          "text" : "See also",
          "type" : "heading"
        },
