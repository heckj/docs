  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "@dynamicCallable implementation requirements (DynamicCallable)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "If a type is marked with the ",
              "type" : "text"
            },
            {
              "code" : "@dynamicCallable",
              "type" : "codeVoice"
            },
            {
              "text" : " attribute, it must provide a valid implementation of ",
              "type" : "text"
            },
            {
              "code" : "dynamicallyCall(withArguments:)",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "dynamicallyCall(withKeywordArguments:)",
              "type" : "codeVoice"
            },
            {
              "text" : ", or both. If it fails to do so, an error will be reported at compile-time. Note that an implementation of ",
              "type" : "text"
            },
            {
              "code" : "dynamicallyCall(withKeywordArguments:)",
              "type" : "codeVoice"
            },
            {
              "text" : " is required to support calls with keyword arguments.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "To be considered valid, an implementation of ",
              "type" : "text"
            },
            {
              "code" : "dynamicallyCall(withArguments:)",
              "type" : "codeVoice"
            },
            {
              "text" : " must:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Be an instance method. ",
                      "type" : "text"
                    },
                    {
                      "code" : "static",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " or ",
                      "type" : "text"
                    },
                    {
                      "code" : "class",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " implementations are not allowed.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Have an argument type which conforms to the ",
                      "type" : "text"
                    },
                    {
                      "code" : "ExpressibleByArrayLiteral",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " protocol. Often, this will be the built in ",
                      "type" : "text"
                    },
                    {
                      "code" : "Array",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " type.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "The return type of ",
                      "type" : "text"
                    },
                    {
                      "code" : "dynamicallyCall(withArguments:)",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " may be any valid type.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "To be considered valid, an implementation of ",
              "type" : "text"
            },
            {
              "code" : "dynamicallyCall(withKeywordArguments:)",
              "type" : "codeVoice"
            },
            {
              "text" : " must:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Be an instance method. ",
                      "type" : "text"
                    },
                    {
                      "code" : "static",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " or ",
                      "type" : "text"
                    },
                    {
                      "code" : "class",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " implementations are not allowed.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Have an argument type which conforms to the ",
                      "type" : "text"
                    },
                    {
                      "code" : "ExpressibleByDictionaryLiteral",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " protocol. This can be ",
                      "type" : "text"
                    },
                    {
                      "code" : "Dictionary",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : ", ",
                      "type" : "text"
                    },
                    {
                      "code" : "KeyValuePairs",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " (which may be used to support duplicated keyword arguments), or some other conforming type.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "The ",
                      "type" : "text"
                    },
                    {
                      "code" : "Key",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " associated type of the argument type must conform to the ",
                      "type" : "text"
                    },
                    {
                      "code" : "ExpressibleByStringLiteral",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " protocol. This type is used to represent the dynamic argument keywords.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "The ",
                      "type" : "text"
                    },
                    {
                      "code" : "Value",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " associated type of the argument type and the return type of ",
                      "type" : "text"
                    },
                    {
                      "code" : "dynamicallyCall(withKeywordArguments:)",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " may be any valid types.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "See-also",
          "level" : 2,
          "text" : "See also",
          "type" : "heading"
        },
        {
          "items" : [
