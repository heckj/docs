    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/existential-type"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Existential Types and Performance (ExistentialType)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Existential types enable runtime polymorphism by allowing a variable to store a",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "type-erased value - a value whose concrete type is not known at compile time,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "but is known to conform to a specified protocol.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Performance-Costs",
          "level" : 2,
          "text" : "Performance Costs",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "To accommodate the variation in size and layout of the concrete values at",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "runtime, existentials are implemented as containers with two main components:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "A pointer to the heap-allocated value (values up to 24 bytes are inlined).",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "A witness table to extract the concrete type and dispatch to the",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "corresponding concrete implementation.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "orderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "This runtime abstraction imposes performance penalties rendering existentials",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "undesirable for performance-critical code paths.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "Exclusivity Enforcement",
                              "type" : "text"
                            }
                          ],
                          "type" : "strong"
                        }
                      ],
                      "type" : "emphasis"
                    },
                    {
                      "text" : " - Existential containers obscure the concrete",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "type from the compiler, preventing static verification of Swift’s ",
                      "type" : "text"
                    },
                    {
                      "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0176-enforce-exclusive-access-to-memory.md",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : ".",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "This forces the compiler to insert dynamic runtime checks on each access to",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "prevent simultaneous conflicting accesses. These checks verify at runtime",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "that the existential value is not being accessed elsewhere, potentially",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "causing a runtime trap if exclusivity is violated. In tight loops or",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "performance-critical paths with frequent property or method access on",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "existentials, these dynamic exclusivity checks dominate the combined cost of",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "heap allocation and dynamic dispatch. The type-erased nature of existentials",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "makes it particularly difficult for the compiler to optimize away these",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "checks through static analysis.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "Reference Counting",
                              "type" : "text"
                            }
                          ],
                          "type" : "strong"
                        }
                      ],
                      "type" : "emphasis"
                    },
                    {
                      "text" : " - Existentials use the witness table to implement",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "retain\/release operations on reference-counted values (both reference and",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "value types) during copy, move, and destroy operations. In addition to the",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "overhead of calling these functions, this indirection prevents inlining of",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "the reference counting logic.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "Heap Allocation",
                              "type" : "text"
                            }
                          ],
                          "type" : "strong"
                        }
                      ],
                      "type" : "emphasis"
                    },
                    {
                      "text" : " - Existentials use heap allocation for all values",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "larger than 24 bytes, including value types like structs. Heap allocations",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "are costly, and accessing a heap-allocated value via a pointer incurs",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "indirection overhead with potential for cache misses.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "Dynamic Dispatch",
                              "type" : "text"
                            }
                          ],
                          "type" : "strong"
                        }
                      ],
                      "type" : "emphasis"
                    },
                    {
                      "text" : " - Method calls on existential types always use dynamic",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "dispatch via the witness table, even for non-virtual methods, since the",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "concrete type of the value is not known at compile time. Apart from the",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "overhead of calling these methods indirectly via the witness table, the",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "indirection prevents standard compiler optimizations such as function",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "inlining and specialization.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "orderedList"
        },
        {
          "anchor" : "Alternatives",
          "level" : 2,
          "text" : "Alternatives",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Given the significant runtime costs imposed by the use of existentials, it is",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "only recommended to use existentials sparingly in performance-critical code,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "preferably at API boundaries or for heterogeneous collections where performance",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "is not critical. Various solutions to eliminate the use of existentials require",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "redesigning the code to avoid runtime polymorphism.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "1-Concrete-Types",
          "level" : 3,
          "text" : "1. Concrete Types",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "If possible, change the implementation to use concrete types. Function",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "overloading can be used to implement separate functions with the same name for",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "every concrete type. Knowing the exact object type at compile time enables the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "whole suite of compiler optimizations.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "protocol Editor { ... }",
            "struct Emacs: Editor { ... }",
            "struct Vim: Editor { ... }",
            "",
            "func moveCursor(_ emacs: Emacs) { ... }",
            "func moveCursor(_ vim: Vim) { ... }"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "2-Generic-Constraints",
          "level" : 3,
          "text" : "2. Generic Constraints",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "For functions that follow the same template for all concrete types conforming to",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "a protocol, ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/generics\/#Type-Constraints",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "can be used instead of repeating the code manually with function overloading.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The compiler will instantiate the code for all concrete types, ensuring static",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "dispatch, inlining, stack allocation for value types, and other standard",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "compiler optimizations blocked by the indirection from dynamic dispatch. This is",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "especially useful for homogeneous collections.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func processEditors<T: Editor>(_ editors: [T]) {",
            "    for editor in editors {",
            "        editor.moveCursor()",
            "    }",
            "}",
            "",
            "let editors: [Emacs] = [Emacs(), Emacs(), Emacs()]",
            "processEditors(editors)"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "3-Opaque-Types",
          "level" : 3,
          "text" : "3. Opaque Types",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "If a single concrete type that conforms to a protocol is being used on all",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "paths, but the concrete type needs to stay hidden, consider using an ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/opaquetypes\/",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Opaque types afford the flexibility of switching to a different concrete type as",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "long as it conforms to the same protocol. Since the compiler knows the concrete",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "type, the code will not incur any existential container overhead and method",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "calls will be dispatched statically unless the opaque type is used across module",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "boundaries and cross-module optimization is disabled or the function cannot be",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "inlined.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func instantiateBestEditor() -> some Editor {",
            "    return Emacs()  \/\/ Compiler knows return type is Emacs",
            "}",
            "",
            "func getDeprecatedEditorPair() -> (some Editor, some Editor) {",
            "    let vim1 = Vim()",
            "    let vim2 = Vim()",
            "    return (vim1, vim2)",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "4-Enum-Types",
          "level" : 3,
          "text" : "4. Enum Types",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use an",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/enumerations\/",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "to model the domain if there is a known fixed set of types conforming to a",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "protocol that cannot be extended by clients. Dispatch on ",
              "type" : "text"
            },
            {
              "code" : "enum",
              "type" : "codeVoice"
            },
            {
              "text" : " cases incurs no",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "overhead since it is optimized to a jump table. There is also no performance",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "loss from pointer indirection since enums are stack allocated.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "enum Editor {",
            "    case emacs(Emacs)",
            "    case vim(Vim)",
            "",
            "    func moveCursor() {",
            "        switch self {",
            "        case .emacs(let e): ...",
            "        case .vim(let v): ...",
            "        }",
            "    }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "5-Type-Erasure",
          "level" : 3,
          "text" : "5. Type Erasure",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Type erasure is a technique that hides the concrete types of constrained objects",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "behind a single type. Conceptually, this technique involves explicitly",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "implementing a witness-table-like functionality in Swift, mimicking existential",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "containers. This is particulary useful for heterogeneous collections. In the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "following example, we intend to call ",
              "type" : "text"
            },
            {
              "code" : "moveCursor",
              "type" : "codeVoice"
            },
            {
              "text" : " on a heterogeneous collection",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "of ",
              "type" : "text"
            },
            {
              "code" : "Editor",
              "type" : "codeVoice"
            },
            {
              "text" : " types. So we wrap all ",
              "type" : "text"
            },
            {
              "code" : "Editor",
              "type" : "codeVoice"
            },
            {
              "text" : " types inside an ",
              "type" : "text"
            },
            {
              "code" : "AnyEditor",
              "type" : "codeVoice"
            },
            {
              "text" : " struct",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "that implements a generic initializer to capture the concrete type and invoke",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "its ",
              "type" : "text"
            },
            {
              "code" : "moveCursor",
              "type" : "codeVoice"
            },
            {
              "text" : " implementation inside a closure. This approach can be easily",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "extended to other methods. While the code still incurs the indirection cost of",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "invoking the methods via closures, it can be controlled and limited to specific",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "methods.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "struct AnyEditor: Editor {",
            "    private let _moveCursor: () -> Void",
            "",
            "    init<T: Editor>(_ editor: T) {",
            "        _moveCursor = { editor.moveCursor() }",
            "    }",
            "",
            "    func moveCursor() {",
            "        _moveCursor()",
            "    }",
            "}",
            "",
            "let editors: [AnyEditor] = [",
            "    AnyEditor(Emacs()),",
            "    AnyEditor(Vim())",
            "]"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "Summary",
          "level" : 2,
          "text" : "Summary",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Existential types trade performance for flexibility - values are heap allocated",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "and accessed indirectly through a pointer, reference counting is not inlined,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "and methods are dispatched dynamically. It is strongly recommended to refactor",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "hot paths in the code to eliminate runtime polymorphism. Use concrete types,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "generic constraints, or opaque types to ensure that the types are known at",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "compile time. Use enum if the set of cases is fixed and known ahead-of-time. Use",
              "type" : "text"
