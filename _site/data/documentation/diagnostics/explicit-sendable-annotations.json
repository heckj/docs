{
  "abstract" : [
    {
      "text" : "Adds a warning for any public types without a ",
      "type" : "text"
    },
    {
      "code" : "Sendable",
      "type" : "codeVoice"
    },
    {
      "text" : " annotation.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/diagnostics\/documentation\/diagnostics",
