  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/explicit-sendable-annotations"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Explicit `Sendable` annotations on public type declarations (ExplicitSendable)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "When enabled, the compiler will emit a warning if a public type has none of the following:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "A conformance to ",
                      "type" : "text"
                    },
                    {
                      "code" : "Sendable",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " protocol;",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "An unavailable conformance to ",
                      "type" : "text"
                    },
                    {
                      "code" : "Sendable",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " protocol;",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "~Sendable",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " conformance to suppress the inference.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "For example, given a simple public type:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "public struct S {",
            "    let x: Int",
            "}"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "As it has no ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " annotations, this diagnostic group will add the following warning:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "1 | public struct S {",
            "  |               |- warning: public struct 'S' does not specify whether it is 'Sendable' or not [#ExplicitSendable]",
            "  |               |- note: consider making struct 'S' conform to the 'Sendable' protocol",
            "  |               `- note: make struct 'S' explicitly non-Sendable to suppress this warning",
            "2 |     let x: Int",
            "3 | }"
          ],
          "syntax" : null,
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
  ],
