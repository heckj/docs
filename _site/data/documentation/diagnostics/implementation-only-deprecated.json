  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Deprecated implementation-only imports (ImplementationOnlyDeprecated)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "When applied to ",
              "type" : "text"
            },
            {
              "code" : "import",
              "type" : "codeVoice"
            },
            {
              "text" : " declarations, the compiler-internal attribute ",
              "type" : "text"
            },
            {
              "code" : "@_implementationOnly",
              "type" : "codeVoice"
            },
            {
              "text" : " attempts prevents declarations from the imported module from being exposed in the ABI or public interface of the dependent module. This attribute became deprecated when support for access levels on ",
              "type" : "text"
            },
            {
              "code" : "import",
              "type" : "codeVoice"
            },
            {
              "text" : " declarations was introduced with ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0409-access-level-on-imports.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "One reason ",
              "type" : "text"
            },
            {
              "code" : "@_implementationOnly import",
              "type" : "codeVoice"
            },
            {
              "text" : " is deprecated is that it is unsafe when used in modules that are built ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "without",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/www.swift.org\/blog\/library-evolution\/",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " enabled. For example, suppose the following code were part of a library named ",
              "type" : "text"
            },
            {
              "code" : "Foo",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "\/\/ Library `Foo`",
            "@_implementationOnly import ImplementationDetail",
            "",
            "public struct Bar {",
            "  internal var x: Baz \/\/ defined in ImplementationDetail",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If ",
              "type" : "text"
            },
            {
              "code" : "Foo",
              "type" : "codeVoice"
            },
            {
              "text" : " is not compiled with library evolution, then the memory layout of values of ",
              "type" : "text"
            },
            {
              "code" : "Bar",
              "type" : "codeVoice"
            },
            {
              "text" : " must be known at compile time in clients of ",
              "type" : "text"
            },
            {
              "code" : "Foo",
              "type" : "codeVoice"
            },
            {
              "text" : ". However, the ",
              "type" : "text"
            },
            {
              "code" : "@_implementationOnly import",
              "type" : "codeVoice"
            },
            {
              "text" : " of ",
              "type" : "text"
            },
            {
              "code" : "ImplementationDetail",
              "type" : "codeVoice"
            },
            {
              "text" : " prevents clients from being able to look up ",
              "type" : "text"
            },
            {
              "code" : "Baz",
              "type" : "codeVoice"
            },
            {
              "text" : " which is a type that contributes to the layout of ",
              "type" : "text"
            },
            {
              "code" : "Foo",
              "type" : "codeVoice"
            },
            {
              "text" : ". As a result, the layout of ",
              "type" : "text"
            },
            {
              "code" : "Foo",
              "type" : "codeVoice"
            },
            {
              "text" : " will be miscalculated resulting in undefined behavior.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
