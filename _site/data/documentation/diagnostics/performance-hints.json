  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Performance Hints (PerformanceHints)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "PerformanceHints",
              "type" : "codeVoice"
            },
            {
              "text" : " diagnostic group provides opt-in guidance for identifying",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "language constructs and code patterns that carry non-obvious runtime performance",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "costs. The diagnostics are intended to help developers writing",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "performance-critical code make informed decisions about the abstractions they",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "use and to surface hidden costs that may not be apparent from the source code",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "alone to a non-expert Swift programmer.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "This diagnostic group is ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "off by default",
                  "type" : "text"
                }
              ],
              "type" : "strong"
            },
            {
              "text" : ". It can be enabled as warnings with",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "-Wwarning PerformanceHints",
              "type" : "codeVoice"
            },
            {
              "text" : ", or escalated to errors with ",
              "type" : "text"
            },
            {
              "code" : "-Werror PerformanceHints",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Sub-groups",
          "level" : 2,
          "text" : "Sub-groups",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "PerformanceHints",
              "type" : "codeVoice"
            },
            {
              "text" : " group contains the following sub-groups, each of which",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "can also be enabled or controlled independently:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "identifier" : "doc:\/\/diagnostics\/documentation\/diagnostics\/existential-type",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : ": Warns on use of existential types (",
                      "type" : "text"
                    },
                    {
                      "code" : "any Protocol",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : "),",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "which incur heap allocation, reference counting, exclusivity enforcement, and",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "dynamic dispatch overhead.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "identifier" : "doc:\/\/diagnostics\/documentation\/diagnostics\/return-type-implicit-copy",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : ": Warns when functions or closures return",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "code" : "Array",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " or ",
                      "type" : "text"
                    },
                    {
                      "code" : "Dictionary",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " values, which leads to implicit heap-allocated copies",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "of the collections.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "identifier" : "doc:\/\/diagnostics\/documentation\/diagnostics\/untyped-throws",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : ": Warns on untyped ",
                      "type" : "text"
                    },
                    {
                      "code" : "throws",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " declarations, where the use of",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "code" : "any Error",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " incurs a heap allocation on each ",
                      "type" : "text"
                    },
                    {
                      "code" : "throw",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : ".",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "For example, to enable only the ",
              "type" : "text"
            },
            {
              "code" : "UntypedThrows",
              "type" : "codeVoice"
            },
            {
              "text" : " checks as warnings:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "-Wwarning UntypedThrows"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Or to enable all performance hints as errors but keep ",
              "type" : "text"
            },
            {
              "code" : "UntypedThrows",
              "type" : "codeVoice"
            },
            {
              "text" : " as a",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "warning:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "-Werror PerformanceHints -Wwarning UntypedThrows"
          ],
          "syntax" : null,
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
  ],
