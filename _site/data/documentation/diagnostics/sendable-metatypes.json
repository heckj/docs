  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/sendable-metatypes"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Sendable metatypes (SendableMetatypes)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Types that are shared in concurrent code generally need to conform to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ". The same is true in generic code when sharing parameters of a generic parameter ",
              "type" : "text"
            },
            {
              "code" : "T",
              "type" : "codeVoice"
            },
            {
              "text" : ". For example, the given code will produce an error under strict concurrency checking",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func doSomethingElsewhere<T>(_ value: T) {",
            "  Task { @concurrent in",
            "    print(value) \/\/ warning: capture of non-Sendable type 'T'",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "because ",
              "type" : "text"
            },
            {
              "code" : "value",
              "type" : "codeVoice"
            },
            {
              "text" : " can have a non-Sendable type that is not safe to share. To address this potential data race, the type ",
              "type" : "text"
            },
            {
              "code" : "T",
              "type" : "codeVoice"
            },
            {
              "text" : " can be marked as ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func doSomethingElsewhere<T: Sendable>(_ value: T) {",
            "  Task { @concurrent in",
            "    print(value)",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The same issue can occur when passing the type ",
              "type" : "text"
            },
            {
              "code" : "T",
              "type" : "codeVoice"
            },
            {
              "text" : " itself, rather than a value of type ",
              "type" : "text"
            },
            {
              "code" : "T",
              "type" : "codeVoice"
            },
            {
              "text" : ". The compiler will indicate such problems by noting that the metatype of ",
              "type" : "text"
            },
            {
              "code" : "T",
              "type" : "codeVoice"
            },
            {
              "text" : ", spelled ",
              "type" : "text"
            },
            {
              "code" : "T.Type",
              "type" : "codeVoice"
            },
            {
              "text" : ", is not ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "protocol P {",
            "  static func doSomething()",
            "}",
            "",
            "func doSomethingStatic<T: P>(_: T.Type) {",
            "  Task { @concurrent in",
            "    T.doSomething() \/\/ warning: capture of non-Sendable type 'T.Type' in an isolated closure",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "In these cases, the type parameter should be required to conform to the ",
              "type" : "text"
            },
            {
              "code" : "SendableMetatype",
              "type" : "codeVoice"
            },
            {
              "text" : " protocol, e.g.,",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func doSomethingStatic<T: P & SendableMetatype>(_: T.Type) {",
            "  Task { @concurrent in",
            "    T.doSomething()",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "SendableMetatype",
              "type" : "codeVoice"
            },
            {
              "text" : " requirement allows the function to share the type ",
              "type" : "text"
            },
            {
              "code" : "T",
              "type" : "codeVoice"
            },
            {
              "text" : " in concurrent code. To maintain data race safety, it prevents callers from using isolated conformances in the call. For example, the following code will be rejected due to a data race:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@MainActor",
            "class C: @MainActor P {",
            "  static func doSomething() { }",
            "}",
            "",
            "@MainActor",
            "func test(c: C) {",
            "  doSomethingStatic(C.self) \/\/ error: main actor-isolated conformance of 'C' to 'P' cannot satisfy conformance requirement for a 'Sendable' type parameter",
            "}",
            ""
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The conformance of ",
              "type" : "text"
            },
            {
              "code" : "C",
              "type" : "codeVoice"
            },
            {
              "text" : " to ",
              "type" : "text"
            },
            {
              "code" : "P",
              "type" : "codeVoice"
            },
            {
              "text" : " can only be used on the main actor, so it cannot be provided to ",
              "type" : "text"
            },
            {
              "code" : "doSomethingStatic",
              "type" : "codeVoice"
            },
            {
              "text" : ", which calls the conformance from a different concurrent task.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
