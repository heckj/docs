    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/string-interpolation-conformance"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Conforming to `StringInterpolationProtocol` (StringInterpolationConformance)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "A type conforming to ",
              "type" : "text"
            },
            {
              "code" : "ExpressibleByStringInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : " uses a helper type called ",
              "type" : "text"
            },
            {
              "code" : "StringInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : " to perform its interpolation. Many types can use ",
              "type" : "text"
            },
            {
              "code" : "DefaultStringInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : ", which implements ",
              "type" : "text"
            },
            {
              "code" : "String",
              "type" : "codeVoice"
            },
            {
              "text" : "’s interpolation behavior. Types can also implement custom behavior by providing their own type conforming to ",
              "type" : "text"
            },
            {
              "code" : "StringInterpolationProtocol",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "In addition to its formal requirements, ",
              "type" : "text"
            },
            {
              "code" : "init(literalCapacity:interpolationCount:)",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "appendLiteral(_:)",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "StringInterpolationProtocol",
              "type" : "codeVoice"
            },
            {
              "text" : " has an additional, informal requirement, ",
              "type" : "text"
            },
            {
              "code" : "appendInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : ". String interpolations using ",
              "type" : "text"
            },
            {
              "code" : "\\()",
              "type" : "codeVoice"
            },
            {
              "text" : " syntax are translated into calls to matching ",
              "type" : "text"
            },
            {
              "code" : "appendInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : " methods.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "code" : "StringInterpolationProtocol",
              "type" : "codeVoice"
            },
            {
              "text" : " conformers must provide at least one ",
              "type" : "text"
            },
            {
              "code" : "appendInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : " method which:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Is an instance method, as opposed to a ",
                      "type" : "text"
                    },
                    {
                      "code" : "static",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " or ",
                      "type" : "text"
                    },
                    {
                      "code" : "class",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " method",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Does not specify a return type, explicitly returns ",
                      "type" : "text"
                    },
                    {
                      "code" : "Void",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : ", or is marked with the ",
                      "type" : "text"
                    },
                    {
                      "code" : "@discardableResult",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " attribute",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Is at least as accessible as its containing type",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "There are no restrictions on an ",
              "type" : "text"
            },
            {
              "code" : "appendInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : " method’s argument list, generic parameters, availability, or error-throwing behavior.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "If ",
              "type" : "text"
            },
            {
              "code" : "appendInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : " is overloaded, the Swift compiler will choose an appropriate overload using the labels and argument types of each interpolation. When choosing an overload, any accessible ",
              "type" : "text"
            },
            {
              "code" : "appendInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : " instance method may be used, even if it does not meet all of the requirements above. However, if a ",
              "type" : "text"
            },
            {
              "code" : "StringInterpolationProtocol",
              "type" : "codeVoice"
            },
            {
              "text" : " conformer doesn’t have any ",
              "type" : "text"
            },
            {
              "code" : "appendInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : " methods which meet all of the requirements, an error will be reported at compile time.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "To learn more about customizing string interpolation behavior, see the standard library documentation of the ",
              "type" : "text"
            },
            {
              "code" : "ExpressibleByStringInterpolation",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "StringInterpolationProtocol",
              "type" : "codeVoice"
            },
            {
              "text" : " protocols.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
