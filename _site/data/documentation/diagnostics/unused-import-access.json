  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Unused import access level (UnusedImportAccess)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "A ",
              "type" : "text"
            },
            {
              "code" : "public",
              "type" : "codeVoice"
            },
            {
              "text" : " or ",
              "type" : "text"
            },
            {
              "code" : "package",
              "type" : "codeVoice"
            },
            {
              "text" : " import was not referenced in any declarations at the corresponding access level.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "A ",
              "type" : "text"
            },
            {
              "code" : "public import",
              "type" : "codeVoice"
            },
            {
              "text" : " is expected to be used either by ",
              "type" : "text"
            },
            {
              "code" : "public",
              "type" : "codeVoice"
            },
            {
              "text" : " declarations or by function bodies that are exposed to other modules using an attribute like ",
              "type" : "text"
            },
            {
              "code" : "@inlinable",
              "type" : "codeVoice"
            },
            {
              "text" : ". A ",
              "type" : "text"
            },
            {
              "code" : "package import",
              "type" : "codeVoice"
            },
            {
              "text" : " is expected to be used by ",
              "type" : "text"
            },
            {
              "code" : "package",
              "type" : "codeVoice"
            },
            {
              "text" : " declarations. If the imported module is not referenced in any declarations with the corresponding access level then its access level can be reduced to avoid exposing unnecessary dependencies.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "To resolve this warning, either lower the access level of the import or remove it if it is unused entirely. If the module is built with ",
              "type" : "text"
            },
            {
              "code" : "-enable-upcoming-feature InternalImportsByDefault",
              "type" : "codeVoice"
            },
            {
              "text" : ", the access level can be omitted to make the import ",
              "type" : "text"
            },
            {
              "code" : "internal",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
