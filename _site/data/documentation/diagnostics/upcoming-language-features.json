        {
          "inlineContent" : [
            {
              "text" : "Upcoming language features allow the incremental adoption of language features that would otherwise",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "only be available in a new language mode, without having to fully migrate to that mode. They can be",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "enabled on the command line with ",
              "type" : "text"
            },
            {
              "code" : "-enable-upcoming-feature <feature>",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Some upcoming features have an additional “migration” mode, where the compiler will emit warnings",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "with fix-its to help migrate to that mode. This can be enabled with ",
              "type" : "text"
            },
            {
              "code" : "-enable-upcoming-feature <feature>:migrate",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
