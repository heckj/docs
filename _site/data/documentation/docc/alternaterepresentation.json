      "parameters" : [
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "A link to another symbol that should be considered an alternate language representation of the current symbol.",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "(required)",
                      "type" : "text"
                    }
                  ],
                  "type" : "strong"
                }
              ],
              "type" : "paragraph"
            },
            {
              "inlineContent" : [
                {
                  "text" : "If you prefer, you can wrap the symbol link in a set of double backticks (``).",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "reference"
        }
      ]
    },
    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "An API that can be called from more than one source language has more than one language representation.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Whenever possible, prefer to define alternative language representations for a symbol by using in-source annotations",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "such as the ",
              "type" : "text"
            },
            {
              "code" : "@objc",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "@_objcImplementation",
              "type" : "codeVoice"
            },
            {
              "text" : " attributes in Swift,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "or the ",
              "type" : "text"
            },
            {
              "code" : "NS_SWIFT_NAME",
              "type" : "codeVoice"
            },
            {
              "text" : " macro in Objective-C.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "If your source language doesn’t have a mechanism for specifying alternate representations or if your intended alternate representation isn’t compatible with those attributes,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "you can use the ",
              "type" : "text"
            },
            {
              "code" : "@AlternateRepresentation",
              "type" : "codeVoice"
            },
            {
              "text" : " directive to specify another symbol that should be considered an alternate representation of the documented symbol.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Metadata {",
            "    @AlternateRepresentation(MyApp\/MyClass\/property)",
            "}"
          ],
          "syntax" : "md",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If you prefer, you can wrap the symbol link in a set of double backticks (``), or use any other supported syntax for linking to symbols.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "For more information about linking to symbols, see ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/linking-to-symbols-and-other-content",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "This provides a hint to the renderer as to the alternate language representations for the current symbol.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The renderer may use this hint to provide a link to these alternate symbols.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "For example, Swift-DocC-Render shows a toggle between supported languages, where switching to a different language representation will redirect to the documentation for the configured alternate symbol.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Special-considerations",
          "level" : 3,
          "text" : "Special considerations",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Links containing a colon (",
              "type" : "text"
            },
            {
              "code" : ":",
              "type" : "codeVoice"
            },
            {
              "text" : ") must be wrapped in quotes:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Metadata {",
            "    @AlternateRepresentation(\"doc:\/\/com.example\/documentation\/MyClass\/property\")",
            "    @AlternateRepresentation(\"MyClass\/myFunc(_:_:)\")",
            "}"
          ],
          "syntax" : "md",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "@AlternateRepresentation",
              "type" : "codeVoice"
            },
            {
              "text" : " directive only specifies an alternate language representation in one direction.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "To define a two-way relationship, add an ",
              "type" : "text"
            },
            {
              "code" : "@AlternateRepresentation",
              "type" : "codeVoice"
            },
            {
              "text" : " directive, linking to this symbol, to the other symbol as well.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "You can only configure custom alternate language representations for languages that the documented symbol doesn’t already have a language representation for,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "either from in-source annotations or from a previous ",
              "type" : "text"
            },
            {
              "code" : "@AlternateRepresentation",
              "type" : "codeVoice"
            },
            {
              "text" : " directive.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
