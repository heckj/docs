  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Install Embedded Swift"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The best way to install Swift for embedded development is using ",
              "type" : "text"
            },
            {
              "identifier" : "http:\/\/github.com\/swiftlang\/swiftly",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ", the official Swift toolchain installer and manager. Since Embedded Swift is still experimental and not yet supported in public Swift releases, you’ll need to use a development toolchain.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "For instructions on how to install ",
              "type" : "text"
            },
            {
              "code" : "swiftly",
              "type" : "codeVoice"
            },
            {
              "text" : ", check out the ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/www.swift.org\/swiftly\/documentation\/swiftly\/getting-started",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " guide.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Swiftly installs the latest release toolchain during ",
                  "type" : "text"
                },
                {
                  "code" : "swiftly init",
                  "type" : "codeVoice"
                },
                {
                  "text" : ", if you only plan on using Embedded Swift, you can avoid downloading this toolchain by using the ",
                  "type" : "text"
                },
                {
                  "code" : "swiftly init --skip-install",
                  "type" : "codeVoice"
                },
                {
                  "text" : " option.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Note",
          "style" : "note",
          "type" : "aside"
        },
        {
          "inlineContent" : [
            {
              "text" : "After installing Swiftly, install the latest main “Development Snapshot” toolchain available for your platform by running:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "$ swiftly install main-snapshot",
            "...",
            "main-snapshot-2025-04-12 installed successfully!"
          ],
          "syntax" : "shell",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "To test that you have Swift installed, run ",
              "type" : "text"
            },
            {
              "code" : "swift --version",
              "type" : "codeVoice"
            },
            {
              "text" : " from your shell or terminal app. It should say “6.2-dev”, meaning you have a “Development Snapshot” toolchain.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "$ swift --version",
            "Apple Swift version 6.2-dev (LLVM 81ab6d9f7e4810f, Swift 9cc1947527bacea)",
            "Target: arm64-apple-macosx15.0",
            "Build config: +assertions"
          ],
          "syntax" : "shell",
          "type" : "codeListing"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "When using other shells, like one integrated into an IDE, be careful to verify that the version of Swift reported matches that of the shell you used to install Swift.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Warning",
          "style" : "warning",
          "type" : "aside"
        }
      ],
      "kind" : "content"
    }
  ],
