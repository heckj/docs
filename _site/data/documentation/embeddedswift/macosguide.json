                    {
                      "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/visions\/embedded-swift.md",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : " will give you an overview of the approaches and goals of Embedded Swift, and also what exactly is in the Embedded Swift language subset.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
