            },
            {
              "kind" : "identifier",
              "text" : "Trait"
            }
          ]
        }
      ],
      "kind" : "declarations"
    },
    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "A trait is a package feature that expresses conditional compilation and potentially optional dependencies.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "It is typically used to expose additional or extended API for the package.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "When you define a trait on a package, the package manager uses the name of that trait as a conditional block for the package’s code.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Use the conditional block to enable imports or code paths for that trait.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "For example, a trait with the canonical name ",
              "type" : "text"
            },
            {
              "code" : "MyTrait",
              "type" : "codeVoice"
            },
            {
              "text" : " allows you to use the name as a conditional block:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "#if MyTrait",
            "\/\/ additional imports or APIs that MyTrait enables",
            "#endif \/\/ MyTrait"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Traits must be strictly additive. Enabling a trait ",
                  "type" : "text"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "must not",
                      "type" : "text"
                    }
                  ],
                  "type" : "strong"
                },
                {
                  "text" : " remove API.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Important",
          "style" : "important",
          "type" : "aside"
        },
        {
          "inlineContent" : [
            {
              "text" : "If your conditional code requires a dependency that you want to enable only when the trait is enabled,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "add a conditional declaration to the target dependencies,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "then include the import statement within the conditional block.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The following example illustrates enabling the dependency ",
              "type" : "text"
            },
            {
              "code" : "MyDependency",
              "type" : "codeVoice"
            },
            {
              "text" : " when the trait ",
              "type" : "text"
            },
            {
              "code" : "Trait1",
              "type" : "codeVoice"
            },
            {
              "text" : " is enabled:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "targets: [",
            "   .target(",
            "       name: \"MyTarget\",",
            "       dependencies: [",
            "           .product(",
            "               name: \"MyAPI\",",
            "               package: \"MyDependency\",",
            "               condition: .when(traits: [\"Trait1\"])",
            "           )",
            "       ]",
            "   ),",
            "]"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Coordinate a declaration like the example above with code that imports the dependency in a conditional block:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "#if Trait1",
            "import MyAPI",
            "#endif \/\/ Trait1"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
  ],
