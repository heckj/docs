            },
            {
              "text" : ": ",
              "type" : "text"
            },
            {
              "code" : "StrictConcurrency",
              "type" : "codeVoice"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Will introduce errors for any code that risks data races.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "This feature implicitly also enables ",
                  "type" : "text"
                },
                {
                  "identifier" : "#Isolated-default-value-expressions",
                  "isActive" : true,
                  "type" : "reference"
                },
                {
                  "text" : ",",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "identifier" : "#Strict-concurrency-for-global-variables",
