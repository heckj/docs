  "primaryContentSections" : [
    {
      "content" : [
        {
          "inlineContent" : [
            {
              "text" : "Swift 6 includes a number of evolution proposals that could potentially affect",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "source compatibility.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "These are all opt-in for the Swift 5 language mode.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "For the previous release’s Migration Guide, see ",
                  "type" : "text"
                },
                {
                  "identifier" : "https:\/\/www.swift.org\/migration-guide-swift5\/",
                  "isActive" : true,
                  "type" : "reference"
                },
                {
                  "text" : ".",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Note",
          "style" : "note",
          "type" : "aside"
        },
        {
          "anchor" : "Handling-Future-Enum-Cases",
          "level" : 2,
          "text" : "Handling Future Enum Cases",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0192-non-exhaustive-enums.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ": ",
              "type" : "text"
            },
            {
              "code" : "NonfrozenEnumExhaustivity",
              "type" : "codeVoice"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Lack of a required ",
              "type" : "text"
            },
            {
              "code" : "@unknown default",
              "type" : "codeVoice"
            },
            {
              "text" : " has changed from a warning to an error.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Concise-magic-file-names",
          "level" : 2,
          "text" : "Concise magic file names",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0274-magic-file.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ": ",
              "type" : "text"
            },
            {
              "code" : "ConciseMagicFile",
              "type" : "codeVoice"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The special expression ",
              "type" : "text"
            },
            {
              "code" : "#file",
              "type" : "codeVoice"
            },
            {
              "text" : " has changed to a human-readable string",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "containing the filename and module name.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Forward-scan-matching-for-trailing-closures",
          "level" : 2,
          "text" : "Forward-scan matching for trailing closures",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0286-forward-scan-trailing-closures.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ": ",
              "type" : "text"
            },
            {
              "code" : "ForwardTrailingClosures",
              "type" : "codeVoice"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Could affect code involving multiple, defaulted closure parameters.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Incremental-migration-to-concurrency-checking",
          "level" : 2,
          "text" : "Incremental migration to concurrency checking",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
