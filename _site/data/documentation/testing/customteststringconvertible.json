            },
            {
              "kind" : "identifier",
              "text" : "CustomTestStringConvertible"
            }
          ]
        }
      ],
      "kind" : "declarations"
    },
    {
      "kind" : "mentions",
      "mentions" : [
        "doc:\/\/org.swift.testing\/documentation\/Testing\/describing-values"
      ]
    },
    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Values whose types conform to this protocol use it to describe themselves",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "when they are present as part of the output of a test. For example, this",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "protocol affects the display of values that are passed as arguments to test",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "functions or that are elements of an expectation failure.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "By default, the testing library converts values to strings using",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "String(describing:)",
              "type" : "codeVoice"
            },
            {
              "text" : ". The resulting string may be inappropriate for some",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "types and their values. If the type of the value is made to conform to",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.testing\/documentation\/Testing\/CustomTestStringConvertible",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ", then the value of its ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.testing\/documentation\/Testing\/CustomTestStringConvertible\/testDescription",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "property will be used instead.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "For example, consider the following type:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "enum Food: CaseIterable {",
            "  case paella, oden, ragu",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If an array of cases from this enumeration is passed to a parameterized test",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "function:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Test(arguments: Food.allCases)",
            "func isDelicious(_ food: Food) { ... }"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Then the values in the array need to be presented in the test output, but",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "the default description of a value may not be adequately descriptive:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "◇ Test case passing 1 argument food → .paella to isDelicious(_:) started.",
            "◇ Test case passing 1 argument food → .oden to isDelicious(_:) started.",
            "◇ Test case passing 1 argument food → .ragu to isDelicious(_:) started."
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "By adopting ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.testing\/documentation\/Testing\/CustomTestStringConvertible",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ", customized descriptions can be",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "included:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "extension Food: CustomTestStringConvertible {",
            "  var testDescription: String {",
            "    switch self {",
            "    case .paella:",
            "      \"paella valenciana\"",
            "    case .oden:",
            "      \"おでん\"",
            "    case .ragu:",
            "      \"ragù alla bolognese\"",
            "    }",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The presentation of these values will then reflect the value of the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.testing\/documentation\/Testing\/CustomTestStringConvertible\/testDescription",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " property:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "◇ Test case passing 1 argument food → paella valenciana to isDelicious(_:) started.",
            "◇ Test case passing 1 argument food → おでん to isDelicious(_:) started.",
            "◇ Test case passing 1 argument food → ragù alla bolognese to isDelicious(_:) started."
          ],
          "syntax" : null,
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
