              ],
              [
                {
                  "inlineContent" : [
                    {
                      "text" : "The process id of the process you wish to attach to. If ",
                      "type" : "text"
                    },
                    {
                      "code" : "pid",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " is omitted, the debugger will attempt to attach to the program by finding a process whose file name matches the file name from ",
