        {
          "anchor" : "Attaching-to-a-Process",
          "level" : 3,
          "text" : "Attaching to a Process",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "You can attach to an existing process by using the ",
              "type" : "text"
            },
            {
              "code" : "\"attach\"",
              "type" : "codeVoice"
            },
            {
              "text" : " request and providing one or both of a ",
              "type" : "text"
            },
            {
              "code" : "\"program\"",
              "type" : "codeVoice"
            },
            {
              "text" : " or ",
              "type" : "text"
            },
            {
              "code" : "\"pid\"",
              "type" : "codeVoice"
            },
            {
              "text" : " to attach to:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "{",
            "    \"label\": \"Debug my-executable\", \/\/ Human readable name for the configuration",
            "    \"type\": \"swift\",                \/\/ All Swift launch configurations use the same type",
            "    \"request\": \"attach\",            \/\/ Attach to a process",
            "    \"program\": \"${workspaceFolder}\/.build\/debug\/my-executable\",",
            "    \"pid\": \"${command:pickProcess}\"",
            "}"
          ],
          "syntax" : "javascript",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The options for attach requests are mostly the same as the launch request with the addition of the following:",
              "type" : "text"
            }
