{
  "abstract" : [
    {
      "text" : "While Swift Concurrency is available in Swift for WebAssembly out of the box, it is single-threaded by default. Read this article for special considerations relevant to multi-threading.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
