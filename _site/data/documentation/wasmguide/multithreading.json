    "title" : "Multi-threading"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Using-threads-in-WebAssembly",
          "level" : 2,
          "text" : "Using threads in WebAssembly",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "While the WebAssembly spec defines ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/github.com\/WebAssembly\/threads",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ",",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "it does not define a way to create threads. This means that WebAssembly modules can’t create",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "threads themselves, and the host environment must provide a way to create threads and run",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "WebAssembly modules on them.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "wasi-threads-proposal",
          "level" : 3,
          "text" : "`wasi-threads` proposal",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "wasi-threads",
              "type" : "codeVoice"
            },
            {
              "text" : " feature is only available in the ",
              "type" : "text"
            },
            {
              "code" : "wasm32-unknown-wasip1-threads",
              "type" : "codeVoice"
            },
            {
              "text" : " target triple, which is explicitly distinct from the ",
              "type" : "text"
            },
            {
              "code" : "wasm32-unknown-wasip1",
              "type" : "codeVoice"
            },
            {
              "text" : " target triple.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "wasm32-unknown-wasip1-threads",
              "type" : "codeVoice"
            },
            {
              "text" : " target triple is only available in development snapshots of Swift SDK for WebAssembly.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "You can run WebAssembly programs built with the ",
              "type" : "text"
            },
            {
              "code" : "wasm32-unknown-wasip1-threads",
              "type" : "codeVoice"
            },
            {
              "text" : " target by using the WasmKit runtime via ",
              "type" : "text"
            },
            {
              "code" : "swift run",
              "type" : "codeVoice"
            },
            {
              "text" : ", passing ",
              "type" : "text"
            },
            {
              "code" : "--swift-sdk",
              "type" : "codeVoice"
            },
            {
              "text" : " option to it.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "# Install a Swift SDK that supports threads (replace URL with the latest available release from swift.org\/install)",
            "$ swift sdk install https:\/\/github.com\/swiftwasm\/swift\/releases\/download\/swift-wasm-DEVELOPMENT-SNAPSHOT-YYYY-MM-DD-a\/swift-wasm-DEVELOPMENT-SNAPSHOT-YYYY-MM-DD-a-wasm32-unknown-wasip1-threads.artifactbundle.zip --checksum <swift_sdk_checksum>",
            "",
            "# Run using the installed Swift SDK",
            "$ swift run --swift-sdk \"$(swiftc -print-target-info | jq -r '.swiftCompilerTag')_wasm-threads\""
          ],
          "syntax" : "console",
          "type" : "codeListing"
        },
        {
          "anchor" : "WebWorkerTaskExecutor-multi-threading-in-the-browser",
          "level" : 3,
          "text" : "`WebWorkerTaskExecutor` - multi-threading in the browser",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "For browser use cases JavaScriptKit provides ",
              "type" : "text"
            },
            {
              "code" : "WebWorkerTaskExecutor",
              "type" : "codeVoice"
            },
            {
              "text" : ", a ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0417-task-executor-preference.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " implementation that runs tasks in a Web Worker. This allows you to run Swift code concurrently in a Web Worker sharing the same memory space.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "This feature is available when you use the ",
              "type" : "text"
            },
            {
              "code" : "wasm32-unknown-wasip1-threads",
              "type" : "codeVoice"
            },
            {
              "text" : " target and ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/developer.mozilla.org\/en-US\/docs\/Web\/JavaScript\/Reference\/Global_Objects\/SharedArrayBuffer",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " for sharing Wasm linear memory between instantiated Wasm threads.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "See more details in the following links:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "identifier" : "https:\/\/github.com\/swiftwasm\/JavaScriptKit\/pull\/256",
                      "isActive" : true,
                      "type" : "reference"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "identifier" : "https:\/\/github.com\/swiftwasm\/JavaScriptKit\/tree\/main\/Examples\/Multithreading",
                      "isActive" : true,
                      "type" : "reference"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "identifier" : "https:\/\/swiftpackageindex.com\/swiftwasm\/javascriptkit\/main\/documentation\/javascripteventloop\/webworkertaskexecutor",
                      "isActive" : true,
                      "type" : "reference"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
