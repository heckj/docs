  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Add @preconcurrency import (AddPreconcurrencyImport)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Adding ",
              "type" : "text"
            },
            {
              "code" : "@preconcurrency",
              "type" : "codeVoice"
            },
            {
              "text" : " to an import suppresses or downgrades ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : "-related diagnostics that originate from the imported module.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "When a module was written before Swift concurrency was introduced, its types may not have ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " conformances. Importing such a module with ",
              "type" : "text"
            },
            {
              "code" : "@preconcurrency",
              "type" : "codeVoice"
            },
            {
              "text" : " tells the compiler to treat missing ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " conformances from that module more leniently, suppressing warnings in ",
              "type" : "text"
            },
            {
              "code" : "minimal",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "targeted",
              "type" : "codeVoice"
            },
            {
              "text" : " strict concurrency modes and downgrading errors to warnings in ",
              "type" : "text"
            },
            {
              "code" : "complete",
              "type" : "codeVoice"
            },
            {
              "text" : " mode.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "To resolve this warning, add ",
              "type" : "text"
            },
            {
              "code" : "@preconcurrency",
              "type" : "codeVoice"
            },
            {
              "text" : " to the import declaration:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@preconcurrency import NonStrictModule"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
  ],
