{
  "abstract" : [
    {
      "text" : "Warnings related to deprecated APIs that may be removed in future versions and should be replaced with more current alternatives.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/diagnostics\/documentation\/diagnostics",
        "doc:\/\/diagnostics\/documentation\/diagnostics\/diagnostic-groups"
      ]
    ]
  },
  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/deprecated-declaration"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Deprecated declaration warnings (DeprecatedDeclaration)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "DeprecatedDeclaration",
              "type" : "codeVoice"
            },
            {
              "text" : " group covers the following warnings:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Use of a function annotated with ",
                      "type" : "text"
                    },
                    {
                      "code" : "@available(<platform>, deprecated: <version>)",
                      "type" : "codeVoice"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "@available(iOS, deprecated: 10.0)",
                    "func oldFunction() {",
                    "  \/\/ This function is deprecated and should not be used.",
                    "}",
                    "",
                    "oldFunction() \/\/ 'oldFunction()' is deprecated"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Use of a function annotated with ",
                      "type" : "text"
                    },
                    {
                      "code" : "@available(<platform>, deprecated: <version>, renamed: \"<new name>\")",
                      "type" : "codeVoice"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "@available(iOS, deprecated: 10.0, renamed: \"newFunction\")",
                    "func oldFunction() {",
                    "  \/\/ This function is deprecated and should not be used.",
                    "}",
                    "",
                    "oldFunction() \/\/ 'oldFunction()' is deprecated: renamed to 'newFunction'"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Use of a type as an instance of a protocol when the type’s conformance to the protocol is marked as deprecated",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "struct S {}",
                    "",
                    "protocol P {}",
                    "",
                    "@available(*, deprecated)",
                    "extension S: P {}",
                    "",
                    "func f(_ p: some P) {}",
                    "",
                    "func test() {",
                    "  f(S()) \/\/ Conformance of 'S' to 'P' is deprecated",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "When a protocol requirement has a default implementation marked as ",
                      "type" : "text"
                    },
                    {
                      "code" : "deprecated",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " and the type conforming to the protocol doesn’t provide that requirement",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "protocol P {",
                    "  func f()",
                    "  func g()",
                    "}",
                    "",
                    "extension P {",
                    "  @available(*, deprecated)",
                    "  func f() {}",
                    "  @available(*, deprecated, message: \"write it yourself\")",
                    "  func g() {}",
                    "}",
                    "",
                    "struct S: P {} \/\/ deprecated default implementation is used to satisfy instance method 'f()' required by protocol 'P'",
                    "              \/\/ deprecated default implementation is used to satisfy instance method 'g()' required by protocol 'P': write it yourself"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "When a protocol requirement has been deprecated",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "struct S: Hashable {",
                    "  var hashValue: Int { \/\/ 'Hashable.hashValue' is deprecated as a protocol requirement; conform type 'S' to 'Hashable' by implementing 'hash(into:)' instead",
                    "    ...",
                    "  }",
                    "}",
                    "final class C: Executor {",
                    "  func enqueue(_ job: __owned Job) {} \/\/ 'Executor.enqueue(Job)' is deprecated as a protocol requirement; conform type 'C' to 'Executor' by implementing 'func enqueue(ExecutorJob)' instead",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        }
      ],
      "kind" : "content"
    }
  ],
