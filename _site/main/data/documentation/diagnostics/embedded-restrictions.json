{
  "abstract" : [
    {
      "text" : "Embedded Swift is a subset of the Swift language that that introduces some restrictions on the use of language features to eliminate the need for the Swift runtime. These restrictions are captured by the ",
      "type" : "text"
    },
    {
      "code" : "EmbeddedRestrictions",
      "type" : "codeVoice"
    },
    {
      "text" : " diagnostic group.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/diagnostics\/documentation\/diagnostics",
        "doc:\/\/diagnostics\/documentation\/diagnostics\/diagnostic-groups"
      ]
    ]
  },
  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/embedded-restrictions"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Embedded Swift language restrictions (EmbeddedRestrictions)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The Embedded Swift compilation model can produce extremely small binaries without external dependencies, suitable for restricted environments including embedded (microcontrollers) and baremetal setups (no operating system at all), and low-level environments (firmware, kernels, device drivers, low-level components of userspace OS runtimes). While the vast majority of Swift language features are available in Embedded Swift, there are some language features that require the full Swift standard library and runtime, which are not available in Embedded Swift.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Diagnostics in the ",
              "type" : "text"
            },
            {
              "code" : "EmbeddedRestrictions",
              "type" : "codeVoice"
            },
            {
              "text" : " group describe those language features that cannot be used in Embedded Swift. These include:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "weak",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " and ",
                      "type" : "text"
                    },
                    {
                      "code" : "unowned",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " references, because Embedded Swift uses a simplified reference-counting model that cannot support them. For example:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "class Node {",
                    "  weak var parent: Node?    \/\/ error: attribute 'weak' cannot be used in Embedded Swift",
                    "}"
                  ],
                  "syntax" : null,
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Dynamic casts to a type involving a protocol are not supported, because Embedded Swift does not include runtime metadata about protocol conformances. For example:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "protocol P: AnyObject { }",
                    "func casting(object: AnyObject) {",
                    "  if let p = object as? P { \/\/ error: cannot perform a dynamic cast to a type involving protocol 'P' in Embedded Swift",
                    "    \/\/ ...",
                    "  }",
                    "}"
                  ],
                  "syntax" : null,
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Non-final generic methods in a class, which are prohibited because they cannot be specialized for every possible call site. For example:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "class MyGenericClass<T> {",
                    "  func f<U>(value: U) { } \/\/ warning: generic instance method 'f(value:)' in a class must be 'final' in Embedded Swift",
                    "",
                    "  func g() { } \/\/ okay, not generic relative to the class itself",
                    "",
                    "  class func h() where T: P { } \/\/ warning: generic class method 'h()' in a class must be 'final' in Embedded Swift",
                    "}"
                  ],
                  "syntax" : null,
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Generic methods used on values of protocol type, which are prohibited because they cannot be specialized for every possible call site. For example:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "protocol P: AnyObject {",
                    "  func doNothing()",
                    "  func doSomething<T>(on value: T)",
                    "}",
                    "",
                    "func testGenerics<Value: P>(value: value, i: Int) {",
                    "  value.doNothing()        \/\/ okay",
                    "  value.doSomething(on: i) \/\/ okay, always specialized",
                    "}",
                    "",
                    "func testValuesOfProtocolType(value: any P, i: Int) {",
                    "  value.doNothing()        \/\/ okay",
                    "  value.doSomething(on: i) \/\/ warning: cannot use generic instance method 'doSomething(on:)' on a value of type 'any P' in Embedded Swift",
                    "}"
                  ],
                  "syntax" : null,
                  "type" : "codeListing"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        }
      ],
      "kind" : "content"
    }
  ],
