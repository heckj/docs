    "title" : "Existential any (ExistentialAny)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "code" : "any",
              "type" : "codeVoice"
            },
            {
              "text" : " was introduced in Swift 5.6 to explicitly mark “existential types”, i.e., abstract boxed types",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "that conform to a set of constraints. For source compatibility, these are not diagnosed by default",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "except for existential types constrained to protocols with ",
              "type" : "text"
            },
            {
              "code" : "Self",
              "type" : "codeVoice"
            },
            {
              "text" : " or associated type requirements",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "(as this was introduced in the same version):",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "protocol Foo {",
            "  associatedtype Bar",
            "",
            "  func foo(_: Bar)",
            "}",
            "",
            "protocol Baz {}",
            "",
            "func pass(foo: Foo) {} \/\/ `any Foo` is required instead of `Foo`",
            "",
            "func pass(baz: Baz) {} \/\/ no warning or error by default for source compatibility"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "When enabled via ",
              "type" : "text"
            },
            {
              "code" : "-enable-upcoming-feature ExistentialAny",
              "type" : "codeVoice"
            },
            {
              "text" : ", the upcoming language feature",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "ExistentialAny",
              "type" : "codeVoice"
            },
            {
              "text" : " will diagnose ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "all",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " existential types without ",
              "type" : "text"
            },
            {
              "code" : "any",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func pass(baz: Baz) {} \/\/ `any Baz` required instead of `Baz`"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "This will become the default in a future language mode.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Migration",
          "level" : 2,
          "text" : "Migration",
          "type" : "heading"
        },
        {
          "code" : [
            "-enable-upcoming-feature ExistentialAny:migrate"
          ],
          "syntax" : "sh",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Enabling migration for ",
              "type" : "text"
            },
            {
              "code" : "ExistentialAny",
              "type" : "codeVoice"
            },
            {
              "text" : " adds fix-its that prepend all existential types with ",
              "type" : "text"
            },
            {
              "code" : "any",
              "type" : "codeVoice"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "as required. No attempt is made to convert to generic (",
              "type" : "text"
            },
            {
              "code" : "some",
              "type" : "codeVoice"
            },
            {
              "text" : ") types.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
