  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/isolated-conformances"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Isolated conformances (IsolatedConformances)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Using an isolated conformance from outside the actor can cause data races in your program. Resolve these errors by only using isolated conformances within the actor.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "A protocol conformance can be isolated to a specific global actor, meaning that the conformance can only be used by code running on that actor. Isolated conformances are expressed by specifying the global actor on the conformance itself:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "protocol P {",
            "  func f()",
            "}",
            "",
            "@MainActor",
            "class MyType: @MainActor P {",
            "  \/*@MainActor*\/ func f() {",
            "    \/\/ must be called on the main actor",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Swift will produce diagnostics if the conformance is directly accessed in code that isn’t guaranteed to execute in the same global actor. For example:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func acceptP<T: P>(_ value: T) { }",
            "",
            "\/*nonisolated*\/ func useIsolatedConformance(myType: MyType) {",
            "  acceptP(myType) \/\/ error: main actor-isolated conformance of 'MyType' to 'P' cannot be used in nonisolated context",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "To address this issue, mark the code as having the same global actor as the conformance it is trying to use. In this case, mark ",
              "type" : "text"
            },
            {
              "code" : "useIsolatedConformance",
              "type" : "codeVoice"
            },
            {
              "text" : " as ",
              "type" : "text"
            },
            {
              "code" : "@MainActor",
              "type" : "codeVoice"
            },
            {
              "text" : " so that the code is guaranteed to execute on the main actor.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "An isolated conformance cannot be used together with a ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " requirement, because doing so would allow the conformance to cross isolation boundaries and be used from outside the global actor. For example:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func acceptSendableP<T: P & Sendable>(_ value: T) { }",
            "",
            "@MainActor func useIsolatedConformanceOnMainActor(myType: MyType) {",
            "  acceptSendableP(myType) \/\/ error: main-actor-isolated conformance of 'MyType' to 'P' cannot satisfy conformance requirement for 'Sendable' type parameter 'T'",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "These errors can be addressed by either making the conformance itself ",
              "type" : "text"
            },
            {
              "code" : "nonisolated",
              "type" : "codeVoice"
            },
            {
              "text" : " or making the generic function not require ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
