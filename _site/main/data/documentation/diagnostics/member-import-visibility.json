    "roleHeading" : "Article",
    "title" : "Member import visibility (MemberImportVisibility)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Prior to enabling this feature, it was possible to use a member if it was declared in a module that",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "was transitively imported. ",
              "type" : "text"
            },
            {
              "code" : "MemberImportVisibility",
              "type" : "codeVoice"
            },
            {
              "text" : " unifies the visibility rules for members to",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "match those of top-level, such that only members contained in a direct import are visible:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func getFileContents() throws -> String {",
            "  \/\/ error: initializer 'init(contentsOfFile:)' is not available due to missing import of defining module 'Foundation'",
            "  return try String(contentsOfFile: \"example.txt\")",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "To resolve the error, add an import of the module that defines the member.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Migration",
          "level" : 2,
          "text" : "Migration",
          "type" : "heading"
        },
        {
          "code" : [
            "-enable-upcoming-feature MemberImportVisibility:migrate"
          ],
          "syntax" : "sh",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Enabling migration for ",
              "type" : "text"
            },
            {
              "code" : "MemberImportVisibility",
              "type" : "codeVoice"
            },
            {
              "text" : " adds fix-its for the missing modules, i.e. those that",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "declare members used in the file and are not directly imported.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "See-also",
          "level" : 2,
          "text" : "See also",
          "type" : "heading"
