  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/non-sendable-superclass"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Unable to conform to Sendable with a non-Sendable superclass (NonSendableSuperclass)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "A class cannot conform to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " when it inherits from a non-Sendable superclass. This prohibition exists because the superclass is free to change its exposed API or internal implementation in ways that would make a ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " conformance unsafe. Consider code like this:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "class MIDIDevice {}",
            "",
            "\/\/ ...",
            "",
            "final class MIDISynth: MIDIDevice, Sendable {}",
            "\/\/          |          `- note: inherits from non-Sendable class 'MIDIDevice'",
            "\/\/          |- error: class 'MIDISynth' cannot conform to the 'Sendable' protocol",
            "\/\/          `- note: a 'Sendable' class cannot inherit from a non-Sendable class"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Since ",
              "type" : "text"
            },
            {
              "code" : "MIDIDevice",
              "type" : "codeVoice"
            },
            {
              "text" : " isn’t ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ", it is allowed to expose mutable state:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "class MIDIDevice {",
            "  var activeNotes: [Note] = []",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "code" : "MIDISynth",
              "type" : "codeVoice"
            },
            {
              "text" : " would inherit ",
              "type" : "text"
            },
            {
              "code" : "activeNotes",
              "type" : "codeVoice"
            },
            {
              "text" : ", and treating ",
              "type" : "text"
            },
            {
              "code" : "MIDISynth",
              "type" : "codeVoice"
            },
            {
              "text" : " as ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " would allow ",
              "type" : "text"
            },
            {
              "code" : "activeNotes",
              "type" : "codeVoice"
            },
            {
              "text" : " to be mutated concurrently, risking a data race.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Normally, a global actor like ",
              "type" : "text"
            },
            {
              "code" : "@MainActor",
              "type" : "codeVoice"
            },
            {
              "text" : " implies ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ", but this is not the case for classes with non-Sendable superclasses for the same reason.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@MainActor class MIDISynth: MIDIDevice {} \/\/ Not implicitly Sendable!"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If ",
              "type" : "text"
            },
            {
              "code" : "@MainActor",
              "type" : "codeVoice"
            },
            {
              "text" : " made ",
              "type" : "text"
            },
            {
              "code" : "MIDISynth",
              "type" : "codeVoice"
            },
            {
              "text" : " conform to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "MIDISynth",
              "type" : "codeVoice"
            },
            {
              "text" : " could be sent to multiple actors, upcast to ",
              "type" : "text"
            },
            {
              "code" : "MIDIDevice",
              "type" : "codeVoice"
            },
            {
              "text" : ", and concurrently mutated:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@MainActor",
            "func useSynth(_ synth: MIDISynth) {",
            "  Task.detached { \/\/ sending would only be possible if MIDISynth were Sendable",
            "    let device: MIDIDevice = synth  \/\/ upcast strips the @MainActor isolation",
            "    device.activeNotes.append(.A)   \/\/ mutates off the main actor...",
            "  }",
            "  synth.activeNotes.append(.C)      \/\/ ...racing with the detached task's mutation",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "However, since ",
              "type" : "text"
            },
            {
              "code" : "MIDISynth",
              "type" : "codeVoice"
            },
            {
              "text" : " is ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "not",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " allowed to conform to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ", sending it to a task while still referencing it on the main actor will be an error.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "How-to-fix",
          "level" : 2,
          "text" : "How to fix",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "If you need to send a class that inherits from a non-Sendable superclass, you have a few options:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "If you wrote the superclass, isolate the superclass to a global actor. Its state is then actor-protected, the base becomes implicitly ",
                      "type" : "text"
                    },
                    {
                      "code" : "Sendable",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : ", and the subclass inherits that conformance:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "@MainActor",
                    "class MIDIDevice {",
                    "  var activeNotes: [Note] = []",
                    "}",
                    "",
                    "class MIDISynth: MIDIDevice {} \/\/ inherits Sendable and @MainActor from MIDIDevice"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "If you don’t control the superclass, you may conform with ",
                      "type" : "text"
                    },
                    {
                      "code" : "@unchecked Sendable",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " if you guarantee the safety of the inherited and subclass state yourself:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "class MIDISynth: MIDIDevice, @unchecked Sendable {}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "This option also applies to a global-actor-isolated subclass, but be aware that your subclass can be upcast after being sent, so actor isolation is insufficient to protect the inherited state:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "@MainActor",
                    "class MIDISynth: MIDIDevice, @unchecked Sendable {}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Instead of trying to conform to ",
                      "type" : "text"
                    },
                    {
                      "code" : "Sendable",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : ", store the instance of the class that you need to share inside a synchronized container, like ",
                      "type" : "text"
                    },
                    {
                      "code" : "Mutex",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : ":",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "import Synchronization",
                    "",
                    "let synth = Mutex(MIDISynth())",
                    "",
                    "Task.detached {",
                    "  synth.withLock { $0.activeNotes.append(.A) }",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "NSObject",
          "level" : 2,
          "text" : "`NSObject`",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "An exception is made for directly inheriting from ",
              "type" : "text"
            },
            {
              "code" : "NSObject",
              "type" : "codeVoice"
            },
            {
              "text" : ". ",
              "type" : "text"
            },
            {
              "code" : "NSObject",
              "type" : "codeVoice"
            },
            {
              "text" : " does not and will not expose mutable stored properties, so direct subclasses are allowed to conform to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " for Objective-C interoperability.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
