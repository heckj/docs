{
  "abstract" : [
    {
      "text" : "Runs nonisolated async functions on the caller’s actor by default.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/diagnostics\/documentation\/diagnostics",
        "doc:\/\/diagnostics\/documentation\/diagnostics\/upcoming-language-features"
      ]
    ]
  },
  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/nonisolated-nonsending-by-default"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "nonisolated(nonsending) by Default (NonisolatedNonsendingByDefault)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Prior to this feature, nonisolated async functions ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "never",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " run on an actor’s executor and instead",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "switch to global generic executor. The motivation was to prevent unnecessary serialization and",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "contention for the actor by switching off of the actor to run the nonisolated async function, but",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "this does  have a number of unfortunate consequences:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "nonisolated",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " is difficult to understand",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Async functions that run on the caller’s actor are difficult to express",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "It’s easy to write invalid async APIs",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "It’s difficult to write higher-order async APIs",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "orderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "Introduced in Swift 6.2, ",
              "type" : "text"
            },
            {
              "code" : "-enable-upcoming-feature NonisolatedNonsendingByDefault",
              "type" : "codeVoice"
            },
            {
              "text" : " changes the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "execution semantics of nonisolated async functions to always run on the caller’s actor by default. A",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "new ",
              "type" : "text"
            },
            {
              "code" : "@concurrent",
              "type" : "codeVoice"
            },
            {
              "text" : " attribute can be added in order to specify that a function must ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "always",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " switch",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "off of an actor to run.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "struct S: Sendable {",
            "  func performSync() {}",
            "",
            "  \/\/ `nonisolated(nonsending)` is the default",
            "  func performAsync() async {}",
            "",
            "  @concurrent",
            "  func alwaysSwitch() async {}",
            "}",
            "",
            "actor MyActor {",
            "  let s: Sendable",
            "",
            "  func call() async {",
            "    s.performSync() \/\/ runs on actor's executor",
            "",
            "    await s.performAsync() \/\/ runs on actor's executor",
            "",
            "    s.alwaysSwitch() \/\/ switches to global generic executor",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "A ",
              "type" : "text"
            },
            {
              "code" : "nonisolated(nonsending)",
              "type" : "codeVoice"
            },
            {
              "text" : " modifier can also be used prior to enabling this upcoming feature in",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "order to run on the caller’s actor. To achieve the same semantics as above, ",
              "type" : "text"
            },
            {
              "code" : "S",
              "type" : "codeVoice"
            },
            {
              "text" : " in this case would",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "instead be:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "struct S: Sendable {",
            "  func performSync() {}",
            "",
            "  nonisolated(nonsending)",
            "  func performAsync() async {}",
            "",
            "  \/\/ `@concurrent` is the default",
            "  func alwaysSwitch() async {}",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "Migration",
          "level" : 2,
          "text" : "Migration",
          "type" : "heading"
        },
        {
          "code" : [
            "-enable-upcoming-feature NonisolatedNonsendingByDefault:migrate"
          ],
          "syntax" : "sh",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Enabling migration for ",
              "type" : "text"
            },
            {
              "code" : "NonisolatedNonsendingByDefault",
              "type" : "codeVoice"
            },
            {
              "text" : " adds fix-its that aim to keep the current",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "async semantics by adding ",
              "type" : "text"
            },
            {
              "code" : "@concurrent",
              "type" : "codeVoice"
            },
            {
              "text" : " to all existing nonisolated async functions and closures.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
