  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/protocol-type-non-conformance"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Protocol types cannot conform to protocols (ProtocolTypeNonConformance)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "In Swift, a protocol that does not have ",
              "type" : "text"
            },
            {
              "code" : "Self",
              "type" : "codeVoice"
            },
            {
              "text" : " or associated type requirements can be used as a type. You can use a variable or constant of a protocol type, also called an ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "existential type",
                  "type" : "text"
                }
              ],
              "type" : "strong"
            },
            {
              "text" : ", to hold a value of any conforming type:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "protocol Animal {",
            "    func makeNoise()",
            "    static var species: String { get }",
            "}",
            "struct Dog: Animal {",
            "    func makeNoise() { print(\"Woof\") }",
            "    static var species: String = \"Canus familiaris\"",
            "}",
            "struct Cat: Animal {",
            "    func makeNoise() { print(\"Meow\") }",
            "    static var species: String = \"Felis catus\"",
            "}",
            "",
            "var animal: Animal \/\/ `Animal` is used here as a type.",
            "animal = Dog()",
            "animal.makeNoise() \/\/ Prints \"Woof\".",
            "animal = Cat()",
            "animal.makeNoise() \/\/ Prints \"Meow\"."
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Notice that it is possible to invoke the method ",
              "type" : "text"
            },
            {
              "code" : "makeNoise()",
              "type" : "codeVoice"
            },
            {
              "text" : " on a value of type ",
              "type" : "text"
            },
            {
              "code" : "Animal",
              "type" : "codeVoice"
            },
            {
              "text" : ", just as it is possible to do so on a value of concrete type ",
              "type" : "text"
            },
            {
              "code" : "Dog",
              "type" : "codeVoice"
            },
            {
              "text" : " or ",
              "type" : "text"
            },
            {
              "code" : "Cat",
              "type" : "codeVoice"
            },
            {
              "text" : ". However, the static property ",
              "type" : "text"
            },
            {
              "code" : "species",
              "type" : "codeVoice"
            },
            {
              "text" : " is not available for the existential type:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "print(Dog.species)    \/\/ Prints \"Canus familiaris\"",
            "print(Cat.species)    \/\/ Prints \"Felis catus\"",
            "print(Animal.species) \/\/ error: static member 'species' cannot be used..."
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Since a type conforms to a protocol only when it satisfies ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "all",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " of that protocol’s requirements, the existential type ",
              "type" : "text"
            },
            {
              "code" : "Animal",
              "type" : "codeVoice"
            },
            {
              "text" : " does not conform to the protocol ",
              "type" : "text"
            },
            {
              "code" : "Animal",
              "type" : "codeVoice"
            },
            {
              "text" : " because it cannot satisfy the protocol’s requirement for the static property ",
              "type" : "text"
            },
            {
              "code" : "species",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func declareAnimalSpecies<T: Animal>(_ animal: T) {",
            "    animal.makeNoise()",
            "    print(\"My species is known as \\(T.species)\")",
            "}",
            "",
            "let dog = Dog()",
            "declareAnimalSpecies(dog)",
            "\/\/ Prints:",
            "\/\/ \"Woof\"",
            "\/\/ \"My species is known as Canus familiaris\"",
            "declareAnimalSpecies(animal)",
            "\/\/ error: protocol type 'Animal' cannot conform to 'Animal'..."
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "In general, any initializers, static members, and associated types required by a protocol can be used only via conforming concrete types. Although Swift allows a protocol that requires initializers or static members to be used as a type, that type ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "does not and cannot",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " conform to the protocol itself.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Currently, even if a protocol ",
              "type" : "text"
            },
            {
              "code" : "P",
              "type" : "codeVoice"
            },
            {
              "text" : " requires no initializers or static members, the existential type ",
              "type" : "text"
            },
            {
              "code" : "P",
              "type" : "codeVoice"
            },
            {
              "text" : " does not conform to ",
              "type" : "text"
            },
            {
              "code" : "P",
              "type" : "codeVoice"
            },
            {
              "text" : " (with exceptions below). This restriction allows library authors to add such requirements (initializers or static members) to an existing protocol without breaking their users’ source code.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Exceptions",
          "level" : 2,
          "text" : "Exceptions",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "When used as a type, the Swift protocol ",
              "type" : "text"
            },
            {
              "code" : "Error",
              "type" : "codeVoice"
            },
            {
              "text" : " conforms to itself; ",
              "type" : "text"
            },
            {
              "code" : "@objc",
              "type" : "codeVoice"
            },
            {
              "text" : " protocols with no static requirements can also be used as types that conform to themselves.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Alternatives",
          "level" : 2,
          "text" : "Alternatives",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Concrete types that ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "do",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " conform to protocols can provide functionality similar to that of existential types. For example, the standard library provides the ",
              "type" : "text"
            },
            {
              "code" : "AnyHashable",
              "type" : "codeVoice"
            },
            {
              "text" : " type for ",
              "type" : "text"
            },
            {
              "code" : "Hashable",
              "type" : "codeVoice"
            },
            {
              "text" : " values. Manual implementation of such ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "type erasure",
                  "type" : "text"
                }
              ],
              "type" : "strong"
            },
            {
              "text" : " can require specific knowledge of the semantic requirements for each protocol involved and is beyond the scope of this discussion.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "In certain scenarios, you might avoid any need for manual type erasure by reworking generic APIs to use existential types instead:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func declareAnimalSpeciesDynamically(_ animal: Animal) {",
            "    animal.makeNoise()",
            "    print(\"My species is known as \\(type(of: animal).species)\")",
            "}",
            "",
            "declareAnimalSpeciesDynamically(animal)",
            "\/\/ Prints:",
            "\/\/ \"Meow\"",
            "\/\/ \"My species is known as Felis catus\""
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "(Note that there is a distinction between the ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "static",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " type of a value as given by the generic parameter ",
              "type" : "text"
            },
            {
              "code" : "T",
              "type" : "codeVoice"
            },
            {
              "text" : " and the ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "dynamic",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : " type of a value obtained by invoking ",
              "type" : "text"
            },
            {
              "code" : "type(of:)",
              "type" : "codeVoice"
            },
            {
              "text" : ". For example, the static type of ",
              "type" : "text"
            },
            {
              "code" : "animal",
              "type" : "codeVoice"
            },
            {
              "text" : " is ",
              "type" : "text"
            },
            {
              "code" : "Animal",
              "type" : "codeVoice"
            },
            {
              "text" : ", while its dynamic type is ",
              "type" : "text"
            },
            {
              "code" : "Cat",
              "type" : "codeVoice"
            },
            {
              "text" : ". Therefore, the two functions ",
              "type" : "text"
            },
            {
              "code" : "declareAnimalSpecies(_:)",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "declareAnimalSpeciesDynamically(_:)",
              "type" : "codeVoice"
            },
            {
              "text" : " are not exact replacements of each other.)",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The same technique might be applicable to members of generic types:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "\/\/ Instead of...",
            "struct Habitat<T: Animal> {",
            "    var animal: T",
            "}",
            "\/\/ ...consider:",
            "struct Habitat {",
            "    var animal: Animal",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "For more on using existential types, see ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/protocols#Protocols-as-Types",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " in ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "The Swift Programming Language",
                  "type" : "text"
                }
              ],
              "type" : "emphasis"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
