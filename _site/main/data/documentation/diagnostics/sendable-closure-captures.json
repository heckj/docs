  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/sendable-closure-captures"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Captures in a `@Sendable` closure (SendableClosureCaptures)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "code" : "@Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " closures can be called multiple times concurrently, so any captured values must also be safe to access concurrently. To prevent data races, the compiler prevents capturing mutable values in a ",
              "type" : "text"
            },
            {
              "code" : "@Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " closure.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "For example:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func callConcurrently(",
            "  _ closure: @escaping @Sendable () -> Void",
            ") { ... }",
            "",
            "func capture() {",
            "  var result = 0",
            "  result += 1",
            "",
            "  callConcurrently {",
            "    print(result)",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The compiler diagnoses the capture of ",
              "type" : "text"
            },
            {
              "code" : "result",
              "type" : "codeVoice"
            },
            {
              "text" : " in a ",
              "type" : "text"
            },
            {
              "code" : "@Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " closure:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "|   callConcurrently {",
            "|     print(result)",
            "|           `- error: reference to captured var 'result' in concurrently-executing code",
            "|   }",
            "| }"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Because the closure is marked ",
              "type" : "text"
            },
            {
              "code" : "@Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ", the implementation of ",
              "type" : "text"
            },
            {
              "code" : "callConcurrently",
              "type" : "codeVoice"
            },
            {
              "text" : " can call ",
              "type" : "text"
            },
            {
              "code" : "closure",
              "type" : "codeVoice"
            },
            {
              "text" : " multiple times concurrently. For example, multiple child tasks within a task group can call ",
              "type" : "text"
            },
            {
              "code" : "closure",
              "type" : "codeVoice"
            },
            {
              "text" : " concurrently:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func callConcurrently(",
            "  _ closure: @escaping @Sendable () -> Void",
            ") {",
            "  Task {",
            "    await withDiscardingTaskGroup { group in",
            "      for _ in 0..<10 {",
            "        group.addTask {",
            "          closure()",
            "        }",
            "      }",
            "    }",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If the type of the capture is ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " and the closure only needs the value of the variable at the point of capture, resolve the error by explicitly capturing the variable by value in the closure’s capture list:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func capture() {",
            "  var result = 0",
            "  result += 1",
            "",
            "  callConcurrently { [result] in",
            "    print(result)",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "This strategy does not apply to captures with non-",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " type. Consider the following example:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "class MyModel {",
            "  func log() { ... }",
            "}",
            "",
            "func capture(model: MyModel) async {",
            "  callConcurrently {",
            "    model.log()",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The compiler diagnoses the capture of ",
              "type" : "text"
            },
            {
              "code" : "model",
              "type" : "codeVoice"
            },
            {
              "text" : " in a ",
              "type" : "text"
            },
            {
              "code" : "@Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " closure:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "| func capture(model: MyModel) async {",
            "|   callConcurrently {",
            "|     model.log()",
            "|     `- error: capture of 'model' with non-Sendable type 'MyModel' in a '@Sendable' closure",
            "|   }",
            "| }"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If a type with mutable state can be referenced concurrently, but all access to mutable state happens on the main actor, isolate the type to the main actor and mark the methods that don’t access mutable state as ",
              "type" : "text"
            },
            {
              "code" : "nonisolated",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@MainActor",
            "class MyModel {",
            "  nonisolated func log() { ... }",
            "}",
            "",
            "func capture(model: MyModel) async {",
            "  callConcurrently {",
            "    model.log()",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The compiler will guarantee that the implementation of ",
              "type" : "text"
            },
            {
              "code" : "log",
              "type" : "codeVoice"
            },
            {
              "text" : " does not access any main actor state.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "If you manually ensure data-race safety, such as by using an external synchronization mechanism, you can use ",
              "type" : "text"
            },
            {
              "code" : "nonisolated(unsafe)",
              "type" : "codeVoice"
            },
            {
              "text" : " to opt out of concurrency checking:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "class MyModel {",
            "  func log() { ... }",
            "}",
            "",
            "func capture(model: MyModel) async {",
            "  nonisolated(unsafe) let model = model",
            "  callConcurrently {",
            "    model.log()",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
  ],
