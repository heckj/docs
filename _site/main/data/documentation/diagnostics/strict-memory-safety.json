{
  "abstract" : [
    {
      "text" : "Warnings that identify the use of language constructs and library APIs that can undermine memory",
      "type" : "text"
    },
    {
      "text" : " ",
      "type" : "text"
    },
    {
      "text" : "safety, disabled by default.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/diagnostics\/documentation\/diagnostics",
        "doc:\/\/diagnostics\/documentation\/diagnostics\/diagnostic-groups"
      ]
    ]
  },
  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/strict-memory-safety"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Strict memory safety (StrictMemorySafety)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Strict memory safety can be enabled with the ",
              "type" : "text"
            },
            {
              "code" : "-strict-memory-safety",
              "type" : "codeVoice"
            },
            {
              "text" : " compiler flag. Examples of",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "memory-unsafe code in Swift include:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Use of a function or type annotated with ",
                      "type" : "text"
                    },
                    {
                      "code" : "@unsafe",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : ":",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "func getPointee<T>(_ pointer: UnsafeMutablePointer<Int>, as type: T.Type) -> T {",
                    "  \/\/ reference to unsafe global function 'unsafeBitCast'",
                    "  return unsafeBitCast(pointer.pointee, to: type)",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Use of a function involving an ",
                      "type" : "text"
                    },
                    {
                      "code" : "@unsafe",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " type:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "func evilMalloc(size: Int) -> Int {",
                    "  \/\/ use of global function 'malloc' involves unsafe type 'UnsafeMutableRawPointer'",
                    "  return Int(bitPattern: malloc(size))",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Use of an entity that makes use of an unsafe language feature:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "\/\/ use of an unowned(unsafe) variable is not memory-safe",
                    "unowned(unsafe) var parentNode: TreeNode<T>"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Definition of a type whose storage contains unsafe types:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "\/\/ struct MyTemporaryBuffer has storage involving unsafe types",
                    "struct MyTemporaryBuffer<T> {",
                    "  private var storage: UnsafeBufferPointer<T>",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Using an ",
                      "type" : "text"
                    },
                    {
                      "code" : "@unsafe",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " operation to satisfy a safe protocol requirement:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "\/\/ conformance of 'MyType' to protocol 'CustomStringConvertible' involves unsafe code",
                    "struct MyType: CustomStringConvertible {",
                    "  @unsafe var description: String {",
                    "    \"I am unsafe!\"",
                    "  }",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "The warnings produced by strict memory safety can be suppressed by acknowledging the unsafe behaior with one of three constructs:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "unsafe",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " expressions to acknowledges that there exists memory-unsafe code within the given expression, similar to the way ",
                      "type" : "text"
                    },
                    {
                      "code" : "try",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " and ",
                      "type" : "text"
                    },
                    {
                      "code" : "await",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " work for throwing and asynchronous functions:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "func evilMalloc(size: Int) -> Int {",
                    "  return unsafe Int(bitPattern: malloc(size))",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "@unsafe",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " attribute, which acknowledges that a type or conformance is also unsafe:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "struct MyType: @unsafe CustomStringConvertible {",
                    "  @unsafe var description: String {",
                    "    \"I am unsafe!\"",
                    "  }",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "@safe",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " attribute to indicate that an entity encapsulates the unsafe behavior to provide a safe interface:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "@safe struct MyTemporaryBuffer<T> {",
                    "  private var storage: UnsafeBufferPointer<T>",
                    "}"
                  ],
                  "syntax" : "swift",
                  "type" : "codeListing"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        }
      ],
      "kind" : "content"
    }
  ],
