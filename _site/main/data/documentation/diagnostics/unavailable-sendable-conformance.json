  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/unavailable-sendable-conformance"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Unavailable Sendable conformance (UnavailableSendableConformance)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "An unavailable sendable conformance is an explicit prohibition on conforming to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ". It is declared by marking the conformance ",
              "type" : "text"
            },
            {
              "code" : "unavailable",
              "type" : "codeVoice"
            },
            {
              "text" : " with the ",
              "type" : "text"
            },
            {
              "code" : "available",
              "type" : "codeVoice"
            },
            {
              "text" : " attribute. Like other conformances, unavailable conformances are inherited by subclasses. Providing an unavailable conformance to the ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " protocol states that a type and its subclasses must not conform to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "class ImageLoader {}",
            "",
            "@available(*, unavailable)",
            "extension ImageLoader: Sendable {}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Suppose you subclass a type with an unavailable ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " conformance:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "final class ThumbnailLoader: ImageLoader, @unchecked Sendable {}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "This results in a warning like:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "| final class ThumbnailLoader: ImageLoader, @unchecked Sendable {}",
            "|             |                                        `- warning: 'ThumbnailLoader' inherits an unavailable 'Sendable' conformance; conforming here risks data races",
            "|             `- note: 'ThumbnailLoader' inherits unavailable conformance to protocol 'Sendable' from superclass here"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "An unavailable ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " conformance means the type does not meet the criteria for ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ", so it would not be safe to treat it or any subclass as ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ". Suppose ",
              "type" : "text"
            },
            {
              "code" : "ImageLoader",
              "type" : "codeVoice"
            },
            {
              "text" : " comes from a library with mutable implementation details like an unsynchronized cache, which makes it unsafe to send, so the library author used an unavailable conformance to ensure it’s never treated as ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ". Sharing an ",
              "type" : "text"
            },
            {
              "code" : "ImageLoader",
              "type" : "codeVoice"
            },
            {
              "text" : " between concurrency domains would be a data race. Your ",
              "type" : "text"
            },
            {
              "code" : "ThumbnailLoader",
              "type" : "codeVoice"
            },
            {
              "text" : " subclass inherits these implementation details, so it must not be marked ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " either.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "These rules also apply to extensions of types; you shouldn’t extend a type to conform to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " when it was defined with an unavailable ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " conformance. Treating a non-",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " type as ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " will prevent enforcing race safety.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Suppressed-conformances",
          "level" : 2,
          "text" : "Suppressed conformances",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "By writing ",
              "type" : "text"
            },
            {
              "code" : "~Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ", a type can suppress inferred ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " conformance without preventing subclasses from adding protections for state and conforming to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ". A superclass can also use ",
              "type" : "text"
            },
            {
              "code" : "~Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " to let subclasses choose whether to be ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "class ImageLoader: ~Sendable {",
            "  \/\/ Not thread safe.",
            "}",
            "",
            "final class ThreadSafeImageLoader: ImageLoader, @unchecked Sendable {",
            "  \/\/ Protects state from ImageLoader in some way that makes it safe to access i.e. via a lock.",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "Sendable-wrapper",
          "level" : 2,
          "text" : "Sendable wrapper",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "To resolve this warning, instead of trying to make a non-",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " type conform to ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ", create a ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : " wrapper that ensures exclusive access, or wrap the type in a ",
              "type" : "text"
            },
            {
              "code" : "Mutex",
              "type" : "codeVoice"
            },
            {
              "text" : ", which is ",
              "type" : "text"
            },
            {
              "code" : "Sendable",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "actor SendableImageLoader {",
            "  let loader: ImageLoader",
            "  \/\/ ...",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
  ],
