  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Unnecessary effect markers (UnnecessaryEffectMarker)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "These warnings are emitted when an effect marker — ",
              "type" : "text"
            },
            {
              "code" : "try",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "await",
              "type" : "codeVoice"
            },
            {
              "text" : ", or ",
              "type" : "text"
            },
            {
              "code" : "unsafe",
              "type" : "codeVoice"
            },
            {
              "text" : " — appears on an expression that contains no operation requiring it. The marker may have been added preemptively, the operation it was needed for may have been removed, or the resolved expression may not contain the operation that was expected to carry the effect.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "UnnecessaryEffectMarker",
              "type" : "codeVoice"
            },
            {
              "text" : " group covers:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "try",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " on an expression that calls no throwing functions",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "await",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " on an expression that performs no ",
                      "type" : "text"
                    },
                    {
                      "code" : "async",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " operations",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "unsafe",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " on an expression that contains no unsafe operations",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "unsafe",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " on a ",
                      "type" : "text"
                    },
                    {
                      "code" : "for",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : "-",
                      "type" : "text"
                    },
                    {
                      "code" : "in",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " loop whose ",
                      "type" : "text"
                    },
                    {
                      "code" : "Sequence",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " has a safe conformance",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "Example",
          "level" : 2,
          "text" : "Example",
          "type" : "heading"
        },
        {
          "code" : [
            "func greet(_ name: String) {",
            "  print(\"Hello, \\(name)\")  \/\/ not throwing, not async, not unsafe",
            "}",
            "",
            "func caller() async throws {",
            "  try greet(\"Ada\")    \/\/ warning: no calls to throwing functions occur within 'try' expression",
            "  await greet(\"Ada\")  \/\/ warning: no 'async' operations occur within 'await' expression",
            "  unsafe greet(\"Ada\") \/\/ warning: no unsafe operations occur within 'unsafe' expression",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "How-to-fix",
          "level" : 2,
          "text" : "How to fix",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Remove the marker:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "func caller() async throws {",
            "  greet(\"Ada\")",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
  ],
