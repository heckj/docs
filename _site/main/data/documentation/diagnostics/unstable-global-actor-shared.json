  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/unstable-global-actor-shared"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Potentially unstable witness for `static var shared` (UnstableGlobalActorShared)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "When declaring a global actor with ",
              "type" : "text"
            },
            {
              "code" : "@globalActor",
              "type" : "codeVoice"
            },
            {
              "text" : ", the concrete instance of the actor used for isolation is returned by",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "static var shared",
              "type" : "codeVoice"
            },
            {
              "text" : ". This property must always return the same actor instance in order for actor isolation to work correctly,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "and establish the exact 1:1 mapping between ",
              "type" : "text"
            },
            {
              "code" : "MyGlobalActor.shared",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "@MyGlobalActor",
              "type" : "codeVoice"
            },
            {
              "text" : " isolation.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Only by using a ",
              "type" : "text"
            },
            {
              "code" : "static let",
              "type" : "codeVoice"
            },
            {
              "text" : " is this property guaranteed by the language.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "When the property is implemented as a stored ",
              "type" : "text"
            },
            {
              "code" : "var",
              "type" : "codeVoice"
            },
            {
              "text" : " (which can be reassigned),",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "or computed property (",
              "type" : "text"
            },
            {
              "code" : "var shared: T { ... }",
              "type" : "codeVoice"
            },
            {
              "text" : ") (which can return a different instance upon access),",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "this guarantee must be enforced dynamically by the implementation.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "As the compiler cannot prove this implementation is correct, and it is critically important for actor isolation correctness,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "the compiler emits a warning for those cases.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The following implementation is incorrect:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@globalActor",
            "public actor MyGlobalActor {",
            "  \/\/ Incorrect! New instance per every invocation",
            "  public static var shared: MyGlobalActor { MyGlobalActor() } ",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The correct way to implement this is as follows:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@globalActor",
            "public actor MyGlobalActor {",
            "  public static let shared = MyGlobalActor()",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If the witness must be a computed property, because of initialization requirements of the shared actor,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "or because the actor is a generic type which would prevent using a ",
              "type" : "text"
            },
            {
              "code" : "let",
              "type" : "codeVoice"
            },
            {
              "text" : " constant,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "you can safely silence this warning as follows:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@globalActor",
            "public actor MyGlobalActor {",
            "  @diagnose(UnstableGlobalActorShared, as: ignored)",
            "  public static var shared: MyGlobalActor { _shared }",
            "",
            "  private static let _shared = MyGlobalActor()",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
  ],
