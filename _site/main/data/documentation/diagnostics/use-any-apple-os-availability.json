{
  "abstract" : [
    {
      "text" : "An opt-in warning that suggests replacing a group of per-platform",
      "type" : "text"
    },
    {
      "text" : " ",
      "type" : "text"
    },
    {
      "code" : "@available",
      "type" : "codeVoice"
    },
    {
      "text" : " specifications with a single ",
      "type" : "text"
    },
    {
      "code" : "anyAppleOS",
      "type" : "codeVoice"
    },
    {
      "text" : " specification when the",
      "type" : "text"
    },
    {
      "text" : " ",
      "type" : "text"
    },
    {
      "text" : "platforms share the same introduced version.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/diagnostics\/documentation\/diagnostics",
