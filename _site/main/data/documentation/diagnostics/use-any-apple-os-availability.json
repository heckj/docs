  },
  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/diagnostics\/documentation\/diagnostics\/use-any-apple-os-availability"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Use anyAppleOS availability (UseAnyAppleOSAvailability)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "code" : "anyAppleOS",
              "type" : "codeVoice"
            },
            {
              "text" : " is a meta-platform that covers all Apple platforms using unified",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "versioning starting at 26.0. When a declaration is available on at least",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "macOS",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "iOS",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "tvOS",
              "type" : "codeVoice"
            },
            {
              "text" : ", and ",
              "type" : "text"
            },
            {
              "code" : "watchOS",
              "type" : "codeVoice"
            },
            {
              "text" : " at the same introduced version, a single",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "anyAppleOS",
              "type" : "codeVoice"
            },
            {
              "text" : " specification expresses the same intent more concisely.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "This warning is opt-in and disabled by default. Enable it with:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "-Wwarning UseAnyAppleOSAvailability"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "or promote it to an error with ",
              "type" : "text"
            },
            {
              "code" : "-Werror UseAnyAppleOSAvailability",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Examples",
          "level" : 2,
          "text" : "Examples",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Short-form grouped availability:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@available(macOS 26, iOS 26, tvOS 26, watchOS 26, *)",
            "func foo() {} \/\/ warning: use '@available(anyAppleOS 26, *)' instead of platform specific '@available' attributes with the same version",
            "",
            "\/\/ Suggested replacement",
            "@available(anyAppleOS 26, *)",
            "func foo() {}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
  ],
