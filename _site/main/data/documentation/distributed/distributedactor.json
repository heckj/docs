{"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc://com.apple.Swift/documentation/Swift/Equatable","doc://com.apple.Swift/documentation/Swift/Hashable","doc://com.apple.Swift/documentation/Swift/Identifiable","doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype"],"type":"inheritsFrom"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Distributed"]]},"sections":[],"metadata":{"roleHeading":"Protocol","title":"DistributedActor","modules":[{"name":"Distributed"}],"role":"symbol","externalID":"s:11Distributed0A5ActorP","symbolKind":"protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistributedActor","kind":"identifier"}],"navigatorTitle":[{"text":"DistributedActor","kind":"identifier"}]},"abstract":[{"text":"Common protocol to which all distributed actors conform implicitly.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DistributedActor"},{"kind":"text","text":" : AnyObject, "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Hashable","preciseIdentifier":"s:SH","text":"Hashable"},{"kind":"text","text":", "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Identifiable","preciseIdentifier":"s:s12IdentifiableP","text":"Identifiable"},{"kind":"text","text":", "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","preciseIdentifier":"s:s8SendableP","text":"Sendable"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc://com.apple.Swift/documentation/Swift/implementing-a-custom-distributed-actor-system"]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The "},{"code":"DistributedActor","type":"codeVoice"},{"type":"text","text":" protocol generalizes over all distributed actor types."},{"type":"text","text":" "},{"type":"text","text":"Distributed actor types implicitly conform to this protocol."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is not possible to conform to this protocol by any other declaration other than a "},{"code":"distributed actor","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is possible to require a type to conform to the"},{"type":"text","text":" "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor","type":"reference","isActive":true},{"type":"text","text":" protocol by refining it with another protocol,"},{"type":"text","text":" "},{"type":"text","text":"or by using a generic constraint."}],"type":"paragraph"},{"anchor":"Synthesized-properties","text":"Synthesized properties","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"For every concrete distributed actor declaration, the compiler synthesizes two properties: "},{"type":"codeVoice","code":"actorSystem"},{"type":"text","text":" and "},{"type":"codeVoice","code":"id"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"They witness the "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/actorSystem-swift.property","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","type":"reference","isActive":true},{"type":"text","text":" protocol requirements of the "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor","type":"reference","isActive":true},{"type":"text","text":" protocol."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is not possible to implement these properties explicitly in user code."},{"text":" ","type":"text"},{"type":"text","text":"These properties are "},{"code":"nonisolated","type":"codeVoice"},{"text":" and accessible even if the instance is ","type":"text"},{"inlineContent":[{"type":"text","text":"remote"}],"type":"emphasis"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"because "},{"inlineContent":[{"type":"text","text":"all"}],"type":"emphasis"},{"type":"text","text":" distributed actor references must store the actor system remote calls"},{"text":" ","type":"text"},{"text":"will be delivered through, as well as the id identifying the target of those calls.","type":"text"}]},{"anchor":"The-ActorSystem-associated-type","level":2,"type":"heading","text":"The ActorSystem associated type"},{"inlineContent":[{"type":"text","text":"Every distributed actor must declare what type of actor system"},{"type":"text","text":" "},{"type":"text","text":"it is part of by implementing the "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","type":"reference","isActive":true},{"type":"text","text":" associated type requirement."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This causes a number of other properties of the actor to be inferred:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the "},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/SerializationRequirement"},{"type":"text","text":" that will be used at compile time to"},{"type":"text","text":" "},{"type":"text","text":"verify "},{"type":"codeVoice","code":"distributed"},{"type":"text","text":" target declarations are well formed,"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"if the distributed actor is "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":", based on the "},{"type":"codeVoice","code":"ID"},{"type":"text","text":" being Codable or not,"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the type of the "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","type":"reference","isActive":true},{"type":"text","text":" accepted in the synthesized default initializer."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"A distributed actor must declare what type of actor system it is ready to"},{"type":"text","text":" "},{"type":"text","text":"work with by fulfilling the "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","isActive":true},{"type":"text","text":" type member requirement:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["distributed actor Greeter {","  typealias ActorSystem = GreetingSystem // which conforms to DistributedActorSystem","","  func greet() -> String { \"Hello!\" }","}"]},{"anchor":"The-DefaultDistributedActorSystem-type-alias","level":3,"type":"heading","text":"The DefaultDistributedActorSystem type alias"},{"inlineContent":[{"type":"text","text":"Since it is fairly common to only be using one specific type of actor system"},{"type":"text","text":" "},{"type":"text","text":"within a module or entire codebase, it is possible to declare the default type"},{"type":"text","text":" "},{"type":"text","text":"of actor system all distributed actors will be using in a module by declaring"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"DefaultDistributedActorSystem"},{"type":"text","text":" module wide typealias:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import Distributed","import AmazingActorSystemLibrary","","typealias DefaultDistributedActorSystem = AmazingActorSystem","","distributed actor Greeter {} // ActorSystem == AmazingActorSystem"]},{"inlineContent":[{"type":"text","text":"This declaration makes all "},{"type":"codeVoice","code":"distributed actor"},{"type":"text","text":" declarations"},{"type":"text","text":" "},{"type":"text","text":"that do not explicitly specify an "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","isActive":true,"type":"reference"},{"type":"text","text":" type alias to assume the"},{"type":"text","text":" "},{"type":"codeVoice","code":"AmazingActorSystem"},{"type":"text","text":" as their "},{"type":"codeVoice","code":"ActorSystem"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is possible for a specific actor to override the system it is using,"},{"type":"text","text":" "},{"type":"text","text":"by declaring an "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","isActive":true,"type":"reference"},{"type":"text","text":" type alias as usual:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["typealias DefaultDistributedActorSystem = AmazingActorSystem","","distributed actor Amazing {","  // ActorSystem == AmazingActorSystem","}","","distributed actor Superb {","  typealias ActorSystem = SuperbActorSystem","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In general the "},{"code":"DefaultDistributedActorSystem","type":"codeVoice"},{"type":"text","text":" should not be declared public,"},{"type":"text","text":" "},{"type":"text","text":"as picking the default should be left up to each specific module of a project."}]},{"type":"heading","text":"Default initializer","level":2,"anchor":"Default-initializer"},{"type":"paragraph","inlineContent":[{"type":"text","text":"While classes and actors receive a synthesized "},{"type":"emphasis","inlineContent":[{"type":"text","text":"argument-free default"},{"type":"text","text":" "},{"type":"text","text":"initializer"}]},{"type":"text","text":" ("},{"type":"codeVoice","code":"init()"},{"type":"text","text":"), distributed actors synthesize a default initializer"},{"type":"text","text":" "},{"type":"text","text":"that accepts a distributed actor system the actor is part of: "},{"type":"codeVoice","code":"init(actorSystem:)"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The accepted actor system must be of the "},{"type":"codeVoice","code":"Self.ActorSystem"},{"type":"text","text":" type, which"},{"type":"text","text":" "},{"type":"text","text":"must conform to the "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem","isActive":true,"type":"reference"},{"type":"text","text":" protocol. This is required"},{"type":"text","text":" "},{"type":"text","text":"because distributed actors are always managed by a concrete"},{"type":"text","text":" "},{"type":"text","text":"distributed actor system and cannot exist on their own without one."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is possible to explicitly declare a parameter-free initializer ("},{"type":"codeVoice","code":"init()"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"however the "},{"type":"codeVoice","code":"actorSystem"},{"type":"text","text":" property still must be assigned a concrete actor"},{"type":"text","text":" "},{"type":"text","text":"system instance the actor shall be part of."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In general it is recommended to always have an "},{"type":"codeVoice","code":"actorSystem"},{"type":"text","text":" parameter as"},{"type":"text","text":" "},{"type":"text","text":"the last non-defaulted non-closure parameter in every actor’s"},{"type":"text","text":" "},{"type":"text","text":"initializer parameter list. This way it is simple to swap in a “test actor"},{"type":"text","text":" "},{"type":"text","text":"system” instance in unit tests, and avoid relying on global state which could"},{"type":"text","text":" "},{"type":"text","text":"make testing more difficult."}]},{"type":"heading","text":"Implicit properties","level":2,"anchor":"Implicit-properties"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every concrete "},{"type":"codeVoice","code":"distributed actor"},{"type":"text","text":" type receives two synthesized properties,"},{"type":"text","text":" "},{"type":"text","text":"which implement the protocol requirements of this protocol: "},{"type":"codeVoice","code":"id"},{"type":"text","text":" and "},{"type":"codeVoice","code":"actorSystem"},{"type":"text","text":"."}]},{"type":"heading","text":"Property: Actor System","level":3,"anchor":"Property-Actor-System"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/actorSystem-swift.property","isActive":true,"type":"reference"},{"type":"text","text":" property is an important part of every distributed actor’s lifecycle management."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both initialization as well as de-initialization require interactions with the actor system,"},{"type":"text","text":" "},{"type":"text","text":"and it is the actor system that handles all remote interactions of an actor, by both sending"},{"type":"text","text":" "},{"type":"text","text":"or receiving remote calls made on the actor."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/actorSystem-swift.property","isActive":true,"type":"reference"},{"type":"text","text":" property must be assigned in every designated initializer"},{"type":"text","text":" "},{"type":"text","text":"of a distributed actor explicitly. It is highly recommended to make it a"},{"type":"text","text":" "},{"type":"text","text":"parameter of every distributed actor initializer, and simply forward the"},{"type":"text","text":" "},{"type":"text","text":"value to the stored property, like this:"}]},{"type":"codeListing","syntax":"swift","code":["init(name: String, actorSystem: Self.ActorSystem) {","  self.name = name","  self.actorSystem = actorSystem","}"]},{"inlineContent":[{"type":"text","text":"Forgetting to initialize the actor system, will result in a compile time error:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["// BAD","init(name: String, actorSystem: Self.ActorSystem) {","  self.name = name","  // BAD, will cause compile-time error; the `actorSystem` was not initialized.","}"]},{"anchor":"Property-Distributed-Actor-Identity","level":3,"type":"heading","text":"Property: Distributed Actor Identity"},{"inlineContent":[{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","isActive":true,"type":"reference"},{"type":"text","text":" is assigned by the actor system during the distributed actor’s"},{"type":"text","text":" "},{"type":"text","text":"initialization, and cannot be set or mutated by the actor itself."}],"type":"paragraph"},{"inlineContent":[{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","isActive":true,"type":"reference"},{"type":"text","text":" is the effective identity of the actor, and is used in equality checks,"},{"type":"text","text":" "},{"type":"text","text":"as well as the actor’s synthesized "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":" conformance if the "},{"type":"codeVoice","code":"ID"},{"type":"text","text":" type"},{"type":"text","text":" "},{"type":"text","text":"conforms to "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Automatic-Conformances","text":"Automatic Conformances"},{"anchor":"Hashable-and-Identifiable-conformance","level":3,"type":"heading","text":"Hashable and Identifiable conformance"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every distributed actor conforms to the "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Identifiable"},{"type":"text","text":" protocols."},{"type":"text","text":" "},{"type":"text","text":"Its identity is strictly driven by its "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","isActive":true},{"type":"text","text":", and therefore hash and equality"},{"type":"text","text":" "},{"type":"text","text":"implementations directly delegate to the "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","isActive":true},{"type":"text","text":" property."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Comparing a local distributed actor instance and a remote reference to it"},{"type":"text","text":" "},{"type":"text","text":"(both using the same "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","isActive":true},{"type":"text","text":") always returns true, as they both conceptually"},{"type":"text","text":" "},{"type":"text","text":"point at the same distributed actor."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is not possible to implement these protocols relying on the actual actor’s"},{"type":"text","text":" "},{"type":"text","text":"state, because it may be remote and the state may not be available. In other"},{"type":"text","text":" "},{"type":"text","text":"words, since these protocols must be implemented using "},{"type":"codeVoice","code":"nonisolated"},{"type":"text","text":" functions,"},{"type":"text","text":" "},{"type":"text","text":"only "},{"type":"codeVoice","code":"nonisolated"},{"type":"text","text":" "},{"type":"codeVoice","code":"id"},{"type":"text","text":" and "},{"type":"codeVoice","code":"actorSystem"},{"type":"text","text":" properties are accessible for their"},{"type":"text","text":" "},{"type":"text","text":"implementations."}]},{"type":"heading","text":"Implicit Codable conformance","level":3,"anchor":"Implicit-Codable-conformance"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If created with an actor system whose "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem/ActorID","isActive":true,"type":"reference"},{"type":"text","text":" is "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"compiler will synthesize code for the concrete distributed actor to conform"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":" as well."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is necessary to support distributed calls where the "},{"type":"codeVoice","code":"SerializationRequirement"},{"type":"text","text":" "},{"type":"text","text":"is "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":" and thus users may want to pass actors as arguments to remote calls."}]},{"inlineContent":[{"type":"text","text":"The synthesized implementations use a single "},{"code":"SingleValueEncodingContainer","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"encode/decode the "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","isActive":true},{"type":"text","text":" property of the actor. The "},{"code":"Decoder","type":"codeVoice"},{"type":"text","text":" required"},{"type":"text","text":" "},{"type":"codeVoice","code":"Decoder/init(from:)"},{"type":"text","text":" is implemented by retrieving an actor system from the"},{"type":"text","text":" "},{"type":"text","text":"decoders’ "},{"code":"userInfo","type":"codeVoice"},{"type":"text","text":", effectively like as follows:"}],"type":"paragraph"},{"code":["decoder.userInfo[.actorSystemKey] as? ActorSystem","","The such obtained actor system is then used to ``resolve(id:using:)`` the decoded ``ID``.","","Use the ``CodingUserInfoKey/actorSystemKey`` to provide the necessary","actor system for the decoding initializer when decoding a distributed actor.","","- SeeAlso: ``DistributedActorSystem``","- SeeAlso: ``Actor``","- SeeAlso: ``AnyActor``"],"type":"codeListing","syntax":"swift"}]}],"kind":"symbol","topicSections":[{"anchor":"Associated-Types","title":"Associated Types","identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","doc://com.apple.Swift/documentation/Distributed/DistributedActor/SerializationRequirement"],"generated":true},{"anchor":"Initializers","title":"Initializers","identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/init(from:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/actorSystem-swift.property","doc://com.apple.Swift/documentation/Distributed/DistributedActor/asLocalActor","doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","doc://com.apple.Swift/documentation/Distributed/DistributedActor/unownedExecutor"],"generated":true},{"anchor":"Instance-Methods","title":"Instance Methods","identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/assertIsolated(_:file:line:)","doc://com.apple.Swift/documentation/Distributed/DistributedActor/assumeIsolated(_:file:line:)","doc://com.apple.Swift/documentation/Distributed/DistributedActor/encode(to:)","doc://com.apple.Swift/documentation/Distributed/DistributedActor/preconditionIsolated(_:file:line:)","doc://com.apple.Swift/documentation/Distributed/DistributedActor/whenLocal(_:)"],"generated":true},{"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/resolve(id:using:)"],"generated":true}],"variants":[{"paths":["/documentation/distributed/distributedactor"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Distributed/DistributedActor","interfaceLanguage":"swift"},"seeAlsoSections":[{"anchor":"Distributed-actors","title":"Distributed actors","identifiers":["doc://com.apple.Swift/documentation/Distributed/Resolvable()","doc://com.apple.Swift/documentation/Distributed/buildDefaultDistributedRemoteActorExecutor(_:)"],"generated":true}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://com.apple.Swift/documentation/Swift/SendableMetatype":{"type":"topic","abstract":[{"type":"text","text":"A type whose metatype can be shared across arbitrary isolation domains"},{"type":"text","text":" "},{"type":"text","text":"without introducing a risk of data races."}],"title":"SendableMetatype","role":"symbol","url":"/documentation/swift/sendablemetatype","identifier":"doc://com.apple.Swift/documentation/Swift/SendableMetatype","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"SendableMetatype"}],"navigatorTitle":[{"kind":"identifier","text":"SendableMetatype"}]},"doc://com.apple.Swift/documentation/Distributed/DistributedActor/SerializationRequirement":{"url":"/documentation/distributed/distributedactor/serializationrequirement","kind":"symbol","type":"topic","title":"SerializationRequirement","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/SerializationRequirement","abstract":[{"type":"text","text":"The serialization requirement to apply to all distributed declarations inside the actor."}],"required":true,"fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"SerializationRequirement"}]},"doc://com.apple.Swift/documentation/Distributed":{"title":"Distributed","identifier":"doc://com.apple.Swift/documentation/Distributed","type":"topic","role":"collection","kind":"symbol","abstract":[],"url":"/documentation/distributed"},"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem/ActorID":{"title":"ActorID","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"ActorID"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SH","kind":"typeIdentifier","text":"Hashable"},{"text":", ","kind":"text"},{"text":"Sendable","preciseIdentifier":"s:s8SendableP","kind":"typeIdentifier"}],"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem/ActorID","type":"topic","required":true,"role":"symbol","abstract":[{"text":"The type ID that will be assigned to any distributed actor managed by this actor system.","type":"text"}],"kind":"symbol","url":"/documentation/distributed/distributedactorsystem/actorid"},"doc://com.apple.Swift/documentation/Distributed/DistributedActor/preconditionIsolated(_:file:line:)":{"abstract":[{"type":"text","text":"Stops program execution if the current task is not executing on this"},{"type":"text","text":" "},{"type":"text","text":"actor’s serial executor."}],"role":"symbol","url":"/documentation/distributed/distributedactor/preconditionisolated(_:file:line:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"preconditionIsolated"},{"kind":"text","text":"("},{"kind":"attribute","text":"@autoclosure"},{"kind":"text","text":" () -> "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"file"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s12StaticStringV","text":"StaticString"},{"kind":"text","text":", "},{"kind":"externalParam","text":"line"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Su","text":"UInt"},{"kind":"text","text":")"}],"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/preconditi