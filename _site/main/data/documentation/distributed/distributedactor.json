{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"relationshipsSections":[{"title":"Inherits From","kind":"relationships","type":"inheritsFrom","identifiers":["doc://com.apple.Swift/documentation/Swift/Equatable","doc://com.apple.Swift/documentation/Swift/Hashable","doc://com.apple.Swift/documentation/Swift/Identifiable","doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/distributed/distributedactor"]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Distributed/DistributedActor"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistributedActor","kind":"identifier"},{"text":" : AnyObject, ","kind":"text"},{"text":"Hashable","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Hashable","preciseIdentifier":"s:SH"},{"text":", ","kind":"text"},{"text":"Identifiable","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Identifiable","preciseIdentifier":"s:s12IdentifiableP"},{"text":", ","kind":"text"},{"text":"Sendable","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","preciseIdentifier":"s:s8SendableP"}],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"DistributedActor"},{"type":"text","text":" protocol generalizes over all distributed actor types."},{"type":"text","text":" "},{"type":"text","text":"Distributed actor types implicitly conform to this protocol."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is not possible to conform to this protocol by any other declaration other than a "},{"type":"codeVoice","code":"distributed actor"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is possible to require a type to conform to the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor"},{"type":"text","text":" protocol by refining it with another protocol,"},{"type":"text","text":" "},{"type":"text","text":"or by using a generic constraint."}],"type":"paragraph"},{"anchor":"Synthesized-properties","text":"Synthesized properties","type":"heading","level":2},{"inlineContent":[{"text":"For every concrete distributed actor declaration, the compiler synthesizes two properties: ","type":"text"},{"code":"actorSystem","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"id","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"They witness the ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/actorSystem-swift.property","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","isActive":true,"type":"reference"},{"text":" protocol requirements of the ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor","isActive":true,"type":"reference"},{"text":" protocol.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is not possible to implement these properties explicitly in user code."},{"type":"text","text":" "},{"type":"text","text":"These properties are "},{"type":"codeVoice","code":"nonisolated"},{"text":" and accessible even if the instance is ","type":"text"},{"inlineContent":[{"type":"text","text":"remote"}],"type":"emphasis"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"because ","type":"text"},{"inlineContent":[{"type":"text","text":"all"}],"type":"emphasis"},{"text":" distributed actor references must store the actor system remote calls","type":"text"},{"text":" ","type":"text"},{"text":"will be delivered through, as well as the id identifying the target of those calls.","type":"text"}],"type":"paragraph"},{"level":2,"text":"The ActorSystem associated type","type":"heading","anchor":"The-ActorSystem-associated-type"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every distributed actor must declare what type of actor system"},{"type":"text","text":" "},{"type":"text","text":"it is part of by implementing the "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype"},{"type":"text","text":" associated type requirement."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This causes a number of other properties of the actor to be inferred:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"the ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/SerializationRequirement","type":"reference","isActive":true},{"text":" that will be used at compile time to","type":"text"},{"text":" ","type":"text"},{"text":"verify ","type":"text"},{"code":"distributed","type":"codeVoice"},{"text":" target declarations are well formed,","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"if the distributed actor is "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":", based on the "},{"code":"ID","type":"codeVoice"},{"type":"text","text":" being Codable or not,"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"the type of the ","type":"text"},{"isActive":true,"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","type":"reference"},{"text":" accepted in the synthesized default initializer.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"A distributed actor must declare what type of actor system it is ready to","type":"text"},{"text":" ","type":"text"},{"text":"work with by fulfilling the ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","isActive":true,"type":"reference"},{"text":" type member requirement:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["distributed actor Greeter {","  typealias ActorSystem = GreetingSystem // which conforms to DistributedActorSystem","","  func greet() -> String { \"Hello!\" }","}"]},{"text":"The DefaultDistributedActorSystem type alias","type":"heading","level":3,"anchor":"The-DefaultDistributedActorSystem-type-alias"},{"type":"paragraph","inlineContent":[{"text":"Since it is fairly common to only be using one specific type of actor system","type":"text"},{"text":" ","type":"text"},{"text":"within a module or entire codebase, it is possible to declare the default type","type":"text"},{"text":" ","type":"text"},{"text":"of actor system all distributed actors will be using in a module by declaring","type":"text"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"code":"DefaultDistributedActorSystem","type":"codeVoice"},{"text":" module wide typealias:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import Distributed","import AmazingActorSystemLibrary","","typealias DefaultDistributedActorSystem = AmazingActorSystem","","distributed actor Greeter {} // ActorSystem == AmazingActorSystem"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This declaration makes all "},{"type":"codeVoice","code":"distributed actor"},{"type":"text","text":" declarations"},{"type":"text","text":" "},{"type":"text","text":"that do not explicitly specify an "},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype"},{"type":"text","text":" type alias to assume the"},{"type":"text","text":" "},{"code":"AmazingActorSystem","type":"codeVoice"},{"type":"text","text":" as their "},{"type":"codeVoice","code":"ActorSystem"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"It is possible for a specific actor to override the system it is using,","type":"text"},{"text":" ","type":"text"},{"text":"by declaring an ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","isActive":true,"type":"reference"},{"text":" type alias as usual:","type":"text"}]},{"code":["typealias DefaultDistributedActorSystem = AmazingActorSystem","","distributed actor Amazing {","  // ActorSystem == AmazingActorSystem","}","","distributed actor Superb {","  typealias ActorSystem = SuperbActorSystem","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In general the "},{"type":"codeVoice","code":"DefaultDistributedActorSystem"},{"type":"text","text":" should not be declared public,"},{"type":"text","text":" "},{"type":"text","text":"as picking the default should be left up to each specific module of a project."}]},{"anchor":"Default-initializer","type":"heading","level":2,"text":"Default initializer"},{"type":"paragraph","inlineContent":[{"text":"While classes and actors receive a synthesized ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"argument-free default","type":"text"},{"text":" ","type":"text"},{"text":"initializer","type":"text"}]},{"text":" (","type":"text"},{"type":"codeVoice","code":"init()"},{"text":"), distributed actors synthesize a default initializer","type":"text"},{"text":" ","type":"text"},{"text":"that accepts a distributed actor system the actor is part of: ","type":"text"},{"type":"codeVoice","code":"init(actorSystem:)"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The accepted actor system must be of the "},{"type":"codeVoice","code":"Self.ActorSystem"},{"type":"text","text":" type, which"},{"type":"text","text":" "},{"type":"text","text":"must conform to the "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem","isActive":true},{"type":"text","text":" protocol. This is required"},{"type":"text","text":" "},{"type":"text","text":"because distributed actors are always managed by a concrete"},{"type":"text","text":" "},{"type":"text","text":"distributed actor system and cannot exist on their own without one."}]},{"inlineContent":[{"type":"text","text":"It is possible to explicitly declare a parameter-free initializer ("},{"code":"init()","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"however the "},{"code":"actorSystem","type":"codeVoice"},{"type":"text","text":" property still must be assigned a concrete actor"},{"type":"text","text":" "},{"type":"text","text":"system instance the actor shall be part of."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In general it is recommended to always have an "},{"code":"actorSystem","type":"codeVoice"},{"type":"text","text":" parameter as"},{"type":"text","text":" "},{"type":"text","text":"the last non-defaulted non-closure parameter in every actor’s"},{"type":"text","text":" "},{"type":"text","text":"initializer parameter list. This way it is simple to swap in a “test actor"},{"type":"text","text":" "},{"type":"text","text":"system” instance in unit tests, and avoid relying on global state which could"},{"type":"text","text":" "},{"type":"text","text":"make testing more difficult."}],"type":"paragraph"},{"text":"Implicit properties","anchor":"Implicit-properties","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Every concrete "},{"type":"codeVoice","code":"distributed actor"},{"type":"text","text":" type receives two synthesized properties,"},{"type":"text","text":" "},{"type":"text","text":"which implement the protocol requirements of this protocol: "},{"type":"codeVoice","code":"id"},{"text":" and ","type":"text"},{"code":"actorSystem","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Property: Actor System","anchor":"Property-Actor-System"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/actorSystem-swift.property","isActive":true},{"type":"text","text":" property is an important part of every distributed actor’s lifecycle management."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both initialization as well as de-initialization require interactions with the actor system,"},{"type":"text","text":" "},{"type":"text","text":"and it is the actor system that handles all remote interactions of an actor, by both sending"},{"type":"text","text":" "},{"type":"text","text":"or receiving remote calls made on the actor."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/actorSystem-swift.property"},{"type":"text","text":" property must be assigned in every designated initializer"},{"type":"text","text":" "},{"type":"text","text":"of a distributed actor explicitly. It is highly recommended to make it a"},{"type":"text","text":" "},{"type":"text","text":"parameter of every distributed actor initializer, and simply forward the"},{"type":"text","text":" "},{"type":"text","text":"value to the stored property, like this:"}]},{"type":"codeListing","code":["init(name: String, actorSystem: Self.ActorSystem) {","  self.name = name","  self.actorSystem = actorSystem","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forgetting to initialize the actor system, will result in a compile time error:"}]},{"type":"codeListing","code":["// BAD","init(name: String, actorSystem: Self.ActorSystem) {","  self.name = name","  // BAD, will cause compile-time error; the `actorSystem` was not initialized.","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Property: Distributed Actor Identity","anchor":"Property-Distributed-Actor-Identity"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","isActive":true},{"type":"text","text":" is assigned by the actor system during the distributed actor’s"},{"type":"text","text":" "},{"type":"text","text":"initialization, and cannot be set or mutated by the actor itself."}]},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","isActive":true},{"text":" is the effective identity of the actor, and is used in equality checks,","type":"text"},{"text":" ","type":"text"},{"text":"as well as the actor’s synthesized ","type":"text"},{"type":"codeVoice","code":"Codable"},{"text":" conformance if the ","type":"text"},{"type":"codeVoice","code":"ID"},{"text":" type","type":"text"},{"text":" ","type":"text"},{"text":"conforms to ","type":"text"},{"type":"codeVoice","code":"Codable"},{"text":".","type":"text"}]},{"level":2,"anchor":"Automatic-Conformances","text":"Automatic Conformances","type":"heading"},{"level":3,"anchor":"Hashable-and-Identifiable-conformance","text":"Hashable and Identifiable conformance","type":"heading"},{"inlineContent":[{"text":"Every distributed actor conforms to the ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Identifiable","type":"codeVoice"},{"text":" protocols.","type":"text"},{"text":" ","type":"text"},{"text":"Its identity is strictly driven by its ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","type":"reference","isActive":true},{"text":", and therefore hash and equality","type":"text"},{"text":" ","type":"text"},{"text":"implementations directly delegate to the ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","type":"reference","isActive":true},{"text":" property.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Comparing a local distributed actor instance and a remote reference to it"},{"type":"text","text":" "},{"type":"text","text":"(both using the same "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","type":"reference","isActive":true},{"type":"text","text":") always returns true, as they both conceptually"},{"type":"text","text":" "},{"type":"text","text":"point at the same distributed actor."}],"type":"paragraph"},{"inlineContent":[{"text":"It is not possible to implement these protocols relying on the actual actor’s","type":"text"},{"text":" ","type":"text"},{"text":"state, because it may be remote and the state may not be available. In other","type":"text"},{"text":" ","type":"text"},{"text":"words, since these protocols must be implemented using ","type":"text"},{"code":"nonisolated","type":"codeVoice"},{"text":" functions,","type":"text"},{"text":" ","type":"text"},{"text":"only ","type":"text"},{"code":"nonisolated","type":"codeVoice"},{"text":" ","type":"text"},{"code":"id","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"actorSystem","type":"codeVoice"},{"text":" properties are accessible for their","type":"text"},{"text":" ","type":"text"},{"text":"implementations.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Implicit-Codable-conformance","text":"Implicit Codable conformance","type":"heading"},{"inlineContent":[{"type":"text","text":"If created with an actor system whose "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem/ActorID"},{"type":"text","text":" is "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"compiler will synthesize code for the concrete distributed actor to conform"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":" as well."}],"type":"paragraph"},{"inlineContent":[{"text":"This is necessary to support distributed calls where the ","type":"text"},{"type":"codeVoice","code":"SerializationRequirement"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"code":"Codable","type":"codeVoice"},{"text":" and thus users may want to pass actors as arguments to remote calls.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The synthesized implementations use a single "},{"type":"codeVoice","code":"SingleValueEncodingContainer"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"encode/decode the "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id"},{"type":"text","text":" property of the actor. The "},{"type":"codeVoice","code":"Decoder"},{"type":"text","text":" required"},{"type":"text","text":" "},{"type":"codeVoice","code":"Decoder/init(from:)"},{"type":"text","text":" is implemented by retrieving an actor system from the"},{"type":"text","text":" "},{"type":"text","text":"decoders’ "},{"type":"codeVoice","code":"userInfo"},{"type":"text","text":", effectively like as follows:"}]},{"type":"codeListing","syntax":"swift","code":["decoder.userInfo[.actorSystemKey] as? ActorSystem","","The such obtained actor system is then used to ``resolve(id:using:)`` the decoded ``ID``.","","Use the ``CodingUserInfoKey/actorSystemKey`` to provide the necessary","actor system for the decoding initializer when decoding a distributed actor.","","- SeeAlso: ``DistributedActorSystem``","- SeeAlso: ``Actor``","- SeeAlso: ``AnyActor``"]}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Distributed"]]},"kind":"symbol","abstract":[{"type":"text","text":"Common protocol to which all distributed actors conform implicitly."}],"topicSections":[{"anchor":"Associated-Types","title":"Associated Types","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/ActorSystem-swift.associatedtype","doc://com.apple.Swift/documentation/Distributed/DistributedActor/SerializationRequirement"]},{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/init(from:)"]},{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/actorSystem-swift.property","doc://com.apple.Swift/documentation/Distributed/DistributedActor/asLocalActor","doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","doc://com.apple.Swift/documentation/Distributed/DistributedActor/unownedExecutor"]},{"anchor":"Instance-Methods","title":"Instance Methods","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/assertIsolated(_:file:line:)","doc://com.apple.Swift/documentation/Distributed/DistributedActor/assumeIsolated(_:file:line:)","doc://com.apple.Swift/documentation/Distributed/DistributedActor/encode(to:)","doc://com.apple.Swift/documentation/Distributed/DistributedActor/preconditionIsolated(_:file:line:)","doc://com.apple.Swift/documentation/Distributed/DistributedActor/whenLocal(_:)"]},{"anchor":"Type-Methods","title":"Type Methods","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActor/resolve(id:using:)"]}],"seeAlsoSections":[{"anchor":"Distributed-Actors","title":"Distributed Actors","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem","doc://com.apple.Swift/documentation/Distributed/Resolvable()","doc://com.apple.Swift/documentation/Distributed/buildDefaultDistributedRemoteActorExecutor(_:)"]}],"metadata":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DistributedActor"}],"title":"DistributedActor","role":"symbol","externalID":"s:11Distributed0A5ActorP","symbolKind":"protocol","roleHeading":"Protocol","modules":[{"name":"Distributed"}],"navigatorTitle":[{"kind":"identifier","text":"DistributedActor"}]},"references":{"doc://com.apple.Swift/documentation/Distributed/DistributedActor/resolve(id:using:)":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"resolve"},{"kind":"text","text":"("},{"kind":"externalParam","text":"id"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s12IdentifiableP2IDQa","kind":"typeIdentifier","text":"ID"},{"kind":"text","text":", "},{"kind":"externalParam","text":"using"},{"kind":"text","text":": "},{"preciseIdentifier":"s:11Distributed0A5ActorP0B6SystemQa","kind":"typeIdentifier","text":"ActorSystem"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Self"}],"abstract":[{"type":"text","text":"Resolves the passed in "},{"type":"codeVoice","code":"id"},{"type":"text","text":" against the "},{"type":"codeVoice","code":"system"},{"type":"text","text":", returning"},{"type":"text","text":" "},{"type":"text","text":"either a local or remote actor reference."}],"role":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/resolve(id:using:)","kind":"symbol","title":"resolve(id:using:)","required":true,"url":"/documentation/distributed/distributedactor/resolve(id:using:)"},"doc://com.apple.Swift/documentation/Distributed/DistributedActor/init(from:)":{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/init(from:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"from","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Decoder","kind":"typeIdentifier","preciseIdentifier":"s:s7DecoderP"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"type":"topic","url":"/documentation/distributed/distributedactor/init(from:)","title":"init(from:)","abstract":[{"type":"text","text":"Initializes an instance of this distributed actor by decoding its "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and passing it to the "},{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem","type":"reference","isActive":true},{"type":"text","text":" obtained from "},{"code":"decoder.userInfo[actorSystemKey]","type":"codeVoice"},{"type":"text","text":"."}],"conformance":{"constraints":[{"code":"ID","type":"codeVoice"},{"text":" conforms to ","type":"text"},{"code":"Decodable","type":"codeVoice"},{"text":".","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}]},"role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Distributed/DistributedActor":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DistributedActor"}],"abstract":[{"type":"text","text":"Common protocol to which all distributed actors conform implicitly."}],"url":"/documentation/distributed/distributedactor","navigatorTitle":[{"kind":"identifier","text":"DistributedActor"}],"title":"DistributedActor","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor"},"doc://com.apple.Swift/documentation/Distributed":{"type":"topic","kind":"symbol","role":"collection","url":"/documentation/distributed","abstract":[],"