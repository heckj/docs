{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Distributed","doc://com.apple.Swift/documentation/Distributed/DistributedActor"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/distributed/distributedactor/id"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"override","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"id","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ID","identifier":"doc://com.apple.Swift/documentation/Swift/Identifiable/ID-swift.associatedtype","kind":"typeIdentifier","preciseIdentifier":"s:s12IdentifiableP2IDQa"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Many distributed actor references may be pointing at, logically, the same actor."},{"type":"text","text":" "},{"type":"text","text":"For example, calling "},{"type":"codeVoice","code":"resolve(id:using:)"},{"type":"text","text":" multiple times, is not guaranteed"},{"type":"text","text":" "},{"type":"text","text":"to return the same exact resolved actor instance, however all the references would"},{"type":"text","text":" "},{"type":"text","text":"represent logically references to the same distributed actor, e.g. on a different node."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Depending on the capabilities of the actor system producing the identifiers,","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"ID"},{"text":" may also be used to store instance specific metadata.","type":"text"}]},{"anchor":"Synthesized-property","type":"heading","level":2,"text":"Synthesized property"},{"type":"paragraph","inlineContent":[{"text":"In concrete distributed actor declarations, a witness for this protocol requirement is synthesized by the compiler.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is not possible to assign a value to the ","type":"text"},{"type":"codeVoice","code":"id"},{"text":" directly; instead, it is assigned during an actors ","type":"text"},{"type":"codeVoice","code":"init"},{"text":" (or ","type":"text"},{"type":"codeVoice","code":"resolve"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"by the managing actor system.","type":"text"}]}],"kind":"content"}],"kind":"symbol","metadata":{"modules":[{"name":"Distributed"}],"required":true,"role":"symbol","title":"id","roleHeading":"Instance Property","externalID":"s:11Distributed0A5ActorP2id2IDQzvp","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"id","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ID","kind":"typeIdentifier","preciseIdentifier":"s:s12IdentifiableP2IDQa"}],"symbolKind":"property"},"identifier":{"url":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Logical identity of this distributed actor."}],"references":{"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id":{"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor/id","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"id"},{"kind":"text","text":": "},{"text":"ID","kind":"typeIdentifier","preciseIdentifier":"s:s12IdentifiableP2IDQa"}],"type":"topic","url":"/documentation/distributed/distributedactor/id","title":"id","abstract":[{"text":"Logical identity of this distributed actor.","type":"text"}],"required":true,"role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Distributed/DistributedActor":{"type":"topic","kind":"symbo