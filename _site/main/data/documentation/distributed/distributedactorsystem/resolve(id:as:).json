{"abstract":[{"type":"text","text":"Resolves a local or remote "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem/ActorID","isActive":true},{"type":"text","text":" to a reference to given actor, or throws if unable to."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"resolve"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Act"},{"kind":"text","text":">("},{"kind":"externalParam","text":"id"},{"kind":"text","text":": "},{"text":"ActorID","kind":"typeIdentifier","preciseIdentifier":"s:11Distributed0A11ActorSystemP0B2IDQa","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem/ActorID"},{"text":", ","kind":"text"},{"text":"as","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"actorType","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Act","kind":"typeIdentifier","preciseIdentifier":"s:11Distributed0A11ActorSystemP7resolve2id2asqd__Sg0B2IDQz_qd__mtKAA0aB0Rd__0G0Qyd__AIRSlF3ActL_qd__mfp"},{"text":".Type) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Act","preciseIdentifier":"s:11Distributed0A11ActorSystemP7resolve2id2asqd__Sg0B2IDQz_qd__mtKAA0aB0Rd__0G0Qyd__AIRSlF3ActL_qd__mfp","kind":"typeIdentifier"},{"text":"? ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Act"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:11Distributed0A5ActorP","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActor","text":"DistributedActor"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"ActorID","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystem/ActorID","preci