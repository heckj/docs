or system, then"},{"type":"text","text":" "},{"type":"text","text":"this function should throw."}],"type":"paragraph"},{"code":["distributed actor Worker { /* ... */ }","","// the following internally calls actorSystem.resolve(id: id, as: Worker.self)","let worker: Worker = try  Worker.resolve(id: id, using: actorSystem)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If this function returns correctly, the returned actor reference is immediately"},{"type":"text","text":" "},{"type":"text","text":"usable. It may not necessarily imply the strict "},{"inlineContent":[{"type":"text","text":"existence"}],"type":"emphasis"},{"text":" of a remote actor","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the identity was pointing towards, e.g. when a remote system allocates actors"},{"text":" ","type":"text"},{"type":"text","text":"lazily as they are first time messaged to, however this should not be a concern"},{"text":" ","type":"text"},{"type":"text","text":"of the sending side."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Detecting liveness of such remote actors shall be offered / by transport libraries","type":"text"},{"type":"text","text":" "},{"text":"by other means, such as “watching an actor for termination” or similar.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"When unable to confirm if the ","type":"text"},{"code":"id","type":"codeVoice"},{"type":"text","text":" is correct, the resolved actor does not match the expected "},{"code":"actorType","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or any other internal validation error within the actor system’s resolve process occurs."}]}],"name":"Throws","type":"aside","style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/distributed/distributedactorsystem/resolve(id:as:)"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"