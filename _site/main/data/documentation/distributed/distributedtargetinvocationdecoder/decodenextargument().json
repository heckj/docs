{"identifier":{"url":"doc://com.apple.Swift/documentation/Distributed/DistributedTargetInvocationDecoder/decodeNextArgument()","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decodeNextArgument"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Argument"},{"kind":"text","text":">() "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Argument","preciseIdentifier":"s:11Distributed0A23TargetInvocationDecoderP18decodeNextArgumentqd__yKlF0G0L_qd__mfp","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method should throw if it has no more arguments available, if decoding the argument failed,"},{"type":"text","text":" "},{"type":"text","text":"or, optionally, if the argument type we’re trying to decode does not match the stored type."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The result of the decoding operation must be stored into the provided ‘pointer’ rather than"},{"text":" ","type":"text"},{"type":"text","text":"returning a value. This pattern allows the runtime to use a heavily optimized, pre-allocated"},{"text":" ","type":"text"},{"text":"buffer for all the arguments and their expected types. The ‘pointer’ passed here is a pointer","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to a “slot” in that pre-allocated buffer. That buffer will then be passed to a thunk that"},{"type":"text","text":" "},{"type":"text","text":"performs the actual distributed (local) instance method invocation."}]},{"type":"heading","text":"Serialization Requirement","anchor":"Serialization-Requirement","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations of this method must ensure that the "},{"type":"codeVoice","code":"Argument"},{"type":"text","text":" type parameter conforms"},{"type":"text","text":" "},{"type":"text","text":"to the types’ "},{"code":"SerializationRequirement","type":"codeVoice"},{"type":"text","text":"."}]}]}],"abstract":[{"type":"text","text":"Attempt to decode the next argument from the underlying buffers into pre-allocated storage"},{"type":"text","text":" "},{"type":"text","text":"pointed at by ‘pointer’."}],"metadata":{"externalID":"s:11Distributed0A23TargetInvocationDecoderP18decodeNextArgumentqd__yKlF","symbolKind":"method","title":"decodeNextArgument()","modules":[{"name":"Distributed"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decodeNextArgument"},{"kind":"text","text":"<"},{"text":"Argument","kind":"genericParameter"},{"kind":"text","text":">() "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Argument","preciseIdentifier":"s:11Distributed0A23TargetInvocationDecoderP18decodeNextArgumentqd__yKlF0G0L_qd__mfp","kind":"typeIdentifier"}],"required":true,"roleHeading":"Instance Method","role":"symbol"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","variants":[{"paths":["/documentation/distributed/distributedtargetinvocationdecoder/decodenextargument()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Distributed","doc://com.apple.Swift/documentation/Distributed/DistributedTargetInvocationDecoder"]]},"sections":[],"references":{"doc://com.apple.Swift/documentation/Distributed":{"title":"Distributed","identifier":"doc://com.apple.Swift/documentation/Distributed","type":"topic","role":"collection","kind":"symbol","abstract":[],"url":"/documentation/distributed"},"doc://com.apple.Swift/documentation/Distributed/DistributedTargetInvocationDecoder/decodeNextArgument()":{"required":true,"type":"topic","abstract":[{"type":"text","text":"Attempt to decode the next argument from the underlying buffers into pre-allocated storage"},{"type":"text","text":" "},{"type":"text","text":"pointed at by ‘pointer’."}],"title":"decodeNextArgument()","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedTargetInvocationDecoder/decodeNextArgument()","url":"/documentation/distributed/distributedtargetinvocationdecoder/decodenextargument()","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decodeNextArgument"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Argument"},{"kind":"text","text":">() "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Argument","preciseIdentifier":"s:11Distributed0A23TargetInvocationDecoderP18decodeNextArgumentqd__yKlF0G0L_qd__mfp"}]},"doc://com.apple.Swift/documentation/Distributed/DistributedTargetInvocationDecoder":{"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DistributedTargetInvocationDecoder"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"DistributedTargetInvocationDecoder"}],"identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedTargetInvocationDecoder","url":"/documentation/distributed/distributedtargetinvocationdecoder","kind":"symbol","abstract":[{"type":"text","text":"Decoder that must be provided to "},{"type":"codeVoice","code":"executeDistributedTarget"},{"type":"text","text":" and is used"},{"type":"text","text":" "},{"type":"text","text":"by the Swift runtime to decode arguments of the invocation."}],"title":"DistributedTargetInvocationDecoder"}}}