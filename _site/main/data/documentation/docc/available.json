          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "The platform name that this version information applies to.",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "(required)",
                      "type" : "text"
                    }
                  ],
                  "type" : "strong"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "platform"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "The semantic version (major",
                  "type" : "text"
                },
                {
                  "code" : ".",
                  "type" : "codeVoice"
                },
                {
                  "text" : "minor",
                  "type" : "text"
                },
                {
                  "code" : ".",
                  "type" : "codeVoice"
                },
                {
                  "text" : "patch) when you introduced this API or documentation page.",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "(required)",
                      "type" : "text"
                    }
                  ],
                  "type" : "strong"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "introduced"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "The semantic version (major",
                  "type" : "text"
                },
                {
                  "code" : ".",
                  "type" : "codeVoice"
                },
                {
                  "text" : "minor",
                  "type" : "text"
                },
                {
                  "code" : ".",
                  "type" : "codeVoice"
                },
                {
                  "text" : "patch) when you deprecated this API or documentation page.",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "(optional)",
                      "type" : "text"
                    }
                  ],
                  "type" : "strong"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "deprecated"
        }
      ]
    },
    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Whenever possible, prefer to specify availability information using in-source annotations such as the ",
              "type" : "text"
            },
            {
              "code" : "@available",
              "type" : "codeVoice"
            },
            {
              "text" : " attribute in Swift or the ",
              "type" : "text"
            },
            {
              "code" : "API_AVAILABLE",
              "type" : "codeVoice"
            },
            {
              "text" : " macro in Objective-C.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Using in-source annotations ensures that your documentation matches the availability of your API.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "If you duplicate availability information in the documentation markup, the information from the ",
              "type" : "text"
            },
            {
              "code" : "@Available",
              "type" : "codeVoice"
            },
            {
              "text" : " directive overrides the information for the in-source annotations from that platform and risks being inaccurate.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "If your source language doesn’t have a mechanism for specifying API availability or if you’re writing articles about a newly introduced or deprecated API,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "you can use the ",
              "type" : "text"
            },
            {
              "code" : "@Available",
              "type" : "codeVoice"
            },
            {
              "text" : " directive to specify when you introduced, and optionally deprecated, an API or documentation page for a given platform.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Each ",
              "type" : "text"
            },
            {
              "code" : "@Available",
              "type" : "codeVoice"
            },
            {
              "text" : " directive specifies the availability information for a single platform.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The directive matches the ",
              "type" : "text"
            },
            {
              "code" : "iOS",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "macOS",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "watchOS",
              "type" : "codeVoice"
            },
            {
              "text" : ", and ",
              "type" : "text"
            },
            {
              "code" : "tvOS",
              "type" : "codeVoice"
            },
            {
              "text" : " platform names case-insensitively.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Any other platform names are displayed verbatim.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "If a platform name contains whitespace, commas, or other special characters you need to surround it with quotation marks (",
              "type" : "text"
            },
            {
              "code" : "\"",
              "type" : "codeVoice"
            },
            {
              "text" : ").",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Metadata {",
            "    @Available(iOS, introduced: \"15.0\")",
            "    @Available(macOS, introduced: \"12.0\", deprecated: \"14.0\")",
            "    @Available(\"My Package\", introduced: \"1.2.3\")",
            "}"
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Both the “introduced” and “deprecated” parameters take string representations of semantic version numbers (major",
              "type" : "text"
            },
            {
              "code" : ".",
              "type" : "codeVoice"
            },
            {
              "text" : "minor",
              "type" : "text"
            },
            {
              "code" : ".",
              "type" : "codeVoice"
            },
            {
              "text" : "patch).",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "If you omit the “patch” or “minor” components, they are assumed to be ",
              "type" : "text"
            },
            {
              "code" : "0",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "This means that ",
              "type" : "text"
            },
            {
              "code" : "\"1.0.0\"",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "\"1.0\"",
              "type" : "codeVoice"
            },
            {
              "text" : ", and ",
              "type" : "text"
            },
            {
              "code" : "\"1\"",
              "type" : "codeVoice"
            },
            {
              "text" : " all specify the same semantic version.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "Before Swift-DocC 6.0, the ",
                  "type" : "text"
                },
                {
                  "code" : "@Available",
                  "type" : "codeVoice"
                },
                {
                  "text" : " directive didn’t support the “deprecated” parameter.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Earlier Versions",
          "style" : "note",
          "type" : "aside"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "In addition to specifying the version when you deprecated an API or documentation page,",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "you can use the ",
                  "type" : "text"
                },
                {
                  "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/DeprecationSummary",
                  "isActive" : true,
                  "type" : "reference"
                },
                {
                  "text" : " directive to provide the reader with additional information about the deprecation or refer them to a replacement API.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Tip",
          "style" : "tip",
          "type" : "aside"
        }
      ],
      "kind" : "content"
    }
