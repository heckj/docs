            },
            {
              "code" : "label",
              "type" : "codeVoice"
            },
            {
              "text" : " is allowed, but the ",
              "type" : "text"
            },
            {
              "code" : "label",
              "type" : "codeVoice"
            },
            {
              "text" : " will override the default label provided by",
              "type" : "text"
            },
            {
              "text" : " ",
