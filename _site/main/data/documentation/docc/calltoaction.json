            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "This directive is only valid within a ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/Metadata",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directive:",
              "type" : "text"
