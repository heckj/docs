    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "A “Call to Action” has two main components: a link or file path, and the link text to display.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The link path can be specified in one of two ways:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "The ",
                      "type" : "text"
                    },
                    {
                      "code" : "url",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " parameter specifies a URL that will be used verbatim. Use this when you’re linking",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "to an external page or externally-hosted file.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "The ",
                      "type" : "text"
                    },
                    {
                      "code" : "path",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " parameter specifies the path to a file hosted within your documentation catalog.",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "Use this if you’re linking to a downloadable file that you’re managing alongside your",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "articles and tutorials.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "The link text can also be specified in one of two ways:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "The ",
                      "type" : "text"
                    },
                    {
                      "code" : "purpose",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " parameter can be used to use a default button label. There are two valid values:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "items" : [
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "code" : "download",
                              "type" : "codeVoice"
                            },
                            {
                              "text" : " indicates that the link is to a downloadable file. The button will be labeled “Download”.",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    },
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "code" : "link",
                              "type" : "codeVoice"
                            },
                            {
                              "text" : " indicates that the link is to an external webpage.",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        },
                        {
                          "inlineContent" : [
                            {
                              "text" : "The button will be labeled “Visit” when used on article pages and “View Source” when used on sample code pages.",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    }
                  ],
                  "type" : "unorderedList"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "The ",
                      "type" : "text"
                    },
                    {
                      "code" : "label",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " parameter specifies the literal text to use as the button label.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "code" : "@CallToAction",
              "type" : "codeVoice"
            },
            {
              "text" : " requires one of ",
              "type" : "text"
            },
            {
              "code" : "url",
              "type" : "codeVoice"
            },
            {
              "text" : " or ",
              "type" : "text"
