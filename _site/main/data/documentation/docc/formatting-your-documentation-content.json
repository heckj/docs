                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            ]
          ],
          "type" : "table"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Don’t add images or code listings between list items. Bulleted and",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "numbered lists must contain two or more items.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Important",
          "style" : "important",
          "type" : "aside"
        },
        {
          "inlineContent" : [
            {
              "text" : "To create a bulleted list, precede each of the list’s items with an asterisk (",
              "type" : "text"
            },
            {
              "code" : "*",
              "type" : "codeVoice"
            },
            {
              "text" : ") and a",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "space. Alternatively, use a dash (",
              "type" : "text"
            },
            {
              "code" : "-",
              "type" : "codeVoice"
            },
            {
              "text" : ") or a plus sign (",
              "type" : "text"
            },
            {
              "code" : "+",
              "type" : "codeVoice"
            },
            {
              "text" : ") instead of an asterisk (",
              "type" : "text"
            },
            {
              "code" : "*",
              "type" : "codeVoice"
            },
            {
              "text" : "); the list markers are interchangeable.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "* Ice",
            "- Fire",
            "* Wind",
            "+ Lightning"
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "To create a numbered list, precede each of the list’s items with the number of the step, then a period (",
              "type" : "text"
            },
            {
              "code" : ".",
              "type" : "codeVoice"
            },
            {
              "text" : ") and a space.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "1. Give the sloth some food.",
            "2. Take the sloth for a walk.",
            "3. Read the sloth a story.",
            "4. Put the sloth to bed."
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "To create a term list, precede each term with a dash (",
              "type" : "text"
            },
            {
              "code" : "-",
              "type" : "codeVoice"
            },
            {
              "text" : ") and a",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "space, the ",
              "type" : "text"
            },
            {
              "code" : "term",
              "type" : "codeVoice"
            },
            {
              "text" : " keyword, and another space. Then add a colon (",
              "type" : "text"
            },
            {
              "code" : ":",
              "type" : "codeVoice"
            },
            {
              "text" : "), a space, and the definition after the term.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "- term Ice: Ice sloths thrive below freezing temperatures.",
            "- term Fire: Fire sloths thrive at boiling temperatures.",
            "- term Wind: Wind sloths thrive at soaring altitudes.",
            "- term Lightning: Lightning sloths thrive in stormy climates."
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "A list item’s text, including terms and their definitions, can use the same",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "style attributes as other text, and include links to other content, including",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "symbols.",
