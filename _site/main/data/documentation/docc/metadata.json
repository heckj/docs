        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use the ",
              "type" : "text"
            },
            {
              "code" : "Metadata",
              "type" : "codeVoice"
            },
            {
              "text" : " directive with other directives to configure how certain documentation files build. Place the directive after the documentation page’s title.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use it with the ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/DocumentationExtension",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directive to replace in-source documentation with the documentation extension file’s content.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "# ``SlothCreator\/Sloth``",
            "",
            "@Metadata {",
            "    @DocumentationExtension(mergeBehavior: override)",
            "}"
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use the ",
              "type" : "text"
            },
            {
              "code" : "Metadata",
              "type" : "codeVoice"
            },
            {
              "text" : " directive with the ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/TechnologyRoot",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directive to customize which article is the top-level page for a documentation catalog (’.docc’ directory) without any framework documentation or other top-level pages.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use the ",
              "type" : "text"
            },
            {
              "code" : "Metadata",
              "type" : "codeVoice"
            },
            {
              "text" : " directive with the ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/DisplayName",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directive to configure a symbol’s documentation page to use a custom display name.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "# ``SlothCreator``",
            "",
            "@Metadata {",
            "    @DisplayName(\"Sloth Creator\")",
            "}"
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use the ",
              "type" : "text"
            },
            {
              "code" : "Metadata",
              "type" : "codeVoice"
            },
            {
              "text" : " directive with the ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/TitleHeading",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directive to configure the text of a page’s title heading.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "# ``SlothCreator``",
            "",
            "@Metadata {",
            "    @TitleHeading(\"Release Notes\")",
            "}"
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Starting with version 6.0, use the ",
              "type" : "text"
            },
            {
              "code" : "Metadata",
              "type" : "codeVoice"
            },
            {
              "text" : " directive with one or more ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/Redirected",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directives",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "to add additional URLs for a page.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "# ``SlothCreator``",
            "",
            "@Metadata {",
            "    @Redirected(from: \"old\/path\/to\/page\")",
            "    @Redirected(from: \"another\/old\/path\/to\/page\")",
            "}"
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Starting with version 6.0, @Redirected is supported as a child directive of @Metadata. In",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "previous versions, @Redirected must be used as a top level directive.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Note",
          "style" : "note",
          "type" : "aside"
        },
        {
          "anchor" : "Usage-in-documentation-comments",
          "level" : 3,
          "text" : "Usage in documentation comments",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "You can specify ",
              "type" : "text"
            },
            {
              "code" : "@Metadata",
              "type" : "codeVoice"
            },
            {
              "text" : " configuration in documentation comments to specify ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/Available",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directives. Other metadata directives are",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "not supported in documentation comments.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Don’t specify an ",
                  "type" : "text"
                },
                {
                  "code" : "@Metadata",
                  "type" : "codeVoice"
                },
                {
                  "text" : " directive in both the symbol’s documentation comment and its documentation extension file.",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "If you have one in each, DocC will pick the one in the documentation extension and discard the one in the documentation",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "comment.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Note",
          "style" : "note",
          "type" : "aside"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Before Swift-DocC 6.1, ",
                  "type" : "text"
                },
                {
                  "code" : "@Metadata",
                  "type" : "codeVoice"
                },
                {
                  "text" : " was not supported in documentation comments.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Earlier versions",
          "style" : "note",
          "type" : "aside"
        }
      ],
      "kind" : "content"
    }
