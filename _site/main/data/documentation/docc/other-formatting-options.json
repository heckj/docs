                }
              ],
              "title" : "First paragraph on a new line"
            }
          ],
          "type" : "tabNavigator"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "If you have much information to provide about a subtopic, consider using a subsection rather than a multi-paragraph aside.",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "This can help with the flow of the text and make the information appear less visually heavy on the page.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Tip",
          "style" : "tip",
          "type" : "aside"
        },
        {
          "anchor" : "Include-Special-Characters-in-Text",
          "level" : 3,
          "text" : "Include Special Characters in Text",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "To escape one or more special characters, precede each with a backslash",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "(",
              "type" : "text"
            },
            {
              "code" : "\\",
              "type" : "codeVoice"
            },
            {
              "text" : ").",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "For example, to display an asterisk (",
              "type" : "text"
            },
            {
              "code" : "*",
              "type" : "codeVoice"
            },
            {
              "text" : ") at the beginning of a line and prevent",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "DocC from converting it into a bulleted list item, place a backslash immediately before it.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "\\* Not a bulleted list item."
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If you use single (",
              "type" : "text"
            },
            {
              "code" : "*",
              "type" : "codeVoice"
            },
            {
              "text" : ") or double (",
              "type" : "text"
            },
            {
              "code" : "**",
              "type" : "codeVoice"
            },
            {
              "text" : ") asterisks to apply italic or bold",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "styling, respectively, you can escape any asterisks that the text contains so",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "DocC doesn’t prematurely terminate the styling.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "*Sloths require sustenance\\* to perform activities.*",
            "",
            "**Sloths require sustenance\\*\\* to perform activities.**"
          ],
          "syntax" : "markdown",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "DocC also supports the translation of hex codes and HTML entities. For example, using the hex code ",
              "type" : "text"
            },
            {
              "code" : "\\&#xa9;",
              "type" : "codeVoice"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "will render as the copyright sign (©).",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
