                }
              ],
              "title" : "First paragraph on the same line as the tag"
            },
            {
              "content" : [
                {
                  "columns" : [
                    {
                      "content" : [
                        {
                          "code" : [
                            "- Note: ",
                            "  The first paragraph.",
                            " ",
                            "  The second paragraph."
                          ],
                          "syntax" : "markdown",
                          "type" : "codeListing"
                        }
                      ],
                      "size" : 1
                    },
                    {
                      "content" : [
                        {
                          "code" : [
                            "> Note: ",
