              "type" : "codeVoice"
            },
            {
              "text" : " directive to provide a hint to the renderer as to how",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "the page should be accented with color. The renderer may use this color,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "depending on the context, as a foundation for other colors used on the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "page. For example, Swift-DocC-Render uses this color as the primary",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "background color of a page’s introduction section and adjusts other",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "elements in the introduction section to account for the new background.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "This directive is only valid within a ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/Metadata",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directive:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
