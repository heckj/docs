        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "The base file name of an image in your documentation catalog.",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "(required)",
                      "type" : "text"
                    }
                  ],
                  "type" : "strong"
                }
              ],
