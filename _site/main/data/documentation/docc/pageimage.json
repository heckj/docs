        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Alternative text that describes the image to screen readers.",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "(optional)",
                      "type" : "text"
                    }
                  ],
                  "type" : "strong"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "alt"
        }
      ]
    },
    {
      "kind" : "mentions",
      "mentions" : [
        "doc:\/\/org.swift.docc\/documentation\/docc\/customizing-the-appearance-of-your-documentation-pages"
      ]
    },
    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "You can use this directive to set the image used when rendering a user-interface element representing the page.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use the “icon” purpose to customize the icon that DocC uses to represent this page in the navigation sidebar.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "For article pages, DocC also uses this icon to represent the article in topics sections and in ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/Links",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directives that use the ",
              "type" : "text"
            },
            {
              "code" : "list",
              "type" : "codeVoice"
            },
            {
              "text" : " visual style.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Page images with the “icon” purpose work best when they’re square and when they have good visual clarity at small sizes (less than 20×20 points).",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Tip",
          "style" : "tip",
          "type" : "aside"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use the “card” purpose to customize the image that DocC uses to represent this page inside ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.docc\/documentation\/docc\/Links",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " directives that use the either the ",
              "type" : "text"
            },
            {
              "code" : "detailedGrid",
              "type" : "codeVoice"
            },
            {
              "text" : " or the ",
              "type" : "text"
            },
            {
              "code" : "compactGrid",
              "type" : "codeVoice"
            },
            {
              "text" : " visual style.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "For article pages, DocC also incorporates a partially faded out version of the card image in the background of the page itself.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Page images with the “card” purpose work best when they have a 16:9 aspect ratio. Currently, the largest size that DocC displays a card image is 640×360 points.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Tip",
          "style" : "tip",
          "type" : "aside"
        },
        {
          "inlineContent" : [
            {
              "text" : "If you specify an “icon” page image without specifying a “card” page image, DocC will use the icon as a fallback in places where the card image is preferred.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "To avoid upscaled pixelated icons in these places, either configure a “card” page image as well or use a scalable vector image asset for the “icon” page image.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
