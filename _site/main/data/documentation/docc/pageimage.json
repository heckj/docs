                      {
                        "inlineContent" : [
                          {
                            "text" : "The image will be used when representing the page as a card, such as in grid styled Topics sections.",
                            "type" : "text"
                          }
                        ],
                        "type" : "paragraph"
                      }
                    ]
                  },
                  "term" : {
                    "inlineContent" : [
                      {
                        "code" : "card",
