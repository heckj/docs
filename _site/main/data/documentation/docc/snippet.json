            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "A named slice automatically ends at the start of the next named slice, without an explicit ",
              "type" : "text"
            },
            {
              "code" : "snippet.end",
              "type" : "codeVoice"
            },
            {
              "text" : " annotation.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "If the referenced snippet includes annotated slices, you can limit the embedded code example to a certain line range by specifying a ",
