          "style" : "note",
          "type" : "aside"
        },
        {
          "inlineContent" : [
            {
              "text" : "You can define named slices of your snippet by annotating the snippet file with ",
              "type" : "text"
            },
            {
              "code" : "\/\/ snippet.<name>",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "\/\/ snippet.end",
              "type" : "codeVoice"
