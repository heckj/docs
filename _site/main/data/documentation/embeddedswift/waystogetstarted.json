          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "These guides provide a practical introduction to Embedded Swift development with specific hardware targets, showing you how to build, upload, and run your first Swift programs on embedded systems.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
