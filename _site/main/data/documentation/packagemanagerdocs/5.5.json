  "metadata" : {
    "modules" : [
      {
        "name" : "Swift Package Manager"
      }
    ],
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "SwiftPM 5.5 Release Notes"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Package-Collections",
          "level" : 3,
          "text" : "Package Collections",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "You can now use package collections to discover, manage, and publish curated lists of packages. Package collections are authored as static JSON documents and can be published to the web or distributed to local file systems. SwiftPM and Xcode locally share the same package collections, so either interface can manage your added collections.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "To try the official Apple Swift Packages collection, run:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift package-collection add https:\/\/developer.apple.com\/swift\/packages\/collections\/apple.json"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Then, to see which packages are included in that collection and can now be imported in your code, run:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift package-collection describe https:\/\/developer.apple.com\/swift\/packages\/collections\/apple.json"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "For more information about usage and how to publish your own package collections, see the ",
              "type" : "text"
            },
            {
              "identifier" : "..\/PackageCollections.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Executable-target-testing",
          "level" : 3,
          "text" : "Executable target testing",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Test targets can now link against executable targets as if they were libraries, so that they can test any data structures or algorithms in them. All the code in the executable except for the main entry point itself is available to the unit test. Separate executables are still linked, and can be tested as a subprocess in the same way as before. This feature is available to tests defined in packages that have a tools version of ",
              "type" : "text"
            },
            {
              "code" : "5.5",
              "type" : "codeVoice"
            },
            {
              "text" : " or newer. (#3316)",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Manifest-API-improvements",
          "level" : 3,
          "text" : "Manifest API improvements",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Two new dependency convenience initializers are now available (#3292, #3310):",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            ".package(url: String, revision: String)",
            ".package(url: String, branch: String)"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Target-based dependency resolution has also been improved. A more intuitive ",
              "type" : "text"
            },
            {
              "code" : ".product(name:, package:)",
              "type" : "codeVoice"
            },
            {
              "text" : " syntax is now accepted, where ",
              "type" : "text"
            },
            {
              "code" : "package",
              "type" : "codeVoice"
            },
            {
              "text" : " is the package name as defined by the package URL. (#3280)",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Other-improvements",
          "level" : 3,
          "text" : "Other improvements",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "code" : "@main",
              "type" : "codeVoice"
            },
            {
              "text" : " can now be used in a single-source file executable as long as the name of the source file isn’t ",
              "type" : "text"
            },
            {
              "code" : "main.swift",
              "type" : "codeVoice"
            },
            {
              "text" : ". To work around special compiler semantics with single-file modules, SwiftPM now passes ",
              "type" : "text"
            },
            {
              "code" : "-parse-as-library",
              "type" : "codeVoice"
            },
            {
              "text" : " when compiling an executable module that contains a single Swift source file whose name is not ",
              "type" : "text"
            },
            {
              "code" : "main.swift",
              "type" : "codeVoice"
            },
            {
              "text" : ". This feature is available in packages that have a tools version of ",
              "type" : "text"
            },
            {
              "code" : "5.5",
              "type" : "codeVoice"
            },
            {
              "text" : " or newer. (#3410)",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "An issue where resolution of packages with binary dependencies failed to extract the binary archive was fixed. (#3507)",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
