        "name" : "Swift Package Manager"
      }
    ],
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "SwiftPM 5.7 Release Notes"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Package-Plugins",
          "level" : 3,
          "text" : "Package Plugins",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0303-swiftpm-extensible-build-tools.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0332-swiftpm-command-plugins.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " which were first introduced in Swift 5.6 have been further refined, with support for generating resources and improved diagnostics. To learn more, refer to the ",
              "type" : "text"
            },
            {
              "identifier" : "..\/Plugins.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " guide.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Package-Registry-Support",
          "level" : 3,
          "text" : "Package Registry Support",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "SwiftPM now supports package registry related capabilities introduced by ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0292-package-registry-service.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " and the corresponding ",
              "type" : "text"
            },
            {
              "identifier" : "..\/Registry.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ". With the exception of package publishing, SwiftPM can resolve and download dependencies from any compliant registry using the defined APIs.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "To get started, users will need to specify their package registry by running the ",
              "type" : "text"
            },
            {
              "code" : "swift package-registry set",
              "type" : "codeVoice"
            },
            {
              "text" : " subcommand or editing the ",
              "type" : "text"
            },
            {
              "code" : "registries.json",
              "type" : "codeVoice"
            },
            {
              "text" : " configuration file. ",
              "type" : "text"
            },
            {
              "code" : "swift package",
              "type" : "codeVoice"
            },
            {
              "text" : " tool’s ",
              "type" : "text"
            },
            {
              "code" : "--use-registry-identity-for-scm",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "--replace-scm-with-registry",
              "type" : "codeVoice"
            },
            {
              "text" : " options might also be of interest.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Module-Aliasing-For-Disambiguation",
          "level" : 3,
          "text" : "Module Aliasing For Disambiguation",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Modules with the same name from different packages can now be disambiguated by module aliasing ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0339-module-aliasing-for-disambiguation.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ". When adding a product dependency for a target in a package manifest, use a new parameter ",
              "type" : "text"
            },
            {
              "code" : "moduleAliases",
              "type" : "codeVoice"
            },
            {
              "text" : " to provide a new unique name for a conflicting module.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "[#4119]",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "Add a ",
                      "type" : "text"
                    },
                    {
                      "code" : "--disable-testable-imports",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " flag to ",
                      "type" : "text"
                    },
                    {
                      "code" : "swift test",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " with which tests are built without the testability feature (",
                      "type" : "text"
                    },
                    {
                      "code" : "import @testable",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " disabled).",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        }
      ],
      "kind" : "content"
    }
