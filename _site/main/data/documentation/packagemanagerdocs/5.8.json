  },
  "kind" : "article",
  "metadata" : {
    "modules" : [
      {
        "name" : "Swift Package Manager"
      }
    ],
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "SwiftPM 5.8 Release Notes"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Package-manifest-changes",
          "level" : 2,
          "text" : "Package manifest changes",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "SwiftPM targets can now specify the upcoming language features they require. ",
              "type" : "text"
            },
            {
              "code" : "Package.swift",
              "type" : "codeVoice"
            },
            {
              "text" : " manifest syntax has been expanded with an API to include setting ",
              "type" : "text"
            },
            {
              "code" : "enableUpcomingFeature",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "enableExperimentalFeature",
              "type" : "codeVoice"
            },
            {
              "text" : " flags at the target level, as specified by ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0362-piecemeal-future-features.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "SwiftPM now allows exposing an executable product that consists solely of a binary target that is backed by an artifact bundle. This allows vending binary executables as their own separate package, independently of plugins that are using them.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "In packages using tools version 5.8 or later, ",
              "type" : "text"
            },
            {
              "code" : "Foundation",
              "type" : "codeVoice"
            },
            {
              "text" : " is no longer implicitly imported into package manifests. If ",
              "type" : "text"
            },
            {
              "code" : "Foundation",
              "type" : "codeVoice"
            },
            {
              "text" : " APIs are used, the module needs to be imported explicitly.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Package-Registry-Support",
          "level" : 2,
          "text" : "Package Registry Support",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "SwiftPM now supports token authentication when interacting with a package registry. The ",
              "type" : "text"
            },
            {
              "code" : "swift package-registry",
              "type" : "codeVoice"
            },
            {
              "text" : " command has two new subcommands ",
              "type" : "text"
            },
            {
              "code" : "login",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "logout",
              "type" : "codeVoice"
            },
            {
              "text" : " as defined in ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/github.com\/swiftlang\/swift-evolution\/blob\/main\/proposals\/0378-package-registry-auth.md",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " for adding\/removing registry credentials.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Other-improvements",
          "level" : 2,
          "text" : "Other improvements",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Improved handling of offline behavior when a compatible cached version of a dependency exists on disk in either the per-package or shared cache. SwiftPM will check for network availability status to determine if it should attempt to update a checked version of a dependency, and when offline will use the cached version without an update.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "New ",
              "type" : "text"
            },
            {
              "code" : "--pkg-config-path",
              "type" : "codeVoice"
            },
            {
              "text" : " option on ",
              "type" : "text"
            },
            {
              "code" : "build",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "test",
              "type" : "codeVoice"
            },
            {
              "text" : ", and ",
              "type" : "text"
            },
            {
              "code" : "run",
              "type" : "codeVoice"
            },
            {
              "text" : " commands has been introduced as an alternative to passing ",
              "type" : "text"
            },
            {
              "code" : "PKG_CONFIG_PATH",
              "type" : "codeVoice"
            },
            {
              "text" : " environment variable. It allows specifying alternative path to search for ",
              "type" : "text"
            },
            {
              "code" : ".pc",
              "type" : "codeVoice"
            },
            {
              "text" : " files used by ",
              "type" : "text"
            },
            {
              "code" : "pkg-config",
              "type" : "codeVoice"
            },
            {
              "text" : ". Use the option multiple times to specify more than one path.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Added new ",
              "type" : "text"
            },
            {
              "code" : "--emit-extension-block-symbols",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "--omit-extension-block-symbols",
              "type" : "codeVoice"
            },
            {
              "text" : " via ",
              "type" : "text"
            },
            {
              "code" : "swift package dump-symbol-graph",
              "type" : "codeVoice"
            },
            {
              "text" : ". ",
              "type" : "text"
            },
            {
              "code" : "--emit-extension-block-symbols",
              "type" : "codeVoice"
            },
            {
              "text" : " dumps symbol graph files that are extension block symbol format. The default behavior does not change. The ",
              "type" : "text"
            },
            {
              "code" : "--omit-extension-block-symbols",
              "type" : "codeVoice"
            },
            {
              "text" : " flag will be used to explicitly disable the feature once the default behavior has been changed to ",
              "type" : "text"
            },
            {
              "code" : "--emit-extension-block-symbols",
              "type" : "codeVoice"
            },
            {
              "text" : " in the future.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
