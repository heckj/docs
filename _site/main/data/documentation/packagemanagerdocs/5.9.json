  "metadata" : {
    "modules" : [
      {
        "name" : "Swift Package Manager"
      }
    ],
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "SwiftPM 5.9 Release Notes"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Cross-compilation",
          "level" : 2,
          "text" : "Cross compilation",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "SwiftPM now supports cross compilation based on the Swift SDK bundle format. While the feature is still considered experimental, we invite users to try it out and provide feedback.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Package-registry",
          "level" : 2,
          "text" : "Package registry",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "SwiftPM can now publish to a registry following the specification defined in SE-0391, as well as support signed packages, which may be required by a registry. Trust-on-first-use (TOFU) validation checks can now use signing identities in addition to fingerprints, and are enforced for source archives as well as package manifests.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Embedded-resources",
          "level" : 2,
          "text" : "Embedded resources",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Basic support for a new ",
              "type" : "text"
            },
            {
              "code" : ".embedInCode",
              "type" : "codeVoice"
            },
            {
              "text" : " resource rule which allows embedding the contents of the resource into the executable code by generating a byte array",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "struct PackageResources {",
            "  static let best_txt: [UInt8] = [104,101,108,108,111,32,119,111,114,108,100,10]",
            "}"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "anchor" : "Other-improvements",
          "level" : 2,
          "text" : "Other improvements",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "CompilerPluginSupport",
              "type" : "codeVoice"
            },
            {
              "text" : " module enables defining macro targets. Macro targets allow authoring and distributing custom Swift macros as APIs in a library.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Packages can use the new ",
              "type" : "text"
            },
            {
              "code" : "package",
              "type" : "codeVoice"
            },
            {
              "text" : " access modifier, allowing access of symbols in another target \/ module within the same package without making them public. SwiftPM automatically sets the new compiler configuration to ensure this feature works out-of-the-box for packages.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "allowNetworkConnections(scope:reason:)",
              "type" : "codeVoice"
            },
            {
              "text" : " setting gives a command plugin permissions to access the network. Permissions can be scoped to Unix domain sockets as well as local or remote IP connections, with an option to limit by port. For non-interactive use cases, the ",
              "type" : "text"
            },
            {
              "code" : "--allow-network-connections",
              "type" : "codeVoice"
            },
            {
              "text" : " command-line flag allows network connections for a particular scope.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "When a package contains a single target, sources may be distributed anywhere within the ",
              "type" : "text"
            },
            {
              "code" : ".\/Sources",
              "type" : "codeVoice"
            },
            {
              "text" : " directory. If sources are placed in a subdirectory under ",
              "type" : "text"
            },
            {
              "code" : ".\/Sources\/<target>",
              "type" : "codeVoice"
            },
            {
              "text" : ", or there is more than one target, the existing expectation for sources apply",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Build tool plugins can be used with C-family targets",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
