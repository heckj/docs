            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Swift Build tasks planned by build tool plugins no longer have unrestricted access to environment variables in order",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "to avoid excessive invalidation in incremental builds.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "Detailed-differences",
          "level" : 4,
          "text" : "Detailed differences",
          "type" : "heading"
        },
        {
          "anchor" : "Resource-support-parity-with-xcodebuild",
          "level" : 5,
          "text" : "Resource support parity with xcodebuild",
          "type" : "heading"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "When targeting Apple platforms, SwiftPM, the same set of resource rules as that ",
                      "type" : "text"
                    },
                    {
                      "code" : "xcodebuild",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " followsare consistently applied when a package contains resource types like asset catalogs, storyboards, Metal sources, etc.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "Swift-Driver-integration",
          "level" : 5,
          "text" : "Swift Driver integration",
          "type" : "heading"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "The ",
                      "type" : "text"
                    },
                    {
                      "code" : "--use-integrated-swift-driver",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " command-line option is deprecated and has not effect. Swift Build always uses the library-based Swift driver.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "On supported platforms, SwiftPM will make use of explicitly-built Clang and Swift modules.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
