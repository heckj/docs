              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Reporting-issues",
          "level" : 2,
          "text" : "Reporting issues",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Please follow these steps when reporting issues:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Review the ",
                      "type" : "text"
                    },
                    {
                      "identifier" : "#Known-issues",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : " listed above to ensure your issue has not already been identified.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "If your issue is not listed, ",
                      "type" : "text"
                    },
                    {
                      "identifier" : "https:\/\/github.com\/swiftlang\/swift-package-manager\/issues",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : " on GitHub.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Include the following information in your report:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "items" : [
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "The exact command that failed",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    },
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "Complete error output",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    },
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "System information (operating system, Swift version, etc.)",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    },
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "Whether the same command works with the native build system",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    }
                  ],
                  "type" : "unorderedList"
                }
              ]
