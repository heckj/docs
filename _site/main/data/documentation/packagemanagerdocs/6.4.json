    "title" : "SwiftPM 6.4 Release Notes"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "SwiftBuild-The-new-default-build-system",
          "level" : 2,
          "text" : "SwiftBuild: The new default build system",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "SwiftPM has changed its default build system to Swift Build. Read more ",
              "type" : "text"
            },
            {
              "text" : "here",
              "type" : "text"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Key-changes-from-the-native-build-system",
          "level" : 3,
          "text" : "Key changes from the native build system",
          "type" : "heading"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Build artifacts are output to a different location. For all build systems, using ",
                      "type" : "text"
                    },
                    {
                      "code" : "swift build --show-bin-path <other build arguments>",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " is the recommended way to determine the build output location.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "code" : "--static-swift-stdlib",
                          "type" : "codeVoice"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : ": Stricter validation (errors instead of silently ignoring)",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "items" : [
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "The native build system silently ignored this option on some platforms; Swift Build now produces an error.",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    },
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "Swift Build generates an error on platforms where statically linking the standard library is not supported.",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    }
                  ],
                  "type" : "unorderedList"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "Detailed-differences",
          "level" : 3,
          "text" : "Detailed differences",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The following sections describe specific behavioral differences you may encounter when migrating to Swift Build.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Resource-support-parity-with-xcodebuild",
          "level" : 4,
          "text" : "Resource support parity with xcodebuild",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "When targeting Apple platforms, SwiftPM consistently applies the same set of resource rules as ",
              "type" : "text"
            },
            {
              "code" : "xcodebuild",
              "type" : "codeVoice"
            },
            {
              "text" : " when a package contains resource types like asset catalogs, storyboards, Metal sources, etc.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Swift-Driver-integration",
          "level" : 4,
          "text" : "Swift Driver integration",
          "type" : "heading"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "The ",
                      "type" : "text"
                    },
                    {
                      "code" : "--use-integrated-swift-driver",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " command-line option is deprecated and has no effect. Swift Build always uses the library-based Swift driver.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "On supported platforms, Swift Build will make use of explicitly-built Clang and Swift modules.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "Enhanced-diagnostics",
          "level" : 4,
          "text" : "Enhanced diagnostics",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Swift Build may produce different log output and diagnostics compared to the native build system.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Other",
          "level" : 4,
          "text" : "Other",
          "type" : "heading"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Supports building universal binaries when targeting Apple platforms. Example invocation: ",
                      "type" : "text"
                    },
                    {
                      "code" : "swift build --arch arm64 --arch x86_64",
                      "type" : "codeVoice"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "Known-issues",
          "level" : 3,
          "text" : "Known issues",
          "type" : "heading"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Swift Build fails to build projects with Linux SDKs generated ",
                      "type" : "text"
                    },
                    {
                      "inlineContent" : [
                        {
                          "text" : "by",
                          "type" : "text"
                        }
                      ],
                      "type" : "emphasis"
                    },
                    {
                      "text" : " the SDK generator.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "items" : [
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "inlineContent" : [
                                {
                                  "text" : "Tracking",
                                  "type" : "text"
                                }
                              ],
                              "type" : "strong"
                            },
                            {
                              "text" : ": ",
                              "type" : "text"
                            },
                            {
                              "identifier" : "https:\/\/github.com\/swiftlang\/swift-package-manager\/issues\/10006",
                              "isActive" : true,
                              "type" : "reference"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    }
                  ],
                  "type" : "unorderedList"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Using the ",
                      "type" : "text"
                    },
                    {
                      "code" : "--explicit-target-dependency-import-check",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " command line option does not behave as expected when building with Swift Build.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "items" : [
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "inlineContent" : [
                                {
                                  "text" : "Tracking",
                                  "type" : "text"
                                }
                              ],
                              "type" : "strong"
                            },
                            {
                              "text" : ": ",
                              "type" : "text"
                            },
                            {
                              "identifier" : "https:\/\/github.com\/swiftlang\/swift-package-manager\/issues\/9620",
                              "isActive" : true,
                              "type" : "reference"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    }
                  ],
                  "type" : "unorderedList"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Building projects that use swift-java and build tool plugins may fail.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "items" : [
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "inlineContent" : [
                                {
                                  "text" : "Tracking",
                                  "type" : "text"
                                }
                              ],
                              "type" : "strong"
                            },
                            {
                              "text" : ": ",
                              "type" : "text"
                            },
                            {
                              "identifier" : "https:\/\/github.com\/swiftlang\/swift-package-manager\/issues\/10060",
                              "isActive" : true,
                              "type" : "reference"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    }
                  ],
                  "type" : "unorderedList"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "Troubleshooting",
          "level" : 3,
          "text" : "Troubleshooting",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "If your package fails to build with Swift Build in Swift 6.4, you can fall back to the previous native build system using the ",
              "type" : "text"
            },
            {
              "code" : "--build-system native",
              "type" : "codeVoice"
            },
            {
              "text" : " flag:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift build --build-system native",
            "swift test --build-system native",
            "swift run --build-system native"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If your build passes using the native build system but fails using Swift Build, please ",
              "type" : "text"
            },
            {
              "identifier" : "#Reporting-issues",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Software-Bill-of-Materials-SBOM-support",
          "level" : 2,
          "text" : "Software Bill of Materials (SBOM) support",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Swift Package Manager can now generate an SBOM for your Swift package. Read more ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PackageManagerDocs\/documentation\/PackageManagerDocs\/GeneratingSBOMs",
              "isActive" : true,
              "overridingTitle" : "here",
              "overridingTitleInlineContent" : [
                {
                  "text" : "here",
                  "type" : "text"
                }
              ],
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Additional-features",
          "level" : 2,
          "text" : "Additional features",
          "type" : "heading"
        },
        {
          "anchor" : "Test-repetition-for-Swift-Testing",
          "level" : 3,
          "text" : "Test repetition for Swift Testing",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "code" : "swift test",
              "type" : "codeVoice"
            },
            {
              "text" : " now supports repeating tests until they match a condition via the ",
              "type" : "text"
            },
            {
              "code" : "--repeat-until",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "--maximum-repetitions",
              "type" : "codeVoice"
            },
            {
              "text" : " arguments.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "This will only repeat the individual test cases that meet the repetition condition.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "--maximum-repetitions",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " provides an upper bound on the number of times a test will repeat.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "--repeat-until",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " supports the following repetition conditions:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "pass",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : ": If the test fails, it will repeat until it passes, or until ",
                      "type" : "text"
                    },
                    {
                      "code" : "maximum-repetitions",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " has been reached.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "fail",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : ": If the test passes, it will repeat until it fails, or until ",
                      "type" : "text"
                    },
                    {
                      "code" : "maximum-repetitions",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " has been reached.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "If ",
              "type" : "text"
            },
            {
              "code" : "--maximum-repetitions",
              "type" : "codeVoice"
            },
            {
              "text" : " is provided without ",
              "type" : "text"
            },
            {
              "code" : "--repeat-until",
              "type" : "codeVoice"
            },
            {
              "text" : ", all tests will repeat ",
              "type" : "text"
            },
            {
              "code" : "maximum-repetitions",
              "type" : "codeVoice"
            },
            {
              "text" : " times.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "LLDB-Debugger-support-in-swift-test",
          "level" : 2,
          "text" : "LLDB Debugger support in `swift test`",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Running ",
              "type" : "text"
            },
            {
              "code" : "swift test --debugger",
              "type" : "codeVoice"
            },
            {
              "text" : " will launch tests in an LLDB debugging session on the command line.  Read more ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PackageManagerDocs\/documentation\/PackageManagerDocs\/SwiftTest",
              "isActive" : true,
              "overridingTitle" : "here",
              "overridingTitleInlineContent" : [
