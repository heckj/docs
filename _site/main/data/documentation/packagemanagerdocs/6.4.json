          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The key features include:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "adding first class support for Software Bill of Materials (SBOM)",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "making the Swift Build build system the default",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "anchor" : "Software-Bill-of-Materials-SBOM-support",
          "level" : 2,
          "text" : "Software Bill of Materials (SBOM) support",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Swift Package Manager can now generate SBOM for your Swift Package.  Read more ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PackageManagerDocs\/documentation\/PackageManagerDocs\/GeneratingSBOMs",
              "isActive" : true,
              "overridingTitle" : "here",
              "overridingTitleInlineContent" : [
                {
                  "text" : "here",
                  "type" : "text"
                }
              ],
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "SwiftBuild-The-new-default-build-system",
          "level" : 2,
          "text" : "SwiftBuild: The new default build system",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "SwiftPM has changed it’s default build system to Swift Build.  Read more ",
              "type" : "text"
            },
            {
              "text" : "here",
              "type" : "text"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Key-improvements-and-differences-between-Native-build-system",
          "level" : 3,
          "text" : "Key improvements and differences between Native build system",
          "type" : "heading"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Build artifacts are output to a different location.  For all build systems, using the ",
                      "type" : "text"
                    },
                    {
                      "code" : "swift build --show-bin-path <other build arguments>",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " is the recommended way to determine the build output location.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "code" : "--static-swift-stdlib",
                          "type" : "codeVoice"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : ": Stricter validation (errors instead of silently ignoring)",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "items" : [
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "The native build system silently ignored this option on some platforms; Swift Build now produces an error.",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    },
                    {
                      "content" : [
                        {
                          "inlineContent" : [
                            {
                              "text" : "The Swift Build build system will generate an error on platforms where static libraries are not supported.",
                              "type" : "text"
                            }
                          ],
                          "type" : "paragraph"
                        }
                      ]
                    }
                  ],
                  "type" : "unorderedList"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Swift Build does not support test targets depending on other test targets.  To work around this,",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "create a non-test target for the test target to depend on.  A runtime error (sample below) will occur if this target is added as a",
                      "type" : "text"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "dependency on non-test targets.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "dyld[67034]: Library not loaded: @rpath\/libTesting.dylib",
                    "Referenced from: <30F1D85A-75C7-358C-B169-96E34550501C> \/Users\/jappleseed\/git\/swiftlang\/swift-package-manager-3\/.build\/out\/Products\/Debug\/swift-package",
