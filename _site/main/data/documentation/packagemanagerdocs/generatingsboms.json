{
  "abstract" : [
    {
      "text" : "Create an inventory of components and dependencies using SBOM documents.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/PackageManagerDocs\/documentation\/PackageManagerDocs"
      ]
    ]
  },
  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/PackageManagerDocs\/documentation\/PackageManagerDocs\/GeneratingSBOMs"
  },
  "kind" : "article",
  "metadata" : {
    "modules" : [
      {
        "name" : "Swift Package Manager"
      }
    ],
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Generating Software Bill of Materials (SBOM)"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Swift Package Manager generates Software Bill of Materials (SBOM) documents for Swift packages and products.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Swift Package Manager currently supports two SBOM formats: CycloneDX and SPDX.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Generate SBOMs using either the ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PackageManagerDocs\/documentation\/PackageManagerDocs\/SwiftBuild",
              "isActive" : true,
              "overridingTitle" : "swift build",
              "overridingTitleInlineContent" : [
                {
                  "code" : "swift build",
                  "type" : "codeVoice"
                }
              ],
              "type" : "reference"
            },
            {
              "text" : " command with SBOM flags or the dedicated ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PackageManagerDocs\/documentation\/PackageManagerDocs\/PackageGenerateSBOM",
              "isActive" : true,
              "overridingTitle" : "swift package generate-sbom",
              "overridingTitleInlineContent" : [
                {
                  "code" : "swift package generate-sbom",
                  "type" : "codeVoice"
                }
              ],
              "type" : "reference"
            },
            {
              "text" : " subcommand.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Use-the-build-command-to-generate-SBOMs",
          "level" : 3,
          "text" : "Use the build command to generate SBOMs",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use the command ",
              "type" : "text"
            },
            {
              "code" : "swift build",
              "type" : "codeVoice"
            },
            {
              "text" : " to compile your project and generate SBOMs.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Using the ",
              "type" : "text"
            },
            {
              "code" : "--sbom-spec",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "--target",
              "type" : "codeVoice"
            },
            {
              "text" : " flags together causes an error.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Generating SBOMs through the Swift Build build backend factors in build-time conditionals.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift build --build-system swiftbuild --sbom-spec cyclonedx",
            "swift build --build-system swiftbuild --sbom-spec spdx",
            "swift build --build-system swiftbuild --sbom-spec cyclonedx --sbom-spec spdx"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The following examples generate SBOMs without using the Swift Build build backend. SBOMs generated without Swift Build may not be fully accurate, as build-time conditionals aren’t applied to the SBOMs.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift build --build-system native --sbom-spec cyclonedx",
            "swift build --build-system native --sbom-spec spdx",
            "swift build --build-system native --sbom-spec cyclonedx --sbom-spec spdx"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "anchor" : "Use-the-package-command-to-generates-SBOMs",
          "level" : 3,
          "text" : "Use the package command to generates SBOMs",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "identifier" : "doc:\/\/PackageManagerDocs\/documentation\/PackageManagerDocs\/PackageGenerateSBOM",
              "isActive" : true,
              "overridingTitle" : "swift package generate-sbom",
              "overridingTitleInlineContent" : [
                {
                  "code" : "swift package generate-sbom",
                  "type" : "codeVoice"
                }
              ],
              "type" : "reference"
            },
            {
              "text" : " generates an SBOM without building.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "This SBOM is less accurate than an SBOM generated from ",
              "type" : "text"
            },
            {
              "code" : "swift build --build-system swiftbuild",
              "type" : "codeVoice"
            },
            {
              "text" : " because build-time conditionals aren’t applied.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "For the highest accuracy, generate SBOMs using the command ",
              "type" : "text"
            },
            {
              "code" : "swift build --build-system swiftbuild",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Not specifying ",
              "type" : "text"
            },
            {
              "code" : "--sbom-spec",
              "type" : "codeVoice"
            },
            {
              "text" : " generates all SBOM specs supported by Swift Package Manager.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift package generate-sbom --sbom-spec cyclonedx",
            "swift package generate-sbom --sbom-spec spdx",
            "swift package generate-sbom --sbom-spec cyclonedx --sbom-spec spdx",
            "swift package generate-sbom"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "anchor" : "Configure-additional-flags",
          "level" : 3,
          "text" : "Configure additional flags",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The following flags apply to both ",
              "type" : "text"
            },
            {
              "code" : "swift build",
              "type" : "codeVoice"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "code" : "swift package generate-sbom",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Generate-SBOM-for-a-single-product",
          "level" : 4,
          "text" : "Generate SBOM for a single product",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Generate an SBOM for a specific product in a package using the ",
              "type" : "text"
            },
            {
              "code" : "--product",
              "type" : "codeVoice"
            },
            {
              "text" : " flag.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift build --build-system swiftbuild --product MyProduct --sbom-spec cyclonedx",
            "swift package generate-sbom --product MyProduct --sbom-spec spdx"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "anchor" : "Filter-SBOM-contents",
          "level" : 4,
          "text" : "Filter SBOM contents",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Filter an SBOM by packages or products by using ",
              "type" : "text"
            },
            {
              "code" : "--sbom-filter <type>",
              "type" : "codeVoice"
            },
            {
              "text" : ". By default, an SBOM includes both packages and products.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Swift Package Manager always includes the primary component, regardless of the applied filter.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift build --build-system swiftbuild --sbom-spec cyclonedx --sbom-filter package",
            "swift package generate-sbom --sbom-spec spdx --sbom-filter product"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "anchor" : "Output-SBOM-to-custom-directory",
          "level" : 4,
          "text" : "Output SBOM to custom directory",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Swift Package Manager places generated SBOMs in ",
              "type" : "text"
            },
            {
              "code" : "<build_output>\/sboms",
              "type" : "codeVoice"
            },
            {
              "text" : " by default.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Use ",
              "type" : "text"
            },
            {
              "code" : "--sbom-output-dir",
              "type" : "codeVoice"
            },
            {
              "text" : " to specify a different directory for generated SBOMs.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift build --build-system swiftbuild --sbom-spec cyclonedx --sbom-output-dir <path>",
            "swift package generate-sbom --sbom-spec spdx --sbom-output-dir <path>"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "anchor" : "Reduce-SBOM-generation-errors-to-warnings",
          "level" : 4,
          "text" : "Reduce SBOM generation errors to warnings",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "By default, if SBOM generation fails, the ",
              "type" : "text"
            },
            {
              "code" : "build",
              "type" : "codeVoice"
            },
            {
              "text" : " or ",
              "type" : "text"
            },
            {
              "code" : "package",
              "type" : "codeVoice"
            },
            {
              "text" : " command also fails.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "--sbom-warning-only",
              "type" : "codeVoice"
            },
            {
              "text" : " flag converts all SBOM generation errors to warnings.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift build --build-system swiftbuild --sbom-spec cyclonedx --sbom-warning-only",
            "swift package generate-sbom --sbom-spec spdx --sbom-warning-only"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "anchor" : "Configure-environment-variables",
          "level" : 3,
          "text" : "Configure environment variables",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Generating SBOMs can be triggered and configured using environment variables that you set prior to running ",
              "type" : "text"
            },
            {
              "code" : "swift build",
              "type" : "codeVoice"
            },
            {
              "text" : " or ",
              "type" : "text"
            },
            {
              "code" : "swift package generate-sbom",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "When you use CLI flags, they take precedence over environment variables.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Configure the following environment variables:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "SWIFTPM_BUILD_SBOM_SPEC",
                      "type" : "codeVoice"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "SWIFTPM_BUILD_SBOM_OUTPUT_DIR",
                      "type" : "codeVoice"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "SWIFTPM_BUILD_SBOM_FILTER",
                      "type" : "codeVoice"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "code" : "SWIFTPM_BUILD_SBOM_WARNING_ONLY",
                      "type" : "codeVoice"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "code" : [
            "SWIFTPM_BUILD_SBOM_SPEC=cyclonedx,spdx swift build --build-system swiftbuild",
            "SWIFTPM_BUILD_SBOM_SPEC=cyclonedx swift package generate-sbom"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "When generating SBOMs using ",
              "type" : "text"
            },
            {
              "code" : "swift build",
              "type" : "codeVoice"
            },
            {
              "text" : " and environment variables, ",
              "type" : "text"
            },
            {
              "code" : "swift build",
              "type" : "codeVoice"
            },
            {
              "text" : " will generate SBOMS if, and only if, the ",
              "type" : "text"
            },
            {
              "code" : "SWIFTPM_BUILD_SBOM_SPEC",
              "type" : "codeVoice"
            },
            {
              "text" : " is set.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
