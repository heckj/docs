    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "To provide a more complete look at what the Swift Package Manager can do, the following example consists of three interdependent packages, which you can explore:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "identifier" : "https:\/\/github.com\/apple\/example-package-playingcard",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : " - Defines PlayingCard, Suit, and Rank types.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "identifier" : "https:\/\/github.com\/apple\/example-package-deckofplayingcards",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : " - Defines a Deck type that shuffles and deals an array of PlayingCard values.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "identifier" : "https:\/\/github.com\/apple\/example-package-dealer",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : " - Defines an executable that creates a DeckOfPlayingCards, shuffles it, and deals the first 10 cards.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "This guide shows you how to create a library that uses another library as a dependency, use the Package Manager to build and test your code, and show you how you might release your own package.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Creating-a-library-package",
          "level" : 3,
          "text" : "Creating a library package",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "This example starts with using an existing package that represents a playing card in a standard 52-card deck.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The package, ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/github.com\/apple\/example-package-playingcard",
              "isActive" : true,
              "overridingTitle" : "PlayingCard",
              "overridingTitleInlineContent" : [
                {
                  "text" : "PlayingCard",
                  "type" : "text"
                }
              ],
              "type" : "reference"
            },
            {
              "text" : ", is available through git and provides a library (",
              "type" : "text"
            },
            {
              "code" : "PlayingCard",
              "type" : "codeVoice"
            },
            {
              "text" : ") that this guide uses and expands upon.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "This example creates the library ",
              "type" : "text"
            },
            {
              "code" : "DeckOfPlayingCards",
              "type" : "codeVoice"
            },
            {
              "text" : " that provides a type that represents a deck of cards and common interactions with the deck, including shuffling, counting, and dealing.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "To start a new library, first make an empty directory, and within it run the ",
              "type" : "text"
            },
            {
              "code" : "swift package init",
              "type" : "codeVoice"
            },
            {
              "text" : " command to initialize a new package:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "mkdir DeckOfPlayingCards",
            "cd DeckOfPlayingCards",
            "swift package init"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The default template that Package Manager creates is a library, which you can control with the ",
              "type" : "text"
            },
            {
              "code" : "--type",
              "type" : "codeVoice"
            },
            {
              "text" : " parameter.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The name of the package defaults to the name of the directory you created, and can be overridden with the ",
              "type" : "text"
            },
            {
              "code" : "--name",
              "type" : "codeVoice"
            },
            {
              "text" : " parameter to the ",
              "type" : "text"
            },
            {
              "code" : "swift package init",
              "type" : "codeVoice"
            },
            {
              "text" : " command.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "For the complete details on options for this command, see the ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/docs.swift.org\/swiftpm\/documentation\/packagemanagerdocs\/packageinit",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The template generates a structure of files in the directory that follow the defaults for a Swift package:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "DeckOfPlayingCards",
            "├── .gitignore",
            "├── Package.swift",
            "├── Sources",
            "│   └── DeckOfPlayingCards",
            "│       └── DeckOfPlayingCards.swift",
            "└── Tests",
            "    └── DeckOfPlayingCardsTests",
            "        └── DeckOfPlayingCardsTests.swift"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The template provides a directory to host a single module that is exposed as a library at ",
              "type" : "text"
            },
            {
              "code" : "Sources\/DeckOfPlayingcards",
              "type" : "codeVoice"
            },
            {
              "text" : ", and a matching directory to host the tests.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The default package structure provides a library that consists of a single target, both of which are named the same as the package: ",
              "type" : "text"
            },
            {
              "code" : "DeckOfPlayingCards",
              "type" : "codeVoice"
            },
            {
              "text" : ", and a test target where you can add tests as you develop your code.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "let package = Package(",
            "    name: \"DeckOfPlayingCards\",",
            "    products: [",
            "        \/\/ Products define the executables and libraries a package produces, making them visible to other packages.",
            "        .library(",
            "            name: \"DeckOfPlayingCards\",",
            "            targets: [\"DeckOfPlayingCards\"]",
            "        ),",
            "    ],",
            "    targets: [",
            "        \/\/ Targets are the basic building blocks of a package, defining a module or a test suite.",
            "        \/\/ Targets can depend on other targets in this package and products from dependencies.",
            "        .target(",
            "            name: \"DeckOfPlayingCards\"",
            "        ),",
            "        .testTarget(",
            "            name: \"DeckOfPlayingCardsTests\",",
            "            dependencies: [\"DeckOfPlayingCards\"]",
            "        ),",
            "    ]",
            ")"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "Adding-a-dependency",
          "level" : 3,
          "text" : "Adding a dependency",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "To add the dependency on the library that provides a PlayingCard so that this example can use it, use the ",
              "type" : "text"
            },
            {
              "code" : "add-dependency",
              "type" : "codeVoice"
            },
            {
              "text" : " command, providing the location where the package is hosted.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift package add-dependency https:\/\/github.com\/apple\/example-package-playingcard --from 3.0.0"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Each dependency within a package specifies a source URL and version requirements.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The source URL is a URL accessible to the current user that resolves to a Git repository.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The package manager uses the version requirements, which follow Semantic Versioning (SemVer) conventions, to determine which Git tag to check out and use to build the dependency.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The above example uses the parameter ",
              "type" : "text"
            },
            {
              "code" : "--from 3.0.0",
              "type" : "codeVoice"
            },
            {
              "text" : ", to indicate the version requirements for the dependency.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "from",
              "type" : "codeVoice"
            },
            {
              "text" : " constrains the dependency chosen to a minimum of ",
              "type" : "text"
            },
            {
              "code" : "3.0.0",
              "type" : "codeVoice"
            },
            {
              "text" : " and extending up to the highest minor and patch release available from the git repository.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Package Manager uses tags, interpreting them as semantic versions, to determine the versions available.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The command updated the ",
              "type" : "text"
            },
            {
              "code" : "Package.swift",
              "type" : "codeVoice"
            },
            {
              "text" : " manifest file, adding the ",
              "type" : "text"
            },
            {
              "code" : "dependencies",
              "type" : "codeVoice"
            },
            {
              "text" : " section:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "let package = Package(",
            "    name: \"DeckOfPlayingCards\",",
            "    products: [",
            "        ...",
            "    ],",
            "    dependencies: [",
            "        .package(url: \"https:\/\/github.com\/apple\/example-package-playingcard\", from: \"3.0.0\"),",
            "    ],",
            "    targets: [",
            "        ...",
            "    ]",
            ")"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Adding the dependency makes it available to the package, but doesn’t include it by default into the targets within the package.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "For example, if you are attempting to build the package using ",
              "type" : "text"
            },
            {
              "code" : "swift build",
              "type" : "codeVoice"
            },
            {
              "text" : ", the build would succeed, but provide the warning:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "warning: 'deckofplayingcards': dependency 'example-package-playingcard' is not used by any target"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If you attempted to use the library in the source, for example ",
              "type" : "text"
            },
            {
              "code" : "import PlayingCard",
              "type" : "codeVoice"
            },
            {
              "text" : ", the compiler reports ",
              "type" : "text"
            },
            {
              "code" : "No such module 'PlayingCard'",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "When you run the swift build command, the Package Manager downloads all of the dependencies, compiles them, and links them to the package module based on the Package.swift manifest.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "You can see the downloaded sources in the ",
              "type" : "text"
            },
            {
              "code" : ".build\/checkouts",
              "type" : "codeVoice"
            },
            {
              "text" : " directory at the root of your project, and intermediate build products in the ",
              "type" : "text"
            },
            {
              "code" : ".build",
              "type" : "codeVoice"
            },
            {
              "text" : " directory at the root of your project.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "You also need to include the dependency on the target where you want to use the library.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Use the command ",
              "type" : "text"
            },
            {
              "code" : "add-target-dependency",
              "type" : "codeVoice"
            },
            {
              "text" : " to add the dependency to the target in this package.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swift package add-target-dependency PlayingCard DeckOfPlayingCards --package example-package-playingcard"
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "This allows DeckOfPlayingCards to access the public members of its dependent modules with import statements.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The above command updates the ",
              "type" : "text"
            },
            {
              "code" : "Package.swift",
              "type" : "codeVoice"
            },
            {
              "text" : " manifest so that the DeckOfPlayingCards target now references the dependency:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            ".target(",
            "    name: \"DeckOfPlayingCards\",",
            "    dependencies: [",
            "        .target(name: \"PlayingCard\"),",
            "    ]",
            "),"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "With this update in place, when you run ",
              "type" : "text"
            },
            {
              "code" : "swift build",
              "type" : "codeVoice"
            },
            {
              "text" : " the package compiles without warnings.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Implement-the-library",
          "level" : 3,
          "text" : "Implement the library",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The template provides an empty file for the source for your package. Remove the content, add ",
              "type" : "text"
            },
            {
              "code" : "import PlayingCard",
              "type" : "codeVoice"
            },
            {
              "text" : ", and your implementation.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The following code provides an example implementation:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "import PlayingCard",
            "",
            "\/\/\/ A model for shuffling and dealing a deck of playing cards.",
            "\/\/\/",
            "\/\/\/ The playing card deck consists of 52 individual cards in four suites: spades, hearts, diamonds, and clubs.",
            "\/\/\/ There are 13 ranks from two to ten, then jack, queen, king, and ace.",
            "public struct Deck: Equatable {",
            "  fileprivate var cards: [PlayingCard]",
            "",
            "  \/\/\/ Returns a deck of playing cards.",
            "  public static func standard52CardDeck() -> Deck {",
            "    var cards: [PlayingCard] = []",
            "    for rank in Rank.allCases {",
            "      for suit in Suit.allCases {",
            "        cards.append(PlayingCard(rank: rank, suit: suit))",
            "      }",
            "    }",
            "",
            "    return Deck(cards)",
            "  }",
            "",
            "  \/\/\/ Creates a deck of playing cards.",
            "  public init(_ cards: [PlayingCard]) {",
            "    self.cards = cards",
            "  }",
            "",
            "  \/\/\/ Randomly shuffles a deck of playing cards.",
            "  public mutating func shuffle() {",
            "    cards.shuffle()",
            "  }",
            "",
            "  \/\/\/ Deals a card from the deck.",
            "  \/\/\/",
            "  \/\/\/ The function returns the last card in the deck.",
            "  public mutating func deal() -> PlayingCard? {",
            "    guard !cards.isEmpty else { return nil }",
            "",
            "    return cards.removeLast()",
            "  }",
            "",
            "  \/\/\/ The number of remaining cards in the deck.",
            "  public var count: Int {",
            "    cards.count",
            "  }",
            "}",
            "",
            "\/\/ MARK: - ExpressibleByArrayLiteral",
            "",
            "extension Deck: ExpressibleByArrayLiteral {",
            "  public init(arrayLiteral elements: PlayingCard...) {",
            "    self.init(elements)",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use ",
              "type" : "text"
            },
            {
              "code" : "swift build",
              "type" : "codeVoice"
            },
            {
              "text" : " to build the package, and ",
              "type" : "text"
            },
            {
              "code" : "swift test",
              "type" : "codeVoice"
            },
            {
              "text" : " to run all the tests associated with the package.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The default template also includes the structure that uses ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/swiftpackageindex.com\/swiftlang\/swift-testing\/documentation\/testing",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " by default, including an empty but functional single test:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "[1\/1] Planning build",
            "Building for debugging...",
            "[10\/10] Linking DeckOfPlayingCardsPackageTests",
            "Build complete! (2.68s)",
            "Test Suite 'All tests' started at 2025-10-09 13:12:08.094.",
            "Test Suite 'All tests' passed at 2025-10-09 13:12:08.095.",
            "     Executed 0 tests, with 0 failures (0 unexpected) in 0.000 (0.001) seconds",
            "◇ Test run started.",
            "↳ Testing Library Version: 1400",
            "↳ Target Platform: arm64e-apple-macos14.0",
            "◇ Test example() started.",
            "✔ Test example() passed after 0.001 seconds.",
            "✔ Test run with 1 test in 0 suites passed after 0.001 seconds."
          ],
          "syntax" : "bash",
          "type" : "codeListing"
        },
        {
          "anchor" : "Add-tests-for-your-package",
          "level" : 3,
          "text" : "Add tests for your package",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Extend the tests to work with the code in your library. Update the contents of ",
              "type" : "text"
            },
            {
              "code" : "Tests\/DeckOfPlayingCardsTests\/DeckOfPlayingCardsTests.swift",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "import DeckOfPlayingCards",
            "import PlayingCard",
            "import Testing",
            "",
            "struct DeckTests {",
            "  @Test",
            "  func standard52CardDeck() {",
            "    var countByPlayingCard: [PlayingCard: Int] = [:]",
            "",
            "    var deck = Deck.standard52CardDeck()",
            "    while let playingCard = deck.deal() {",
            "      countByPlayingCard[playingCard, default: 0] += 1",
            "    }",
            "",
            "    #expect(countByPlayingCard.count == 52)",
            "    #expect(countByPlayingCard.values.allSatisfy({ $0 == 1 }))",
            "",
            "    for rank in Rank.allCases {",
            "      for suit in Suit.allCases {",
            "        let playingCard = PlayingCard(rank: rank, suit: suit)",
            "        #expect(countByPlayingCard[playingCard] == 1)",
            "      }",
            "    }",
            "  }",
            "",
            "  @Test",
            "  func deal() {",
            "    let playingCard = PlayingCard(rank: .ace, suit: .clubs)",
            "    var deck: Deck = [playingCard]",
            "",
            "    #expect(deck.deal() == playingCard)",
            "    #expect(deck.deal() == nil)",
            "  }",
            "",
            "  @Test",
            "  func countEmptyDeckHasZeroCards() {",
            "    let deck = Deck()",
            "    \/\/XCTAssertEqual(deck.count, 0)",
            "    #expect(deck.count == 0)",
            "  }",
            "",
            "  @Test",
            "  func countStandard52CardDeckHas52Cards() {",
            "    let deck = Deck.standard52CardDeck()",
            "",
            "    #expect(deck.count == 52)",
            "  }",
            "",
            "  @Test",
            "  func countDealingDecreasesCountByOne() throws {",
            "    var deck = Deck([",
            "      PlayingCard(rank: .ace, suit: .spades), PlayingCard(rank: .queen, suit: .hearts),",
            "    ])",
            "",
            "    #expect(deck.count == 2)",
            "    try #require(deck.deal() != nil)",
            "    #expect(deck.count == 1)",
            "  }",
            "}"
