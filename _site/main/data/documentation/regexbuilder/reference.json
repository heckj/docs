{"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","identifiers":["doc://com.apple.Swift/documentation/Swift/RegexComponent"],"kind":"relationships"}],"abstract":[{"text":"A reference to a captured portion of a regular expression.","type":"text"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/regexbuilder/reference"]}],"identifier":{"url":"doc://com.apple.Swift/documentation/RegexBuilder/Reference","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/RegexBuilder"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Reference"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Capture"},{"kind":"text","text":">"}]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a "},{"type":"codeVoice","code":"Reference"},{"type":"text","text":" to access a regular expression, both during"},{"type":"text","text":" "},{"type":"text","text":"the matching process and after a capture has been successful."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, the "},{"type":"codeVoice","code":"kind"},{"type":"text","text":" reference captures either "},{"code":"\"CREDIT\"","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"\"DEBIT\"","type":"codeVoice"},{"type":"text","text":" at the beginning of a line. Later in the regular expression, the"},{"type":"text","text":" "},{"type":"text","text":"presence of "},{"code":"kind","type":"codeVoice"},{"type":"text","text":" matches the same substring that was captured previously"},{"type":"text","text":" "},{"text":"at the end of the line.","type":"text"}]},{"type":"codeListing","code":["let kindRef = Reference(Substring.self)","let kindRegex = ChoiceOf {","    \"CREDIT\"","    \"DEBIT\"","}","","let transactionRegex = Regex {","    Anchor.startOfLine","    Capture(kindRegex, as: kindRef)","    OneOrMore(.anyNonNewline)","    kindRef","    Anchor.endOfLine","}","","let validTransaction = \"CREDIT     109912311421    Payroll   $69.73  CREDIT\"","let invalidTransaction = \"DEBIT     00522142123    Expense   $5.17  CREDIT\"","","print(validTransaction.contains(transactionRegex))","// Prints \"true\"","print(invalidTransaction.contains(transactionRegex))","// Prints \"false\""],"syntax":"swift"},{"inlineContent":[{"text":"Any reference that is used for matching must be captured elsewhere in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Regex"},{"type":"text","text":" block. You can use a reference for matching before it is captured;"},{"text":" ","type":"text"},{"type":"text","text":"in that case, the reference will not match until it has previously been"},{"text":" ","type":"text"},{"text":"captured.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To access the captured “transaction kind”, you can use the "},{"type":"codeVoice","code":"kind"},{"type":"text","text":" reference"},{"text":" ","type":"text"},{"type":"text","text":"to subscript a "},{"type":"codeVoice","code":"Regex.Match"},{"text":" instance:","type":"text"}]},{"type":"codeListing","code":["if let match = validTransaction.firstMatch(of: transactionRegex) {","    print(match[kindRef])","}","// Prints \"CREDIT\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use a "},{"code":"Reference","type":"codeVoice"},{"type":"text","text":" to capture a transformed value, include a "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" "},{"text":"closure when capturing.","type":"text"}]},{"code":["struct Transaction {","    var id: UInt64","}","let transactionRef = Reference(Transaction.self)","","let transactionIDRegex = Regex {","    Capture(kindRegex, as: kindRef)","    OneOrMore(.whitespace)","    TryCapture(as: transactionRef) {","        OneOrMore(.digit)","    } transform: { str in","        UInt64(str).map(Transaction.init(id:))","    }","    OneOrMore(.anyNonNewline)","    kindRef","    Anchor.endOfLine","}","","if let match = validTransaction.firstMatch(of: transactionIDRegex) {","    print(match[transactionRef])","}","// Prints \"Transaction(id: 109912311421)\""],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"Reference"}],"symbolKind":"struct","role":"symbol","externalID":"s:12RegexBuilder9ReferenceV","roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Reference"}],"modules":[{"name":"RegexBuilder"}],"title":"Reference"},"seeAlsoSections":[{"title":"Captures","generated":true,"identifiers":["doc://com.apple.Swift/documentation/RegexBuilder/Capture","doc://com.apple.Swift/documentation/RegexBuilder/TryCapture"],"anchor":"Captures"}],"sections":[],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc://com.apple.Swift/documentation/RegexBuilder/Reference/init(_:)"],"anchor":"Initializers"},{"title":"Instance Properties","generated":true,"identifiers":["doc://com.apple.Swift/documentation/RegexBuilder/Reference/regex"],"anchor":"Instance-Properties"}],"references":{"doc://com.apple.Swift/documentation/Swift/RegexComponent":{"url":"/documentation/swift/regexcomponent","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"A type that represents a regular expression."}],"title":"RegexComponent","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"RegexComponent"}],"navigatorTitle":[{"kind":"identifier","text":"RegexComponent"}],"identifier":"doc://com.apple.Swift/documentation/Swift/RegexComponent"},"doc://com.apple.Swift/documentation/RegexBuilder/Capture":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Capture"}],"title":"Capture","type":"topic","role":"symbol","identifier":"doc://com.apple.Swift/documentation/RegexBuilder/Capture","kind":"symbol","abstract":[{"text":"A regex component that saves the matched substring, or a transformed result,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for access in a regex match."}],"navigatorTitle":[{"text":"Capture","kind":"identifier"}],"url":"/documentation/regexbuilder/capture"},"doc://com.apple.Swift/documentation/RegexBuilder/Reference/init(_:)":{"title":"init(_:)","role":"symbol","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/RegexBuilder/Reference/init(_:)","abstract":[{"text":"Creates a reference with the specified capture type.","type":"text"}],"type":"topic","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Capture","kind":"typeIdentifier","preciseIdentifier":"s:12RegexBuilder9ReferenceV7Capturexmfp"},{"text":".Type)","kind":"text"}],"url":"/documentation/regexbuilder/reference/init(_:)"},"doc://com.apple.Swift/documentation/RegexBuilder/Reference/regex":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/RegexBuilder/Reference/regex","url":"/documentation/regexbuilder/reference/regex","kind":"symbol","role":"symbol","title":"regex","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"regex","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Regex","kind":"typeIdentifier","preciseIdentifier":"s:17_StringProcessing5RegexV"},{"text":"<","kind":"text"},{"text":"Capture","kind":"typeIdentifier","preciseIdentifier":"s:12RegexBuilder9ReferenceV7Capturexmfp"},{"text":">","kind":"text"}],"abstract":[]},"doc://com.apple.Swift/documentation/RegexBuilder/Reference":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Reference"}],"abstract":[{"text":"A reference to a captured portion of a regular expression.","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/RegexBuilder/Reference","title":"Reference","kind":"symbol","type":"topic","url":"/documentation/regexbuilder/reference","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Reference"}]},"doc://com.apple.Swift/documentation/RegexBuilder/TryCapture":{"abstract":[{"text":"A regex component that attempts to transform a matched substring, saving","type":"text"},{"text":" ","type":"text"},{"text":"the result if successful and backtracking if the transformation fails.","type":"text"}],"title":"TryCapture","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/RegexBuilder/TryCapture","url":"/documentation/regexbuilder/trycapture","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TryCapture","kind":"identifier"}],"navigatorTitle":[{"text":"TryCapture","kind":"identifier"}],"type":"topic"},"doc://com.apple.Swift/documentation/RegexBuilder":{"role":"collection","abstract":[],"identifier":"doc://com.apple.Swift/documentation/RegexBuilder","title":"RegexBuilder","type":"topic","kind":"symbol","url":"/documentation/regexbuilder"}}}