{"sections":[],"abstract":[{"type":"text","text":"A reference to a captured portion of a regular expression."}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/RegexBuilder/Reference"},"relationshipsSections":[{"type":"conformsTo","identifiers":["doc://com.apple.Swift/documentation/Swift/RegexComponent"],"kind":"relationships","title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Reference","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Capture","kind":"genericParameter"},{"text":">","kind":"text"}],"languages":["swift"]}]},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a "},{"type":"codeVoice","code":"Reference"},{"type":"text","text":" to access a regular expression, both during"},{"type":"text","text":" "},{"type":"text","text":"the matching process and after a capture has been successful."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, the "},{"type":"codeVoice","code":"kind"},{"type":"text","text":" reference captures either "},{"type":"codeVoice","code":"\"CREDIT\""},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"DEBIT\""},{"type":"text","text":" at the beginning of a line. Later in the regular expression, the"},{"type":"text","text":" "},{"type":"text","text":"presence of "},{"type":"codeVoice","code":"kind"},{"type":"text","text":" matches the same substring that was captured previously"},{"type":"text","text":" "},{"type":"text","text":"at the end of the line."}]},{"type":"codeListing","syntax":"swift","code":["let kindRef = Reference(Substring.self)","let kindRegex = ChoiceOf {","    \"CREDIT\"","    \"DEBIT\"","}","","let transactionRegex = Regex {","    Anchor.startOfLine","    Capture(kindRegex, as: kindRef)","    OneOrMore(.anyNonNewline)","    kindRef","    Anchor.endOfLine","}","","let validTransaction = \"CREDIT     109912311421    Payroll   $69.73  CREDIT\"","let invalidTransaction = \"DEBIT     00522142123    Expense   $5.17  CREDIT\"","","print(validTransaction.contains(transactionRegex))","// Prints \"true\"","print(invalidTransaction.contains(transactionRegex))","// Prints \"false\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any reference that is used for matching must be captured elsewhere in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"Regex"},{"type":"text","text":" block. You can use a reference for matching before it is captured;"},{"type":"text","text":" "},{"type":"text","text":"in that case, the reference will not match until it has previously been"},{"type":"text","text":" "},{"type":"text","text":"captured."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To access the captured “transaction kind”, you can use the "},{"type":"codeVoice","code":"kind"},{"type":"text","text":" reference"},{"type":"text","text":" "},{"type":"text","text":"to subscript a "},{"type":"codeVoice","code":"Regex.Match"},{"type":"text","text":" instance:"}]},{"type":"codeListing","syntax":"swift","code":["if let match = validTransaction.firstMatch(of: transactionRegex) {","    print(match[kindRef])","}","// Prints \"CREDIT\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use a "},{"type":"codeVoice","code":"Reference"},{"type":"text","text":" to capture a transformed value, include a "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" "},{"type":"text","text":"closure when capturing."}]},{"type":"codeListing","syntax":"swift","code":["struct Transaction {","    var id: UInt64","}","let transactionRef = Reference(Transaction.self)","","let transactionIDRegex = Regex {","    Capture(kindRegex, as: kindRef)","    OneOrMore(.whitespace)","    TryCapture(as: transactionRef) {","        OneOrMore(.digit)","    } transform: { str in","        UInt64(str).map(Transaction.init(id:))","    }","    OneOrMore(.anyNonNewline)","    kindRef","    Anchor.endOfLine","}","","if let match = validTransaction.firstMatch(of: transactionIDRegex) {","    print(match[transactionRef])","}","// Prints \"Transaction(id: 109912311421)\""]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"anchor":"Captures","identifiers":["doc://com.apple.Swift/documentation/RegexBuilder/Capture","doc://com.apple.Swift/documentation/RegexBuilder/TryCapture"],"generated":true,"title":"Captures"}],"kind":"symbol","variants":[{"paths":["/documentation/regexbuilder/reference"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/RegexBuilder"]]},"metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Reference"}],"navigatorTitle":[{"kind":"identifier","text":"Reference"}],"symbolKind":"struct","externalID":"s:12RegexBuilder9ReferenceV","title":"Reference","roleHeading":"Structure","role":"symbol","modules":[{"name":"RegexBuilder"}]},"topicSections":[{"anchor":"Initializers","identifiers":["doc://com.apple.Swift/documentation/RegexBuilder/Reference/init(_:)"],"generated":true,"title":"Initializers"},{"anchor":"Instance-Properties","identifiers":["doc://com.apple.Swift/documentation/RegexBuilder/Reference/regex"],"generated":true,"title":"Instance Properties"}],"references":{"doc://com.apple.Swift/documentation/RegexBuilder/TryCapture":{"url":"/documentation/regexbuilder/trycapture","title":"TryCapture","navigatorTitle":[{"kind":"identifier","text":"TryCapture"}],"type":"topic","role":"symbol","abstract":[{"type":"text","text":"A regex component that attempts to transform a matched substring, saving"},{"type":"text","text":" "},{"type":"text","text":"the result if successful and backtracking if the transformation fails."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"TryCapture"}],"identifier":"doc://com.apple.Swift/documentation/RegexBuilder/TryCapture","kind":"symbol"},"doc://com.apple.Swift/documentation/RegexBuilder/Reference":{"url":"/documentation/regexbuilder/reference","navigatorTitle":[{"kind":"identifier","text":"Reference"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Reference"}],"title":"Reference","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/RegexBuilder/Reference","abstract":[{"text":"A reference to a captured portion of a regular expression.","type":"text"}],"role":"symbol","type":"topic"},"doc://com.apple.Swift/documentation/RegexBuilder/Reference/regex":{"url":"/documentation/regexbuilder/reference/regex","abstract":[],"identifier":"doc://com.apple.Swift/documentation/RegexBuilder/Reference/regex","type":"topic","title":"regex","kind":"symbol","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"regex","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Regex","preciseIdentifier":"s:17_StringProcessing5RegexV","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Capture","preciseIdentifier":"s:12RegexBuilder9ReferenceV7Capturexmfp","kind":"typeIdentifier"},{"text":">","kind":"text"}]},"doc://com.apple.Swift/documentation/RegexBuilder/Reference/init(_:)":{"url":"/documentation/regexbuilder/reference/init(_:)","abstract":[{"type":"text","text":"Creates a reference with the specified capture type."}],"identifier":"doc://com.apple.Swift/documentation/RegexBuilder/Reference/init(_:)","type":"topic","title":"init(_:)","kind":"symbol","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Capture","preciseIdentifier":"s:12RegexBuilder9ReferenceV7Capturexmfp","kind":"typeIdentifier"},{"text":".Type)","kind":"text"}]},"doc://com.apple.Swift/documentation/RegexBuilder/Capture":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/RegexBuilder/Capture","type":"topic","title":"Capture","kind":"symbol","url":"/documentation/regexbuilder/capture","navigatorTitle":[{"kind":"identifier","text":"Capture"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Capture","kind":"identifier"}],"abstract":[{"text":"A regex component that saves the matched substring, or a transformed result,","type":"text"},{"text":" ","type":"text"},{"text":"for access in a regex match.","type":"text"}]},"doc://com.apple.Swift/documentation/RegexBuilder":{"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/RegexBuilder","title":"RegexBuilder","abstract":[],"type":"topic","role":"collection","url":"/documentation/regexbuilder"},"doc://com.apple.Swift/documentation/Swift/RegexComponent":{"abstract":[{"text":"A type that represents a regular expression.","type":"text"}],"role":"symbol","url":"/documentation/swift/regexcomponent","type":"topic","kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RegexComponent","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/RegexComponent","title":"RegexComponent","navigatorTitle":[{"text":"RegexComponent","kind":"identifier"}]}}}