{"kind":"symbol","abstract":[{"type":"text","text":"Capture a backtrace from the current program location."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"capture"},{"kind":"text","text":"("},{"kind":"externalParam","text":"algorithm"},{"kind":"text","text":": "},{"identifier":"doc://com.apple.Swift/documentation/Runtime/Backtrace/UnwindAlgorithm","preciseIdentifier":"s:7Runtime9BacktraceV15UnwindAlgorithmO","kind":"typeIdentifier","text":"UnwindAlgorithm"},{"kind":"text","text":" = .auto, "},{"kind":"externalParam","text":"limit"},{"kind":"text","text":": "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":"? = 64, "},{"kind":"externalParam","text":"offset"},{"kind":"text","text":": "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":" = 0, "},{"kind":"externalParam","text":"top"},{"kind":"text","text":": "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":" = 16, "},{"kind":"externalParam","text":"images"},{"kind":"text","text":": "},{"identifier":"doc://com.apple.Swift/documentation/Runtime/ImageMap","preciseIdentifier":"s:7Runtime8ImageMapV","kind":"typeIdentifier","text":"ImageMap"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"identifier":"doc://com.apple.Swift/documentation/Runtime/Backtrace","preciseIdentifier":"s:7Runtime9BacktraceV","kind":"typeIdentifier","text":"Backtrace"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"code":"capture()","type":"codeVoice"},{"type":"text","text":" method itself will not be included in the backtrace;"},{"type":"text","text":" "},{"text":"i.e. the first frame will be the one in which ","type":"text"},{"code":"capture()","type":"codeVoice"},{"text":" was called,","type":"text"},{"text":" ","type":"text"},{"text":"and its programCounter value will be the return address for the","type":"text"},{"text":" ","type":"text"},{"code":"capture()","type":"codeVoice"},{"text":" method call.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Parameters:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"algorithm:     Specifies which unwind mechanism to use.  If this","type":"text"},{"text":" ","type":"text"},{"text":"is set to ","type":"text"},{"code":".auto","type":"codeVoice"},{"text":", we will use the platform default.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"limit:         The backtrace will include at most this number of","type":"text"},{"text":" ","type":"text"},{"text":"frames; you can set this to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to remove the","type":"text"},{"text":" ","type":"text"},{"text":"limit completely if required.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"offset:        Says how many frames to skip; this makes it easy to","type":"text"},{"text":" ","type":"text"},{"text":"wrap this API without having to inline things and","type":"text"},{"text":" ","type":"text"},{"text":"without including unnecessary frames in the backtrace.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"top:           Sets the minimum number of frames to capture at the"},{"type":"text","text":" "},{"type":"text","text":"top of the stack."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"images:        (Optional) A list of captured images.  This allows you"},{"type":"text","text":" "},{"type":"text","text":"to capture images once, and then generate multiple"},{"type":"text","text":" "},{"type":"text","text":"backtraces using a single set of captured images."}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"metadata":{"role":"symbol","modules":[{"name":"Runtime"}],"title":"capture(algorithm:limit:offset:top:images:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"capture","kind":"identifier"},{"text":"(","kind":"text"},{"text":"algorithm","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnwindAlgorithm","kind":"typeIdentifier","preciseIdentifier":"s:7Runtime9BacktraceV15UnwindAlgorithmO"},{"text":", ","kind":"text"},{"text":"limit","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":"?, ","kind":"text"},{"text":"offset","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"top","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"images","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ImageMap","kind":"typeIdentifier","preciseIdentifier":"s:7Runtime8ImageMapV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Backtrace","kind":"typeIdentifier","preciseIdentifier":"s:7Runtime9BacktraceV"}],"symbolKind":"method","externalID":"s:7Runtime9BacktraceV7capture9algorithm5limit6offset3top6imagesA2C15UnwindAlgorithmO_SiSgS2iAA8ImageMapVSgtKFZ","roleHeading":"Type Method"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Runtime","doc://com.apple.Swift/documentation/Runtime/Backtrace"]]},"variants":[{"paths":["/documentation/runtime/backtrace/capture(a