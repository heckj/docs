        {
          "anchor" : "Preconcurrency-annotations",
          "level" : 2,
          "text" : "Preconcurrency annotations",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The ",
              "type" : "text"
            },
            {
              "code" : "@preconcurrency",
              "type" : "codeVoice"
            },
            {
              "text" : " attribute can be used directly on library APIs to",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "stage in new concurrency requirements that are checked at compile time",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "without breaking source or ABI compatibility for clients:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@preconcurrency @MainActor",
            "struct S { ... }",
            "",
            "@preconcurrency",
            "public func performConcurrently(",
            "  completion: @escaping @Sendable () -> Void",
            ") { ... }"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Clients do not need to use a ",
              "type" : "text"
            },
            {
              "code" : "@preconcurrency import",
              "type" : "codeVoice"
            },
            {
              "text" : " for the new errors",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "to be downgraded. If the clients build with minimal concurrency checking,",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "errors from ",
              "type" : "text"
            },
            {
              "code" : "@preconcurrency",
              "type" : "codeVoice"
            },
            {
              "text" : " APIs will be suppressed. If the clients build",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "with complete concurrency checking or the Swift 6 language mode, the errors",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "will be downgraded to warnings.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "For ABI compatibility, ",
              "type" : "text"
            },
            {
              "code" : "@preconcurrency",
              "type" : "codeVoice"
            },
            {
              "text" : " will mangle symbol names without any",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "concurrency annotations. If an API was introduced with some concurrency",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "annotations, and is later updated to include additional concurrency",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "annotations, then applying ",
              "type" : "text"
            },
            {
              "code" : "@preconcurrency",
              "type" : "codeVoice"
            },
            {
              "text" : " is not sufficient for preserving",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "mangling. ",
              "type" : "text"
            },
            {
              "code" : "@_silgen_name",
              "type" : "codeVoice"
            },
            {
              "text" : " can be used in cases where you need more precise",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "control over mangling concurrency annotations.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "Note that all APIs imported from C, C++, and Objective-C are automatically",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "considered ",
              "type" : "text"
            },
            {
              "code" : "@preconcurrency",
              "type" : "codeVoice"
            },
            {
              "text" : ". Concurrency attributes can always be applied",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "to these APIs using ",
              "type" : "text"
            },
            {
              "code" : "__attribute__((__swift_attr__(\"<attribute name>\")))",
