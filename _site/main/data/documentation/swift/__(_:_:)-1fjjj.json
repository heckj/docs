arguments."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This operator uses short-circuit evaluation: "},{"type":"codeVoice","code":"optional"},{"type":"text","text":" is checked first,"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"defaultValue"},{"type":"text","text":" is evaluated only if "},{"type":"codeVoice","code":"optional"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". For example:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let goodNumber = Int(\"100\") ?? Int(\"42\")","print(goodNumber)","// Prints \"Optional(100)\"","","let notSoGoodNumber = Int(\"invalid-input\") ?? Int(\"42\")","print(notSoGoodNumber)","// Prints \"Optional(42)\""]},{"inlineContent":[{"text":"In this example, ","type":"text"},{"code":"goodNumber","type":"codeVoice"},{"type":"text","text":" is assigned a value of "},{"type":"codeVoice","code":"100"},{"type":"text","text":" because"},{"type":"text","text":" "},{"type":"codeVoice","code":"Int(\"100\")"},{"type":"text","text":" succeeds in returning a non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" result. When"},{"type":"text","text":" "},{"type":"codeVoice","code":"notSoGoodNumber"},{"type":"text","text":" is initialized, "},{"type":"codeVoice","code":"Int(\"invalid-input\")"},{"type":"text","text":" fails and returns"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", and so "},{"type":"codeVoice","code":"Int(\"42\")"},{"text":" is called to supply a default value.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the result of this nil-coalescing operation is itself an optional"},{"type":"text","text":" "},{"type":"text","text":"value, you can chain default values by using "},{"type":"codeVoice","code":"??"},{"type":"text","text":" multiple times. The"},{"type":"text","text":" "},{"type":"text","text":"first optional value that isn’t "},{"type":"codeVoice","code":"nil"},{"text":" stops the chain and becomes the","type":"text"},{"text":" ","type":"text"},{"text":"result of the whole expression. The next example tries to find the correct","type":"text"},{"text":" ","type":"text"},{"text":"text for a greeting in two separate dictionaries before falling back to a","type":"text"},{"text":" ","type":"text"},{"text":"static default.","type":"text"}]},{"code":["let greeting = userPrefs[greetingKey] ??","    defaults[greetingKey] ?? \"Greetings!\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"userPrefs[greetingKey]"},{"type":"text","text":" has a value, that value is assigned to"},{"type":"text","text":" "},{"code":"greeting","type":"codeVoice"},{"type":"text","text":". If not, any value in "},{"code":"defaults[greetingKey]","type":"codeVoice"},{"type":"text","text":" will succeed, and"},{"text":" ","type":"text"},{"text":"if not that, ","type":"text"},{"code":"greeting","type":"codeVoice"},{"text":" will be set to the non-optional default value,","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"Greetings!\""},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/__(_:_:)-1fjjj":{"role":"symbol","url":"/documentation/swift/__(_:_:)-1fjjj","identifier":"doc://com.apple.Swift/documentation/Swift/__(_:_:)-1fjjj","kind":"symbol","title":"??(_:_:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"??","kind":"identifier"},{"text":" ","kind":"text"},{"text":"<","kind":"text"},{"text":"T","kind":"ge