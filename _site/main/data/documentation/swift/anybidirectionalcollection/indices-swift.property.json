n","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"A collection’s ","type":"text"},{"code":"indices","type":"codeVoice"},{"text":" property can hold a strong reference to the","type":"text"},{"text":" ","type":"text"},{"text":"collection itself, causing the collection to be non-uniquely referenced.","type":"text"},{"text":" ","type":"text"},{"text":"If you mutate the collection while iterating over its indices, a strong","type":"text"},{"text":" ","type":"text"},{"text":"reference can cause an unexpected copy of the collection. To avoid the","type":"text"},{"text":" ","type":"text"},{"text":"unexpected copy, use the ","type":"text"},{"code":"index(after:)","type":"codeVoice"},{"text":" method starting with","type":"text"},{"text":" ","type":"text"},{"code":"startIndex","type":"codeVoice"},{"text":" to produce indices instead.","type":"text"}]},{"code":["var c = MyFancyCollection([10, 20, 30, 40, 50])","var i = c.startIndex","while i != c.endIndex {","    c[i] /= 5","    i = c.index(after: i)","}","// c == MyFancyCollection([2, 4, 6, 8, 10])"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["/documentation/swift/anybidirectionalcollection/indices-swift.property"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/AnyBidirectionalCollection":{"abstract":[{"text":"A type-erased wrapper over any collection with indices that","type":"text"},{"text":" ","type":"text"},{"text":"support bidirectional traversal.","type":"text"}],"title":"AnyBidirectionalCollection","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AnyBidirectionalCollection","url":"/documentation/swift/anybidirectionalcollection","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyBidirectionalCollection"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"AnyBidirectionalCollection"}]},"doc://com.apple.Swift