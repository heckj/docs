ype":"text","text":" "},{"type":"text","text":"of the strings in the slice, and then uses that index in the original"},{"type":"text","text":" "},{"type":"text","text":"array."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""]},{"inlineContent":[{"type":"text","text":"Always use the slice’s "},{"type":"codeVoice","code":"startIndex"},{"type":"text","text":" property instead of assuming that its"},{"type":"text","text":" "},{"type":"text","text":"indices start at a particular value. Attempting to access an element by"},{"type":"text","text":" "},{"type":"text","text":"using an index outside the bounds of the slice’s indices may result in a"},{"type":"text","text":" "},{"type":"text","text":"runtime error, even if that index is valid for the original collection."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O(1)"}]}],"name":"Complexity"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/AnyBidirectionalCollection/subscript(_:)-8f134":{"title":"subscript(_:)","fragments":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">("},{"preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp","kind":"typeIdentifier","text":"R"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Sl11SubSequenceQa","kind":"typeIdentifier","text":"SubSequence"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AnyBidirectionalCollection/subscript(_:)-8f134","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Accesses the contiguous subrange of the coll