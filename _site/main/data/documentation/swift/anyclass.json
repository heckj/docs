aultValue() -> Int {","        return 42","    }","}","","func getDefaultValue(_ c: AnyClass) -> Int? {","    return c.getDefaultValue?()","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"getDefaultValue(_:)"},{"type":"text","text":" function uses optional chaining to safely call"},{"type":"text","text":" "},{"type":"text","text":"the implicitly unwrapped class method on "},{"type":"codeVoice","code":"c"},{"type":"text","text":". Calling the function with"},{"type":"text","text":" "},{"type":"text","text":"different class types shows how the "},{"type":"codeVoice","code":"getDefaultValue()"},{"type":"text","text":" class method is"},{"type":"text","text":" "},{"type":"text","text":"only conditionally available."}]},{"syntax":"swift","type":"codeListing","code":["print(getDefaultValue(IntegerRef.self))","// Prints \"Optional(42)\"","","print(getDefaultValue(NSString.self))","// Prints \"nil\""]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"references":{"doc://com.apple.Swift/documentation/Swift/AnyObject":{"identifier":"doc://com.apple.Swift/documentation/Swift/AnyObject","abstract":[{"type":"text","text":"The protocol to which all classes implicitly conform."}],"type":"topic","role":"symbol","url":"/documentation/swift/anyobject","navigatorTitle":[{"kind":"identifier","text":"AnyObject"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyObject"}],"title":"AnyObject"},"doc://com.apple.Swift/documentation/Swift/AnyClass":{"identifier":"doc://com.apple.Swift/documentation/Swift/AnyClass","abstract":[{"type":"text","text":"The protocol to which all class types implicitly conform."}],"type":"topic","role":"symbol","url":"/documentation/swift/anyclass","navigatorTitle":[{"kind":"identifier","text":"AnyClass"}],"kind":"symbol","fragments":[{"kind":"keywor