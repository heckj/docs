t"},{"code":"startIndex","type":"codeVoice"},{"text":" to produce indices instead.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var c = MyFancyCollection([10, 20, 30, 40, 50])","var i = c.startIndex","while i != c.endIndex {","    c[i] /= 5","    i = c.index(after: i)","}","// c == MyFancyCollection([2, 4, 6, 8, 10])"]}],"kind":"content"}],"metadata":{"externalID":"s:SlsSIyxG7IndicesRtzrlE7indicesAAvp::SYNTHESIZED::s:s13AnyCollectionV","roleHeading":"Instance Property","symbolKind":"property","extendedModule":"Swift","role":"symbol","title":"indices","conformance":{"availabilityPrefix":[{"text":"Available when","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}],"constraints":[{"code":"Indices","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"DefaultIndices<Self>","type":"codeVoice"},{"text":".","type":"text"}]},"modules":[{"name":"Swift"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"indices","kind":"identifier"},{"text":": ","kind":"text"},{"text":"DefaultIndices","kind":"typeIdentifier","preciseIdentifier":"s:SI"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}]},"references":{"doc://com.apple.Swift/documentation/Swift/AnyCollection/indices-swift.property":{"identifier":"doc://com.apple.Swift/documentation/Swift/AnyCollection/indices-swift.property","abstract":[{"type":"text","text":"The indices that are valid for subscripting the collection, in ascending"},{"type":"text","text":" "},{"type":"text","text":"order."}],"kind":"symbol","type":"topic","role":"symbol","url":"/documentation/swift/anycollection/indices-swift.property","title":"indices","conformance":{"availabilityPrefix":[{"type":"text","text":"Available when"}],"constraints":[{"type":"codeVoice","code":"Indices"},{"type":"text","text":" is "},{"type":"codeVoice","code":"DefaultIndices<Self>"},{"type":"text","text":"."}],"conformancePrefix":[{"type":"text","text":"Conf