{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AnyCollection/prefix(through:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"prefix","kind":"identifier"},{"text":"(","kind":"text"},{"text":"through","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"position","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Index","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa"},{"text":") -> ","kind":"text"},{"text":"SubSequence","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","kind":"typeIdentifier","preciseIdentifier":"s:Sl11SubSequenceQa"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The index of the last element to include in the"},{"type":"text","text":" "},{"type":"text","text":"resulting subsequence. "},{"code":"position","type":"codeVoice"},{"text":" must be a valid index of the collection","type":"text"},{"text":" ","type":"text"},{"text":"that is not equal to the ","type":"text"},{"code":"endIndex","type":"codeVoice"},{"text":" property.","type":"text"}]}],"name":"position"}],"kind":"parameters"},{"content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A subsequence up to, and including, the given position."}]}],"kind":"content"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The resulting subsequence "},{"inlineContent":[{"text":"includes","type":"text"}],"type":"emphasis"},{"type":"text","text":" the element at the position"},{"type":"text","text":" "},{"type":"text","text":"specified by the "},{"code":"through","type":"codeVoice"},{"type":"te