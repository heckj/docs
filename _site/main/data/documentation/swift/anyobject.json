{"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/AnyObject"},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"The protocol to which all classes implicitly conform."}],"metadata":{"roleHeading":"Type Alias","title":"AnyObject","modules":[{"name":"Swift"}],"role":"symbol","externalID":"s:s9AnyObjecta","symbolKind":"typealias","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyObject"}],"navigatorTitle":[{"kind":"identifier","text":"AnyObject"}]},"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/AnyClass"],"generated":true,"title":"Existential Types","anchor":"Existential-Types"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyObject"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You use "},{"code":"AnyObject","type":"codeVoice"},{"type":"text","text":" when you need the flexibility of an untyped object or"},{"type":"text","text":" "},{"type":"text","text":"when you use bridged Objective-C methods and properties that return an"},{"type":"text","text":" "},{"type":"text","text":"untyped result. "},{"code":"AnyObject","type":"codeVoice"},{"type":"text","text":" can be used as the concrete type for an"},{"type":"text","text":" "},{"type":"text","text":"instance of any class, class type, or class-only protocol. For example:"}]},{"code":["class FloatRef {","    let value: Float","    init(_ value: Float) {","        self.value = value","    }","}","","let x = FloatRef(2.3)","let y: AnyObject = x","let z: AnyObject = FloatRef.self"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"code":"AnyObject","type":"codeVoice"},{"type":"text","text":" can also be used as the concrete type for an instance of a type"},{"type":"text","text":" "},{"type":"text","text":"that bridges to an Objective-C class. Many value types in Swift bridge to"},{"type":"text","text":" "},{"type":"text","text":"Objective-C counterparts, like "},{"code":"String","type":"codeVoice"},{"type":"text","text":" and "},{"code":"Int","type":"codeVoice"},{"type":"text","text":"."}]},{"code":["let s: AnyObject = \"This is a bridged string.\" as NSString","print(s is NSString)","// Prints \"true\"","","let v: AnyObject = 100 as NSNumber","print(type(of: v))","// Prints \"__NSCFNumber\""],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The flexible behavior of the "},{"code":"AnyObject","type":"codeVoice"},{"type":"text","text":" protocol is similar to"},{"type":"text","text":" "},{"type":"text","text":"Objective-C’s "},{"code":"id","type":"codeVoice"},{"type":"text","text":" type. For this reason, imported Objective-C types"},{"type":"text","text":" "},{"type":"text","text":"frequently use "},{"code":"AnyObject","type":"codeVoice"},{"type":"text","text":" as the type for properties, method parameters,"},{"type":"text","text":" "},{"type":"text","text":"and return values."}]},{"level":1,"text":"Casting AnyObject Instances to a Known Type","type":"heading","anchor":"Casting-AnyObject-Instances-to-a-Known-Type"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Objects with a concrete type of "},{"code":"AnyObject","type":"codeVoice"},{"type":"text","text":" maintain a specific dynamic"},{"type":"text","text":" "},{"type":"text","text":"type and can be cast to that type using one of the type-cast operators"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"as","type":"codeVoice"},{"type":"text","text":", "},{"code":"as?","type":"codeVoice"},{"type":"text","text":", or "},{"code":"as!","type":"codeVoice"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example uses the conditional downcast operator ("},{"code":"as?","type":"codeVoice"},{"type":"text","text":") to"},{"type":"text","text":" "},{"type":"text","text":"conditionally cast the "},{"code":"s","type":"codeVoice"},{"type":"text","text":" constant declared above to an instance of"},{"type":"text","text":" "},{"type":"text","text":"Swift’s "},{"code":"String","type":"codeVoice"},{"type":"text","text":" type."}]},{"code":["if let message = s as? String {","    print(\"Successful cast to String: \\(message)\")","}","// Prints \"Successful cast to String: This is a bridged string.\""],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have prior knowledge that an "},{"code":"AnyObject","type":"codeVoice"},{"type":"text","text":" instance has a particular"},{"type":"text","text":" "},{"type":"text","text":"type, you can use the unconditional downcast operator ("},{"code":"as!","type":"codeVoice"},{"type":"text","text":"). Performing"},{"type":"text","text":" "},{"type":"text","text":"an invalid cast triggers a runtime error."}]},{"code":["let message = s as! String","print(\"Successful cast to String: \\(message)\")","// Prints \"Successful cast to String: This is a bridged string.\"","","let badCase = v as! String","// Runtime error"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Casting is always safe in the context of a "},{"code":"switch","type":"codeVoice"},{"type":"text","text":" statement."}]},{"code":["let mixedArray: [AnyObject] = [s, v]","for object in mixedArray {","    switch object {","    case let x as String:","        print(\"'\\(x)' is a String\")","    default:","        print(\"'\\(object)' is not a String\")","    }","}","// Prints \"'This is a bridged string.' is a String\"","// Prints \"'100' is not a String\""],"syntax":"swift","type":"codeListing"},{"level":1,"text":"Accessing Objective-C Methods and Properties","type":"heading","anchor":"Accessing-Objective-C-Methods-and-Properties"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you use "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" as a concrete type, you have at your disposal"},{"type":"text","text":" "},{"type":"text","text":"every "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" method and property—that is, methods and properties"},{"type":"text","text":" "},{"type":"text","text":"imported from Objective-C or marked with the "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" attribute. Because"},{"type":"text","text":" "},{"type":"text","text":"Swift can’t guarantee at compile time that these methods and properties"},{"type":"text","text":" "},{"type":"text","text":"are actually available on an "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" instance’s underlying type, these"},{"type":"text","text":" "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" symbols are available as implicitly unwrapped optional methods and"},{"type":"text","text":" "},{"type":"text","text":"properties, respectively."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example defines an "},{"type":"codeVoice","code":"IntegerRef"},{"text":" type with an ","type":"text"},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" method named"},{"type":"text","text":" "},{"type":"codeVoice","code":"getIntegerValue()"},{"type":"text","text":"."}]},{"code":["class IntegerRef {","    let value: Int","    init(_ value: Int) {","        self.value = value","    }","","    @objc func getIntegerValue() -> Int {","        return value","    }","}","","func getObject() -> AnyObject {","    return IntegerRef(100)","}","","let obj: AnyObject = getObject()"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the example, "},{"type":"codeVoice","code":"obj"},{"type":"text","text":" has a static type of "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" and a dynamic type"},{"type":"text","text":" "},{"type":"text","text":"of "},{"code":"IntegerRef","type":"codeVoice"},{"type":"text","text":". You can use optional chaining to call the "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" method"},{"text":" ","type":"text"},{"code":"getIntegerValue()","type":"codeVoice"},{"text":" on ","type":"text"},{"type":"codeVoice","code":"obj"},{"type":"text","text":" safely. If you’re sure of the dynamic type of"},{"type":"text","text":" "},{"type":"codeVoice","code":"obj"},{"text":", you can call ","type":"text"},{"type":"codeVoice","code":"getIntegerValue()"},{"type":"text","text":" directly."}]},{"syntax":"swift","type":"codeListing","code":["let possibleValue = obj.getIntegerValue?()","print(possibleValue)","// Prints \"Optional(100)\"","","let certainValue = obj.getIntegerValue()","print(certainValue)","// Prints \"100\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the dynamic type of "},{"type":"codeVoice","code":"obj"},{"type":"text","text":" doesn’t implement a "},{"type":"codeVoice","code":"getIntegerValue()"},{"type":"text","text":" "},{"type":"text","text":"method, the system returns a runtime error when you initialize"},{"type":"text","text":" "},{"type":"codeVoice","code":"certainValue"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, if you need to test whether "},{"type":"codeVoice","code":"obj.getIntegerValue()"},{"type":"text","text":" exists,"},{"type":"text","text":" "},{"type":"text","text":"use optional binding before calling the method."}]},{"type":"codeListing","syntax":"swift","code":["if let f = obj.getIntegerValue {","    print(\"The value of 'obj' is \\(f())\")","} else {","    print(\"'obj' does not have a 'getIntegerValue()' method\")","}","// Prints \"The value of 'obj' is 100\""]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/anyobject"]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/AnyObject":{"identifier":"doc://com.apple.Swift/documentation/Swift/AnyObject","abstract":[{"type":"text","text":"The protocol to which all classes implicitly conform."}],"type":"topic","role":"symbol","url":"/documentation/swift/anyobject","navigatorTitle":[{"kind":"identifier","text":"AnyObject"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyObject"}],"title":"AnyObject"},"doc://com.apple.Swift/documentation/Swift/AnyClass":{"identifier":"doc://com.apple.Swift/documentation/Swift/AnyClass","abstract":[{"type":"text","text":"The protocol to which all class types implicitly conform."}],"type":"topic","role":"symbol","url":"/documentation/swift/anyclass","navigatorTitle":[{"kind":"identifier","text":"AnyClass"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyClass"}],"title":"AnyClass"}}}