{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyObject"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"You use "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" when you need the flexibility of an untyped object or"},{"type":"text","text":" "},{"type":"text","text":"when you use bridged Objective-C methods and properties that return an"},{"type":"text","text":" "},{"type":"text","text":"untyped result. "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" can be used as the concrete type for an"},{"type":"text","text":" "},{"type":"text","text":"instance of any class, class type, or class-only protocol. For example:"}],"type":"paragraph"},{"code":["class FloatRef {","    let value: Float","    init(_ value: Float) {","        self.value = value","    }","}","","let x = FloatRef(2.3)","let y: AnyObject = x","let z: AnyObject = FloatRef.self"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" can also be used as the concrete type for an instance of a type"},{"type":"text","text":" "},{"type":"text","text":"that bridges to an Objective-C class. Many value types in Swift bridge to"},{"text":" ","type":"text"},{"text":"Objective-C counterparts, like ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["let s: AnyObject = \"This is a bridged string.\" as NSString","print(s is NSString)","// Prints \"true\"","","let v: AnyObject = 100 as NSNumber","print(type(of: v))","// Prints \"__NSCFNumber\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The flexible behavior of the ","type":"text"},{"type":"codeVoice","code":"AnyObject"},{"text":" protocol is similar to","type":"text"},{"text":" ","type":"text"},{"text":"Objective-C’s ","type":"text"},{"type":"codeVoice","code":"id"},{"text":" type. For this reason, imported Objective-C types","type":"text"},{"text":" ","type":"text"},{"text":"frequently use ","type":"text"},{"type":"codeVoice","code":"AnyObject"},{"text":" as the type for properties, method parameters,","type":"text"},{"text":" ","type":"text"},{"text":"and return values.","type":"text"}]},{"text":"Casting AnyObject Instances to a Known Type","anchor":"Casting-AnyObject-Instances-to-a-Known-Type","level":1,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Objects with a concrete type of ","type":"text"},{"code":"AnyObject","type":"codeVoice"},{"text":" maintain a specific dynamic","type":"text"},{"text":" ","type":"text"},{"text":"type and can be cast to that type using one of the type-cast operators","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"as","type":"codeVoice"},{"text":", ","type":"text"},{"code":"as?","type":"codeVoice"},{"text":", or ","type":"text"},{"code":"as!","type":"codeVoice"},{"text":").","type":"text"}]},{"inlineContent":[{"text":"This example uses the conditional downcast operator (","type":"text"},{"code":"as?","type":"codeVoice"},{"text":") to","type":"text"},{"text":" ","type":"text"},{"text":"conditionally cast the ","type":"text"},{"code":"s","type":"codeVoice"},{"text":" constant declared above to an instance of","type":"text"},{"text":" ","type":"text"},{"text":"Swift’s ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" type.","type":"text"}],"type":"paragraph"},{"code":["if let message = s as? String {","    print(\"Successful cast to String: \\(message)\")","}","// Prints \"Successful cast to String: This is a bridged string.\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"If you have prior knowledge that an ","type":"text"},{"code":"AnyObject","type":"codeVoice"},{"text":" instance has a particular","type":"text"},{"text":" ","type":"text"},{"text":"type, you can use the unconditional downcast operator (","type":"text"},{"code":"as!","type":"codeVoice"},{"text":"). Performing","type":"text"},{"text":" ","type":"text"},{"text":"an invalid cast triggers a runtime error.","type":"text"}],"type":"paragraph"},{"code":["let message = s as! String","print(\"Successful cast to String: \\(message)\")","// Prints \"Successful cast to String: This is a bridged string.\"","","let badCase = v as! String","// Runtime error"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Casting is always safe in the context of a ","type":"text"},{"type":"codeVoice","code":"switch"},{"text":" statement.","type":"text"}],"type":"paragraph"},{"code":["let mixedArray: [AnyObject] = [s, v]","for object in mixedArray {","    switch object {","    case let x as String:","        print(\"'\\(x)' is a String\")","    default:","        print(\"'\\(object)' is not a String\")","    }","}","// Prints \"'This is a bridged string.' is a String\"","// Prints \"'100' is not a String\""],"type":"codeListing","syntax":"swift"},{"level":1,"anchor":"Accessing-Objective-C-Methods-and-Properties","text":"Accessing Objective-C Methods and Properties","type":"heading"},{"inlineContent":[{"type":"text","text":"When you use "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" as a concrete type, you have at your disposal"},{"text":" ","type":"text"},{"text":"every ","type":"text"},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" method and property—that is, methods and properties"},{"type":"text","text":" "},{"type":"text","text":"imported from Objective-C or marked with the "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" attribute. Because"},{"type":"text","text":" "},{"text":"Swift can’t guarantee at compile time that these methods and properties","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are actually available on an "},{"code":"AnyObject","type":"codeVoice"},{"type":"text","text":" instance’s underlying type, these"},{"type":"text","text":" "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" symbols are available as implicitly unwrapped optional methods and"},{"type":"text","text":" "},{"type":"text","text":"properties, respectively."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example defines an "},{"type":"codeVoice","code":"IntegerRef"},{"text":" type with an ","type":"text"},{"code":"@objc","type":"codeVoice"},{"text":" method named","type":"text"},{"text":" ","type":"text"},{"code":"getIntegerValue()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"codeListing","code":["class IntegerRef {","    let value: Int","    init(_ value: Int) {","        self.value = value","    }","","    @objc func getIntegerValue() -> Int {","        return value","    }","}","","func getObject() -> AnyObject {","    return IntegerRef(100)","}","","let obj: AnyObject = getObject()"],"syntax":"swift"},{"inlineContent":[{"text":"In the example, ","type":"text"},{"type":"codeVoice","code":"obj"},{"text":" has a static type of ","type":"text"},{"type":"codeVoice","code":"AnyObject"},{"text":" and a dynamic type","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"type":"codeVoice","code":"IntegerRef"},{"type":"text","text":". You can use optional chaining to call the "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" method"},{"type":"text","text":" "},{"code":"getIntegerValue()","type":"codeVoice"},{"text":" on ","type":"text"},{"type":"codeVoice","code":"obj"},{"type":"text","text":" safely. If you’re sure of the dynamic type of"},{"type":"text","text":" "},{"type":"codeVoice","code":"obj"},{"type":"text","text":", you can call "},{"type":"codeVoice","code":"getIntegerValue()"},{"type":"text","text":" directly."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let possibleValue = obj.getIntegerValue?()","print(possibleValue)","// Prints \"Optional(100)\"","","let certainValue = obj.getIntegerValue()","print(certainValue)","// Prints \"100\""]},{"inlineContent":[{"text":"If the dynamic type of ","type":"text"},{"code":"obj","type":"codeVoice"},{"text":" doesn’t implement a ","type":"text"},{"code":"getIntegerValue()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"method, the system returns a runtime error when you initialize"},{"type":"text","text":" "},{"type":"codeVoice","code":"certainValue"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, if you need to test whether "},{"code":"obj.getIntegerValue()","type":"codeVoice"},{"type":"text","text":" exists,"},{"type":"text","text":" "},{"type":"text","text":"use optional binding before calling the method."}]},{"syntax":"swift","type":"codeListing","code":["if let f = obj.getIntegerValue {","    print(\"The value of 'obj' is \\(f())\")","} else {","    print(\"'obj' does not have a 'getIntegerValue()' method\")","}","// Prints \"The value of 'obj' is 100\""]}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AnyObject","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"Swift"}],"role":"symbol","roleHeading":"Type Alias","title":"AnyObject","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyObject"}],"symbolKind":"typealias","navigatorTitle":[{"kind":"identifier","text":"AnyObject"}],"externalID":"s:s9AnyObjecta"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"variants":[{"paths":["/documentation/swift/anyobject"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"seeAlsoSections":[{"generated":true,"title":"Existential Types","anchor":"Existential-Types","identifiers":["doc://com.apple.Swift/documentation/Swift/AnyClass"]}],"abstract":[{"type":"text","text":"The protocol to which all classes implicitly conform."}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/AnyClass":{"url":"/documentation/swift/anyclass","type":"topic","title":"AnyClass","kind":"symbol","abstract":[{"type":"text","text":"The protocol to which all class types implicitly conform."}],"role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyClass"}],"navigatorTitle":[{"kind":"identifier","text":"AnyClass"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AnyClass"},"doc://com.apple.Swift/documentation/Swift/AnyObject":{"fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"AnyObject"}],"title":"AnyObject","type":"topic","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AnyObject","kind":"symbol","abstract":[{"text":"The protocol to which all classes implicitly conform.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"AnyObject"}],"url":"/documentation/swift/anyobject"}}}