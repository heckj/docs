{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/AnyRandomAccessCollection/subscript(_:)-9umyp"},"abstract":[{"text":"Accesses the contiguous subrange of the collection’s elements specified","type":"text"},{"text":" ","type":"text"},{"text":"by a range expression.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">("},{"kind":"internalParam","text":"r"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"R","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","text":"SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"R"},{"kind":"text","text":" : "},{"identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression","kind":"typeIdentifier","text":"RangeExpression","preciseIdentifier":"s:SX"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","text":"Index","preciseIdentifier":"s:Sl5IndexQa"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"R"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound","text":"Bound","preciseIdentifier":"s:SX5BoundQa"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The range expression is converted to a concrete subrange relative to this","type":"text"},{"text":" ","type":"text"},{"text":"collection. For example, using a ","type":"text"},{"type":"codeVoice","code":"PartialRangeFrom"},{"text":" range expression","type":"text"},{"text":" ","type":"text"},{"text":"with an array accesses the subrange from the start of the range","type":"text"},{"text":" ","type":"text"},{"text":"expression until the end of the array.","type":"text"}]},{"type":"codeListing","code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2...]","print(streetsSlice)","// [\"Channing\", \"Douglas\", \"Evarts\"]"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The accessed slice uses the same indices for the same elements as the","type":"text"},{"text":" ","type":"text"},{"text":"original collection uses. This example searches ","type":"text"},{"type":"codeVoice","code":"streetsSlice"},{"text":" for one","type":"text"},{"text":" ","type":"text"},{"text":"of the strings in the slice, and then uses that index in the original","type":"text"},{"text":" ","type":"text"},{"text":"array.","type":"text"}]},{"code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always use the slice’s "},{"type":"codeVoice","code":"startIndex"},{"type":"text","text":" property instead of assuming that its"},{"text":" ","type":"text"},{"type":"text","text":"indices start at a particular value. Attempting to access an element by"},{"text":" ","type":"text"},{"text":"using an index outside the bounds of the slice’s indices may result in a","type":"text"},{"text":" ","type":"text"},{"text":"runtime error, even if that index is valid for the original collection.","type":"text"}]},{"type":"codeListing","co