neContent":[{"type":"text","text":"n"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the length of the sequence."}],"type":"paragraph"}],"name":"Complexity"}]}],"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AnySequence"]]},"abstract":[{"type":"text","text":"Returns the longest possible subsequences of the sequence, in order,"},{"type":"text","text":" "},{"type":"text","text":"around elements equal to the given element."}],"references":{"doc://com.apple.Swift/documentation/Swift/Bool":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","type":"topic","title":"Bool","kind":"symbol","url":"/documentation/swift/bool","navigatorTitle":[{"kind":"identifier","text":"Bool"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Bool"}],"abstract":[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/Int":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Int","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Int"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Int","url":"/documentation/swift/int","kind":"symbol","abstract":[{"type":"text","text":"A signed integer value type."}],"title":"Int"},"doc://com.apple.Swift/documentation/Swift/AnySequence":{"identifier":"doc://com.apple.Swift/docu