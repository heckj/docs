{"abstract":[{"type":"text","text":"Use macros to generate repetitive code at compile time."}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Swift macros help you avoid writing repetitive code in Swift","type":"text"},{"text":" ","type":"text"},{"text":"by generating that part of your source code at compile time.","type":"text"},{"text":" ","type":"text"},{"text":"Calling a macro is always additive:","type":"text"},{"text":" ","type":"text"},{"text":"The macro adds new code alongside the code that you wrote,","type":"text"},{"text":" ","type":"text"},{"text":"but never modifies or deletes code that’s already part of your project.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Many libraries provide macros,"},{"type":"text","text":" "},{"type":"text","text":"including the Swift standard library and many frameworks."},{"type":"text","text":" "},{"type":"text","text":"You can also write your own macros."}]},{"type":"paragraph","inlineContent":[{"text":"Because macros generate Swift code,","type":"text"},{"text":" ","type":"text"},{"text":"you use the same tools for development and debugging,","type":"text"},{"text":" ","type":"text"},{"text":"regardless of whether your code uses macros.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"macro-expansion"}]},{"type":"heading","level":3,"text":"Call a Macro","anchor":"Call-a-Macro"},{"type":"paragraph","inlineContent":[{"text":"The syntax you use to call a macro varies slightly,","type":"text"},{"text":" ","type":"text"},{"text":"depending on whether you attach the macro to a declaration.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To attach a macro to a declaration,"},{"type":"text","text":" "},{"type":"text","text":"write an at sign ("},{"code":"@","type":"codeVoice"},{"type":"text","text":") before the macro’s name"},{"type":"text","text":" "},{"type":"text","text":"and write any macro arguments after its name."},{"type":"text","text":" "},{"type":"text","text":"This syntax is the same as writing an attribute."},{"type":"text","text":" "},{"type":"text","text":"For example:"}]},{"syntax":"swift","code":["@Observable","public final class MyObject {","    public var someProperty: String = \"\"","    public var someOtherProperty: Int = 0","    fileprivate var somePrivateProperty: Int = 1","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"A macro that’s attached to a declaration","type":"text"},{"text":" ","type":"text"},{"text":"generates code","type":"text"},{"text":" ","type":"text"},{"text":"and adds that code to the declaration.","type":"text"},{"text":" ","type":"text"},{"text":"For example,","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","isActive":true,"type":"reference"},{"text":" macro in the code above","type":"text"},{"text":" ","type":"text"},{"text":"adds additional members to the ","type":"text"},{"code":"MyObject","type":"codeVoice"},{"text":" class","type":"text"},{"text":" ","type":"text"},{"text":"so it implements the ","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","isActive":true,"type":"reference"},{"text":" protocol,","type":"text"},{"text":" ","type":"text"},{"text":"and marks ","type":"text"},{"code":"MyObject","type":"codeVoice"},{"text":" as conforming to ","type":"text"},{"code":"Observable","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To call a macro without attaching it to a declaration,"},{"type":"text","text":" "},{"type":"text","text":"write a number sign ("},{"type":"codeVoice","code":"#"},{"type":"text","text":") before the macro’s name"},{"type":"text","text":" "},{"type":"text","text":"and write any macro arguments after its name."},{"type":"text","text":" "},{"type":"text","text":"This syntax is the same as "},{"type":"codeVoice","code":"#if"},{"type":"text","text":" and other compile-time operations."},{"type":"text","text":" "},{"type":"text","text":"For example:"}]},{"type":"codeListing","syntax":"swift","code":["let messagePredicate = #Predicate<Message> { message in","    message.recipient == \"John Appleseed\"","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A macro that isn’t attached to a declaration"},{"type":"text","text":" "},{"type":"text","text":"generates code and adds that code"},{"type":"text","text":" "},{"type":"text","text":"in the location where where you call the macro."},{"type":"text","text":" "},{"type":"text","text":"For example,"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"Predicate"},{"type":"text","text":" macro in the code above creates an instance of the"},{"type":"text","text":" "},{"type":"text","text":"Swift Foundation "},{"type":"codeVoice","code":"Predicate"},{"type":"text","text":" structure."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more information,"},{"type":"text","text":" "},{"type":"text","text":"see "},{"identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros","isActive":true,"type":"reference"},{"type":"text","text":" in "},{"identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language","type":"reference","isActive":true},{"type":"text","text":"."}]},{"level":3,"text":"Inspect an Expanded Macro","anchor":"Inspect-an-Expanded-Macro","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"When you build your project,","type":"text"},{"text":" ","type":"text"},{"text":"Swift reads your code and finds the places where you call a macro.","type":"text"},{"text":" ","type":"text"},{"text":"Swift then calls the implementation of each macro,","type":"text"},{"text":" ","type":"text"},{"text":"to expand the code.","type":"text"},{"text":" ","type":"text"},{"text":"Finally, Swift builds your project as usual,","type":"text"},{"text":" ","type":"text"},{"text":"including the generated code.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To view the code that a macro generated,"},{"type":"text","text":" "},{"type":"text","text":"click on the code where you call the macro in Xcode,"},{"type":"text","text":" "},{"type":"text","text":"then choose Editor > Expand Macro."},{"type":"text","text":" "},{"type":"text","text":"You can read the expanded code"},{"type":"text","text":" "},{"type":"text","text":"to help you understand details about the macro’s behavior,"},{"type":"text","text":" "},{"type":"text","text":"and you can use the expanded code"},{"type":"text","text":" "},{"type":"text","text":"to help you debug code that uses macros."},{"type":"text","text":" "},{"type":"text","text":"For example,"},{"type":"text","text":" "},{"text":"you can set breakpoints inside code generated by a macro.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/applying-macros"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/applying-macros","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"Swift"}],"roleHeading":"Article","role":"article","title":"Applying Macros"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","doc:\/\/com.apple.Swift\/documentation\/Swift\/macros"]]},"kind":"article","references":{"doc://com.apple.Swift/documentation/Swift/swift-standard-library":{"url":"\/documentation\/swift\/swift-standard-library","role":"collectionGroup","title":"Swift Standard Library","type":"topic","kind":"article","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","abstract":[{"text":"Solve complex problems and write high-performance, readable code.","type":"text"}]},"https://docs.swift.org/swift-book/documentation/the-swift-programming-language":{"url":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language","titleInlineContent":[{"text":"The Swift Programming Language","type":"text"}],"type":"link","title":"The Swift Programming Language"},"doc://com.apple.Swift/documentation/Swift/macros":{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/macros","type":"topic","url":"\/documentation\/swift\/macros","abstract":[{"text":"Generate boilerplate code and perform other compile-time operations.","type":"text"}],"title":"Macros","role":"collectionGroup","kind":"article"},"doc://com.apple.Swift/documentation/Observation/Observable":{"title":"Observable","abstract":[{"text":"A type that emits notifications to observers when underlying data changes.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","url":"\/documentation\/observation\/observable","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Observable","kind":"identifier"}],"navigatorTitle":[{"text":"Observable","kind":"identifier"}],"type":"topic"},"macro-expansion":{"identifier":"macro-expansion","alt":"A diagram showing an overview of macro expansion. On the left, a stylized representation of Swift code. On the right, the same code with several lines added by the macro.","type":"image","variants":[{"traits":["2x","light"],"url":"\/images\/com.apple.Swift\/macro-expansion@2x.png"},{"traits":["2x","dark"],"url":"\/images\/com.apple.Swift\/macro-expansion~dark@2x.png"}]},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"\/documentation\/swift","role":"collection","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift"},"doc://com.apple.Swift/documentation/Observation/Observable()":{"abstract":[{"type":"text","text":"Defines and implements conformance of the Observable protocol."}],"type":"topic","title":"Observable()","fragments":[{"kind":"keyword","text":"macro"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observable"},{"kind":"text","text":"()"}],"kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","role":"symbol","url":"\/documentation\/observation\/observable()"},"https://docs.swift.org/swift-book/documentation/the-swift-programming-language/macros":{"type":"link","titleInlineContent":[{"text":"Macros","type":"text"}],"identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros","url":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros","title":"Macros"}}}