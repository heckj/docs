{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/applying-macros"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/applying-macros"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"metadata":{"role":"article","roleHeading":"Article","title":"Applying Macros","modules":[{"name":"Swift"}]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"Swift macros help you avoid writing repetitive code in Swift"},{"type":"text","text":" "},{"type":"text","text":"by generating that part of your source code at compile time."},{"type":"text","text":" "},{"type":"text","text":"Calling a macro is always additive:"},{"type":"text","text":" "},{"type":"text","text":"The macro adds new code alongside the code that you wrote,"},{"type":"text","text":" "},{"type":"text","text":"but never modifies or deletes code that’s already part of your project."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Many libraries provide macros,"},{"type":"text","text":" "},{"type":"text","text":"including the Swift standard library and many frameworks."},{"type":"text","text":" "},{"type":"text","text":"You can also write your own macros."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because macros generate Swift code,"},{"type":"text","text":" "},{"type":"text","text":"you use the same tools for development and debugging,"},{"type":"text","text":" "},{"type":"text","text":"regardless of whether your code uses macros."}],"type":"paragraph"},{"inlineContent":[{"identifier":"macro-expansion","type":"image"}],"type":"paragraph"},{"anchor":"Call-a-Macro","level":3,"type":"heading","text":"Call a Macro"},{"inlineContent":[{"type":"text","text":"The syntax you use to call a macro varies slightly,"},{"type":"text","text":" "},{"type":"text","text":"depending on whether you attach the macro to a declaration."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To attach a macro to a declaration,"},{"type":"text","text":" "},{"type":"text","text":"write an at sign ("},{"code":"@","type":"codeVoice"},{"type":"text","text":") before the macro’s name"},{"type":"text","text":" "},{"type":"text","text":"and write any macro arguments after its name."},{"type":"text","text":" "},{"type":"text","text":"This syntax is the same as writing an attribute."},{"type":"text","text":" "},{"type":"text","text":"For example:"}],"type":"paragraph"},{"code":["@Observable","public final class MyObject {","    public var someProperty: String = \"\"","    public var someOtherProperty: Int = 0","    fileprivate var somePrivateProperty: Int = 1","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"A macro that’s attached to a declaration"},{"type":"text","text":" "},{"type":"text","text":"generates code"},{"type":"text","text":" "},{"type":"text","text":"and adds that code to the declaration."},{"type":"text","text":" "},{"type":"text","text":"For example,"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","isActive":true},{"type":"text","text":" macro in the code above"},{"type":"text","text":" "},{"type":"text","text":"adds additional members to the "},{"type":"codeVoice","code":"MyObject"},{"type":"text","text":" class"},{"type":"text","text":" "},{"type":"text","text":"so it implements the "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","isActive":true},{"type":"text","text":" protocol,"},{"type":"text","text":" "},{"type":"text","text":"and marks "},{"type":"codeVoice","code":"MyObject"},{"type":"text","text":" as conforming to "},{"code":"Observable","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To call a macro without attaching it to a declaration,"},{"type":"text","text":" "},{"type":"text","text":"write a number sign ("},{"type":"codeVoice","code":"#"},{"type":"text","text":") before the macro’s name"},{"type":"text","text":" "},{"type":"text","text":"and write any macro arguments after its name."},{"type":"text","text":" "},{"type":"text","text":"This syntax is the same as "},{"code":"#if","type":"codeVoice"},{"type":"text","text":" and other compile-time operations."},{"type":"text","text":" "},{"type":"text","text":"For example:"}],"type":"paragraph"},{"type":"codeListing","code":["let messagePredicate = #Predicate<Message> { message in","    message.recipient == \"John Appleseed\"","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"A macro that isn’t attached to a declaration"},{"type":"text","text":" "},{"type":"text","text":"generates code and adds that code"},{"type":"text","text":" "},{"type":"text","text":"in the location where where you call the macro."},{"type":"text","text":" "},{"type":"text","text":"For example,"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"Predicate"},{"type":"text","text":" macro in the code above creates an instance of the"},{"type":"text","text":" "},{"type":"text","text":"Swift Foundation "},{"type":"codeVoice","code":"Predicate"},{"type":"text","text":" structure."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more information,"},{"type":"text","text":" "},{"type":"text","text":"see "},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros"},{"type":"text","text":" in "},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language"},{"type":"text","text":"."}]},{"type":"heading","level":3,"anchor":"Inspect-an-Expanded-Macro","text":"Inspect an Expanded Macro"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you build your project,"},{"type":"text","text":" "},{"type":"text","text":"Swift reads your code and finds the places where you call a macro."},{"type":"text","text":" "},{"type":"text","text":"Swift then calls the implementation of each macro,"},{"type":"text","text":" "},{"type":"text","text":"to expand the code."},{"type":"text","text":" "},{"type":"text","text":"Finally, Swift builds your project as usual,"},{"type":"text","text":" "},{"type":"text","text":"including the generated code."}]},{"inlineContent":[{"type":"text","text":"To view the code that a macro generated,"},{"type":"text","text":" "},{"type":"text","text":"click on the code where you call the macro in Xcode,"},{"type":"text","text":" "},{"type":"text","text":"then choose Editor > Expand Macro."},{"type":"text","text":" "},{"type":"text","text":"You can read the expanded code"},{"type":"text","text":" "},{"type":"text","text":"to help you understand details about the macro’s behavior,"},{"type":"text","text":" "},{"type":"text","text":"and you can use the expanded code"},{"type":"text","text":" "},{"type":"text","text":"to help you debug code that uses macros."},{"type":"text","text":" "},{"type":"text","text":"For example,"},{"type":"text","text":" "},{"type":"text","text":"you can set breakpoints inside code generated by a macro."}],"type":"paragraph"}]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","doc:\/\/com.apple.Swift\/documentation\/Swift\/macros"]]},"abstract":[{"type":"text","text":"Use macros to generate repetitive code at compile time."}],"references":{"doc://com.apple.Swift/documentation/Swift/swift-standard-library":{"type":"topic","abstract":[{"text":"Solve complex problems and write high-performance, readable code.","type":"text"}],"title":"Swift Standard Library","role":"collectionGroup","url":"\/documentation\/swift\/swift-standard-library","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","kind":"article"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","url":"\/documentation\/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Observation/Observable()":{"type":"topic","title":"Observable()","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","role":"symbol","abstract":[{"type":"text","text":"Defines and implements conformance of the Observable protocol."}],"url":"\/documentation\/observation\/observable()","fragments":[{"kind":"keyword","text":"macro"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observable"},{"kind":"text","text":"()"}]},"https://docs.swift.org/swift-book/documentation/the-swift-programming-language":{"identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language","type":"link","title":"The Swift Programming Language","titleInlineContent":[{"type":"text","text":"The Swift Programming Language"}],"url":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language"},"https://docs.swift.org/swift-book/documentation/the-swift-programming-language/macros":{"identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros","type":"link","title":"Macros","titleInlineContent":[{"type":"text","text":"Macros"}],"url":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros"},"doc://com.apple.Swift/documentation/Swift/macros":{"type":"topic","abstract":[{"type":"text","text":"Generate boilerplate code and perform other compile-time operations."}],"title":"Macros","role":"collectionGroup","url":"\/documentation\/swift\/macros","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/macros","kind":"article"},"doc://com.apple.Swift/documentation/Observation/Observable":{"navigatorTitle":[{"kind":"identifier","text":"Observable"}],"type":"topic","title":"Observable","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","role":"symbol","abstract":[{"type":"text","text":"A type that emits notifications to observers when underlying data changes."}],"url":"\/documentation\/observation\/observable","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observable"}]},"macro-expansion":{"alt":"A diagram showing an overview of macro expansion. On the left, a stylized representation of Swift code. On the right, the same code with several lines added by the macro.","identifier":"macro-expansion","type":"image","variants":[{"url":"\/images\/com.apple.Swift\/macro-expansion@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/macro-expansion~dark@2x.png","traits":["2x","dark"]}]}}}