type":"text","text":"copies its elements into the new storage. The new storage is a multiple"},{"type":"text","text":" "},{"type":"text","text":"of the old storage’s size. This exponential growth strategy means that"},{"type":"text","text":" "},{"type":"text","text":"appending an element happens in constant time, averaging the performance"},{"type":"text","text":" "},{"type":"text","text":"of many append operations. Append operations that trigger reallocation"},{"type":"text","text":" "},{"text":"have a performance cost, but they occur less and less often as the array","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"grows larger."}]},{"type":"paragraph","inlineContent":[{"text":"The following example creates an array of integers from an array literal,","type":"text"},{"text":" ","type":"text"},{"text":"then appends the elements of another collection. Before appending, the","type":"text"},{"type":"text","text":" "},{"text":"array allocates new storage that is large enough store the resulting","type":"text"},{"type":"text","text":" "},{"type":"text","text":"elements."}]},{"type":"codeListing","syntax":"swift","code":["var numbers = [10, 20, 30, 40, 50]","// numbers.count == 5","// numbers.capacity == 5","","numbers.append(contentsOf: stride(from: 60, through: 100, by: 10))","// numbers.count == 10","// numbers.capacity == 10"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/array/capacity"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://com.apple.Swift/documentation/Swift/Array":{"navigatorTitle":[{"text":"Array","kind":"identifier"}],"url":"/documentation/swift/array","abstract":[{"text":"An ordered, random-access collection.","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Array","type":"topic","title":"Array","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Array","kind":"identi