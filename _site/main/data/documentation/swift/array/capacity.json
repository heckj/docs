{"abstract":[{"type":"text","text":"The total number of elements that the array can contain without"},{"type":"text","text":" "},{"type":"text","text":"allocating new storage."}],"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/Array/isEmpty","doc://com.apple.Swift/documentation/Swift/Array/count"],"anchor":"Inspecting-an-Array","title":"Inspecting an Array","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"capacity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Int","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Every array reserves a specific amount of memory to hold its contents."},{"type":"text","text":" "},{"type":"text","text":"When you add elements to an array and that array begins to exceed its"},{"type":"text","text":" "},{"type":"text","text":"reserved capacity, the array allocates a larger region of memory and"},{"type":"text","text":" "},{"type":"text","text":"copies its elements into the new storage. The new storage is a multiple"},{"type":"text","text":" "},{"type":"text","text":"of the old storage’s size. This exponential growth strategy means that"},{"type":"text","text":" "},{"type":"text","text":"appending an element happens in constant time, averaging the performance"},{"type":"text","text":" "},{"type":"text","text":"of many append operations. Append operations that trigger reallocation"},{"type":"text","text":" "},{"type":"text","text":"have a performance cost, but they occur less and less often as the array"},{"type":"text","text":" "},{"type":"text","text":"grows larger."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example creates an array of integers from an array literal,"},{"type":"text","text":" "},{"type":"text","text":"then appends the elements of another collection. Before appending, the"},{"type":"text","text":" "},{"type":"text","text":"array allocates new storage that is large enough store the resulting"},{"type":"text","text":" "},{"type":"text","text":"elements."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["var numbers = [10, 20, 30, 40, 50]","// numbers.count == 5","// numbers.capacity == 5","","numbers.append(contentsOf: stride(from: 60, through: 100, by: 10))","// numbers.count == 10","// numbers.capacity == 10"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/array/capacity"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Array/capacity","interfaceLanguage":"swift"},"metadata":{"title":"capacity","modules":[{"name":"Swift"}],"roleHeading":"Instance Property","symbolKind":"property","role":"symbol","extendedModule":"Swift","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"capacity","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"externalID":"s:Sa8capacitySivp"},"sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Array"]]},"kind":"symbol","references":{"doc://com.apple.Swift/documentation/Swift/Array":{"navigatorTitle":[{"kind":"identifier","text":"Array"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Array","abstract":[{"text":"An ordered, random-access collection.","type":"text"}],"role":"symbol","title":"Array","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Array"}],"url":"/documentation/swift/array","type":