{"abstract":[{"type":"text","text":"Creates an array containing the elements of a sequence."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/array/init(_:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Array"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"init","kind":"keyword"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"s","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"S","preciseIdentifier":"s:SaySayxGqd__c7ElementQyd__RszSTRd__lufc1SL_qd__mfp","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"typeIdentifier"},{"text":" == ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":".","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","text":"Element","preciseIdentifier":"s:ST7ElementQa","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence","preciseIdentifier":"s:ST","text":"Sequence","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The sequence of elements to turn into an array.","type":"text"}],"type":"paragraph"}],"name":"s"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"You can use this initializer to create an array from any other type that","type":"text"},{"text":" ","type":"text"},{"text":"conforms to the ","type":"text"},{"code":"Sequence","type":"codeVoice"},{"text":" protocol. For example, you might want to","type":"text"},{"text":" ","type":"text"},{"text":"create an array with the integers from 1 through 7. Use this initializer","type":"text"},{"text":" ","type":"text"},{"text":"around a range instead of typing all those numbers in an array literal.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let numbers = Array(1...7)","print(numbers)","// Prints \"[1, 2, 3, 4, 5, 6, 7]\""]},{"inlineContent":[{"type":"text","text":"You can also use this initializer to convert a complex sequence or"},{"type":"text","text":" "},{"type":"text","text":"collection type back to an array. For example, the "},{"code":"keys","type":"codeVoice"},{"type":"text","text":" property of"},{"type":"text","text":" "},{"type":"text","text":"a dictionary isn’t an array with its own storage, it’s a collection"},{"type":"text","text":" "},{"type":"text","text":"that maps its elements from the dictionary only when they’re"},{"type":"text","text":" "},{"type":"text","text":"accessed, saving the time and space needed to allocate an array. If"},{"type":"text","text":" "},{"text":"you need to pass those keys to a method that takes an array, however,","type":"text"},{"text":" ","type":"text"},{"text":"use this initializer to convert that list from its type of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"LazyMapCollection<Dictionary<String, Int>, Int>"},{"type":"text","text":" to a simple"},{"type":"text","text":" "},{"type":"codeVoice","code":"[String]"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func cacheImages(withNames names: [String]) {","    // custom image loading and caching"," }","","let namedHues: [String: Int] = [\"Vermillion\": 18, \"Magenta\": 302,","        \"Gold\": 50, \"Cerise\": 320]","let colorNames = Array(namedHues.keys)","cacheImages(withNames: colorNames)","","print(colorNames)","// Prints \"[\"Gold\", \"Cerise\", \"Magenta\", \"Vermillion\"]\""]}]}],"identifier":{"url":"doc