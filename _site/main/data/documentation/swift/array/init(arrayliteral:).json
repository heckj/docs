":"Swift","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"arrayLiteral","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sa7Elementxmfp","text":"Element","kind":"typeIdentifier"},{"text":"...)","kind":"text"}],"externalID":"s:Sa12arrayLiteralSayxGxd_tcfc"},"sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Array"]]},"kind":"symbol","references":{"doc://com.apple.Swift/documentation/Swift/Array":{"navigatorTitle":[{"kind":"identifier","text":"Array"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Array","abstract":[{"text":"An ordered, random-access collection.","type":"text"}],"role":"symbol","title":"Array","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Array"}],"url":"/documentation/swift/array","type":"topic"},"doc://com.apple.Swift/documentation/Swift/Array/init(arrayLiteral:)":{"role":"symbol","url":"/documentation/swift/array/init(arrayliteral:)","identifier":"doc://com.apple.Swift/documentation/Swift/Array/init(arrayLiteral:)","kind":"symbol","type":"topic","title":"init(arrayLiteral:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"arrayLiteral","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Element","preciseIdentifier":"s:Sa7Elementxmfp","kind":"typeIdentifier"},{"kind":"text","text":"...)"}],"abstract":[{"type":"text","text":"Creates an array from the given array literal."}]},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"}}}