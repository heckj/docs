{"seeAlsoSections":[{"title":"Reordering an Array’s Elements","identifiers":["doc://com.apple.Swift/documentation/Swift/Array/sort()","doc://com.apple.Swift/documentation/Swift/Array/sort(by:)","doc://com.apple.Swift/documentation/Swift/Array/sorted()","doc://com.apple.Swift/documentation/Swift/Array/sorted(by:)","doc://com.apple.Swift/documentation/Swift/Array/reverse()","doc://com.apple.Swift/documentation/Swift/Array/reversed()","doc://com.apple.Swift/documentation/Swift/Array/shuffle()","doc://com.apple.Swift/documentation/Swift/Array/shuffle(using:)","doc://com.apple.Swift/documentation/Swift/Array/shuffled()","doc://com.apple.Swift/documentation/Swift/Array/shuffled(using:)","doc://com.apple.Swift/documentation/Swift/Array/swapAt(_:_:)"],"generated":true,"anchor":"Reordering-an-Arrays-Elements"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"partition"},{"kind":"text","text":"("},{"text":"by","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"belongsInSecondPartition","kind":"internalParam"},{"text":": (","kind":"text"},{"text":"Element","identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Element","kind":"typeIdentifier","preciseIdentifier":"s:SM7ElementQa"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Index","identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Index","kind":"typeIdentifier","preciseIdentifier":"s:SM5IndexQa"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A predicate used to partition"},{"type":"text","text":" "},{"type":"text","text":"the collection. All elements satisfying this predicate are ordered"},{"type":"text","text":" "},{"type":"text","text":"after all elements not satisfying it."}],"type":"paragraph"}],"name":"belongsInSecondPartition"}]},{"kind":"content","content":[{"level":2,"anchor":"return-value","type":"heading","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The index of the first element in the reordered collection"},{"type":"text","text":" "},{"type":"text","text":"that matches "},{"code":"belongsInSecondPartition","type":"codeVoice"},{"type":"text","text":". If no elements in the"},{"type":"text","text":" "},{"type":"text","text":"collection match "},{"code":"belongsInSecondPartition","type":"codeVoice"},{"type":"text","text":", the returned index is"},{"text":" ","type":"text"},{"text":"equal to the collection’s ","type":"text"},{"code":"endIndex","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"After partitioning a collection, there is a pivot index "},{"code":"p","type":"codeVoice"},{"type":"text","text":" where"},{"type":"text","text":" "},{"type":"text","text":"no element before "},{"code":"p","type":"codeVoice"},{"type":"text","text":" satisfies the "},{"code":"belongsInSecondPartition","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"predicate and every element at or after "},{"code":"p","type":"codeVoice"},{"type":"text","text":" satisfies"},{"type":"text","text":" "},{"code":"belongsInSecondPartition","type":"codeVoice"},{"text":". This operation isn’t guaranteed to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stable, so the relative ordering of elements within the partitions might"},{"type":"text","text":" "},{"type":"text","text":"change."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the following example, an array of numbers is partitioned by a"},{"type":"text","text":" "},{"text":"predicate that matches elements greater than 30.","type":"text"}],"type":"paragraph"},{"code":["var numbers = [30, 40, 20, 30, 30, 60, 10]","let p = numbers.partition(by: { $0 > 30 })","// p == 5","// numbers == [30, 10, 20, 30, 30, 60, 40]"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"numbers"},{"type":"text","text":" array is now arranged in two partitions. The first"},{"type":"text","text":" "},{"type":"text","text":"partition, "},{"type":"codeVoice","code":"numbers[..<p]"},{"text":", is made up of the elements that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are not greater than 30. The second partition, "},{"type":"codeVoice","code":"numbers[p...]"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"is made up of the elements that "},{"type":"emphasis","inlineContent":[{"type":"text","text":"are"}]},{"text":" greater than 30.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let first = numbers[..<p]","// first == [30, 10, 20, 30, 30]","let second = numbers[p...]","// second == [60, 40]"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the order of elements in both partitions changed."},{"type":"text","text":" "},{"text":"That is, ","type":"text"},{"code":"40","type":"codeVoice"},{"type":"text","text":" appears before "},{"type":"codeVoice","code":"60"},{"type":"text","text":" in the original collection,"},{"type":"text","text":" "},{"type":"text","text":"but, after calling "},{"type":"codeVoice","code":"partition(by:)"},{"type":"text","text":", "},{"type":"codeVoice","code":"60"},{"type":"text","text":" appears before "},{"type":"codeVoice","code":"40"},{"type":"text","text":"."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"type":