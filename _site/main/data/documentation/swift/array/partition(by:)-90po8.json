{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Array"]]},"sections":[],"metadata":{"symbolKind":"method","modules":[{"name":"Swift"}],"role":"symbol","extendedModule":"Swift","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"partition"},{"kind":"text","text":"("},{"kind":"externalParam","text":"by"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","preciseIdentifier":"s:SM7ElementQa","text":"Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":") "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Index","preciseIdentifier":"s:SM5IndexQa"}],"roleHeading":"Instance Method","title":"partition(by:)","externalID":"s:SMsE9partition2by5IndexQzSb7ElementQzKXE_tKF::SYNTHESIZED::s:Sa"},"abstract":[{"type":"text","text":"Reorders the elements of the collection such that all the elements"},{"type":"text","text":" "},{"type":"text","text":"that match the given predicate are after all the elements that don’t"},{"type":"text","text":" "},{"type":"text","text":"match."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"mutating"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"partition"},{"kind":"text","text":"("},{"kind":"externalParam","text":"by"},{"kind":"text","text":" "},{"kind":"internalParam","text":"belongsInSecondPartition"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:SM7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Element"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Bool"},{"text":") ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Index","preciseIdentifier":"s:SM5IndexQa","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Index"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A predicate used to partition"},{"type":"text","text":" "},{"type":"text","text":"the collection. All elements satisfying this predicate are ordered"},{"type":"text","text":" "},{"type":"text","text":"after all elements not satisfying it."}]}],"name":"belongsInSecondPartition"}],"kind":"parameters"},{"content":[{"anchor":"return-value","level":2,"type":"heading","text":"Return Value"},{"inlineContent":[{"type":"text","text":"The index of the first element in the reordered collection"},{"type":"text","text":" "},{"type":"text","text":"that matches "},{"type":"codeVoice","code":"belongsInSecondPartition"},{"type":"text","text":". If no elements in the"},{"type":"text","text":" "},{"type":"text","text":"collection match "},{"code":"belongsInSecondPartition","type":"codeVoice"},{"type":"text","text":", the returned index is"},{"type":"text","text":" "},{"type":"text","text":"equal to the collection’s "},{"code":"endIndex","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"After partitioning a collection, there is a pivot index "},{"type":"codeVoice","code":"p"},{"type":"text","text":" where"},{"type":"text","text":" "},{"type":"text","text":"no element before "},{"type":"codeVoice","code":"p"},{"type":"text","text":" satisfies the "},{"type":"codeVoice","code":"belongsInSecondPartition"},{"type":"text","text":" "},{"type":"text","text":"predicate and every element at or after "},{"type":"codeVoice","code":"p"},{"type":"text","text":" satisfies"},{"type":"text","text":" "},{"type":"codeVoice","code":"belongsInSecondPartition"},{"type":"text","text":". This operation isn’t guaranteed to be"},{"type":"text","text":" "},{"type":"text","text":"stable, so the relative ordering of elements within the partitions might"},{"type":"text","text":" "},{"type":"text","text":"change."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the following example, an array of numbers is partitioned by a"},{"type":"text","text":" "},{"type":"text","text":"predicate that matches elements greater than 30."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var numbers = [30, 40, 20, 30, 30, 60, 10]","let p = numbers.partition(by: { $0 > 30 })","// p == 5","// numbers == [30, 10, 20, 30, 30, 60, 40]"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"numbers","type":"codeVoice"},{"text":" array is now arranged in two partitions. The first","type":"text"},{"text":" ","type":"text"},{"text":"partition, ","type":"text"},{"code":"numbers[..<p]","type":"codeVoice"},{"text":", is made up of the elements that","type":"text"},{"text":" ","type":"text"},{"text":"are not greater than 30. The second partition, ","type":"text"},{"code":"numbers[p...]","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"is made up of the elements that ","type":"text"},{"inlineContent":[{"type":"text","text":"are"}],"type":"emphasis"},{"text":" greater than 30.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let first = numbers[..<p]","// first == [30, 10, 20, 30, 30]","let second = numbers[p...]","// second == [60, 40]"]},{"type":"paragraph","inlineContent":[{"text":"Note that the order of elements in both partitions changed.","type":"text"},{"text":" ","type":"text"},{"text":"That is, ","type":"text"},{"code":"40","type":"codeVoice"},{"text":" appears before ","type":"text"},{"code":"60","type":"codeVoice"},{"text":" in the original collection,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"but, after calling "},{"code":"partition(by:)","type":"codeVoice"},{"type":"text","text":", "},{"code":"60","type":"codeVoice"},{"type":"text","text":" appears before "},{"code":"40","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"aside","style":"note","name":"Complexity","content":[{"inlineContent":[{"type":"text","text":"O("},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the length of the collection."}],"type":"paragraph"}]}]}],"kind":"symbol","variants":[{"paths":["/documentation/swift/array/partition(by:)-90po8"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Array/partition(by:)-90po8"},"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/Array/sort()","doc://com.apple.Swift/documentation/Swift/Array/sort(by:)","doc://com.apple.Swift/documentation/Swift/Array/sorted()","doc://com.apple.Swift/documentation/Swift/Array/sorted(by:)","doc://com.apple.Swift/documentation/Swift/Array/reverse()","doc://com.apple.Swift/documentation/Swift/Array/reversed()","doc://com.apple.Swift/documentation/Swift/Array/shuffle()","doc://com.apple.Swift/documentation/Swift/Array/shuffle(using:)","doc://com.apple.Swift/documentation/Swift/Array/shuffled()","doc://com.apple.Swift/documentation/Swift/Array/shuffled(using:)","doc://com.apple.Swift/documentation/Swift/Array/swapAt(_:_:)"],"anchor":"Reordering-an-Arrays-Elements","title":"Reordering an Array’s Elements","generated":true}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.apple.Swift/documentation/Swift/Array/shuffle(using:)":{"url":"/documentation/swift/array/shuffle(using:)","type":"topi