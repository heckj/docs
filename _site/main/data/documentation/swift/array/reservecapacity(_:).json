{"sections":[],"seeAlsoSections":[{"generated":true,"anchor":"Adding-Elements","title":"Adding Elements","identifiers":["doc://com.apple.Swift/documentation/Swift/Array/append(_:)","doc://com.apple.Swift/documentation/Swift/Array/insert(_:at:)","doc://com.apple.Swift/documentation/Swift/Array/insert(contentsOf:at:)","doc://com.apple.Swift/documentation/Swift/Array/replaceSubrange(_:with:)","doc://com.apple.Swift/documentation/Swift/Array/replaceSubrange(_:with:)-7293p"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/array/reservecapacity(_:)"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Reserves enough space to store the specified number of elements.","type":"text"}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Array/reserveCapacity(_:)","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Array"]]},"metadata":{"modules":[{"name":"Swift"}],"role":"symbol","roleHeading":"Instance Method","title":"reserveCapacity(_:)","extendedModule":"Swift","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reserveCapacity"},{"kind":"text","text":"("},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":")"}],"externalID":"s:Sa15reserveCapacityyySiF"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reserveCapacity"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"minimumCapacity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"minimumCapacity","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The requested number of elements to store."}]}]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"If you are adding a known number of elements to an array, use this method","type":"text"},{"text":" ","type":"text"},{"text":"to avoid multiple reallocations. This method ensures that the array has","type":"text"},{"text":" ","type":"text"},{"text":"unique, mutable, contiguous storage, with space allocated for at least","type":"text"},{"text":" ","type":"text"},{"text":"the requested number of elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Calling the ","type":"text"},{"code":"reserveCapacity(_:)","type":"codeVoice"},{"text":" method on an array with bridged storage","type":"text"},{"text":" ","type":"text"},{"text":"triggers a copy to contiguous storage even if the existing storage","type":"text"},{"text":" ","type":"text"},{"text":"has room to store ","type":"text"},{"code":"minimumCapacity","type":"codeVoice"},{"text":" elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For performance reasons, the size of the newly allocated storage might be"},{"type":"text","text":" "},{"type":"text","text":"greater than the requested capacity. Use the array’s "},{"type":"codeVoice","code":"capacity"},{"type":"text","text":" property"},{"type":"text","text":" "},{"type":"text","text":"to determine the size of the new storage."}]},{"type":"heading","level":1,"anchor":"Preserving-an-Arrays-Geometric-Growth-Strategy","text":"Preserving an Array’s Geometric Growth Strategy"},{"type":"paragraph","inlineContent":[{"text":"If you implement a custom data structure backed by an array that grows","type":"text"},{"text":" ","type":"text"},{"text":"dynamically, naively calling the ","type":"text"},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"text":" method can lead","type":"text"},{"text":" ","type":"text"},{"text":"to worse than expected performance. Arrays need to follow a geometric","type":"text"},{"text":" ","type":"text"},{"text":"allocation pattern for appending elements to achieve amortized","type":"text"},{"text":" ","type":"text"},{"text":"constant-time performance. The ","type":"text"},{"type":"codeVoice","code":"Array"},{"text":" type’s ","type":"text"},{"type":"codeVoice","code":"append(_:)"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"append(contentsOf:)"},{"text":" methods take care of this detail for you, but","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"text":" allocates only as much space as you tell it to","type":"text"},{"text":" ","type":"text"},{"text":"(padded to a round value), and no more. This avoids over-allocation, but","type":"text"},{"text":" ","type":"text"},{"text":"can result in insertion not having amortized constant-time performance.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code declares "},{"type":"codeVoice","code":"values"},{"type":"text","text":", an array of integers, and the"},{"type":"text","text":" "},{"type":"codeVoice","code":"addTenQuadratic()"},{"type":"text","text":" function, which adds ten more values to the "},{"type":"codeVoice","code":"values"},{"type":"text","text":" "},{"type":"text","text":"array on each call."}]},{"type":"codeListing","syntax":"swift","code":["  var values: [Int] = [0, 1, 2, 3]","","  // Don't use 'reserveCapacity(_:)' like this","  func addTenQuadratic() {","      let newCount = values.count + 10","      values.reserveCapacity(newCount)","      for n in values.count..<newCount {","          values.append(n)","      }","  }"]},{"type":"paragraph","inlineContent":[{"text":"The call to ","type":"text"},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"text":" increases the ","type":"text"},{"type":"codeVoice","code":"values"},{"text":" array’s capacity","type":"text"},{"text":" ","type":"text"},{"text":"by exactly 10 elements on each pass through ","type":"text"},{"type":"codeVoice","code":"addTenQuadratic()"},{"text":", which","type":"text"},{"text":" ","type":"text"},{"text":"is linear growth. Instead of having constant time when averaged over","type":"text"},{"text":" ","type":"text"},{"text":"many calls, the function may decay to performance that is linear in","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"values.count"},{"text":". This is almost certainly not what you want.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In cases like this, the simplest fix is often to simply remove the call","type":"text"},{"text":" ","type":"text"},{"text":"to ","type":"text"},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"text":", and let the ","type":"text"},{"type":"codeVoice","code":"append(_:)"},{"text":" method grow the array","type":"text"},{"text":" ","type":"text"},{"text":"for you.","type":"text"}]},{"syntax":"swift","code":["  func addTen() {","      let newCount = values.count + 10","      for n in values.count..<newCount {","          values.append(n)","      }","  }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you need more control over the capacity of your array, implement your"},{"type":"text","text":" "},{"type":"text","text":"own geometric growth strategy, passing the size you compute to"},{"type":"text","text":" "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":"."}],"type":"paragraph"},{"style":"note","name":"Complexity","content":[{"inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":" is the number of elements in the array."}],"type":"paragraph"}],"type":"aside"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/Array":{"navigatorTitle":[{"kind":"identifier","text":"Array"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Array","abstract":[{"text":"An ordered, random-access collection.","type":"text"}],"role":"symbol","title":"Array","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Array"}],"url":"/documentation/swift/array","type":"topic"},"doc://com.apple.Swift/documentation/Swift/Array/replaceSubrange(_:with:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"replaceSubrange"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"C"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"Range","preciseIdentifier":"s:Sn"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"with"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"C","preciseIdentifier":"s:Sa15replaceSubrange_4withySnySiG_qd__nt7ElementQyd__RszSlRd__lF1CL_qd__mfp"},{"text":")","kind":"text"}],"type":"topic","title":"replaceSubrange(_:with:)","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Array/replaceSubrange(_:with:)","kind":"symbol","abstract":[{"type":"text","text":"Replaces a range of elements with the elements in the specified"},{"type":"text","text":" "},{"type":"text","text":"collection."}],"url":"/documentation/swift/array/replacesubrange(_:with:)"},"doc://com.apple.Swift/documentation/Swift/Array/reserveCapac