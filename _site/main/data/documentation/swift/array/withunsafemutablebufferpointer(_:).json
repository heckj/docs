,"text":"The return value, if any, of the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure parameter."}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Often, the optimizer can eliminate bounds checks within an array"},{"type":"text","text":" "},{"type":"text","text":"algorithm, but when that fails, invoking the same algorithm on the"},{"type":"text","text":" "},{"type":"text","text":"buffer pointer passed into your closure lets you trade safety for speed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example shows how modifying the contents of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"UnsafeMutableBufferPointer"},{"type":"text","text":" argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" alters the contents of"},{"type":"text","text":" "},{"type":"text","text":"the array:"}],"type":"paragraph"},{"code":["var numbers = [1, 2, 3, 4, 5]","numbers.withUnsafeMutableBufferPointer { buffer in","    for i in stride(from: buffer.startIndex, to: buffer.endIndex - 1, by: 2) {","        buffer.swapAt(i, i + 1)","    }","}","print(numbers)","// Prints \"[2, 1, 4, 3, 5]\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The pointer passed as an argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" is valid only during the"},{"type":"text","text":" "},{"type":"text","text":"execution of "},{"type":"codeVoice","code":"withUnsafeMutableBufferPointer(_:)"},{"type":"text","text":". Do not store or"},{"type":"text","text":" "},{"type":"text","text":"return the pointer for later use."}],"type":"paragraph"},{"style":"warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not rely on anything about the array that is the target of"},{"type":"text","text":" "},{"type":"text","text":"this method during ex