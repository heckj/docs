d":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"title":"capacity","type":"topic","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice/capacity","kind":"symbol","abstract":[{"type":"text","text":"The total number of elements that the array can contain without"},{"type":"text","text":" "},{"type":"text","text":"allocating new storage."}],"url":"/documentation/swift/arrayslice/capacity"},"doc://com.apple.Swift/documentation/Swift/ContiguousArray":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ContiguousArray","kind":"identifier"}],"abstract":[{"text":"A contiguously stored array.","type":"text"}],"role":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/ContiguousArray","kind":"symbol","title":"ContiguousArray","navigatorTitle":[{"kind":"identifier","text":"ContiguousArray"}],"url":"/documentation/swift/contiguousarray"},"doc://com.apple.Swift/documentation/Swift/ArraySlice/Hashable-Implementations":{"title":"Hashable Implementations","type":"topic","role":"collectionGroup","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice/Hashable-Implementations","kind":"article","abstract":[],"url":"/documentation/swift/arrayslice/hashable-implementations"},"doc://com.apple.Swift/documentation/Swift/ExpressibleByArrayLiteral":{"conformance":{"availabilityPrefix":[{"text":"Available when","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}],"constraints":[{"type":"codeVoice","code":"Element"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Copyable"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Escapable"},{"type":"text","text":"."}]},"title":"ExpressibleByArrayLiteral","navigatorTitle":[{"text":"ExpressibleByArrayLiteral","kind":"identifier"}],"role":"symbol","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ExpressibleByArrayLiteral","abstract":[{"text":"A type that can be init