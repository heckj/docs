{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/arrayslice/capacity"]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ArraySlice/capacity","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"extendedModule":"Swift","roleHeading":"Instance Property","externalID":"s:s10ArraySliceV8capacitySivp","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"capacity","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"symbolKind":"property","title":"capacity","modules":[{"name":"Swift"}]},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ArraySlice"]]},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"The total number of elements that the array can contain without"},{"type":"text","text":" "},{"type":"text","text":"allocating new storage."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"capacity"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","identifier":"doc://com.apple.Swift/documentation/Swift/Int","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every array reserves a specific amount of memory to hold its contents."},{"type":"text","text":" "},{"type":"text","text":"When you add elements to an array and that array begins to exceed its"},{"type":"text","text":" "},{"type":"text","text":"reserved capacity, the array allocates a larger region of memory and"},{"type":"text","text":" "},{"type":"text","text":"copies its elements into the new storage. The new storage is a multiple"},{"type":"text","text":" "},{"type":"text","text":"of the old storage’s size. This exponential growth strategy means that"},{"type":"text","text":" "},{"type":"text","text":"appending an element happens in constant time, averaging the performance"},{"type":"text","text":" "},{"type":"text","text":"of many append operations. Append operations that trigger reallocation"},{"type":"text","text":" "},{"type":"text","text":"have a performance cost, but they occur less and less often as the array"},{"type":"text","text":" "},{"type":"text","text":"grows larger."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example creates an array of integers from an array literal,"},{"type":"text","text":" "},{"type":"text","text":"then appends the elements of another collection. Before appending, the"},{"type":"text","text":" "},{"type":"text","text":"array allocates new storage that is large enough store the resulting"},{"type":"text","text":" "},{"type":"text","text":"elements."}]},{"type":"codeListing","code":["var numbers = [10, 20, 30, 40, 50]","// numbers.count == 5","// numbers.capacity == 5","","numbers.append(contentsOf: stride(from: 60, through: 100, by: 10))","// numbers.count == 10","// numbers.capacity == 10"],"syntax":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/Int":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Int","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Int"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Int","url":"/documentation/swift/int","kind":"symbol","abstract":[{"type":"text","text":"A signed integer value type."}],"title":"Int"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/ArraySlice/capacity":{"url":"/documentation/swift/arrayslice/capacity","abstract":[{"type":"text","text":"The total number of elements that the array can contain without"},{"type":"text","text":" "},{"type":"text","text":"allocating new storage."}],"identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice/capacity","type":"topic","kind":"symbol","title":"capacity","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"capacity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"doc://com.apple.Swift/documentation/Swift/ArraySlice":{"type":"topic","abstract":[{"type":"text","text":"A slice of an "},{"type":"codeVoice","code":"Array"},{"type":"text","text":", "},{"type":"codeVoice","code":"ContiguousArray"},{"type":"text","text":", or "},{"type":"codeVoice","code":"ArraySlice"},{"type":"text","text":" instance."}],"title":"ArraySlice","role":"symbol","url":"/documentation/swift/arrayslice","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ArraySlice"}],"navigatorTitle":[{"kind":"identifier","text":"ArraySlice"}]}}}