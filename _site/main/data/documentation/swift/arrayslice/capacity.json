{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ArraySlice/capacity","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"capacity"},{"text":": ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Int","text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Every array reserves a specific amount of memory to hold its contents."},{"type":"text","text":" "},{"type":"text","text":"When you add elements to an array and that array begins to exceed its"},{"type":"text","text":" "},{"type":"text","text":"reserved capacity, the array allocates a larger region of memory and"},{"type":"text","text":" "},{"type":"text","text":"copies its elements into the new storage. The new storage is a multiple"},{"type":"text","text":" "},{"type":"text","text":"of the old storage’s size. This exponential growth strategy means that"},{"type":"text","text":" "},{"type":"text","text":"appending an element happens in constant time, averaging the performance"},{"type":"text","text":" "},{"type":"text","text":"of many append operations. Append operations that trigger reallocation"},{"type":"text","text":" "},{"type":"text","text":"have a performance cost, but they occur less and less often as the array"},{"type":"text","text":" "},{"text":"grows larger.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example creates an array of integers from an array literal,"},{"type":"text","text":" "},{"type":"text","text":"then appends the elements of another collection. Before appending, the"},{"text":" ","type":"text"},{"type":"text","text":"array allocates new storage that is large enough store the resulting"},{"type":"text","text":" "},{"type":"text","text":"elements."}],"type":"paragraph"},{"type":"codeListing","code":["var numbers = [10, 20, 30, 40, 50]","// numbers.count == 5","// numbers.capacity == 5","","numbers.append(contentsOf: stride(from: 60, through: 100, by: 10))","// numbers.count == 10","// numbers.capacity == 10"],"syntax":"swift"}]}],"metadata":{"extendedModule":"Swift","role":"symbol","title":"capacity","symbolKind":"property","modules":[{"name":"Swift"}],"externalID":"s:s10ArraySliceV8capacitySivp","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"capacity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"roleHeading":"Instance Property"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ArraySlice"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/arrayslice/capacity"]}],"sections":[],"abstract":[{"type":"text","text":"The total number of elements that the array can contain without"},{"text":" ","type":"text"},{"type":"text","text":"allocating new storage."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://com.apple.Swift/documentation/Swift/ArraySlice/capacity":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"capacity"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"title":"capacity","type":"topic","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice/capacity","kind":"symbol","abstract":[{"type":"text","text":"The total number of elements that the array can contain without"},{"type":"text","text":" "},{"type":"text","text":"allocating new storage."}],"url":"/documentation/swift/arrayslice/capacity"},"doc://com.apple.Swift/documentation/Swift/ArraySlice":{"identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice","title":"ArraySlice","type":"topic","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ArraySlice","kind":"identifier"}],"navigatorTitle":[{"text":"ArraySlice","kind":"identifier"}],"url":"/documentation/swift/arrayslice","abstract":[{"type":"text","text":"A slice of an "},{"type":"codeVoice","code":"Array"},{"type":"text","text":", "},{"type":"codeVoice","code":"ContiguousArray"},{"type":"text","text":", or "},{"type":"codeVoice","code":"ArraySlice"},{"type":"text","text":" instance."}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/Int":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Int","title":"Int","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Int"}],"navigatorTitle":[{"kind":"identifier","text":"Int"}],"url":"/documentation/swift/int","abstract":[{"text":"A signed integer value type.","type":"text"}],"role":"symbol"}}}