{"sections":[],"abstract":[{"type":"text","text":"Creates an array containing the elements of a sequence."}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ArraySlice/init(_:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"s"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s10ArraySliceVyAByxGqd__c7ElementQyd__RszSTRd__lufc1SL_qd__mfp","text":"S"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Element"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":"."},{"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa","text":"Element"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":" : "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence","kind":"typeIdentifier","preciseIdentifier":"s:ST","text":"Sequence"}]}]},{"kind":"parameters","parameters":[{"name":"s","content":[{"type":"paragraph","inlineContent":[{"text":"The sequence of elements to turn into an array.","type":"text"}]}]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"You can use this initializer to create an array from any other type that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"conforms to the "},{"type":"codeVoice","code":"Sequence"},{"type":"text","text":" protocol. For example, you might want to"},{"type":"text","text":" "},{"text":"create an array with the integers from 1 through 7. Use this initializer","type":"text"},{"text":" ","type":"text"},{"text":"around a range instead of typing all those numbers in an array literal.","type":"text"}],"type":"paragraph"},{"code":["let numbers = Array(1...7)","print(numbers)","// Prints \"[1, 2, 3, 4, 5, 6, 7]\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"You can also use this initializer to convert a complex sequence or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"collection type back to an array. For example, the "},{"code":"keys","type":"codeVoice"},{"type":"text","text":" property of"},{"type":"text","text":" "},{"type":"text","text":"a dictionary isn’t an array with its own storage, it’s a collection"},{"type":"text","text":" "},{"type":"text","text":"that maps its elements from the dictionary only when they’re"},{"type":"text","text":" "},{"type":"text","text":"accessed, saving the time and space needed to allocate an array. If"},{"type":"text","text":" "},{"type":"text","text":"you need to pass those keys to a method that takes an array, however,"},{"type":"text","text":" "},{"type":"text","text":"use this initializer to convert that list from its type of"},{"type":"text","text":" "},{"code":"LazyMapCollection<Dictionary<String, Int>, Int>","type":"codeVoice"},{"type":"text","text":" to a simple"},{"type":"text","text":" "},{"code":"[String]","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func cacheImagesWithNames(names: [String]) {","    // custom image loading and caching"," }","","let namedHues: [String: Int] = [\"Vermillion\": 18, \"Magenta\": 302,","        \"Gold\": 50, \"Cerise\": 320]","let colorNames = Array(namedHues.keys)","cacheImagesWithNames(colorNames)","","print(colorNames)","// Prints \"[\"Gold\", \"Cerise\", \"Magenta\", \"Vermillion\"]\""]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","variants":[{"paths":["/documentation/swift/arrayslice/init(_:)"],"traits":[{"interfaceLanguage"