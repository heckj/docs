{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reserveCapacity"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"minimumCapacity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":")"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"minimumCapacity","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The requested number of elements to store."}]}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you are adding a known number of elements to an array, use this method"},{"type":"text","text":" "},{"type":"text","text":"to avoid multiple reallocations. This method ensures that the array has"},{"type":"text","text":" "},{"type":"text","text":"unique, mutable, contiguous storage, with space allocated for at least"},{"type":"text","text":" "},{"type":"text","text":"the requested number of elements."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling the "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":" method on an array with bridged storage"},{"type":"text","text":" "},{"type":"text","text":"triggers a copy to contiguous storage even if the existing storage"},{"type":"text","text":" "},{"type":"text","text":"has room to store "},{"type":"codeVoice","code":"minimumCapacity"},{"type":"text","text":" elements."}]},{"inlineContent":[{"type":"text","text":"For performance reasons, the size of the newly allocated storage might be"},{"type":"text","text":" "},{"type":"text","text":"greater than the requested capacity. Use the array’s "},{"type":"codeVoice","code":"capacity"},{"type":"text","text":" property"},{"type":"text","text":" "},{"type":"text","text":"to determine the size of the new storage."}],"type":"paragraph"},{"type":"heading","level":1,"anchor":"Preserving-an-Arrays-Geometric-Growth-Strategy","text":"Preserving an Array’s Geometric Growth Strategy"},{"inlineContent":[{"type":"text","text":"If you implement a custom data structure backed by an array that grows"},{"type":"text","text":" "},{"type":"text","text":"dynamically, naively calling the "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":" method can lead"},{"type":"text","text":" "},{"type":"text","text":"to worse than expected performance. Arrays need to follow a geometric"},{"type":"text","text":" "},{"type":"text","text":"allocation pattern for appending elements to achieve amortized"},{"type":"text","text":" "},{"type":"text","text":"constant-time performance. The "},{"type":"codeVoice","code":"Array"},{"type":"text","text":" type’s "},{"type":"codeVoice","code":"append(_:)"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"append(contentsOf:)"},{"type":"text","text":" methods take care of this detail for you, but"},{"type":"text","text":" "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":" allocates only as much space as you tell it to"},{"type":"text","text":" "},{"type":"text","text":"(padded to a round value), and no more. This avoids over-allocation, but"},{"type":"text","text":" "},{"type":"text","text":"can result in insertion not having amortized constant-time performance."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following code declares "},{"type":"codeVoice","code":"values"},{"type":"text","text":", an array of integers, and the"},{"type":"text","text":" "},{"type":"codeVoice","code":"addTenQuadratic()"},{"type":"text","text":" function, which adds ten more values to the "},{"type":"codeVoice","code":"values"},{"text":" ","type":"text"},{"text":"array on each call.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["  var values: [Int] = [0, 1, 2, 3]","","  // Don't use 'reserveCapacity(_:)' like this","  func addTenQuadratic() {","      let newCount = values.count + 10","      values.reserveCapacity(newCount)","      for n in values.count..<newCount {","          values.append(n)","      }","  }"]},{"inlineContent":[{"type":"text","text":"The call to "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":" increases the "},{"type":"codeVoice","code":"values"},{"type":"text","text":" array’s capacity"},{"type":"text","text":" "},{"type":"text","text":"by exactly 10 elements on each pass through "},{"type":"codeVoice","code":"addTenQuadratic()"},{"type":"text","text":", which"},{"type":"text","text":" "},{"type":"text","text":"is linear growth. Instead of having constant time when averaged over"},{"type":"text","text":" "},{"type":"text","text":"many calls, the function may decay to performance that is linear in"},{"type":"text","text":" "},{"type":"codeVoice","code":"values.count"},{"type":"text","text":". This is almost certainly not what you want."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In cases like this, the simplest fix is often to simply remove the call"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":", and let the "},{"type":"codeVoice","code":"append(_:)"},{"type":"text","text":" method grow the array"},{"type":"text","text":" "},{"type":"text","text":"for you."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["  func addTen() {","      let newCount = values.count + 10","      for n in values.count..<newCount {","          values.append(n)","      }","  }"]},{"inlineContent":[{"type":"text","text":"If you need more control over the capacity of your array, implement your"},{"type":"text","text":" "},{"type":"text","text":"own geometric growth strategy, passing the size you compute to"},{"type":"text","text":" "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the number of elements in the array."}]}],"type":"aside","style":"note","name":"Complexity"}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/arrayslice/reservecapacity(_:)"]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ArraySlice"]]},"abstract":[{"type":"text","text":"Reserves enough space to store the specified number of elements."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"role":"symbol","roleHeading":"Instance Method","title":"reserveCapacity(_:)","externalID":"s:s10ArraySliceV15reserveCapacityyySiF","extendedModule":"Swift","symbolKind":"method","modules":[{"name":"Swift"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"reserveCapacity"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}]},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/ArraySlice/reserveCapacity(_:)"},"references":{"doc://com.apple.Swift/documentation/Swift/ArraySlice":{"type":"topic","abstract":[{"type":"text","text":"A slice of an "},{"type":"codeVoice","code":"Array"},{"type":"text","text":", "},{"type":"codeVoice","code":"ContiguousArray"},{"type":"text","text":", or "},{"type":"codeVoice","code":"ArraySlice"},{"type":"text","text":" instance."}],"title":"ArraySlice","role":"symbol","url":"/documentation/swift/arrayslice","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ArraySlice"}],"navigatorTitle":[{"kind":"identifier","text":"ArraySlice"}]},"doc://com.apple.Swift/documentation/Swift/ArraySlice/reserveCapacity(_:)":{"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Reserves enough space to store the specified number of elements."}],"title":"reserveCapacity(_:)","url":"/documentation/swift/arrayslice/reservecapacity(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reserveCapacity"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice/reserveCapacity(_:)"},"doc://com.apple.Swift/documentation/Swift/Int":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Int","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Int"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Int","url":"/documentation/swift/int","kind":"symbol","abstract":[{"type":"text","text":"A signed integer value type."}],"title":"Int"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"}}}