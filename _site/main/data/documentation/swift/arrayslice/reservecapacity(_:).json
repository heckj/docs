{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ArraySlice/reserveCapacity(_:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"mutating","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reserveCapacity","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"minimumCapacity","kind":"internalParam"},{"text":": ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":")","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The requested number of elements to store.","type":"text"}],"type":"paragraph"}],"name":"minimumCapacity"}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If you are adding a known number of elements to an array, use this method"},{"type":"text","text":" "},{"type":"text","text":"to avoid multiple reallocations. This method ensures that the array has"},{"type":"text","text":" "},{"type":"text","text":"unique, mutable, contiguous storage, with space allocated for at least"},{"type":"text","text":" "},{"type":"text","text":"the requested number of elements."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling the "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"text":" method on an array with bridged storage","type":"text"},{"type":"text","text":" "},{"text":"triggers a copy to contiguous storage even if the existing storage","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"has room to store "},{"type":"codeVoice","code":"minimumCapacity"},{"text":" elements.","type":"text"}]},{"inlineContent":[{"text":"For performance reasons, the size of the newly allocated storage might be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"greater than the requested capacity. Use the array’s "},{"code":"capacity","type":"codeVoice"},{"type":"text","text":" property"},{"type":"text","text":" "},{"type":"text","text":"to determine the size of the new storage."}],"type":"paragraph"},{"level":1,"type":"heading","anchor":"Preserving-an-Arrays-Geometric-Growth-Strategy","text":"Preserving an Array’s Geometric Growth Strategy"},{"inlineContent":[{"type":"text","text":"If you implement a custom data structure backed by an array that grows"},{"type":"text","text":" "},{"type":"text","text":"dynamically, naively calling the "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":" method can lead"},{"type":"text","text":" "},{"type":"text","text":"to worse than expected performance. Arrays need to follow a geometric"},{"type":"text","text":" "},{"type":"text","text":"allocation pattern for appending elements to achieve amortized"},{"type":"text","text":" "},{"type":"text","text":"constant-time performance. The "},{"type":"codeVoice","code":"Array"},{"type":"text","text":" type’s "},{"type":"codeVoice","code":"append(_:)"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"append(contentsOf:)"},{"type":"text","text":" methods take care of this detail for you, but"},{"type":"text","text":" "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":" allocates only as much space as you tell it to"},{"type":"text","text":" "},{"type":"text","text":"(padded to a round value), and no more. This avoids over-allocation, but"},{"type":"text","text":" "},{"type":"text","text":"can result in insertion not having amortized constant-time performance."}],"type":"paragraph"},{"inlineContent":[{"text":"The following code declares ","type":"text"},{"code":"values","type":"codeVoice"},{"text":", an array of integers, and the","type":"text"},{"text":" ","type":"text"},{"code":"addTenQuadratic()","type":"codeVoice"},{"text":" function, which adds ten more values to the ","type":"text"},{"code":"values","type":"codeVoice"},{"text":" ","type":"text"},{"text":"array on each call.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["  var values: [Int] = [0, 1, 2, 3]","","  // Don't use 'reserveCapacity(_:)' like this","  func addTenQuadratic() {","      let newCount = values.count + 10","      values.reserveCapacity(newCount)","      for n in values.count..<newCount {","          values.append(n)","      }","  }"]},{"type":"paragraph","inlineContent":[{"text":"The call to ","type":"text"},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"text":" increases the ","type":"text"},{"type":"codeVoice","code":"values"},{"text":" array’s capacity","type":"text"},{"text":" ","type":"text"},{"text":"by exactly 10 elements on each pass through ","type":"text"},{"type":"codeVoice","code":"addTenQuadratic()"},{"text":", which","type":"text"},{"text":" ","type":"text"},{"text":"is linear growth. Instead of having constant time when averaged over","type":"text"},{"text":" ","type":"text"},{"text":"many calls, the function may decay to performance that is linear in","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"values.count"},{"text":". This is almost certainly not what you want.","type":"text"}]},{"inlineContent":[{"type":"text","text":"In cases like this, the simplest fix is often to simply remove the call"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":", and let the "},{"type":"codeVoice","code":"append(_:)"},{"type":"text","text":" method grow the array"},{"type":"text","text":" "},{"type":"text","text":"for you."}],"type":"paragraph"},{"code":["  func addTen() {","      let newCount = values.count + 10","      for n in values.count..<newCount {","          values.append(n)","      }","  }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"If you need more control over the capacity of your array, implement your","type":"text"},{"text":" ","type":"text"},{"text":"own geometric growth strategy, passing the size you compute to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"text":".","type":"text"}],"type":"paragraph"},{"name":"Complexity","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":"), where "},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" is the number of elements in the array."}],"type":"paragraph"}]}]}],"metadata":{"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"Swift"}],"externalID":"s:s10ArraySliceV15reserveCapacityyySiF","title":"reserveCapacity(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"reserveCapacity","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":")"}],"extendedModule":"Swift","role":"symbol"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ArraySlice"]]},"kind":"symbol","variants":[{"paths":["/documentation/swift/arrayslice/reservecapacity(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"Reserves enough space to store the specified number of elements.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.apple.Swift/documentation/Swift/ArraySlice":{"identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice","title":"ArraySlice","type":"topic","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ArraySlice","kind":"identifier"}],"navigatorTitle":[{"text":"ArraySlice","kind":"identifier"}],"url":"/documentation/swift/arrayslice","abstract":[{"type":"text","text":"A slice of an "},{"type":"codeVoice","code":"Array"},{"type":"text","text":", "},{"type":"codeVoice","code":"ContiguousArray"},{"type":"text","text":", or "},{"type":"codeVoice","code":"ArraySlice"},{"type":"text","text":" instance."}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift/ArraySlice/reserveCapacity(_:)":{"role":"symbol","abstract":[{"text":"Reserves enough space to store the specified number of elements.","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice/reserveCapacity(_:)","title":"reserveCapacity(_:)","kind":"symbol","type":"topic","url":"/documentation/swift/arrayslice/reservecapacity(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reserveCapacity","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"doc://com.apple.Swift/documentation/Swift/Int":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Int","title":"Int","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Int"}],"navigatorTitle":[{"kind":"identifier","text":"Int"}],"url":"/documentation/swift/int","abstract":[{"text":"A signed integer value type.","type":"text"}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"}}}