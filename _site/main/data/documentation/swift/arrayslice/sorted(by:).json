apple.Swift/documentation/Swift/Sequence/Element","type":"topic","required":true,"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"A type representing the sequence’s elements."}],"url":"/documentation/swift/sequence/element"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/ArraySlice":{"type":"topic","abstract":[{"type":"text","text":"A slice of an "},{"type":"codeVoice","code":"Array"},{"type":"text","text":", "},{"type":"codeVoice","code":"ContiguousArray"},{"type":"text","text":", or "},{"type":"codeVoice","code":"ArraySlice"},{"type":"text","text":" instance."}],"title":"ArraySlice","role":"symbol","url":"/documentation/swift/arrayslice","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ArraySlice"}],"navigatorTitle":[{"kind":"identifier","text":"ArraySlice"}]}}}