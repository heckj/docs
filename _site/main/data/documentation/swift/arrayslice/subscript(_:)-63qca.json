 = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[i!])","// Prints \"Evarts\""]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ArraySlice"]]},"references":{"doc://com.apple.Swift/documentation/Swift/ArraySlice":{"type":"topic","abstract":[{"type":"text","text":"A slice of an "},{"type":"codeVoice","code":"Array"},{"type":"text","text":", "},{"type":"codeVoice","code":"ContiguousArray"},{"type":"text","text":", or "},{"type":"codeVoice","code":"ArraySlice"},{"type":"text","text":" instance."}],"title":"ArraySlice","role":"symbol","url":"/documentation/swift/arrayslice","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ArraySlice"}],"navigatorTitle":[{"kind":"identifier","text":"ArraySlice"}]},"doc://com.apple.Swift/documentation/Swift/Int":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Int","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Int"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Int","url":"/documentation/swift/int","kind":"symbol","abstract":[{"type":"text","text":"A signed integer value type."}],"title":"Int"},"doc://com.apple.Swift/documentation/Swift/Range":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Range"}],"role":"symbol","abstract":[{"type":"text","text":"A half-open interval from a lower bound up to, but not including, an upper"},{"type":"text","text":" "},{"type":"text","text":"bound."}],"url":"/documentation/swift/range","identifier":"doc://com.apple.Swift/documentation/Swift/Range","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Range"}],"title":"Range"},"doc://com.apple.Swift