fety for speed."}]},{"type":"paragraph","inlineContent":[{"text":"The following example shows how modifying the contents of the","type":"text"},{"type":"text","text":" "},{"code":"UnsafeMutableBufferPointer","type":"codeVoice"},{"text":" argument to ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" alters the contents of","type":"text"},{"text":" ","type":"text"},{"text":"the array:","type":"text"}]},{"code":["var numbers = [1, 2, 3, 4, 5]","numbers.withUnsafeMutableBufferPointer { buffer in","    for i in stride(from: buffer.startIndex, to: buffer.endIndex - 1, by: 2) {","        buffer.swapAt(i, i + 1)","    }","}","print(numbers)","// Prints \"[2, 1, 4, 3, 5]\""],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The pointer passed as an argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" is valid only during the"},{"type":"text","text":" "},{"type":"text","text":"execution of "},{"type":"codeVoice","code":"withUnsafeMutableBufferPointer(_:)"},{"type":"text","text":". Do not store or"},{"type":"text","text":" "},{"text":"return the pointer for later use.","type":"text"}]},{"type":"aside","name":"Warning","style":"warning","content":[{"type":"paragraph","inlineContent":[{"text":"Do not rely on anything about the array that is the target of","type":"text"},{"text":" ","type":"text"},{"text":"this method during execution of the ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" closure; it might not","type":"text"},{"text":" ","type":"text"},{"text":"appear to have its correct value. Instead, use only the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"UnsafeMutableBufferPointer"},{"type":"text","text":" argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":"."}]}]}],"kind":"content"}],"kind":"symbol","metadata":{"role":"symbol","externalID":"s:s10ArraySliceV30withUnsafeMutableBufferPointeryqd__qd__SryxGzqd_0_YKXEqd_0_YKs5ErrorRd_0_r0