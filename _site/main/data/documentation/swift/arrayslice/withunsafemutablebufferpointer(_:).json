:"R"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"E"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:s5ErrorP","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Error","text":"Error"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"body","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure with an "},{"type":"codeVoice","code":"UnsafeMutableBufferPointer"},{"type":"text","text":" "},{"type":"text","text":"parameter that points to the contiguous storage for the array."},{"type":"text","text":" "},{"type":"text","text":"If "},{"type":"codeVoice","code":"body"},{"type":"text","text":" has a return value, that value is also"},{"type":"text","text":" "},{"type":"text","text":"used as the return value for the "},{"type":"codeVoice","code":"withUnsafeMutableBufferPointer(_:)"},{"type":"text","text":" "},{"type":"text","text":"method. The pointer argument is valid only for the duration of the"},{"type":"text","text":" "},{"type":"text","text":"method’s execution."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Return Value","level":2,"anchor":"return-value","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value, if any, of the "},{"code":"body","type":"codeVoice"},{"type":"text","text":" closure parameter."}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Often, the optimizer can eliminate bounds checks within an array"},{"type":"text","text":" "},{"type":"text","text":"algorithm, but when that fails, invoking the same algorithm on the"},{"type":"text","text":" "},{"type":"text","text":"buffer pointer passed into your closure lets you trade safety for speed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows how modifying the contents of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"UnsafeMutableBufferPointer"},{"type":"text","text":" argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" alters the contents of"},{"type":"text","text":" "},{"type":"text","text":"the array:"}]},{"syntax":"swift","type":"codeListing","code":["var numbers = [1, 2, 3, 4, 5]","numbers.withUnsafeMutableBufferPointer { buffer in","    for i in stride(from: buffer.startIndex, to: buffer.endIndex - 1, by: 2) {","        buffer.swapAt(i, i + 1)","    }","}","print(numbers)","// Prints \"[2, 1, 4, 3, 5]\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The pointer passed as an argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" is valid only during the"},{"type":"text","text":" "},{"type":"text","text":"execution of "},{"type":"codeVoice","code":"withUnsafeMutableBufferPointer(_:)"},{"type":"text","text":". Do not store or"},{"type":"text","text":" "},{"type":"text","text":"return the pointer for later use."}]},{"name":"Warning","content":[{"inlineContent":[{"type":"text","text":"Do not rely on anything about the array that is the target of"},{"type":"text","text":" "},{"type":"text","text":"this method during execution of the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure; it might not"},{"type":"text","text":" "},{"type":"text","text":"appear to have its correct value. Instead, use only the"},{"type":"text","text":" "},{"type":"codeVoice","code":"UnsafeMutableBufferPointer"},{"type":"text","text":" argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":"."}],"type":"paragraph"}],"style":"warning","type":"aside"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Calls the given closure with a pointer to the array’s mutable contiguous","type":"text"},{"text":" ","type":"text"},{"text":"storage.","type":"text"}],"references":{"doc://com.apple.Swift/documentati