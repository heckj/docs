{"kind":"symbol","abstract":[{"type":"text","text":"Calls the given closure with a pointer to the underlying bytes of the"},{"type":"text","text":" "},{"type":"text","text":"array’s mutable contiguous storage."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withUnsafeMutableBytes"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"text":"body","kind":"internalParam"},{"text":": (","kind":"text"},{"text":"UnsafeMutableRawBufferPointer","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawBufferPointer","preciseIdentifier":"s:Sw","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"R","preciseIdentifier":"s:s10ArraySliceV22withUnsafeMutableBytesyqd__qd__SwKXEKlF1RL_qd__mfp","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"R","preciseIdentifier":"s:s10ArraySliceV22withUnsafeMutableBytesyqd__qd__SwKXEKlF1RL_qd__mfp","kind":"typeIdentifier"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure with an "},{"code":"UnsafeMutableRawBufferPointer","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"parameter that points to the contiguous storage for the array."},{"type":"text","text":" "},{"type":"text","text":"If no such storage exists, it is created. If "},{"code":"body","type":"codeVoice"},{"type":"text","text":" has a return value, that value is also"},{"type":"text","text":" "},{"type":"text","text":"used as the return value for the "},{"code":"withUnsafeMutableBytes(_:)","type":"codeVoice"},{"type":"text","text":" method."},{"type":"text","text":" "},{"type":"text","text":"The argument is valid only for the duration of the closure’s"},{"type":"text","text":" "},{"type":"text","text":"execution."}]}],"name":"body"}]},{"content":[{"text":"Return Value","level":2,"type":"heading","anchor":"return-value"},{"inlineContent":[{"text":"The return value, if any, of the ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" closure parameter.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The array’s "},{"type":"codeVoice","code":"Element"},{"type":"text","text":" type must be a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"trivial type"}]},{"type":"text","text":", which can be copied"},{"type":"text","text":" "},{"type":"text","text":"with just a bit-for-bit copy without any indirection or"},{"type":"text","text":" "},{"type":"text","text":"reference-counting operations. Generally, native Swift types that do not"},{"type":"text","text":" "},{"type":"text","text":"contain strong or weak references are trivial, as are imported C structs"},{"type":"text","text":" "},{"type":"text","text":"and enums."}]},{"type":"paragraph","inlineContent":[{"text":"The following example copies bytes from the ","type":"text"},{"code":"byteValues","type":"codeVoice"},{"text":" array into","type":"text"},{"text":" ","type":"text"},{"code":"numbers","type":"codeVoice"},{"text":", an array of ","type":"text"},{"code":"Int32","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","code":["var numbers: [Int32] = [0, 0]","var byteValues: [UInt8] = [0x01, 0x00, 0x00, 0x00, 0x02, 0x00, 0x00, 0x00]","","numbers.withUnsafeMutableBytes { destBytes in","    byteValues.withUnsafeBytes { srcBytes in","        destBytes.copyBytes(from: srcBytes)","    }","}","// numbers == [1, 2]"],"syntax":"swift"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows the behavior on a little-endian platform."}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The pointer passed as an argument to "},{"type":"codeVoice","code":"body"},{"text":" is valid only for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lifetime of the closure. Do not escape it from the closure for later"},{"type":"text","text":" "},{"type":"text","text":"use."}]},{"style":"warning","content":[{"type":"paragraph","inlineContent":[{"text":"Do not rely on anything about the array that is the target of","type":"text"},{"text":" ","type":"text"},{"text":"this method during execution of the ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" closure; it might not","type":"text"},{"text":" ","type":"text"},{"text":"appear to have its correct value. Instead, use only the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"UnsafeMutableRawBufferPointer"},{"text":" argument to ","type":"text"},{"type":"codeVoice","code":"body"},{"text":".","type":"text"}]}],"type":"aside","name":"Warning"}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ArraySlice"]]},"metadata":{"role":"symbol","modules":[{"name":"Swift"}],"extendedModule":"Swift","title":"withUnsafeMutableBytes(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withUnsafeMutableBytes"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">(("},{"preciseIdentifier":"s:Sw","kind":"typeIdentifier","text":"UnsafeMutableRawBufferPointer"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:s10ArraySliceV22withUnsafeMutableBytesyqd__qd__SwKXEKlF1RL_qd__mfp","kind":"typeIdentifier","text":"R"},{"kind":"text","text":