nd":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"body","kind":"internalParam"},{"text":": (","kind":"text"},{"text":"UnsafeMutableRawBufferPointer","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawBufferPointer","preciseIdentifier":"s:Sw"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"R","preciseIdentifier":"s:s10ArraySliceV22withUnsafeMutableBytesyqd__qd__SwKXEKlF1RL_qd__mfp","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"R","kind":"typeIdentifier","preciseIdentifier":"s:s10ArraySliceV22withUnsafeMutableBytesyqd__qd__SwKXEKlF1RL_qd__mfp"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"A closure with an ","type":"text"},{"type":"codeVoice","code":"UnsafeMutableRawBufferPointer"},{"text":" ","type":"text"},{"type":"text","text":"parameter that points to the contiguous storage for the array."},{"type":"text","text":" "},{"text":"If no such storage exists, it is created. If ","type":"text"},{"type":"codeVoice","code":"body"},{"type":"text","text":" has a return value, that value is also"},{"type":"text","text":" "},{"type":"text","text":"used as the return value for the "},{"type":"codeVoice","code":"withUnsafeMutableBytes(_:)"},{"type":"text","text":" method."},{"type":"text","text":" "},{"type":"text","text":"The argument is valid only for the duration of the closure’s"},{"type":"text","text":" "},{"type":"text","text":"execution."}],"type":"paragraph"}],"name":"body"}]},{"content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"inlineContent":[{"text":"The return value, if any, of the ","type":"text"},{"code":"body","type":"codeVoice"},{"type":"text","text":" closure parameter."}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"The array’s ","type":"text"},{"code":"Element","type":"codeVoice"},{"type":"text","text":" type must be a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"trivial type"}]},{"type":"text","text":", which can be copied"},{"type":"text","text":" "},{"type":"text","text":"with just a bit-for-bit copy without any indirection or"},{"text":" ","type":"text"},{"type":"text","text":"reference-counting operations. Generally, native Swift types that do not"},{"type":"text","text":" "},{"type":"text","text":"contain strong or weak references are trivial, as are imported C structs"},{"type":"text","text":" "},{"type":"text","text":"and enums."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example copies bytes from the "},{"type":"codeVoice","code":"byteValues"},{"type":"text","text":" array into"},{"type":"text","text":" "},{"type":"codeVoice","code":"numbers"},{"type":"text","text":", an array of "},{"type":"codeVoice","code":"Int32"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var numbers: [Int32] = [0, 0]","var byteValues: [UInt8] = [0x01, 0x00, 0x00, 0x00, 0x02, 0x00, 0x00, 0x00]","","numbers.withUnsafeMutableBytes { destBytes in","    byteValues.withUnsafeBytes { srcBytes in","        destBytes.copyBytes(from: srcBytes)","    }","}","// numbers == [1, 2]"]},{"type":"aside","content":[{"inlineContent":[{"text":"This example shows the behavior on a little-endian platform.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"text":"The pointer passed as an argument to ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" is valid only for the","type":"text"},{"text":" ","type":"text"},{"text":"lifetime of the closure. Do not escape it from the closure for later","type":"text"},{"text":" ","type":"text"},{"text":"use.","type":"text"}]},{"style":"warning","type":"aside","name":"Warning","content":[{"type":"paragraph","inlineContent":[{"text":"Do not rely on anything about the array that is the target of","type":"text"},{"text":" ","type":"text"},{"text":"this method during execution of the ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" closure; it might not","type":"text"},{"text":" ","type":"text"},{"text":"appear to have its correct value. Instead, use only the","type":"text"},{"text":" ","type":"text"},{"code":"UnsafeMutableRawBufferPointer","type":"codeVoice"},{"text":" argument to ","type":"text"},{"code":"body","type":"codeVoice"},{"text":".","type":"text"}]}]}]}],"references":{"doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawBufferPointer":{"abstract":[{"text":"A mutable nonowning collection interface to the bytes in a","type":"text"},{"text":" ","type":"text"},{"text":"region of memory.","type":"text"}],"role":"symbol","url":"/documentation/swift/unsafemutablerawbufferpointer","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"UnsafeMutableRawBufferPointer","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawBufferPointer","title":"UnsafeMutableRawBufferPointer","navigatorTitle":[{"kind":"identifier","text":"UnsafeMutableRawBufferPointer"}]},"doc://com.apple.Swift/documentation/Swift/ArraySlice":{"type":"topic","abstract":[{"type":"text","text":"A slice of an "},{"type":"codeVoice","code":"Array"},{"type":"text","text":", "},{"type":"codeVoice","code":"ContiguousArray"},{"type":"text","text":", or "},{"type":"codeVoice","code":"ArraySlice"},{"type":"text","text":" instance."}],"title":"ArraySlice","role":"symbol","url":"/documentation/swift/arrayslice","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ArraySlice"}],"navigatorTitle":[{"ki