ext":"An error-throwing mapping closure. ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"accepts an element of this sequence as its parameter and returns a"},{"type":"text","text":" "},{"type":"text","text":"transformed value of the same or of a different type. If "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" "},{"type":"text","text":"throws an error, the sequence ends."}]}]}]},{"content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"text":"An asynchronous sequence that contains, in order, the","type":"text"},{"text":" ","type":"text"},{"text":"non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" elements produced by the ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" closure. The sequence","type":"text"},{"text":" ","type":"text"},{"text":"ends either when the base sequence ends or when ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" throws an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"text":" method to transform every element received from","type":"text"},{"text":" ","type":"text"},{"text":"a base asynchronous sequence, while also discarding any ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"from the closure. Typically, you use this to transform from one type of","type":"text"},{"text":" ","type":"text"},{"text":"element to another.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In this example, an asynchronous sequence called ","type":"text"},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" "},{"type":"text","text":"method takes each "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. Since there is no key for "},{"type":"codeVoice","code":"4"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" in this case, which "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" omits from the"},{"type":"text","text":" "},{"type":"text","text":"transformed asynchronous sequence. When the value is "},{"type":"codeVoice","code":"5"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"type":"text","text":"throws "},{"type":"codeVoice","code":"MyError"},{"type":"text","text":", terminating the sequence."}]},{"code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["/documentation/swift/asynccompactmapsequence/compactmap(_:)-9t1q8"],"traits":[{"interfaceLanguage":"swift"}]}],"ref