{"sections":[],"abstract":[{"type":"text","text":"Creates an asynchronous sequence that maps the given error-throwing"},{"type":"text","text":" "},{"type":"text","text":"closure over the asynchronous sequence’s elements."}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AsyncCompactMapSequence/map(_:)-21iha","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@preconcurrency"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"transform"},{"kind":"text","text":": "},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" "},{"kind":"attribute","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","text":"Element","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","preciseIdentifier":"s:Sci7ElementQa"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"AsyncThrowingMapSequence","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":">"}]}]},{"kind":"parameters","parameters":[{"name":"transform","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A mapping closure. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" accepts an element"},{"type":"text","text":" "},{"type":"text","text":"of this sequence as its parameter and returns a transformed value of the"},{"type":"text","text":" "},{"type":"text","text":"same or of a different type. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" can also throw an error, which"},{"type":"text","text":" "},{"type":"text","text":"ends the transformed sequence."}]}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the elements"},{"type":"text","text":" "},{"type":"text","text":"produced by the "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" closure."}],"type":"paragraph"}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method to transform every element received from a base"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence. Typically, you use this to transform from one type"},{"type":"text","text":" "},{"type":"text","text":"of element to another."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" produces "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" "},{"text":"values from ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" to ","type":"text"},{"code":"5","type":"codeVoice"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"map(_:)"},{"text":" method","type":"text"},{"type":"text","text":" "},{"type":"text","text":"takes each "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" and looks up a corresponding "},{"code":"String","type":"codeVoice"},{"type":"text","text":" from a"},{"text":" ","type":"text"},{"code":"romanNumeralDict","type":"codeVoice"},{"text":" dictionary. This means the outer ","type":"text"},{"type":"codeVoice","code":"for await in"},{"type":"text","text":" loop"},{"type":"text","text":" "},{"type":"text","text":"iterates over "},{"code":"String","type":"codeVoice"},{"type":"text","text":" instances instead of the underlying "},{"type":"codeVoice","code":"Int"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"that ","type":"text"},{"code":"Counter","type":"codeVoice"},{"text":" produces. Also, the dictionary doesn’t provide a key for","type":"text"},{"text":" ","type":"text"},{"code":"4","type":"codeVoice"},{"text":", and the closure throws an error for any key it can’t look up, so","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"receiving this value from "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" ends the modified sequence with an"},{"type":"text","text":" "},{"type":"text","text":"error."}]},{"type":"codeListing","syntax":"swift","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/asynccompactmapsequen