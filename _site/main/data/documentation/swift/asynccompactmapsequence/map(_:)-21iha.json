{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["/documentation/swift/asynccompactmapsequence/map(_:)-21iha"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AsyncCompactMapSequence/map(_:)-21iha","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@preconcurrency"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"transform"},{"kind":"text","text":": "},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" "},{"kind":"attribute","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","text":"Element","preciseIdentifier":"s:Sci7ElementQa"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence","text":"AsyncThrowingMapSequence","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":">"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"transform","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A mapping closure. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" accepts an element"},{"type":"text","text":" "},{"type":"text","text":"of this sequence as its parameter and returns a transformed value of the"},{"type":"text","text":" "},{"type":"text","text":"same or of a different type. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" can also throw an error, which"},{"type":"text","text":" "},{"type":"text","text":"ends the transformed sequence."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the elements"},{"type":"text","text":" "},{"type":"text","text":"produced by the "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" closure."}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method to transform every element received from a base"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence. Typically, you use this to transform from one type"},{"type":"text","text":" "},{"type":"text","text":"of element to another."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"text":" ","type":"text"},{"text":"values from ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"5","type":"codeVoice"},{"text":". The closure provided to the ","type":"text"},{"code":"map(_:)","type":"codeVoice"},{"text":" method","type":"text"},{"text":" ","type":"text"},{"text":"takes each ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" and looks up a corresponding ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" from a","type":"text"},{"text":" ","type":"text"},{"code":"romanNumeralDict","type":"codeVoice"},{"text":" dictionary. This means the outer ","type":"text"},{"code":"for await in","type":"codeVoice"},{"text":" loop","type":"text"},{"text":" ","type":"text"},{"text":"iterates over ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" instances instead of the underlying ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"that ","type":"text"},{"code":"Counter","type":"codeVoice"},{"text":" produces. Also, the dictionary doesn’t provide a key for","type":"text"},{"text":" ","type":"text"},{"code":"4","type":"codeVoice"},{"text":", and the closure throws an error for any key it can’t look up, so","type":"text"},{"text":" ","type":"text"},{"text":"receiving this value from ","type":"text"},{"code":"Counter","type":"codeVoice"},{"text":" ends the modified sequence with an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncCompactMapSequence"]]},"kind":"symbol","abstract":[{"text":"Creates an asynchronous sequence that maps the given error-throwing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"closure over the asynchronous sequence’s elements."}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"map","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Transformed","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" (","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:Sci7ElementQa"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Transformed","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"text":") -> ","kind":"text"},{"text":"AsyncThrowingMapSequence","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Transformed","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"text":">","kind":"text"}],"title":"map(_:)","role":"symbol","externalID":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF::SYNTHESIZED::s:12_Concurrency23AsyncCompactMapSequenceV","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"Swift","relatedModules":[]}],"extendedModule":"_Concurrency"},"references":{"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence":{"abstract":[{"type":"text","text":"An asynchronous sequence that maps the given error-throwing closure over the"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence’s elements."}],"kind":"symbol","title":"AsyncThrowingMapSequence","identifier":"doc://com.appl