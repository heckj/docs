quence","kind":"identifier"}],"abstract":[{"type":"text","text":"An asynchronous sequence which omits elements from the base sequence until a"},{"type":"text","text":" "},{"type":"text","text":"given closure returns false, after which it passes through all remaining"},{"type":"text","text":" "},{"type":"text","text":"elements."}],"url":"/documentation/swift/asyncdropwhilesequence","navigatorTitle":[{"kind":"identifier","text":"AsyncDropWhileSequence"}],"title":"AsyncDropWhileSequence","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncDropWhileSequence"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element":{"title":"Element","role":"symbol","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","type":"topic","abstract":[{"text":"The type of element produced by this asynchronous sequence.","type":"text"}],"fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Element"}],"required":true,"url":"/documentation/swift/asyncsequence/element"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingCompactMapSequence":{"abstract":[{"type":"text","text":"An asynchronous sequence that maps an error-throwing closure over the base"},{"type":"text","text":" "},{"type":"text","text":"sequence’s elements, omitting results that don’t return a value."}],"title":"AsyncThrowingCompactMapSequence","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingCompactMapSequence","url":"/documentation/swift/asyncthrowingcompactmapsequence","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncThrowingCo