fier","text":"ElementOfResult"},{"kind":"text","text":">"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An error-throwing mapping closure. "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"accepts an element of this sequence as its parameter and returns a"},{"text":" ","type":"text"},{"text":"transformed value of the same or of a different type. If ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" ","type":"text"},{"text":"throws an error, the sequence ends.","type":"text"}]}],"name":"transform"}],"kind":"parameters"},{"content":[{"anchor":"return-value","level":2,"text":"Return Value","type":"heading"},{"inlineContent":[{"text":"An asynchronous sequence that contains, in order, the","type":"text"},{"text":" ","type":"text"},{"text":"non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" elements produced by the ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" closure. The sequence","type":"text"},{"text":" ","type":"text"},{"text":"ends either when the base sequence ends or when ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" throws an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"code":"compactMap(_:)","type":"codeVoice"},{"text":" method to transform every element received from","type":"text"},{"text":" ","type":"text"},{"text":"a base asynchronous sequence, while also discarding any ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"from the closure. Typically, you use this to transform from one type of","type":"text"},{"text":" ","type":"text"},{"text":"element to another.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" "},{"type":"text","text":"method takes each "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. Since there is no key for "},{"type":"codeVoice","code":"4"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" in this case, which "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" omits from the"},{"type":"text","text":" "},{"type":"text","text":"transformed asynchronous sequence. When the value is "},{"type":"codeVoice","code":"5"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"type":"text","text":"throws "},{"type":"codeVoice","code":"MyError"},{"type":"text","text":", terminating the sequence."}]},{"syntax":"swift","type":"codeListing","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncFilterSequence"]]},"kind":"symbol","abstract":[{"type":"text","text":"Creates an asynchronous sequence that maps an error-throwing closure over"},{"type":"text","text":" "},{"type":"text","text":"the base sequence’s elements, omitting results that don’t return a value."}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"compactMap","kind":"identifier"},{"text":"<","kind":"text"},{"text":"ElementOfResult","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" (","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:Sci7ElementQa"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"ElementOfResult","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp"},{"text":"?) -> ","kind":"text"},{"text":"AsyncThrowingCompactMapSequence","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency31AsyncThrowingCompactMapSequenceV"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ElementOfResult","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp"},{"text":">","kind":"text"}],"title":"compactMap(_:)","role":"symbol","externalID":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF::SYNTHESIZED::s:12_Concurrency19AsyncFilterSequenceV","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"Swift","relatedModules":[]}],"extendedModule":"_Concurrency"},"references":{"doc:/