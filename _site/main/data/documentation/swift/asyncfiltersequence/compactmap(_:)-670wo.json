larations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"An error-throwing mapping closure. ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" ","type":"text"},{"text":"accepts an element of this sequence as its parameter and returns a","type":"text"},{"text":" ","type":"text"},{"text":"transformed value of the same or of a different type. If ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" ","type":"text"},{"text":"throws an error, the sequence ends.","type":"text"}]}],"name":"transform"}]},{"kind":"content","content":[{"anchor":"return-value","type":"heading","text":"Return Value","level":2},{"inlineContent":[{"text":"An asynchronous sequence that contains, in order, the","type":"text"},{"text":" ","type":"text"},{"text":"non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" elements produced by the ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" closure. The sequence","type":"text"},{"text":" ","type":"text"},{"text":"ends either when the base sequence ends or when ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" throws an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"text":" method to transform every element received from","type":"text"},{"text":" ","type":"text"},{"text":"a base asynchronous sequence, while also discarding any ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"from the closure. Typically, you use this to transform from one type of","type":"text"},{"text":" ","type":"text"},{"text":"element to another.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In this example, an asynchronous sequence called ","type":"text"},{"type":"codeVoice","code":"Counter"},{"text":" produces ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" ","type":"text"},{"text":"values from ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"5"},{"text":". The closure provided to the ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"text":" ","type":"text"},{"text":"method takes each ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" and looks up a corresponding ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" from a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"romanNumeralDict"},{"text":" dictionary. Since there is no key for ","type":"text"},{"type":"codeVoice","code":"4"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" in this case, which ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"text":" omits from the","type":"text"},{"text":" ","type":"text"},{"text":"transformed asynchronous sequence. When the value is ","type":"text"},{"type":"codeVoice","code":"5"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"throws ","type":"text"},{"type":"codeVoice","code":"MyError"},{"text":", terminating the sequence.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}]}],"references":{"doc:/