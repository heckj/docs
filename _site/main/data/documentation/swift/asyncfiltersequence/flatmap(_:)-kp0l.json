mapping closure. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" "},{"type":"text","text":"accepts an element of this sequence as its parameter and returns an"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncSequence"},{"type":"text","text":". If "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" throws an error, the sequence ends."}],"type":"paragraph"}],"name":"transform"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A single, flattened asynchronous sequence that contains all"},{"type":"text","text":" "},{"type":"text","text":"elements in all the asynchronous sequences produced by "},{"code":"transform","type":"codeVoice"},{"type":"text","text":". The"},{"type":"text","text":" "},{"type":"text","text":"sequence ends either when the last sequence created from the last"},{"type":"text","text":" "},{"type":"text","text":"element from base sequence ends, or when "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" throws an error."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to receive a single-level asynchronous sequence when your"},{"type":"text","text":" "},{"type":"text","text":"transformation produces an asynchronous sequence for each element."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" produces "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"code":"1","type":"codeVoice"},{"type":"text","text":" to "},{"code":"5","type":"codeVoice"},{"type":"text","text":". The transforming closure takes the received "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"and returns a new "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" that counts that high. For example, when the"},{"type":"text","text":" "},{"type":"text","text":"transform receives "},{"code":"3","type":"codeVoice"},{"type":"text","text":" from the base sequence, it creates a new "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"that produces the values "},{"code":"1","type":"codeVoice"},{"type":"text","text":", "},{"code":"2","type":"codeVoice"},{"type":"text","text":", and "},{"code":"3","type":"codeVoice"},{"type":"text","text":". The "},{"code":"flatMap(_:)","type":"codeVoice"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"“flattens” the resulting sequence-of-sequences into a single"},{"type":"text","text":" "},{"code":"AsyncSequence","type":"codeVoice"},{"type":"text","text":". However, when the closure receives "},{"code":"4","type":"codeVoice"},{"type":"text","text":", it throws an"},{"type":"text","text":" "},{"type":"text","text":"error, terminating the sequence."}]},{"type":"codeListing","code":["do {","    let stream = Counter(howHigh: 5)","        .flatMap { (value) -> Counter in","            if value == 4 {","                throw MyError()","            }","            return Counter(howHigh: value)","        }","    for try await number in stream {","        print(number, terminator: \" \")","    }","} catch {","    print(error)","}","// Prints \"1 1 2 1 2 3 MyError() \""],"syntax":"swift"}]}],"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncFilterSequence"]]},"abstract":[{"type":"text","text":"Creates an asynchronous sequence that concatenates the results of calling"},{"type":"text","text":" "},{"type":"text","text":"the given error-throwing transformation with each element of this"},{"type":"text","text":" "},{"type":"text","text":"sequence."}],"refe