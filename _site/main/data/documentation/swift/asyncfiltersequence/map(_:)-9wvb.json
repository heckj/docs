"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@preconcurrency"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"transform"},{"kind":"text","text":": "},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" "},{"kind":"attribute","text":"@escaping"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:Sci7ElementQa","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","text":"Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","kind":"typeIdentifier","text":"Transformed"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence","text":"AsyncThrowingMapSequence"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","kind":"typeIdentifier","text":"Transformed"},{"kind":"text","text":">"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A mapping closure. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" accepts an element"},{"type":"text","text":" "},{"type":"text","text":"of this sequence as its parameter and returns a transformed value of the"},{"type":"text","text":" "},{"type":"text","text":"same or of a different type. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" can also throw an error, which"},{"type":"text","text":" "},{"type":"text","text":"ends the transformed sequence."}],"type":"paragraph"}],"name":"transform"}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the elements"},{"type":"text","text":" "},{"type":"text","text":"produced by the "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" closure."}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method to transform every element received from a base"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence. Typically, you use this to transform from one type"},{"type":"text","text":" "},{"type":"text","text":"of element to another."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"takes each "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. This means the outer "},{"type":"codeVoice","code":"for await in"},{"type":"text","text":" loop"},{"type":"text","text":" "},{"type":"text","text":"iterates over "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instances instead of the underlying "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"that "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces. Also, the dictionary doesn’t provide a key for"},{"type":"text","text":" "},{"type":"codeVoice","code":"4"},{"type":"text","text":", and the closure throws an error for any key it can’t look up, so"},{"type":"text","text":" "},{"type":"text","text":"receiving this value from "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" ends the modified sequence with an"},{"type":"text","text":" "},{"type":"text","text":"error."}]},{"type":"codeListing","syntax":"swift","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/asyncfiltersequence/map(_:)-9wvb"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.apple.Swift/documentation/Swift/AsyncFilterSequence/map(_:)-9wvb":{"abstract":[{"type":"text","text":"Creates an asynchronous sequence that maps the given error-throwing"},{"type":"text","text":" "},{"type":"text","text":"closure over the asynchronous sequence’s elements."}],"role":"symbol","url":"/documentation/swift/asyncfiltersequence/map(_:)-9wvb","ki