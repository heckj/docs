{"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/AsyncFlatMapSequence/map(_:)-5ncr2"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"abstract":[{"text":"Creates an asynchronous sequence that maps the given error-throwing","type":"text"},{"text":" ","type":"text"},{"text":"closure over the asynchronous sequence’s elements.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@preconcurrency"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"map","kind":"identifier"},{"kind":"text","text":"<"},{"text":"Transformed","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"_","kind":"externalParam"},{"kind":"text","text":" "},{"text":"transform","kind":"internalParam"},{"kind":"text","text":": "},{"text":"@Sendable","kind":"attribute"},{"kind":"text","text":" "},{"text":"@escaping","kind":"attribute"},{"kind":"text","text":" ("},{"text":"Element","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","preciseIdentifier":"s:Sci7ElementQa","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"async","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":") -> "},{"text":"AsyncThrowingMapSequence","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"text":"Transformed","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"text":">","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A mapping closure. ","type":"text"},{"type":"codeVoice","code":"transform"},{"type":"text","text":" accepts an element"},{"type":"text","text":" "},{"type":"text","text":"of this sequence as its parameter and returns a transformed value of the"},{"text":" ","type":"text"},{"type":"text","text":"same or of a different type. "},{"code":"transform","type":"codeVoice"},{"text":" can also throw an error, which","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"ends the transformed sequence."}]}],"name":"transform"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"An asynchronous sequence that contains, in order, the elements","type":"text"},{"text":" ","type":"text"},{"text":"produced by the ","type":"text"},{"code":"transform","type":"codeVoice"},{"type":"text","text":" closure."}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method to transform every element received from a base"},{"text":" ","type":"text"},{"text":"asynchronous sequence. Typically, you use this to transform from one type","type":"text"},{"type":"text","text":" "},{"text":"of element to another.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"text":"values from ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"takes each "},{"type":"codeVoice","code":"Int"},{"text":" and looks up a corresponding ","type":"text"},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"code":"romanNumeralDict","type":"codeVoice"},{"type":"text","text":" dictionary. This means the outer "},{"code":"for await in","type":"codeVoice"},{"type":"text","text":" loop"},{"type":"text","text":" "},{"type":"text","text":"iterates over "},{"code":"String","type":"codeVoice"},{"type":"text","text":" instances instead of the underlying "},{"type":"codeVoice","code":"Int"},{"text":" values","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that "},{"type":"codeVoice","code":"Counter"},{"text":" produces. Also, the dictionary doesn’t provide a key for","type":"text"},{"text":" ","type":"text"},{"code":"4","type":"codeVoice"},{"text":", and the closure throws an error for any key it can’t look up, so","type":"text"},{"text":" ","type":"text"},{"text":"receiving this value from ","type":"text"},{"code":"Counter","type":"codeVoice"},{"text":" ends the modified sequence with an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}]},{"syntax":"swift","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""],"type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/asyncflatmapsequence/map