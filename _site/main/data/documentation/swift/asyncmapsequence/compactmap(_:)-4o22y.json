e":"text","text":"transformed value of the same or of a different type. If "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"throws an error, the sequence ends."}]}],"name":"transform"}]},{"kind":"content","content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the"},{"type":"text","text":" "},{"type":"text","text":"non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" elements produced by the "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" closure. The sequence"},{"type":"text","text":" "},{"type":"text","text":"ends either when the base sequence ends or when "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" throws an"},{"type":"text","text":" "},{"type":"text","text":"error."}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" method to transform every element received from"},{"type":"text","text":" "},{"type":"text","text":"a base asynchronous sequence, while also discarding any "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"from the closure. Typically, you use this to transform from one type of"},{"type":"text","text":" "},{"type":"text","text":"element to another."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" produces "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"code":"1","type":"codeVoice"},{"type":"text","text":" to "},{"code":"5","type":"codeVoice"},{"type":"text","text":". The closure provided to the "},{"code":"compactMap(_:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"method takes each "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" and looks up a corresponding "},{"code":"String","type":"codeVoice"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"code":"romanNumeralDict","type":"codeVoice"},{"type":"text","text":" dictionary. Since there is no key for "},{"code":"4","type":"codeVoice"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" in this case, which "},{"code":"compactMap(_:)","type":"codeVoice"},{"type":"text","text":" omits from the"},{"type":"text","text":" "},{"type":"text","text":"transformed asynchronous sequence. When the value is "},{"code":"5","type":"codeVoice"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"type":"text","text":"throws "},{"code":"MyError","type":"codeVoice"},{"type":"text","text":", terminating the sequence."}]},{"type":"codeListing","syntax":"swift","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}]}],"variants":[{"paths":["/documentation/swift/asyncmapsequence/compactmap(_:)-4o22y"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncMapSequence"]]},"references":{"doc://com.apple.S