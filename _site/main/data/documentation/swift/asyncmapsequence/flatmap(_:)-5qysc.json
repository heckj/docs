"AsyncSequence","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"An error-throwing mapping closure. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" "},{"type":"text","text":"accepts an element of this sequence as its parameter and returns an"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncSequence"},{"type":"text","text":". If "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" throws an error, the sequence ends."}],"type":"paragraph"}],"name":"transform"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A single, flattened asynchronous sequence that contains all"},{"type":"text","text":" "},{"type":"text","text":"elements in all the asynchronous sequences produced by "},{"type":"codeVoice","code":"transform"},{"type":"text","text":". The"},{"type":"text","text":" "},{"type":"text","text":"sequence ends either when the last sequence created from the last"},{"type":"text","text":" "},{"type":"text","text":"element from base sequence ends, or when "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" throws an error."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to receive a single-level asynchronous sequence when your"},{"type":"text","text":" "},{"type":"text","text":"transformation produces an asynchronous sequence for each element."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The transforming closure takes the received "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"and returns a new "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" that counts that high. For example, when the"},{"type":"text","text":" "},{"type":"text","text":"transform receives "},{"type":"codeVoice","code":"3"},{"type":"text","text":" from the base sequence, it creates a new "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" "},{"type":"text","text":"that produces the values "},{"type":"codeVoice","code":"1"},{"type":"text","text":", "},{"type":"codeVoice","code":"2"},{"type":"text","text":", and "},{"type":"codeVoice","code":"3"},{"type":"text","text":". The "},{"type":"codeVoice","code":"flatMap(_:)"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"“flattens” the resulting sequence-of-sequences into a single"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncSequence"},{"type":"text","text":". However, when the closure receives "},{"type":"codeVoice","code":"4"},{"type":"text","text":", it throws an"},{"type":"text","text":" "},{"type":"text","text":"error, terminating the sequence."}]},{"type":"codeListing","code":["do {","    let stream = Counter(howHigh: 5)","        .flatMap { (value) -> Counter in","            if value == 4 {","                throw MyError()","            }","            return Counter(howHigh: value)","        }","    for try await number in stream {","        print(number, terminator: \" \")","    }","} catch {","    print(error)","}","// Prints \"1 1 2 1 2 3 MyError() \""],"syntax":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncMapSequence"]]},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AsyncMapSequence/flatMap(_:)-5qysc","interfaceLanguage":"swift"},"references":{"