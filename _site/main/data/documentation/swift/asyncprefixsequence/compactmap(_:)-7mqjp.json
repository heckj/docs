{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncPrefixSequence"]]},"kind":"symbol","abstract":[{"type":"text","text":"Creates an asynchronous sequence that maps an error-throwing closure over"},{"type":"text","text":" "},{"type":"text","text":"the base sequence’s elements, omitting results that don’t return a value."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@preconcurrency","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"compactMap","kind":"identifier"},{"text":"<","kind":"text"},{"text":"ElementOfResult","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"transform","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" ","kind":"text"},{"text":"@escaping","kind":"attribute"},{"text":" (","kind":"text"},{"text":"Element","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","kind":"typeIdentifier","preciseIdentifier":"s:Sci7ElementQa"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"ElementOfResult","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp"},{"text":"?) -> ","kind":"text"},{"text":"AsyncThrowingCompactMapSequence","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingCompactMapSequence","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency31AsyncThrowingCompactMapSequenceV"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ElementOfResult","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp"},{"text":">","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"An error-throwing mapping closure. "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"accepts an element of this sequence as its parameter and returns a"},{"type":"text","text":" "},{"type":"text","text":"transformed value of the same or of a different type. If "},{"code":"transform","type":"codeVoice"},{"text":" ","type":"text"},{"text":"throws an error, the sequence ends.","type":"text"}],"type":"paragraph"}],"name":"transform"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the"},{"type":"text","text":" "},{"type":"text","text":"non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" elements produced by the "},{"type":"codeVoice","code":"transform"},{"text":" closure. The sequence","type":"text"},{"text":" ","type":"text"},{"text":"ends either when the base sequence ends or when ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" throws an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}]}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" method to transform every element received from"},{"type":"text","text":" "},{"type":"text","text":"a base asynchronous sequence, while also discarding any "},{"type":"codeVoice","code":"nil"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"from the closure. Typically, you use this to transform from one type of","type":"text"},{"text":" ","type":"text"},{"text":"element to another.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" "},{"type":"text","text":"method takes each "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. Since there is no key for "},{"type":"codeVoice","code":"4"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" in this case, which ","type":"text"},{"code":"compactMap(_:)","type":"codeVoice"},{"text":" omits from the","type":"text"},{"text":" ","type":"text"},{"text":"transformed asynchronous sequence. When the value is ","type":"text"},{"code":"5","type":"codeVoice"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"throws ","type":"text"},{"code":"MyError","type":"codeVoice"},{"text":", terminating the sequence.","type":"text"}]},{"code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AsyncPrefixSequence/compactMap(_:)-7mqjp","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/asyncprefixsequence/compactmap(_:)-7mqjp"]}],"metadata":{"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","externalID":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF::SYNTHESIZED::s:12_Concurrency19AsyncPrefixSequenceV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"compactMap","kind":"identifier"},{"text":"<","kind":"text"},{"text":"ElementOfResult","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:Sci7ElementQa","kind":"typeIdentifier","text":"Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp","text":"ElementOfResult"},{"kind":"text","text":"?) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency31AsyncThrowingCompactMapSequenceV","text":"AsyncThrowingCompactMapSequence"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp","text":"ElementOfResult"},{"kind":"text","text":">"}],"extendedModule":"_Concurrency","title":"compactMap(_:)","modules":[{"relatedModules":[],"name":"Swift"}]},"references":{"doc:/