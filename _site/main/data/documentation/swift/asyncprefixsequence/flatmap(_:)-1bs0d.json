a single-level asynchronous sequence when your"},{"type":"text","text":" "},{"type":"text","text":"transformation produces an asynchronous sequence for each element."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" produces "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"code":"1","type":"codeVoice"},{"type":"text","text":" to "},{"code":"5","type":"codeVoice"},{"type":"text","text":". The transforming closure takes the received "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"and returns a new "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" that counts that high. For example, when the"},{"type":"text","text":" "},{"type":"text","text":"transform receives "},{"code":"3","type":"codeVoice"},{"type":"text","text":" from the base sequence, it creates a new "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"that produces the values "},{"code":"1","type":"codeVoice"},{"type":"text","text":", "},{"code":"2","type":"codeVoice"},{"type":"text","text":", and "},{"code":"3","type":"codeVoice"},{"type":"text","text":". The "},{"code":"flatMap(_:)","type":"codeVoice"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"“flattens” the resulting sequence-of-sequences into a single"},{"type":"text","text":" "},{"code":"AsyncSequence","type":"codeVoice"},{"type":"text","text":". However, when the closure receives "},{"code":"4","type":"codeVoice"},{"type":"text","text":", it throws an"},{"type":"text","text":" "},{"type":"text","text":"error, terminating the sequence."}]},{"type":"codeListing","code":["do {","    let stream = Counter(howHigh: 5)","        .flatMap { (value) -> Counter in","            if value == 4 {","                throw MyError()","            }","        