text","text":"An asynchronous sequence that contains, in order, the"},{"type":"text","text":" "},{"type":"text","text":"non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" elements produced by the "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" closure. The sequence"},{"type":"text","text":" "},{"type":"text","text":"ends either when the base sequence ends or when "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" throws an"},{"type":"text","text":" "},{"type":"text","text":"error."}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" method to transform every element received from"},{"type":"text","text":" "},{"type":"text","text":"a base asynchronous sequence, while also discarding any "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"text":"from the closure. Typically, you use this to transform from one type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"element to another."}]},{"type":"paragraph","inlineContent":[{"text":"In this example, an asynchronous sequence called ","type":"text"},{"code":"Counter","type":"codeVoice"},{"text":" produces ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" ","type":"text"},{"text":"values from ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"5","type":"codeVoice"},{"text":". The closure provided to the ","type":"text"},{"code":"compactMap(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"method takes each ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" and looks up a corresponding ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" from a","type":"text"},{"text":" ","type":"text"},{"code":"romanNumeralDict","type":"codeVoice"},{"text":" dictionary. Since there is no key for ","type":"text"},{"code":"4","type":"codeVoice"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" in this case, which ","type":"text"},{"code":"compactMap(_:)","type":"codeVoice"},{"text":" omits from the","type":"text"},{"text":" ","type":"text"},{"text":"transformed asynchronous sequence. When the value is ","type":"text"},{"code":"5","type":"codeVoice"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"throws ","type":"text"},{"code":"MyError","type":"codeVoice"},{"text":", terminating the sequence.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncPrefixWhileSequence"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/asyncprefixwhilesequence/compactmap(_:)-1wsos"]}],"sections":[],"abstract":[{"text":"Creates an asynchronous sequence that maps an error-throwing closure over","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the base sequence’s elements, omitting results that don’t return a value."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AsyncPrefixWhileSequence/compactMap(_:)-1wsos","interfaceLanguage":"swift"},