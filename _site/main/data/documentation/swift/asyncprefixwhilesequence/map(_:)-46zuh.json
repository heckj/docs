{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["/documentation/swift/asyncprefixwhilesequence/map(_:)-46zuh"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"Creates an asynchronous sequence that maps the given error-throwing","type":"text"},{"text":" ","type":"text"},{"text":"closure over the asynchronous sequence’s elements.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/AsyncPrefixWhileSequence/map(_:)-46zuh"},"kind":"symbol","metadata":{"extendedModule":"_Concurrency","title":"map(_:)","modules":[{"relatedModules":[],"name":"Swift"}],"roleHeading":"Instance Method","role":"symbol","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:Sci7ElementQa","kind":"typeIdentifier","text":"Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","kind":"typeIdentifier","text":"Transformed"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV","kind":"typeIdentifier","text":"AsyncThrowingMapSequence"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","kind":"typeIdentifier","text":"Transformed"},{"kind":"text","text":">"}],"externalID":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF::SYNTHESIZED::s:12_Concurrency24AsyncPrefixWhileSequenceV"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@preconcurrency"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"transform"},{"kind":"text","text":": "},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" "},{"kind":"attribute","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","text":"Element","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","preciseIdentifier":"s:Sci7ElementQa"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"AsyncThrowingMapSequence","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":">"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A mapping closure. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" accepts an element"},{"type":"text","text":" "},{"type":"text","text":"of this sequence as its parameter and returns a transformed value of the"},{"type":"text","text":" "},{"type":"text","text":"same or of a different type. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" can also throw an error, which"},{"type":"text","text":" "},{"type":"text","text":"ends the transformed sequence."}]}],"name":"transform"}]},{"content":[{"anchor":"return-value","level":2,"text":"Return Value","type":"heading"},{"inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the elements"},{"type":"text","text":" "},{"type":"text","text":"produced by the "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" closure."}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method to transform every element received from a base"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence. Typically, you use this to transform from one type"},{"type":"text","text":" "},{"type":"text","text":"of element to another."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"takes each "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. This means the outer "},{"type":"codeVoice","code":"for await in"},{"type":"text","text":" loop"},{"type":"text","text":" "},{"type":"text","text":"iterates over "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instances instead of the underlying "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"that "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces. Also, the dictionary doesn’t provide a key for"},{"type":"text","text":" "},{"type":"codeVoice","code":"4"},{"type":"text","text":", and the closure throws an error for any key it can’t look up, so"},{"type":"text","text":" "},{"type":"text","text":"receiving this value from "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" ends the modified sequence with an"},{"type":"text","text":" "},{"type":"text","text":"error."}],"type":"paragraph"},{"syntax":"swift","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncPrefixWhileSequence"]]},"references":{"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element":{"fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","abstract":[{"text":"The type of element produced by this asynchronous sequence.","type":"text"}],"type":"topic","role":"symbol","url":"/documentation/swift/asyncsequence/element","kind":"symbol","required":true,"title":"Element"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/AsyncPrefixWhileSequence":{"url":"/documentation/swift/asyncprefixwhilesequence","title":"AsyncPrefixWhileSequence","navigatorTitle":[{"kind":"identifier","text":"AsyncPrefixWhileSequence"}],"type":"topic","role":"symbol","abstract":[{"type":"text","text":"An asynchronous sequence, containing the initial, consecutive"},{"type":"text","text":" "},{"type":"text","text":"elements of the base sequence that satisfy a given predicate."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncPrefixWhileSequence"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncPrefixWhileSequence","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence":{"url":"/documentation/swift/asyncthrowingmapsequence","type":"topic","kind":"symbol","title":"AsyncThrowingMapSequence","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence","abstract":[{"type":"text","text":"An asynchronous sequence that maps the given error-throwing closure over the"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence’s elements."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncThrowingMapSequence"}],"navigatorTitle":[{"text":"AsyncThrowingMapSequence","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/AsyncPrefixWhileSequence/map(_:)-46zuh":{"url":"/documentation/swift/asyncprefixwhilesequence/map(_:)-46zuh","title"