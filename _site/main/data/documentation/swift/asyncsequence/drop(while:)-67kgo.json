{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncSequence"]]},"kind":"symbol","abstract":[{"text":"Omits elements from the base sequence until a given error-throwing closure","type":"text"},{"text":" ","type":"text"},{"text":"returns false, after which it passes through all remaining elements.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@preconcurrency"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"drop"},{"kind":"text","text":"("},{"kind":"externalParam","text":"while"},{"kind":"text","text":" "},{"kind":"internalParam","text":"predicate"},{"kind":"text","text":": "},{"text":"@Sendable","kind":"attribute"},{"text":" ","kind":"text"},{"text":"@escaping","kind":"attribute"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:Sci7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","text":"Element","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","text":"Bool","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:12_Concurrency30AsyncThrowingDropWhileSequenceV","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence","text":"AsyncThrowingDropWhileSequence","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"An error-throwing closure that takes an element as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a parameter and returns a Boolean value indicating whether to drop the"},{"type":"text","text":" "},{"text":"element from the modified sequence.","type":"text"}],"type":"paragraph"}],"name":"predicate"}]},{"content":[{"level":2,"type":"heading","anchor":"return-value","text":"Return Value"},{"inlineContent":[{"text":"An asynchronous sequence that skips over values until the","type":"text"},{"text":" ","type":"text"},{"text":"provided closure returns ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" or throws an error.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":"drop(while:)","type":"codeVoice"},{"text":" to omit elements from an asynchronous sequence until","type":"text"},{"text":" ","type":"text"},{"text":"the element received meets a condition you specify. If the closure you","type":"text"},{"text":" ","type":"text"},{"text":"provide throws an error, the sequence produces no elements and throws","type":"text"},{"text":" ","type":"text"},{"text":"the error instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" produces "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"code":"1","type":"codeVoice"},{"type":"text","text":" to "},{"code":"10","type":"codeVoice"},{"type":"text","text":". The predicate passed to the "},{"type":"codeVoice","code":"drop(while:)"},{"text":" ","type":"text"},{"text":"method throws an error if it encounters an even number, and otherwise","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returns "},{"type":"codeVoice","code":"true"},{"type":"text","text":" while it receives elements less than "},{"type":"codeVoice","code":"5"},{"type":"text","text":". Because the"},{"type":"text","text":" "},{"type":"text","text":"predicate throws when it receives "},{"type":"codeVoice","code":"2"},{"type":"text","text":" from the base sequence, this example"},{"type":"text","text":" "},{"type":"text","text":"throws without ever printing anything."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["do {","    let stream = Counter(howHigh: 10)","        .drop {","            if $0 % 2 == 0 {","                throw EvenError()","            }","            return $0 < 5","        }","    for try await number in stream {","        print(number)","    }","} catch {","    print(error)","}","// Prints \"EvenError()\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After the predicate returns "},{"code":"false","type":"codeVoice"},{"type":"text","text":", the sequence never executes it again,"},{"type":"text","text":" "},{"type":"text","text":"and from then on the sequence passes through elements from its underlying"},{"type":"text","text":" "},{"type":"text","text":"sequence. A predicate that throws an error also never executes again."}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/drop(while:)-67kgo","interfaceLanguage":"swift"},"seeAlsoSections":[{"anchor":"Excluding-Elements","title":"Excluding Elements","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/AsyncSequence/dropFirst(_:)","doc://com.apple.Swift/documentation/Swift/AsyncDropFirstSequence","doc://com.apple.Swift/documentation/Swift/AsyncSequence/drop(while:)-9sp3b","doc://com.apple.Swift/documentation/Swift/AsyncDropWhileSequence","doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence","doc://com.apple.Swift/documentation/Swift/AsyncSequence/filter(_:)-435af","doc://com.apple.Swift/documentation/Swift/AsyncFilterSequence","doc://com.apple.Swift/documentation/Swift/AsyncSequence/filter(_:)-2cc0l","doc://com.apple.Swift/documentation/Swift/AsyncThrowingFilterSequence"]}],"schemaVersion":{"minor":3,"major":0,"patch