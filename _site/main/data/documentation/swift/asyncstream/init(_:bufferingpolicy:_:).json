er"}],"url":"/documentation/swift/void","type":"topic"},"doc://com.apple.Swift/documentation/Swift/AsyncStream":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"AsyncStream"}],"abstract":[{"type":"text","text":"An asynchronous sequence generated from a closure that calls a continuation"},{"type":"text","text":" "},{"type":"text","text":"to produce new elements."}],"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncStream","title":"AsyncStream","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncStream"}],"url":"/documentation/swift/asyncstream","type":"topic"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"}}}