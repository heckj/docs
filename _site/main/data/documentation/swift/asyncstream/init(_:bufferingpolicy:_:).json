{"sections":[],"abstract":[{"type":"text","text":"Constructs an asynchronous stream for an element type, using the"},{"type":"text","text":" "},{"type":"text","text":"specified buffering policy and element-producing closure."}],"metadata":{"modules":[{"relatedModules":[],"name":"Swift"}],"roleHeading":"Initializer","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:ScS7Elementxmfp","text":"Element"},{"kind":"text","text":".Type, "},{"kind":"externalParam","text":"bufferingPolicy"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:ScS12ContinuationV","text":"Continuation"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:ScS12ContinuationV15BufferingPolicyO","text":"BufferingPolicy"},{"kind":"text","text":", ("},{"kind":"typeIdentifier","preciseIdentifier":"s:ScS12ContinuationV","text":"Continuation"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")"}],"symbolKind":"init","title":"init(_:bufferingPolicy:_:)","externalID":"s:ScS_15bufferingPolicy_ScSyxGxm_ScS12ContinuationV09BufferingB0Oyx__GyADyx_GXEtcfc"},"seeAlsoSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/AsyncStream/Continuation/BufferingPolicy","doc://com.apple.Swift/documentation/Swift/AsyncStream/Continuation"],"title":"Creating a Continuation-Based Stream","anchor":"Creating-a-Continuation-Based-Stream"}],"variants":[{"paths":["/documentation/swift/asyncstream/init(_:bufferingpolicy:_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/AsyncStream/init(_:bufferingPolicy:_:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"elementType"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:ScS7Elementxmfp"},{"kind":"text","text":".Type = Element.self, "},{"kind":"externalParam","text":"bufferingPolicy"},{"kind":"text","text":" "},{"text":"limit","kind":"internalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:ScS12ContinuationV","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncStream/Continuation","kind":"typeIdentifier","text":"Continuation"},{"kind":"text","text":"."},{"preciseIdentifier":"s:ScS12ContinuationV15BufferingPolicyO","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncStream/Continuation/BufferingPolicy","kind":"typeIdentifier","text":"BufferingPolicy"},{"text":" = .unbounded, ","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"build"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"Continuation","preciseIdentifier":"s:ScS12ContinuationV","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncStream/Continuation"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","identifier":"doc://com.apple.Swift/documentation/Swift/Void","text":"Void","kind":"typeIdentifier"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The type of element the "},{"type":"codeVoice","code":"AsyncStream"},{"type":"text","text":" produces."}]}],"name":"elementType"},{"name":"limit","content":[{"inlineContent":[{"text":"A ","type":"text"},{"code":"Continuation.BufferingPolicy","type":"codeVoice"},{"text":" value to","type":"text"},{"text":" ","type":"text"},{"text":"set the stream’s buffering behavior. By default, the stream buffers an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"unlimited number of elements. You can also set the policy to buffer a"},{"type":"text","text":" "},{"text":"specified number of oldest or newest elements.","type":"text"}],"type":"paragraph"}]},{"name":"build","content":[{"inlineContent":[{"text":"A custom closure that yields values to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"AsyncStream"},{"text":". This closure receives an ","type":"text"},{"type":"codeVoice","code":"AsyncStream.Continuation"},{"text":" ","type":"text"},{"text":"instance that it uses to provide elements to the stream and terminate the","type":"text"},{"text":" ","type":"text"},{"text":"stream when finished.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"AsyncStream.Continuation"},{"type":"text","text":" received by the "},{"type":"codeVoice","code":"build"},{"type":"text","text":" closure is"},{"type":"text","text":" "},{"type":"text","text":"appropriate for use in concurrent contexts. It is thread safe to send and"},{"type":"text","text":" "},{"type":"text","text":"finish; all calls to the continuation are serialized. However, calling"},{"type":"text","text":" "},{"type":"text","text":"this from multiple concurrent contexts could result in out-of-order"},{"type":"text","text":" "},{"type":"text","text":"delivery."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows an "},{"type":"codeVoice","code":"AsyncStream"},{"type":"text","text":" created with this"},{"type":"text","text":" "},{"type":"text","text":"initializer that produces 100 random numbers on a one-second interval,"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"yield(_:)"},{"type":"text","text":" to deliver each element to the awaiting call point."},{"type":"text","text":" "},{"type":"text","text":"When the "},{"type":"codeVoice","code":"for"},{"type":"text","text":" loop exits, the stream finishes by calling the"},{"type":"text","text":" "},{"type":"text","text":"continuation’s "},{"type":"codeVoice","code":"finish()"},{"type":"text","text":" method."}]},{"type":"codeListing","syntax":"swift","code":["let stream = AsyncStream<Int>(Int.self,","                              bufferingPolicy: .bufferingNewest(5)) { continuation in","    Task.detached {","        for _ in 0..<100 {","            await Task.sleep(1 * 1_000_000_000)","            continuation.yield(Int.random(in: 1...10))","        }","        continuation.finish()","    }","}","","// Call point:","for await random in stream {","    print(random)","}"]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncStream"]]},"references":{"doc://com.apple.Swift/documentation/Swift/AsyncStream/init(_:bufferingPolicy:_:)":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:ScS7Elementxmfp"},{"kind":"text","text":".Type, "},{"kind":"externalParam","text":"bufferingPolicy"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Continuation","preciseIdentifier":"s:ScS12ContinuationV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:ScS12ContinuationV15BufferingPolicyO","text":"BufferingPolicy"},{"kind":"text","text":", ("},{"kind":"typeIdentifier","preciseIdentifier":"s:ScS12ContinuationV","text":"Continuation"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")"}],"role":"symbol","url":"/documentation/swift/asyncstream/init(_:bufferingpolicy:_:)","abstract":[{"type":"text","text":"Constructs an asynchronous stream for an element type, using the"},{"type":"text","text":" "},{"type":"text","text":"specified buffering policy and element-producing closure."}],"identifier":"