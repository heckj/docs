{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/asyncstream/init(unfolding:oncancel:)"]}],"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@preconcurrency","kind":"attribute"},{"text":" ","kind":"text"},{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"unfolding"},{"text":" ","kind":"text"},{"text":"produce","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"attribute","text":"@Sendable"},{"text":" () ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:ScS7Elementxmfp"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"onCancel"},{"text":": (","kind":"text"},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" () -> "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")? = nil)"}]}],"kind":"declarations"},{"parameters":[{"name":"produce","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure that asynchronously produces elements for the"},{"type":"text","text":" "},{"type":"text","text":"stream."}]}]},{"name":"onCancel","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure to execute when canceling the stream’s task."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this convenience initializer when you have an asynchronous function","type":"text"},{"text":" ","type":"text"},{"text":"that can produce elements for the stream, and don’t want to invoke","type":"text"},{"text":" ","type":"text"},{"text":"a continuation manually. This initializer “unfolds” your closure into","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"an asynchronous stream. The created stream handles conformance"},{"text":" ","type":"text"},{"type":"text","text":"to the "},{"type":"codeVoice","code":"AsyncSequence"},{"type":"text","text":" protocol automatically, including termination"},{"type":"text","text":" "},{"type":"text","text":"(either by cancellation or by returning "},{"code":"nil","type":"codeVoice"},{"text":" from the closure to finish","type":"text"},{"type":"text","text":" "},{"text":"iteration).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following example shows an ","type":"text"},{"code":"AsyncStream","type":"codeVoice"},{"type":"text","text":" created with this"},{"type":"text","text":" "},{"text":"initializer that produces random numbers on a one-second interval. This","type":"text"},{"text":" ","type":"text"},{"text":"example uses the Swift multiple trailing closure syntax, which omits","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"unfolding"},{"text":" parameter label.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let stream = AsyncStream<Int> {","    await Task.sleep(1 * 1_000_000_000)","    return Int.random(in: 1...10)","} onCancel: { @Sendable () in print(\"Canceled.\") }","","// Call point:","for await random in stream {","    print(random)","}"]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the system might call the "},{"type":"codeVoice","code":"onCancel"},{"type":"text","text":" callback as"},{"type":"text","text":" "},{"text":"part of task cancellation, it’s subject to the same considerations for","type":"text"},{"text":" ","type":"text"},{"text":"avoiding deadlock as outlined in the documentation for","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/withTaskCancellationHandler(operation:onCancel:)"},{"text":".","type":"text"}]}],"type":"aside","name":"Note"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AsyncStream/init(unfolding:onCancel:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Constructs an asynchronous stream from a given element-producing"},{"type":"text","text":" "},{"type":"text","text":"closure, with an optional closure to handle cancellation."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"symbol","title":"init(unfolding:onCancel:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"unfolding","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" () "},{"text":"async","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:ScS7Elementxmfp","text":"Element","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"onCancel","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"@Sendable","kind":"attribute"},{"text":" () -> ","kind":"text"},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"text":")?)","kind":"text"}],"roleHeading":"Initializer","symbolKind":"init","modules":[{"name":"Swift","relatedModules":[]}],"externalID":"s:ScS9unfolding8onCancelScSyxGxSgyYac_yycSgtcfc"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncStream"]]},"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/AsyncStream/init(unfolding:onCancel:)":{"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"text":"unfolding","kind":"externalParam"},{"kind":"