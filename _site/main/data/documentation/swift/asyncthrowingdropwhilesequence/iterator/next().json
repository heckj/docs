{"sections":[],"abstract":[{"type":"text","text":"Produces the next element in the drop-while sequence."}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"next"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Base","preciseIdentifier":"s:12_Concurrency30AsyncThrowingDropWhileSequenceV4Basexmfp"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:Sci7ElementQa"},{"kind":"text","text":"?"}],"role":"symbol","externalID":"s:12_Concurrency30AsyncThrowingDropWhileSequenceV8IteratorV4next7ElementQzSgyYaKF","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"Swift","relatedModules":[]}],"title":"next()"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/asyncthrowingdropwhilesequence/iterator/next()"]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence/Iterator/next()","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"next"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency30AsyncThrowingDropWhileSequenceV4Basexmfp","text":"Base"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","preciseIdentifier":"s:Sci7ElementQa","text":"Element"},{"kind":"text","text":"?"}],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This iterator calls "},{"type":"codeVoice","code":"next()"},{"type":"text","text":" on its base iterator and evaluates the"},{"type":"text","text":" "},{"type":"text","text":"result with the "},{"type":"codeVoice","code":"predicate"},{"type":"text","text":" closure. As long as the predicate returns"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":", this method returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". After the predicate returns "},{"type":"codeVoice","code":"false"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"for a value received from the base iterator, this method returns that"},{"type":"text","text":" "},{"type":"text","text":"value. After that, the iterator returns values received from its"},{"type":"text","text":" "},{"type":"text","text":"base iterator as-is, and never executes the predicate closure again."},{"type":"text","text":" "},{"type":"text","text":"If calling the closure throws an error, the sequence ends and "},{"type":"codeVoice","code":"next()"},{"type":"text","text":" "},{"type":"text","text":"rethrows the error."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence","doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence/Iterator"]]},"references":{"doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence/Iterator/next()":{"url":"/documentation/swift/asyncthrowingdropwhilesequence/iterator/next()","title":"next()","abstract":[{"type":"text","text":"Produces the next element in the drop-while sequence."}],"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"next"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:12_Concurrency30AsyncThrowingDropWhileSequenceV4Basexmfp","kind":"typeIdentifier","text":"Base"},{"kind":"text","text":"."},{"preciseIdentifier":"s:Sci7ElementQa","kind":"typeIdentifier","text":"Element"},{"kind":"text","text":"?"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence/Iterator/next()","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence/Iterator":{"navigatorTitle":[{"kind":"identifier","text":"Iterator"}],"url":"/documentation/swift/asyncthrowingdropwhilesequence/iterator","title":"AsyncThrowingDropWhileSequence.Iterator","abstract":[{"text":"The iterator that produces elements of the drop-while sequence.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Iterator"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence/Iterator","role":"symbol","kind":"symbol","conformance":{"availabilityPrefix":[{"type":"text","text":"Available when"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"type":"codeVoice","code":"Base"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"AsyncSequence"},{"type":"text","text":"."}]}},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence":{"navigatorTitle":[{"text":"AsyncThrowingDropWhileSequence","kind":"identifier"}],"type":"topic","title":"AsyncThrowingDropWhileSequence","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingDropWhileSequence","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"An asynchronous sequence which omits elements from the base sequence until a"},{"type":"text","text":" "},{"type":"text","text":"given error-throwing closure returns false, after which it passes through"},{"type":"text","text":" "},{"type":"text","text":"all remaining elements."}],"url":"/documentation/swift/asyncthrowingdropwhilesequence","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncThrowingDropWhileSequence","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element":{"fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","abstract":[{"text":"The type of element produced by this asynchronous sequence.","type":"text"}],"type":"topic","role":"symbol","url":"/documentation/swift/asyncsequence/element","kind":"symbol","required":true,"title":"Element"}}}