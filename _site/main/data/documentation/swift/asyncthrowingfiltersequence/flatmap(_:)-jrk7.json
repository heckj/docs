its":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","abstract":[{"type":"text","text":"Creates an asynchronous sequence that concatenates the results of calling"},{"type":"text","text":" "},{"type":"text","text":"the given error-throwing transformation with each element of this"},{"type":"text","text":" "},{"type":"text","text":"sequence."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@preconcurrency","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"flatMap","kind":"identifier"},{"text":"<","kind":"text"},{"text":"SegmentOfResult","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"transform","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" ","kind":"text"},{"text":"@escaping","kind":"attribute"},{"text":" (","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:Sci7ElementQa"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"SegmentOfResult","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE7flatMapyAA017AsyncThrowingFlatC8SequenceVyxqd__Gqd__7ElementQzYaKcSciRd__lF15SegmentOfResultL_qd__mfp"},{"text":") -> ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingFlatMapSequence","text":"AsyncThrowingFlatMapSequence","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency28AsyncThrowingFlatMapSequenceV"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"SegmentOfResult","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE7flatMapyAA017AsyncThrowingFlatC8SequenceVyxqd__Gqd__7ElementQzYaKcSciRd__lF15SegmentOfResultL_qd__mfp"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SegmentOfResult","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence","text":"AsyncSequence","kind":"typeIdentifier","preciseIdentifier":"s:Sci"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"transform","content":[{"type":"paragraph","inlineContent":[{"text":"An error-throwing mapping closure. ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" ","type":"text"},{"text":"accepts an element of this sequence as its parameter and returns an","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"AsyncSequence"},{"text":". If ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" throws an error, the sequence ends.","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A single, flattened asynchronous sequence that contains all"},{"type":"text","text":" "},{"type":"text","text":"elements in all the asynchronous sequences produced by "},{"type":"codeVoice","code":"transform"},{"type":"text","text":". The"},{"type":"text","text":" "},{"type":"text","text":"sequence ends either when the last sequence created from the last"},{"type":"text","text":" "},{"type":"text","text":"element from base sequence ends, or when "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" throws an error."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to receive a single-level asynchronous sequence when your"},{"type":"text","text":" "},{"type":"text","text":"transformation produces an asynchronous sequence for each element."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The transforming closure takes the received "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"and returns a new "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" that counts that high. For example, when the"},{"type":"text","text":" "},{"type":"text","text":"transform receives "},{"type":"codeVoice","code":"3"},{"type":"text","text":" from the base sequence, it creates a new "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" "},{"type":"text","text":"that produces the values "},{"type":"codeVoice","code":"1"},{"type":"text","text":", "},{"type":"codeVoice","code":"2"},{"type":"text","text":", and "},{"type":"codeVoice","code":"3"},{"type":"text","text":". The "},{"type":"codeVoice","code":"flatMap(_:)"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"“flattens” the resulting sequence-of-sequences into a single"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncSequence"},{"type":"text","text":". However, when the closure receives "},{"type":"codeVoice","code":"4"},{"type":"text","text":", it throws an"},{"type":"text","text":" "},{"type":"text","text":"error, terminating the sequence."}]},{"type":"codeListing","code":["do {","    let stream = Counter(howHigh: 5)","        .flatMap { (value) -> Counter in","            if value == 4 {","                throw MyError()","            }","            return Counter(howHigh: value)","        }","    for try await number in stream {","        print(number, terminator: \" \")","    }","} catch {","    print(error)","}","// Prints \"1 1 2 1 2 3 MyError() \""],"syntax":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element":{"fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","abstract":[{"text":"The type of element produced by this asynchronous sequence.","type":"text"}],"type":"topic","role":"symbol","url":"/documentation/swift/asyncsequence/element","kind":"symbol","required":true,"title":"Element"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingFlatMapSequence":{"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingFlatMapSequence","abstract":[{"type":"text","text":"An asynchronous sequence that concatenates the results of calling a given"},{"type":"text","text":" "},{"type":"text","text":"error-throwing transformation with each element of this sequence."}],"type":"topic","role":"symbol","url":"/documentation/swift/asyncthrowingflatmapsequence","navigatorTitle":[{"kind":"identifier","text":"AsyncThrowingFlatMapSequence"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncThrowingFlatMapSequence"}],"title":"AsyncThrowingFlatMapSequence"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingFilterSequence":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncThrowingFilterSequence"}],"abstract":[{"type":"text","text":"An asynchronous sequence that contains, in order, the elements of"},{"type":"text","text":" "},{"type":"text","text":"the base sequence that satisfy the given error-throwing predicate."}],"navigatorTitle":[{"kind":"identifier","text":"AsyncThrowingFilterSequence"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingFilterSequence","type":"topic","url":"/documentation/swift/asyncthrowingfiltersequence","title":"AsyncThrowingFilterSequence","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/AsyncSequence":{"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence","abstract":[{"type":"text","text":"A type that provides asynchronous, sequential, iterated access to its"},{"type":"text","text":" "},{"type":"text","text":"elements."}],"type":"topic","role":"symbol","url":"/documentation/swift/asyncsequence","navigatorTitle":[{"kind":"identifier","text":"AsyncSequence"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncSequence"}],"title":"AsyncSequence"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingFilterSequence/flatMap(_:)-jrk7":{"type":"topic","title":"flatMap(_:)","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingFilterSequence/flatMap(_:)-jrk7","role":"symbol","abstract":[{"text":"Creates an asynchronous sequence that concatenates the results of calling","type":"text"},{"type":"text","text":" "},{"text":"the given error-throwing transformation with each element of this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"sequence."}],"url":"/documentation/swift/asyncthrowingfiltersequence/flatmap(_:)-jrk7","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"flatMap"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"SegmentOfResult"},{"kind":"text","text":">("},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci7ElementQa","text":"Element"},{"kind":"text","text":") "},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"tex