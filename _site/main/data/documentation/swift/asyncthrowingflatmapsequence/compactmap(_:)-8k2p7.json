ult"},{"kind":"text","text":">"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"An error-throwing mapping closure. ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" ","type":"text"},{"type":"text","text":"accepts an element of this sequence as its parameter and returns a"},{"text":" ","type":"text"},{"type":"text","text":"transformed value of the same or of a different type. If "},{"code":"transform","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"throws an error, the sequence ends."}]}],"name":"transform"}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the"},{"type":"text","text":" "},{"type":"text","text":"non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" elements produced by the "},{"code":"transform","type":"codeVoice"},{"text":" closure. The sequence","type":"text"},{"text":" ","type":"text"},{"text":"ends either when the base sequence ends or when ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" throws an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"error."}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"text":" method to transform every element received from","type":"text"},{"text":" ","type":"text"},{"text":"a base asynchronous sequence, while also discarding any ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"from the closure. Typically, you use this to transform from one type of","type":"text"},{"text":" ","type":"text"},{"text":"element to another.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In this example, an asynchronous sequence called ","type":"text"},{"code":"Counter","type":"codeVoice"},{"text":" produces ","type":"text"},{"code":"Int","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"5"},{"text":". The closure provided to the ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" "},{"type":"text","text":"method takes each "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"text":" from a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"romanNumeralDict"},{"text":" dictionary. Since there is no key for ","type":"text"},{"code":"4","type":"codeVoice"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" in this case, which "},{"type":"codeVoice","code":"compactMap(_:)"},{"text":" omits from the","type":"text"},{"text":" ","type":"text"},{"text":"transformed asynchronous sequence. When the value is ","type":"text"},{"type":"codeVoice","code":"5"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"throws ","type":"text"},{"type":"codeVoice","code":"MyError"},{"type":"text","text":", terminating the sequence."}]},{"type":"codeListing","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I I