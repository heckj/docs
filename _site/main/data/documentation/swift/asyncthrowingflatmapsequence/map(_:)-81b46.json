":"transform"},{"text":" accepts an element","type":"text"},{"text":" ","type":"text"},{"text":"of this sequence as its parameter and returns a transformed value of the","type":"text"},{"text":" ","type":"text"},{"text":"same or of a different type. ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" can also throw an error, which","type":"text"},{"text":" ","type":"text"},{"text":"ends the transformed sequence.","type":"text"}]}],"name":"transform"}]},{"kind":"content","content":[{"anchor":"return-value","type":"heading","text":"Return Value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the elements"},{"type":"text","text":" "},{"type":"text","text":"produced by the "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" closure."}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"Use the ","type":"text"},{"code":"map(_:)","type":"codeVoice"},{"text":" method to transform every element received from a base","type":"text"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence. Typically, you use this to transform from one type"},{"type":"text","text":" "},{"type":"text","text":"of element to another."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"takes each "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. This means the outer "},{"type":"codeVoice","code":"for await in"},{"type":"text","text":" loop"},{"type":"text","text":" "},{"type":"text","text":"iterates over "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instances instead of the underlying "},{"type":"codeVoice","code":"Int"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"that ","type":"text"},{"code":"Counter","type":"codeVoice"},{"text":" produces. Also, the dictionary doesn’t provide a key for","type":"text"},{"text":" ","type":"text"},{"code":"4","type":"codeVoice"},{"text":", and the closure throws an error for any key it can’t look up, so","type":"text"},{"text":" ","type":"text"},{"text":"receiving this value from ","type":"text"},{"code":"Counter","type":"codeVoice"},{"text":" ends the modified sequence with an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/AsyncTh