element received meets a condition you specify."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"10"},{"type":"text","text":". The "},{"type":"codeVoice","code":"drop(while:)"},{"type":"text","text":" method causes the modified"},{"type":"text","text":" "},{"type":"text","text":"sequence to ignore received values until it encounters one that is"},{"type":"text","text":" "},{"type":"text","text":"divisible by "},{"type":"codeVoice","code":"3"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["let stream = Counter(howHigh: 10)","    .drop { $0 % 3 != 0 }","for await number in stream {","    print(number, terminator: \" \")","}","// Prints \"3 4 5 6 7 8 9 10 \""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After the predicate returns "},{"type":"codeVoice","code":"false"},{"type":"text","text":", the sequence never executes it again,"},{"type":"text","text":" "},{"type":"text","text":"and from then on the sequence passes through elements from its underlying"},{"type":"text","text":" "},{"type":"text","text":"sequence as-is."}]}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence"]]},"references":{"doc://com.apple.Swift/documentation/Swift/AsyncDropWhileSequence":{"url":"/documentation/swift/asyncdropwhilesequence","kind":"symbol","type":"topic","title":"AsyncDropWhileSequence","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncDropWhileSequence","abstract":[{"type":"text","text":"An asynchronous sequence which omits elements from