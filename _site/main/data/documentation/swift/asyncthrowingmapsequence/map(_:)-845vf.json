{"abstract":[{"type":"text","text":"Creates an asynchronous sequence that maps the given error-throwing"},{"type":"text","text":" "},{"type":"text","text":"closure over the asynchronous sequence’s elements."}],"metadata":{"extendedModule":"_Concurrency","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" ("},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:Sci7ElementQa"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"text":" ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","text":"Transformed"},{"kind":"text","text":") -> "},{"text":"AsyncThrowingMapSequence","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","text":"Transformed"},{"text":">","kind":"text"}],"role":"symbol","roleHeading":"Instance Method","title":"map(_:)","symbolKind":"method","modules":[{"relatedModules":[],"name":"Swift"}],"externalID":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF::SYNTHESIZED::s:12_Concurrency24AsyncThrowingMapSequenceV"},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence/map(_:)-845vf"},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@preconcurrency"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"map","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Transformed","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"transform","kind":"internalParam"},{"kind":"text","text":": "},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" "},{"text":"@escaping","kind":"attribute"},{"text":" (","kind":"text"},{"text":"Element","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","preciseIdentifier":"s:Sci7ElementQa"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","kind":"typeIdentifier","text":"Transformed"},{"kind":"text","text":") -> "},{"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence","text":"AsyncThrowingMapSequence","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","text":"Transformed"},{"kind":"text","text":">"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"transform","content":[{"inlineContent":[{"type":"text","text":"A mapping closure. "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" accepts an element"},{"type":"text","text":" "},{"type":"text","text":"of this sequence as its parameter and returns a transformed value of the"},{"type":"text","text":" "},{"type":"text","text":"same or of a different type. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" can also throw an error, which"},{"type":"text","text":" "},{"type":"text","text":"ends the transformed sequence."}],"type":"paragraph"}]}]},{"content":[{"level":2,"anchor":"return-value","type":"heading","text":"Return Value"},{"inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the elements"},{"type":"text","text":" "},{"type":"text","text":"produced by the "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" closure."}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Use the ","type":"text"},{"code":"map(_:)","type":"codeVoice"},{"text":" method to transform every element received from a base","type":"text"},{"text":" ","type":"text"},{"text":"asynchronous sequence. Typically, you use this to transform from one type","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of element to another."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"text":" ","type":"text"},{"text":"values from ","type":"text"},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"text":". The closure provided to the ","type":"text"},{"code":"map(_:)","type":"codeVoice"},{"text":" method","type":"text"},{"text":" ","type":"text"},{"text":"takes each ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" and looks up a corresponding ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" from a","type":"text"},{"text":" ","type":"text"},{"code":"romanNumeralDict","type":"codeVoice"},{"text":" dictionary. This means the outer ","type":"text"},{"code":"for await in","type":"codeVoice"},{"text":" loop","type":"text"},{"text":" ","type":"text"},{"text":"iterates over ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" instances instead of the underlying ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"that ","type":"text"},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces. Also, the dictionary doesn’t provide a key for"},{"type":"text","text":" "},{"type":"codeVoice","code":"4"},{"type":"text","text":", and the closure throws an error for any key it can’t look up, so"},{"type":"text","text":" "},{"type":"text","text":"receiving this value from "},{"code":"Counter","type":"codeVoice"},{"text":" ends the modified sequence with an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""],"type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["/documentation/swift/asyncthrowingmapsequence/map(_:)-845vf"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element":{"title":"Element","role":"symbol","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","type":"topic","abstract":[{"text":"The type of element produced by this asynchronous sequence.","type":"text"}],"fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Element"}],"required":true,"url":"/documentation/swift/asyncsequence/element"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence":{"abstract":[{"type":"text","text":"An asynchronous sequence that maps the given error-throwing closure over the"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence’s elements."}],"kind":"symbol","title":"AsyncThrowingMapSequence","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence","url":"/documentation/swift/asyncthrowingmapsequence","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncThrowingMapSequence"}],"navigatorTitle":[{"kind":"identifier","text":"AsyncThrowingMapSequence"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence/map(_:)-845vf":{"abstract":[{"type":"text","text":"Creates an asynchronous sequence that maps the given error-throwing"},{"type":"text","text":" "},{"type":"text","text":"closure over the asynchronous sequence’s elements."}],"type":"topic","title":"map(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci7ElementQa","text":"Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","text":"Transformed"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV","text":"Async