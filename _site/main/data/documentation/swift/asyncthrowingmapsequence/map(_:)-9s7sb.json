},{"text":" ","kind":"text"},{"text":"map","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Transformed","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"transform","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" ","kind":"text"},{"text":"@escaping","kind":"attribute"},{"text":" (","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:Sci7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Transformed","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA16AsyncMapSequenceVyxqd__Gqd__7ElementQzYaclF11TransformedL_qd__mfp"},{"text":") -> ","kind":"text"},{"text":"AsyncMapSequence","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency16AsyncMapSequenceV","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncMapSequence"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Transformed","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA16AsyncMapSequenceVyxqd__Gqd__7ElementQzYaclF11TransformedL_qd__mfp"},{"text":">","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A mapping closure. "},{"code":"transform","type":"codeVoice"},{"type":"text","text":" accepts an element"},{"type":"text","text":" "},{"type":"text","text":"of this sequence as its parameter and returns a transformed value of the"},{"type":"text","text":" "},{"type":"text","text":"same or of a different type."}]}],"name":"transform"}],"kind":"parameters"},{"content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"An asynchronous sequence that contains, in order, the elements","type":"text"},{"text":" ","type":"text"},{"text":"produced by the ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" closure.","type":"text"}]}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"map(_:)"},{"text":" method to transform every element received from a base","type":"text"},{"text":" ","type":"text"},{"text":"asynchronous sequence. Typically, you use this to transform from one type","type":"text"},{"text":" ","type":"text"},{"text":"of element to another.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In this example, an asynchronous sequence called ","type":"text"},{"type":"codeVoice","code":"Counter"},{"text":" produces ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" ","type":"text"},{"text":"values from ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"5"},{"text":". The closure provided to the ","type":"text"},{"type":"codeVoice","code":"map(_:)"},{"text":" method","type":"text"},{"text":" ","type":"text"},{"text":"takes each ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" and looks up a corresponding ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" from a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"romanNumeralDict"},{"text":" dictionary. This means the outer ","type":"text"},{"type":"codeVoice","code":"for await in"},{"text":" loop","type":"text"},{"text":" ","type":"text"},{"text":"iterates over ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" instances instead of the underlying ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"that ","type":"text"},{"type":"codeVoice","code":"Counter"},{"text":" produces:","type":"text"}]},{"code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","let stream = Counter(howHigh: 5)","    .map { romanNumeralDict[$0] ?? \"(unknown)\" }","for await numeral in stream {","    print(numeral, terminator: \" \")","}","// Prints \"I II III (unknown) V \""],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence"]]},"references":{"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence":{"url":"/documentation/swift/asyncthrowingmapsequence","type":"topic","kind":"symbol","title":"AsyncThrowingMapSequence","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence","abstract":[{"type":"text","text":"An asynchronous sequence that maps the given error-throwing closure over the"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence’s elements."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncThrowingMapSequence"}],"navigatorTitle":[{"text":"AsyncThrowingMapSequence","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element":{"fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","abstract":[{"text":"The type of element produced by this asynchronous sequence.","type":"text"}],"type":"topic","role":"symbol","url":"/documentation/swift/asyncsequence/element","kind":"symbol","required":true,"title":"Element"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence/map(_:)-9s7sb":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"map","kind":"identifier"},{"text":"<","kind":"tex