sion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncThrowingPrefixWhileSequence"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@preconcurrency"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"compactMap"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"ElementOfResult"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"transform"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"kind":"text","text":" "},{"text":"@escaping","kind":"attribute"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","preciseIdentifier":"s:Sci7ElementQa","text":"Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp","text":"ElementOfResult","kind":"typeIdentifier"},{"text":"?) -> ","kind":"text"},{"text":"AsyncThrowingCompactMapSequence","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingCompactMapSequence","preciseIdentifier":"s:12_Concurrency31AsyncThrowingCompactMapSequenceV","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ElementOfResult","preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp","kind":"typeIdentifier"},{"kind":"text","text":">"}]}],"kind":"declarations"},{"parameters":[{"name":"transform","content":[{"inlineContent":[{"type":"text","text":"An error-throwing mapping closure. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" "},{"type":"text","text":"accepts an element of this sequence as its parameter and returns a"},{"type":"text","text":" "},{"type":"text","text":"transformed value of the same or of a different type. If "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" "},{"type":"text","text":"throws an error, the sequence ends."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the"},{"type":"text","text":" "},{"type":"text","text":"non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" elements produced by the "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" closure. The sequence"},{"type":"text","text":" "},{"text":"ends either when the base sequence ends or when ","type":"text"},{"type":"codeVoice","code":"transform"},{"type":"text","text":" throws an"},{"type":"text","text":" "},{"type":"text","text":"error."}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" method to transform every element received from"},{"type":"text","text":" "},{"type":"text","text":"a base asynchronous sequence, while also discarding any "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"from the closure. Typically, you use this to transform from one type of"},{"type":"text","text":" "},{"type":"text","text":"element to another."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"compactMap(_:)"},{"text":" ","type":"text"},{"type":"text","text":"method takes each "},{"type":"codeVoice","code":"Int"},{"text":" and looks up a corresponding ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" from a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. Since there is no key for "},{"type":"codeVoice","code":"4"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"text":"returns ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" in this case, which ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" omits from the"},{"type":"text","text":" "},{"type":"text","text":"transformed asynchronous sequence. When the value is "},{"type":"codeVoice","code":"5"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"text":"throws ","type":"text"},{"code":"MyError","type":"codeVoice"},{"type":"text","text":", terminating the sequence."}]},{"syntax":"swift","type":"codeListing","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}]}],"variants":[{"paths":["/documentation/swift/asyncthrowingprefixwhilesequence/compactmap(_:)-31ugu"],"traits":[{