{"abstract":[{"text":"Creates an asynchronous sequence that maps the given error-throwing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"closure over the asynchronous sequence’s elements."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@preconcurrency","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"transform"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"attribute","text":"@escaping"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:Sci7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","text":"Element","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","kind":"typeIdentifier","text":"Transformed"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence","text":"AsyncThrowingMapSequence","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","kind":"typeIdentifier","text":"Transformed"},{"kind":"text","text":">"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A mapping closure. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" accepts an element"},{"type":"text","text":" "},{"type":"text","text":"of this sequence as its parameter and returns a transformed value of the"},{"type":"text","text":" "},{"type":"text","text":"same or of a different type. "},{"type":"codeVoice","code":"transform"},{"text":" can also throw an error, which","type":"text"},{"text":" ","type":"text"},{"text":"ends the transformed sequence.","type":"text"}],"type":"paragraph"}],"name":"transform"}]},{"kind":"content","content":[{"level":2,"anchor":"return-value","text":"Return Value","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"An asynchronous sequence that contains, in order, the elements","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"produced by the "},{"type":"codeVoice","code":"transform"},{"text":" closure.","type":"text"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method to transform every element received from a base"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence. Typically, you use this to transform from one type"},{"type":"text","text":" "},{"type":"text","text":"of element to another."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" produces "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"takes each "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. This means the outer "},{"type":"codeVoice","code":"for await in"},{"type":"text","text":" loop"},{"type":"text","text":" "},{"text":"iterates over ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" instances instead of the underlying ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"that ","type":"text"},{"code":"Counter","type":"codeVoice"},{"type":"text","text":" produces. Also, the dictionary doesn’t provide a key for"},{"type":"text","text":" "},{"type":"codeVoice","code":"4"},{"type":"text","text":", and the closure throws an error for any key it can’t look up, so"},{"type":"text","text":" "},{"text":"receiving this value from ","type":"text"},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" ends the modified sequence with an"},{"type":"text","text":" "},{"text":"error.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""],"syntax":"swift"}]}],"variants":[{"paths":["/documentation/swift/asyncthrowingprefixwhilesequence/map(_:)-60mi5"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingPrefixWhileSequence/map(_:)