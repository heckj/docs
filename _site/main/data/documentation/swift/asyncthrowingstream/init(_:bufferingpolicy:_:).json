{"abstract":[{"text":"Constructs an asynchronous stream for an element type, using the","type":"text"},{"text":" ","type":"text"},{"text":"specified buffering policy and element-producing closure.","type":"text"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream"]]},"metadata":{"externalID":"s:Scs_15bufferingPolicy_Scsyxs5Error_pGxm_Scs12ContinuationV09BufferingB0OyxsAB_p__GyAEyxsAB_p_GXEtcsAB_pRs_rlufc","symbolKind":"init","title":"init(_:bufferingPolicy:_:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:Scs7Elementxmfp"},{"text":".Type, ","kind":"text"},{"text":"bufferingPolicy","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Continuation","kind":"typeIdentifier","preciseIdentifier":"s:Scs12ContinuationV"},{"text":".","kind":"text"},{"text":"BufferingPolicy","kind":"typeIdentifier","preciseIdentifier":"s:Scs12ContinuationV15BufferingPolicyO"},{"text":", (","kind":"text"},{"text":"Continuation","kind":"typeIdentifier","preciseIdentifier":"s:Scs12ContinuationV"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")","kind":"text"}],"modules":[{"relatedModules":[],"name":"Swift"}],"role":"symbol","roleHeading":"Initializer"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/asyncthrowingstream/init(_:bufferingpolicy:_:)"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/init(_:bufferingPolicy:_:)"},"seeAlsoSections":[{"generated":true,"title":"Creating a Continuation-Based Stream","identifiers":["doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation/BufferingPolicy","doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation"],"anchor":"Creating-a-Continuation-Based-Stream"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"elementType","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Scs7Elementxmfp","text":"Element","kind":"typeIdentifier"},{"text":".Type = Element.self, ","kind":"text"},{"text":"bufferingPolicy","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"limit"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation","text":"Continuation","preciseIdentifier":"s:Scs12ContinuationV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation/BufferingPolicy","text":"BufferingPolicy","preciseIdentifier":"s:Scs12ContinuationV15BufferingPolicyO"},{"kind":"text","text":" = .unbounded, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"build"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation","text":"Continuation","preciseIdentifier":"s:Scs12ContinuationV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Void","text":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Failure"},{"kind":"text","text":" == any "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Error","text":"Error","preciseIdentifier":"s:s5ErrorP"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"elementType","content":[{"type":"paragraph","inlineContent":[{"text":"The type of element the ","type":"text"},{"code":"AsyncThrowingStream","type":"codeVoice"},{"text":" ","type":"text"},{"text":"produces.","type":"text"}]}]},{"name":"limit","content":[{"type":"paragraph","inlineContent":[{"text":"The maximum number of elements to","type":"text"},{"text":" ","type":"text"},{"text":"hold in the buffer. By default, this value is unlimited. Use a","type":"text"},{"text":" ","type":"text"},{"code":"Continuation.BufferingPolicy","type":"codeVoice"},{"text":" to buffer a specified number of oldest","type":"text"},{"text":" ","type":"text"},{"text":"or newest elements.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A custom closure that yields values to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncThrowingStream"},{"type":"text","text":". This closure receives an"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncThrowingStream.Continuation"},{"type":"text","text":" instance that it uses to provide"},{"type":"text","text":" "},{"type":"text","text":"elements to the stream and terminate the stream when finished."}]}],"name":"build"}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"The "},{"code":"AsyncStream.Continuation","type":"codeVoice"},{"type":"text","text":" received by the "},{"code":"build","type":"codeVoice"},{"type":"text","text":" closure is"},{"type":"text","text":" "},{"type":"text","text":"appropriate for use in concurrent contexts. It is thread safe to send and"},{"type":"text","text":" "},{"type":"text","text":"finish; all calls are to the continuation are serialized. However, calling"},{"type":"text","text":" "},{"type":"text","text":"this from multiple concurrent contexts could result in out-of-order"},{"type":"text","text":" "},{"type":"text","text":"delivery."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example shows an "},{"type":"codeVoice","code":"AsyncStream"},{"type":"text","text":" created with this"},{"text":" ","type":"text"},{"text":"initializer that produces 100 random numbers on a one-second interval,","type":"text"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"yield(_:)"},{"type":"text","text":" to deliver each element to the awaiting call point."},{"type":"text","text":" "},{"type":"text","text":"When the "},{"type":"codeVoice","code":"for"},{"type":"text","text":" loop exits, the stream finishes by calling the"},{"text":" ","type":"text"},{"text":"continuation’s ","type":"text"},{"type":"codeVoice","code":"finish()"},{"type":"text","text":" method. If the random number is divisible by 5"},{"type":"text","text":" "},{"text":"with no remainder, the stream throws a ","type":"text"},{"code":"MyRandomNumberError","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let stream = AsyncThrowingStream<Int, Error>(Int.self,","                                             bufferingPolicy: .bufferingNewest(5)) { continuation in","    Task.detached {","        for _ in 0..<100 {","            await Task.sleep(1 * 1_000_000_000)","            let random = Int.random(in: 1...10)","            if random % 5 == 0 {","                continuation.finish(throwing: MyRandomNumberError())","                return","            } else {","                continuation.yield(random)","            }","        }","        continuation.finish()","    }","}","","// Call point:","do {","    for try await random in stream {","        print(random)","    }","} catch {","    print(error)","}"]}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream":{"type":"topic","kind":"symbol","abstract":[{"text":"An asynchronous sequence generated from an error-throwing closure that","type":"text"},{"text":" ","type":"text"},{"text":"calls a continuation to produce new elements.",