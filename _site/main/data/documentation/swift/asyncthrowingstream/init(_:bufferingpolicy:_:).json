{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/init(_:bufferingPolicy:_:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream"]]},"kind":"symbol","seeAlsoSections":[{"anchor":"Creating-a-Continuation-Based-Stream","identifiers":["doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation/BufferingPolicy","doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation"],"generated":true,"title":"Creating a Continuation-Based Stream"}],"metadata":{"externalID":"s:Scs_15bufferingPolicy_Scsyxs5Error_pGxm_Scs12ContinuationV09BufferingB0OyxsAB_p__GyAEyxsAB_p_GXEtcsAB_pRs_rlufc","role":"symbol","roleHeading":"Initializer","modules":[{"name":"Swift","relatedModules":[]}],"title":"init(_:bufferingPolicy:_:)","symbolKind":"init","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Scs7Elementxmfp","text":"Element","kind":"typeIdentifier"},{"kind":"text","text":".Type, "},{"kind":"externalParam","text":"bufferingPolicy"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Scs12ContinuationV","kind":"typeIdentifier","text":"Continuation"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"BufferingPolicy","preciseIdentifier":"s:Scs12ContinuationV15BufferingPolicyO"},{"kind":"text","text":", ("},{"kind":"typeIdentifier","text":"Continuation","preciseIdentifier":"s:Scs12ContinuationV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":")"}]},"abstract":[{"text":"Constructs an asynchronous stream for an element type, using the","type":"text"},{"text":" ","type":"text"},{"text":"specified buffering policy and element-producing closure.","type":"text"}],"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"elementType","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:Scs7Elementxmfp"},{"text":".Type = Element.self, ","kind":"text"},{"text":"bufferingPolicy","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"limit","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Continuation","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation","preciseIdentifier":"s:Scs12ContinuationV"},{"text":".","kind":"text"},{"text":"BufferingPolicy","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation/BufferingPolicy","preciseIdentifier":"s:Scs12ContinuationV15BufferingPolicyO"},{"text":" = .unbounded, ","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"build","kind":"internalParam"},{"text":": (","kind":"text"},{"text":"Continuation","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/Continuation","preciseIdentifier":"s:Scs12ContinuationV"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Void","preciseIdentifier":"s:s4Voida"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Failure","kind":"typeIdentifier"},{"text":" == any ","kind":"text"},{"text":"Error","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Error","preciseIdentifier":"s:s5ErrorP"}]}],"kind":"declarations"},{"parameters":[{"name":"elementType","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The type of element the "},{"type":"codeVoice","code":"AsyncThrowingStream"},{"type":"text","text":" "},{"type":"text","text":"produces."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The maximum number of elements to"},{"type":"text","text":" "},{"type":"text","text":"hold in the buffer. By default, this value is unlimited. Use a"},{"type":"text","text":" "},{"type":"codeVoice","code":"Continuation.BufferingPolicy"},{"type":"text","text":" to buffer a specified number of oldest"},{"type":"text","text":" "},{"type":"text","text":"or newest elements."}]}],"name":"limit"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A custom closure that yields values to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncThrowingStream"},{"type":"text","text":". This closure receives an"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncThrowingStream.Continuation"},{"type":"text","text":" instance that it uses to provide"},{"type":"text","text":" "},{"type":"text","text":"elements to the stream and terminate the stream when finished."}]}],"name":"build"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"AsyncStream.Continuation"},{"type":"text","text":" received by the "},{"type":"codeVoice","code":"build"},{"type":"text","text":" closure is"},{"type":"text","text":" "},{"type":"text","text":"appropriate for use in concurrent contexts. It is thread safe to send and"},{"type":"text","text":" "},{"type":"text","text":"finish; all calls to the continuation are serialized. However, calling"},{"type":"text","text":" "},{"type":"text","text":"this from multiple concurrent contexts could result in out-of-order"},{"type":"text","text":" "},{"type":"text","text":"delivery."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows an "},{"type":"codeVoice","code":"AsyncStream"},{"type":"text","text":" created with this"},{"type":"text","text":" "},{"type":"text","text":"initializer that produces 100 random numbers on a one-second interval,"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"yield(_:)"},{"type":"text","text":" to deliver each element to the awaiting call point."},{"type":"text","text":" "},{"type":"text","text":"When the "},{"type":"codeVoice","code":"for"},{"type":"text","text":" loop exits, the stream finishes by calling the"},{"type":"text","text":" "},{"type":"text","text":"continuation’s "},{"type":"codeVoice","code":"finish()"},{"type":"text","text":" method. If the random number is divisible by 5"},{"type":"text","text":" "},{"type":"text","text":"with no remainder, the stream throws a "},{"type":"codeVoice","code":"MyRandomNumberError"},{"type":"text","text":"."}]},{"type":"codeListing","code":["let stream = AsyncThrowingStream<Int, Error>(Int.self,","                                             bufferingPolicy: .bufferingNewest(5)) { continuation in","    Task.detached {","        for _ in 0..<100 {","            await Task.sleep(1 * 1_000_000_000)","            let random = Int.random(in: 1...10)","            if random % 5 == 0 {","                continuation.finish(throwing: MyRandomNumberError())","                return","            } else {","                continuation.yield(random)","            }","        }","        continuation.finish()","    }","}","","// Call point:","do {","    for try await random in stream {","        print(random)","    }","} catch {","    print(error)","}"],"syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/asyncthrowingstream/init(_:bufferingpolicy:_:)"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.apple.Swift/documentation/Swift/Void":{"kind":"symbol","navigatorTitle":[{"text":"Void","kind":"identifier"}],"title":"Void","abstract":[{"type":"text","text":"The return type of functions that don’t explicitly specify a return type,"},{"text":" ","type":"text"},{"type":"text","t