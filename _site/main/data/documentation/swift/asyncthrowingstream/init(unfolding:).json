typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Failure","kind":"typeIdentifier"},{"text":" == any ","kind":"text"},{"text":"Error","identifier":"doc://com.apple.Swift/documentation/Swift/Error","preciseIdentifier":"s:s5ErrorP","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"produce","content":[{"type":"paragraph","inlineContent":[{"text":"A closure that asynchronously produces elements for the","type":"text"},{"text":" ","type":"text"},{"text":"stream.","type":"text"}]}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Use this convenience initializer when you have an asynchronous function","type":"text"},{"text":" ","type":"text"},{"text":"that can produce elements for the stream, and don’t want to invoke","type":"text"},{"text":" ","type":"text"},{"text":"a continuation manually. This initializer “unfolds” your closure into","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a full-blown asynchronous stream. The created stream handles adherence to"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"AsyncSequence","type":"codeVoice"},{"text":" protocol automatically. To terminate the stream with","type":"text"},{"text":" ","type":"text"},{"text":"an error, throw the error from your closure.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following example shows an ","type":"text"},{"type":"codeVoice","code":"AsyncThrowingStream"},{"type":"text","text":" created with this"},{"type":"text","text":" "},{"type":"text","text":"initializer that produces random numbers on a one-second interval. If the"},{"type":"text","text":" "},{"type":"text","text":"random number is divisible by 5 with no remainder, the stream throws a"},{"type":"text","text":" "},{"type":"codeVoice","code":"MyRandomNumberError"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["let stream = AsyncThrowingStream<Int, Error> {","    await Task.sleep(1 * 1_000_000_000)","    let random = Int.random(in: 1...10)","    if random % 5 == 0 {","        throw MyRandomNumberError()","    }","    return random","}","","// Call point:","do {","    for try await random in stream {","        print(random)","    }","} catch {","    print(error)","}"]}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream":{"type":"topic","kind":"symbol","abstract":[{"text":"An asynchronous sequence generated from an error-throwing closure that","type":"text"},{"text":" ","type":"text"},{"text":"calls a continuation to produce new elements.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"AsyncThrowingStream"}],"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncThrowingStream","kind":"identifier"}],"url":"/documentation/swift/asyncthrowingstream","title":"AsyncThrowingStream"},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/init(unfolding:)":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"unfolding"},{"kind":"text","text":": "},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" () "},{"text":"async","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:Scs7Elementxmfp"},{"kind":"text","text":"?)"}],"abstract":[{"t