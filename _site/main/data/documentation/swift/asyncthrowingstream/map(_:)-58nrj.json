ibute","text":"@preconcurrency"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"text":"transform","kind":"internalParam"},{"text":": ","kind":"text"},{"kind":"attribute","text":"@Sendable"},{"text":" ","kind":"text"},{"kind":"attribute","text":"@escaping"},{"text":" (","kind":"text"},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:Sci7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Transformed","kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV","text":"AsyncThrowingMapSequence","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncThrowingMapSequence"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":">"}],"languages":["swift"]}]},{"parameters":[{"name":"transform","content":[{"inlineContent":[{"text":"A mapping closure. ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" accepts an element","type":"text"},{"text":" ","type":"text"},{"text":"of this sequence as its parameter and returns a transformed value of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"same or of a different type. "},{"type":"codeVoice","code":"transform"},{"text":" can also throw an error, which","type":"text"},{"text":" ","type":"text"},{"text":"ends the transformed sequence.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"inlineContent":[{"text":"An asynchronous sequence that contains, in order, the elements","type":"text"},{"text":" ","type":"text"},{"text":"produced by the ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" closure.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method to transform every element received from a base"},{"text":" ","type":"text"},{"type":"text","text":"asynchronous sequence. Typically, you use this to transform from one type"},{"text":" ","type":"text"},{"type":"text","text":"of element to another."}]},{"type":"paragraph","inlineContent":[{"text":"In this example, an asynchronous sequence called ","type":"text"},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"takes each "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. This means the outer "},{"type":"codeVoice","code":"for await in"},{"type":"text","text":" loop"},{"type":"text","text":" "},{"type":"text","text":"iterates over "},{"type":"codeVoice","code":"String"},{"text":" instances instead of the underlying ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" values","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that "},{"type":"codeVoice","code":"Counter"},{"text":" produces. Also, the dictionary doesn’t provide a key for","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"4"},{"type":"text","text":", and the closure throws an error for any key it can’t look up, so"},{"text":" ","type":"text"},{"type":"text","text":"receiving this value from "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" ends the modified sequence with an"},{"text":" ","type":"text"},{"type":"text","text":"error."}]},{"type":"codeListing","syntax":"swift","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""]}]}],"variants":[{"paths":["/documentation/swift/asyncthrowingstream/map(_:)-58nrj"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/map(_:)-4a4ke","doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/compactMap(_:)-7mgih","doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/compactMap(_:)-944nt","doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/flatMap(_:)-vhin","doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/reduce(_:_:)","doc://com.apple.Swift/documentat