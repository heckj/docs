,"text":"BinaryInteger"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/CustomStringConvertible","text":"CustomStringConvertible","preciseIdentifier":"s:s23CustomStringConvertibleP"},{"kind":"text","text":", "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Hashable","text":"Hashable","preciseIdentifier":"s:SH"},{"kind":"text","text":", "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric","text":"Numeric","preciseIdentifier":"s:Sj"},{"kind":"text","text":", "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Strideable","text":"Strideable","preciseIdentifier":"s:Sx"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric/Magnitude-swift.associatedtype","text":"Magnitude","preciseIdentifier":"s:Sj9MagnitudeQa"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/BinaryInteger","text":"BinaryInteger","preciseIdentifier":"s:Sz"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric/Magnitude-swift.associatedtype","text":"Magnitude","preciseIdentifier":"s:Sj9MagnitudeQa"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric/Magnitude-swift.associatedtype","text":"Magnitude","preciseIdentifier":"s:Sj9MagnitudeQa"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric/Magnitude-swift.associatedtype","text":"Magnitude","preciseIdentifier":"s:Sj9MagnitudeQa"}]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"BinaryInteger"},{"text":" protocol is the basis for all the integer types","type":"text"},{"text":" ","type":"text"},{"text":"provided by the standard library. All of the standard library’s integer","type":"text"},{"text":" ","type":"text"},{"text":"types, such as ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"UInt32"},{"text":", conform to ","type":"text"},{"type":"codeVoice","code":"BinaryInteger"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","level":1,"text":"Converting Between Numeric Types","anchor":"Converting-Between-Numeric-Types"},{"inlineContent":[{"text":"You can create new instances of a type that conforms to the ","type":"text"},{"code":"BinaryInteger","type":"codeVoice"},{"text":" ","type":"text"},{"text":"protocol from a floating-point number or another binary integer of any","type":"text"},{"text":" ","type":"text"},{"text":"type. The ","type":"text"},{"code":"BinaryInteger","type":"codeVoice"},{"text":" protocol provides initializers for four","type":"text"},{"text":" ","type":"text"},{"text":"different kinds of conversion.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"Range-Checked Conversion","anchor":"Range-Checked-Conversion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You use the default "},{"code":"init(_:)","type":"codeVoice"},{"type":"text","text":" initializer to create a new instance when"},{"type":"text","text":" "},{"type":"text","text":"you’re sure that the value passed is representable in the new type. For"},{"type":"text","text":" "},{"type":"text","text":"example, an instance of "},{"type":"codeVoice","code":"Int16"},{"type":"text","text":" can represent the value "},{"type":"codeVoice","code":"500"},{"type":"text","text":", so the"},{"type":"text","text":" "},{"type":"text","text":"first conversion in the code sample below succeeds. That same value is too"},{"type":"text","text":" "},{"type":"text","text":"large to represent as an "},{"type":"codeVoice","code":"Int8"},{"type":"text","text":" instance, so the second conversion fails,"},{"type":"text","text":" "},{"type":"text","text":"triggering a runtime error."}]},{"syntax":"swift","type":"codeListing","code":["let x: Int = 500","let y = Int16(x)","// y == 500","","let z = Int8(x)","// Error: Not enough bits to represent..."]},{"type":"paragraph","inlineContent":[{"text":"When you create a binary integer from a floating-point value using the","type":"text"},{"text":" ","type":"text"},{"text":"default initializer, the value is rounded toward zero before the range is","type":"text"},{"text":" ","type":"text"},{"text":"checked. In the following example, the value ","type":"text"},{"code":"127.75","type":"codeVoice"},{"text":" is rounded to ","type":"text"},{"code":"127","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which is representable by the ","type":"text"},{"code":"Int8","type":"codeVoice"},{"text":" type.  ","type":"text"},{"code":"128.25","type":"codeVoice"},{"text":" is rounded to ","type":"text"},{"code":"128","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which is not representable as an ","type":"text"},{"code":"Int8","type":"codeVoice"},{"text":" instance, triggering a runtime","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let e = Int8(127.75)","// e == 127","","let f = Int8(128.25)","// Error: Double value cannot be converted..."]},{"text":"Exact Conversion","anchor":"Exact-Conversion","type":"heading","level":2},{"inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"init?(exactly:)"},{"text":" initializer to create a new instance after","type":"text"},{"text":" ","type":"text"},{"text":"checking whether the passed value is representable. Instead of trapping on","type":"text"},{"text":" ","type":"text"},{"text":"out-of-range values, using the failable ","type":"text"},{"type":"codeVoice","code":"init?(exactly:)"},{"text":" ","type":"text"},{"text":"initializer results in ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let x = Int16(exactly: 500)","// x == Optional(500)","","let y = Int8(exactly: 500)","// y == nil"]},{"type":"paragraph","inlineContent":[{"text":"When converting floating-point values, the ","type":"text"},{"code":"init?(exactly:)","type":"codeVoice"},{"text":" initializer","type":"text"},{"text":" ","type":"text"},{"text":"checks both that the passed value has no fractional part and that the","type":"text"},{"text":" ","type":"text"},{"text":"value is representable in the resulting type.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let e = Int8(exactly: 23.0)       // integral value, representable","// e == Optional(23)","","let f = Int8(exactly: 23.75)      // fractional value, representable","// f == nil","","let g = Int8(exactly: 500.0)      // integral value, nonrepresentable","// g == nil"]},{"type":"heading","level":2,"text":"Clamping Conversion","anchor":"Clamping-Conversion"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"init(clamping:)"},{"text":" initializer to create a new instance of a binary","type":"text"},{"text":" ","type":"text"},{"text":"integer type where out-of-range values are clamped to the representable","type":"text"},{"text":" ","type":"text"},{"text":"range of the type. For a type ","type":"text"},{"type":"codeVoice","code":"T"},{"text":", the resulting value is in the range","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"T.min...T.max"},{"text":".","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let x = Int16(clamping: 500)","// x == 500","","let y = Int8(clamping: 500)","// y == 127","","let z = UInt8(clamping: -500)","// z == 0"]},{"type":"heading","level":2,"text":"Bit Pattern Conversion","anchor":"Bit-Pattern-Conversion"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"init(truncatingIfNeeded:)"},{"text":" initializer to create a new instance","type":"text"},{"text":" ","type":"text"},{"text":"with the same bit pattern as the passed value, extending or truncating the","type":"text"},{"text":" ","type":"text"},{"text":"value’s representation as necessary. Note that the value may not be","type":"text"},{"text":" ","type":"text"},{"text":"preserved, particularly when converting between signed to unsigned integer","type":"text"},{"text":" ","type":"text"},{"text":"types or when the destination type has a smaller bit width than the source","type":"text"},{"text":" ","type":"text"},{"text":"type. The following example shows how extending and truncating work for","type":"text"},{"text":" ","type":"text"},{"text":"nonnegative integers:","type":"text"}]},{"code":["let q: Int16 = 850","// q == 0b00000011_01010010","","let r = Int8(truncatingIfNeeded: q)      // truncate 'q' to fit in 8 bits","// r == 82","//   == 0b01010010","","let s = Int16(truncatingIfNeeded: r)     // extend 'r' to fill 16 bits","// s == 82","//   == 0b00000000_01010010"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Any padding is performed by "},{"type":"emphasis","inlineContent":[{"type":"text","text":"sign-extending"}]},{"type":"text","text":" the passed value. When"},{"type":"text","text":" "},{"type":"text","text":"nonnegative integers are extended, the result is padded with zeroes. When"},{"type":"text","text":" "},{"type":"text","text":"negative integers are extended, the result is padded with ones. This"},{"type":"text","text":" "},{"type":"text","text":"example shows several extending conversions of a negative value—note"},{"type":"text","text":" "},{"text":"that negative values are sign-extended even when converting to an unsigned","type":"text"},{"text":" ","type":"text"},{"text":"type.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let t: Int8 = -100","// t == -100","// t's binary representation == 0b10011100","","let u = UInt8(truncatingIfNeeded: t)","// u == 156","// u's binary representation == 0b10011100","","let v = Int16(truncatingIfNeeded: t)","// v == -100","// v's binary representation == 0b11111111_10011100","","let w = UInt16(truncatingIfNeeded: t)","// w == 65436","// w's binary representation == 0b11111111_10011100"]},{"anchor":"Comparing-Across-Integer-Types","level":1,"text":"Comparing Across Integer Types","type":"heading"},{"inlineContent":[{"text":"You can use relational operators, such as the less-than and equal-to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operators ("},{"type":"codeVoice","code":"<"},{"text":" and ","type":"text"},{"code":"==","type":"codeVoice"},{"type":"text","text":"), to compare instances of different binary integer"},{"text":" ","type":"text"},{"text":"types. The following example compares instances of the ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":", ","type":"text"},{"code":"UInt","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"UInt8","type":"codeVoice"},{"text":" types:","type":"text"}],"type":"paragraph"},{"code":["let x: Int = -23","let y: UInt = 1_000","let z: UInt8 = 23","","if x < y {","    print(\"\\(x) is less than \\(y).\")","}","// Prints \"-23 is less than 1000.\"","","if z > x {","    print(\"\\(z) is greater than \\(x).\")","}","// Prints \"23 is greater than -23.\""],"type":"codeListing","syntax":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"kind":"symbol","abstract":[{"text":"An integer type with a binary representation.","type":"text"}],"topicSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/BinaryInteger/init()"],"anchor":"Creating-a-Binary-Integer","title":"Creating a Binary Integer"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/BinaryInteger/init(_:)-8gmdl","doc://com.apple.Swift/documentation/Swift/BinaryInteger/init(clamping:)","doc://com.apple.Swift/documentation/Swift/BinaryInteger/init(truncatingIfNeeded:)"],"anchor":"Converting-Integers","title":"Converting Integers"},{"anchor":"Converting-Floating-Point-Values","title":"Converting Floating-Point Values","identifiers":["doc://com.apple.Swift/documentation/Swift/BinaryInteger/init(_:)-2ln0u"]},{"identifiers":["doc://com.apple.Swift/documentation/Swift/BinaryInteger/init(exactly:)"],"title":"Converting with No Loss of Precision","anchor":"Converting-with-No-Loss-of-Precision"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/binary-integer-operators","doc://com.apple.Swift/documentation/Swift/BinaryInteger/quotientAndRemainder(dividingBy:)","doc://com.apple.Swift/documentation/Swift/BinaryInteger/isMultiple(of:)"],"title":"Performing Calculations","anchor":"Performing-Calculations"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/BinaryInteger/signum()"],"anchor":"Finding-the-Sign-and-Magnitude","title":"Finding the Sign and Magnitude"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/BinaryInteger/isSigned"],"title":"Accessing Numeric Constants","anchor":"Accessing-Numeric-Constants"},{"title":"Working with Binary Representation","anchor":"Working-with-Binary-Representation","identifiers":["doc://com.apple.Swift/documentation/Swift/BinaryInteger/bitWidth","doc://com.apple.Swift/documentation/Swift/BinaryInteger/trailingZeroBitCount","doc://com.apple.Swift/documentation/Swift/BinaryInteger/words-swift.property","doc://com.apple.Swift/documentation/Swift/BinaryInteger/Words-swift.associatedtype"]},{"anchor":"Initializers","generated":true,"title":"Ini