mentation/Swift/UInt","doc://com.apple.Swift/documentation/Swift/UInt128","doc://com.apple.Swift/documentation/Swift/UInt16","doc://com.apple.Swift/documentation/Swift/UInt32","doc://com.apple.Swift/documentation/Swift/UInt64","doc://com.apple.Swift/documentation/Swift/UInt8"],"type":"conformingTypes","kind":"relationships","title":"Conforming Types"}],"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/FixedWidthInteger","doc://com.apple.Swift/documentation/Swift/SignedInteger","doc://com.apple.Swift/documentation/Swift/UnsignedInteger"],"anchor":"Integer","generated":true,"title":"Integer"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BinaryInteger","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:s23CustomStringConvertibleP","identifier":"doc://com.apple.Swift/documentation/Swift/CustomStringConvertible","text":"CustomStringConvertible","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:SH","identifier":"doc://com.apple.Swift/documentation/Swift/Hashable","text":"Hashable","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Sj","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric","text":"Numeric","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Sx","identifier":"doc://com.apple.Swift/documentation/Swift/Strideable","text":"Strideable","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:Sj9MagnitudeQa","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric/Magnitude-swift.associatedtype","text":"Magnitude","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:Sz","identifier":"doc://com.apple.Swift/documentation/Swift/BinaryInteger","text":"BinaryInteger","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:Sj9MagnitudeQa","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric/Magnitude-swift.associatedtype","text":"Magnitude","kind":"typeIdentifier"},{"text":" == ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:Sj9MagnitudeQa","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric/Magnitude-swift.associatedtype","text":"Magnitude","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:Sj9MagnitudeQa","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric/Magnitude-swift.associatedtype","text":"Magnitude","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"BinaryInteger"},{"type":"text","text":" protocol is the basis for all the integer types"},{"type":"text","text":" "},{"type":"text","text":"provided by the standard library. All of the standard library’s integer"},{"type":"text","text":" "},{"type":"text","text":"types, such as "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and "},{"type":"codeVoice","code":"UInt32"},{"type":"text","text":", conform to "},{"type":"codeVoice","code":"BinaryInteger"},{"type":"text","text":"."}]},{"level":1,"type":"heading","anchor":"Converting-Between-Numeric-Types","text":"Converting Between Numeric Types"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can create new instances of a type that conforms to the "},{"type":"codeVoice","code":"BinaryInteger"},{"type":"text","text":" "},{"type":"text","text":"protocol from a floating-point number or another binary integer of any"},{"type":"text","text":" "},{"type":"text","text":"type. The "},{"type":"codeVoice","code":"BinaryInteger"},{"type":"text","text":" protocol provides initializers for four"},{"type":"text","text":" "},{"type":"text","text":"different kinds of conversion."}]},{"level":2,"type":"heading","anchor":"Range-Checked-Conversion","text":"Range-Checked Conversion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You use the default "},{"type":"codeVoice","code":"init(_:)"},{"type":"text","text":" initializer to create a new instance when"},{"type":"text","text":" "},{"type":"text","text":"you’re sure that the value passed is representable in the new type. For"},{"type":"text","text":" "},{"type":"text","text":"example, an instance of "},{"type":"codeVoice","code":"Int16"},{"type":"text","text":" can represent the value "},{"type":"codeVoice","code":"500"},{"type":"text","text":", so the"},{"type":"text","text":" "},{"type":"text","text":"first conversion in the code sample below succeeds. That same value is too"},{"type":"text","text":" "},{"type":"text","text":"large to represent as an "},{"type":"codeVoice","code":"Int8"},{"type":"text","text":" instance, so the second conversion fails,"},{"type":"text","text":" "},{"type":"text","text":"triggering a runtime error."}]},{"type":"codeListing","syntax":"swift","code":["let x: Int = 500","let y = Int16(x)","// y == 500","","let z = Int8(x)","// Error: Not enough bits to represent..."]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you create a binary integer from a floating-point value using the"},{"type":"text","text":" "},{"type":"text","text":"default initializer, the value is rounded toward zero before the range is"},{"type":"text","text":" "},{"type":"text","text":"checked. In the following example, the value "},{"type":"codeVoice","code":"127.75"},{"type":"text","text":" is rounded to "},{"type":"codeVoice","code":"127"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which is representable by the "},{"type":"codeVoice","code":"Int8"},{"type":"text","text":" type.  "},{"type":"codeVoice","code":"128.25"},{"type":"text","text":" is rounded to "},{"type":"codeVoice","code":"128"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which is not representable as an "},{"type":"codeVoice","code":"Int8"},{"type":"text","text":" instance, triggering a runtime"},{"type":"text","text":" "},{"type":"text","text":"error."}]},{"type":"codeListing","syntax":"swift","code":["let e = Int8(127.75)","// e == 127","","let f = Int8(128.25)","// Error: Double value cannot be converted..."]},{"level":2,"type":"heading","anchor":"Exact-Conversion","text":"Exact Conversion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"init?(exactly:)"},{"type":"text","text":" initializer to create a new instance after"},{"type":"text","text":" "},{"type":"text","text":"checking whether the passed value is representable. Instead of trapping on"},{"type":"text","text":" "},{"type":"text","text":"out-of-range values, using the failable "},{"type":"codeVoice","code":"init?(exactly:)"},{"type":"text","text":" "},{"type":"text","text":"initializer results in "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["let x = Int16(exactly: 500)","// x == Optional(500)","","let y = Int8(exactly: 500)","// y == nil"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When converting floating-point values, the "},{"type":"codeVoice","code":"init?(exactly:)"},{"type":"text","text":" initializer"},{"type":"text","text":" "},{"type":"text","text":"checks both that the passed value has no fractional part and that the"},{"type":"text","text":" "},{"type":"text","text":"value is representable in the resulting type."}]},{"type":"codeListing","syntax":"swift","code":["let e = Int8(exactly: 23.0)       // integral value, representable","// e == Optional(23)","","let f = Int8(exactly: 23.75)      // fractional value, representable","// f == nil","","let g = Int8(exactly: 500.0)      // integral value, nonrepresentable","// g == nil"]},{"level":2,"type":"heading","anchor":"Clamping-Conversion","text":"Clamping Conversion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"init(clamping:)"},{"type":"text","text":" initializer to create a new instance of a binary"},{"type":"text","text":" "},{"type":"text","text":"integer type where out-of-range values are clamped to the representable"},{"type":"text","text":" "},{"type":"text","text":"range of the type. For a type "},{"type":"codeVoice","code":"T"},{"type":"text","text":", the resulting value is in the range"},{"type":"text","text":" "},{"type":"codeVoice","code":"T.min...T.max"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["let x = Int16(clamping: 500)","// x == 500","","let y = Int8(clamping: 500)","// y == 127","","let z = UInt8(clamping: -500)","// z == 0"]},{"level":2,"type":"heading","anchor":"Bit-Pattern-Conversion","text":"Bit Pattern Conversion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"init(truncatingIfNeeded:)"},{"type":"text","text":" initializer to create a new instance"},{"type":"text","text":" "},{"type":"text","text":"with the same bit pattern as the passed value, extending or truncating the"},{"type":"text","text":" "},{"type":"text","text":"value’s representation as necessary. Note that the value may not be"},{"type":"text","text":" "},{"type":"text","text":"preserved, particularly when converting between signed to unsigned integer"},{"type":"text","text":" "},{"type":"text","text":"types or when the destination type has a smaller bit width than the source"},{"type":"text","text":" "},{"type":"text","text":"type. The following example shows how extending and truncating work for"},{"type":"text","text":" "},{"type":"text","text":"nonnegative integers:"}]},{"type":"codeListing","syntax":"swift","code":["let q: Int16 = 850","// q == 0b00000011_01010010","","let r = Int8(truncatingIfNeeded: q)      // truncate 'q' to fit in 8 bits","// r == 82","//   == 0b01010010","","let s = Int16(truncatingIfNeeded: r)     // extend 'r' to fill 16 bits","// s == 82","//   == 0b00000000_01010010"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any padding is performed by "},{"type":"emphasis","inlineContent":[{"type":"text","text":"sign-extending"}]},{"type":"text","text":" the passed value. When"},{"type":"text","text":" "},{"type":"text","text":"nonnegative integers are extended, the result is padded with zeroes. When"},{"type":"text","text":" "},{"type":"text","text":"negative integers are extended, the result is padded with ones. This"},{"type":"text","text":" "},{"type":"text","text":"example shows several extending conversions of a negative value—note"},{"type":"text","text":" "},{"type":"text","text":"that negative values are sign-extended even when converting to an unsigned"},{"type":"text","text":" "},{"type":"text","text":"type."}]},{"type":"codeListing","syntax":"swift","code":["let t: Int8 = -100","// t == -100","// t's binary representation == 0b10011100","","let u = UInt8(truncatingIfNeeded: t)","// u == 156","// u's binary representation == 0b10011100","","let v = Int16(truncatingIfNeeded: t)","// v == -100","// v's binary representation == 0b11111111_10011100","","let w = UInt16(truncatingIfNeeded: t)","// w == 65436","// w's binary representation == 0b11111111_10011100"]},{"level":1,"type":"heading","anchor":"Comparing-Across-Integer-Types","text":"Comparing Across Integer Types"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use relational operators, such as the less-than and equal-to"},{"type":"text","text":" "},{"type":"text","text":"operators ("},{"type":"codeVoice","code":"<"},{"type":"text","text":" and "},{"type":"codeVoice","code":"=="},{"type":"text","text":"), to compare instances of different binary integer"},{"type":"text","text":" "},{"type":"text","text":"types. The following example compares instances of the "},{"type":"codeVoice","code":"Int"},{"type":"text","text":", "},{"type":"codeVoice","code":"UInt"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"UInt8"},{"type":"text","text":" types:"}]},{"type":"codeListing","syntax":"swift","code":["let x: Int = -23","let y: UInt = 1_000","let z: UInt8 = 23","","if x < y {","    print(\"\\(x) is less than \\(y).\")","}","// Prints \"-23 is less than 1000.\"","","if z > x {","    print(\"\\(z) is greater than \\(x).\")","}","// Prints \"23 is greater than -23.\""]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/binaryinteger"]}],"abstract":[{"type":"text","text":"An integer type with a binary representation."}],"references":{"doc://com.apple.Swift/documentation/Swift/Numeric":{"navigatorTitle":[{"kind":"identifier","text":"Numeric"}],"url":"/documentation/swift/numeric","title":"Numeric","abstract":[{"text":"A type with values that support multiplication.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Numeric"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Numeric","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/UInt8":{"navigatorTitle":[{"text":"UInt8","kind":"identifier"}],"url":"/documentation/swift/uint8","title":"UInt8","abstract":[{"type":"text","text":"An 8-bit unsigned integer value"},{"type":"text","text":" "},{"type":"text","text":"type."}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UInt8","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/UInt8","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/BinaryInteger":{"navigatorTitle":[{"kind":"identi