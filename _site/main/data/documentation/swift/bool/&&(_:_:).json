pe":"codeVoice","code":"lhs"},{"type":"text","text":" evaluates to "},{"type":"codeVoice","code":"true"},{"type":"text","text":". For example:"}],"type":"paragraph"},{"type":"codeListing","code":["let measurements = [7.44, 6.51, 4.74, 5.88, 6.27, 6.12, 7.76]","let sum = measurements.reduce(0, +)","","if measurements.count > 0 && sum / Double(measurements.count) < 6.5 {","    print(\"Average measurement is less than 6.5\")","}","// Prints \"Average measurement is less than 6.5\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"In this example, ","type":"text"},{"code":"lhs","type":"codeVoice"},{"text":" tests whether ","type":"text"},{"code":"measurements.count","type":"codeVoice"},{"text":" is greater than","type":"text"},{"text":" ","type":"text"},{"text":"zero. Evaluation of the ","type":"text"},{"code":"&&","type":"codeVoice"},{"text":" operator is one of the following:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"measurements.count","type":"codeVoice"},{"text":" is equal to zero, ","type":"text"},{"code":"lhs","type":"codeVoice"},{"text":" evaluates to ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"rhs","type":"codeVoice"},{"text":" is not evaluated, preventing a divide-by-zero error in the","type":"text"},{"text":" ","type":"text"},{"text":"expression ","type":"text"},{"code":"sum / Double(measurements.count)","type":"codeVoice"},{"text":". The result of the","type":"text"},{"text":" ","type":"text"},{"text":"operation is ","type":"text"},{"code":"false","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"measurements.count"},{"type":"text","text":" is greater than zero, "},{"code":"lhs","type":"codeVoice"},{"type":"text","text":" evaluates to"},{"type":"text","text":" "},{"code":"true","type":"cod