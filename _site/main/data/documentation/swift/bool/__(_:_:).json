"codeVoice","code":"true"},{"text":". If both values are","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", the operator returns ","type":"text"},{"type":"codeVoice","code":"false"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This operator uses short-circuit evaluation: The left-hand side (","type":"text"},{"type":"codeVoice","code":"lhs"},{"text":") is","type":"text"},{"text":" ","type":"text"},{"text":"evaluated first, and the right-hand side (","type":"text"},{"type":"codeVoice","code":"rhs"},{"text":") is evaluated only if","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"lhs"},{"text":" evaluates to ","type":"text"},{"type":"codeVoice","code":"false"},{"text":". For example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let majorErrors: Set = [\"No first name\", \"No last name\", ...]","let error = \"\"","","if error.isEmpty || !majorErrors.contains(error) {","    print(\"No major errors detected\")","} else {","    print(\"Major error: \\(error)\")","}","// Prints \"No major errors detected\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, "},{"code":"lhs","type":"codeVoice"},{"text":" tests whether ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" is an empty string.","type":"text"},{"text":" ","type":"text"},{"text":"Evaluation of the ","type":"text"},{"code":"||","type":"codeVoice"},{"text":" operator is one of the following:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"When ","type":"text"},{"type":"codeVoice","code":"error"},{"text":" is an empty string, ","type":"text"},{"type":"codeVoice","code":"lhs"},{"text":" evaluates to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" and ","type":"text"},{"code":"rhs","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"not evaluated, skipping the call to ","type":"text"},{"type":"codeVoice","code":"majorErrors.contains(_:)"},{"text":". The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"result of the operation is "},{"code":"true","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"code":"error","type":"codeVoice"},{"text":" is not an empty string, ","type":"text"},{"code":"lhs","type":"codeVoice"},{"text":" evaluates to ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"rhs","type":"codeVoice"},{"text":" is evaluated. The result of evaluating ","type":"text"},{"code":"rhs","type":"codeVoice"},{"text":" is the result of the","type":"text"},{"type":"text","text":" "},{"code":"||","type":"codeVoice"},{"type":"text","text":" operation."}]}]}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"anchor":"Transforming-a-Boolean","generated":true,"title":"Transforming a Boolean","identifiers":["doc://com.apple.Swift/documentation/Swift/Bool/toggle()","doc://com.apple.Swift/documentation/Swift/Bool/!(_:)","doc://com.apple.Swift/documentation/Swift/Bool/&&(_:_:)"]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/bool/__(_:_:)"]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Bool"]]},"metadata":{"role":"symbol","roleHeading":"Operator","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"||","kind":"identifier"},{"text":" ","kind":"text"},{"text":"(","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"@autoclosure","kind":"attribute"},{"text":" () ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preci