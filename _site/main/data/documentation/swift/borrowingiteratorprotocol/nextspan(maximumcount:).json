{"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/BorrowingIteratorProtocol/nextSpan(maximumCount:)"},"metadata":{"externalID":"s:s25BorrowingIteratorProtocolP8nextSpan12maximumCounts0E0Vy7ElementQzGSi_tF","role":"symbol","roleHeading":"Instance Method","modules":[{"name":"Swift"}],"title":"nextSpan(maximumCount:)","required":true,"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"nextSpan"},{"kind":"text","text":"("},{"text":"maximumCount","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Span","preciseIdentifier":"s:s4SpanV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:s25BorrowingIteratorProtocolP7ElementQa"},{"kind":"text","text":">"}]},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/BorrowingIteratorProtocol"]]},"kind":"symbol","sections":[],"variants":[{"paths":["/documentation/swift/borrowingiteratorprotocol/nextspan(maximumcount:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"@_lifetime(&self) @_lifetime(self: copy self) "},{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"nextSpan"},{"kind":"text","text":"("},{"kind":"externalParam","text":"maximumCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Span","preciseIdentifier":"s:s4SpanV","text":"Span"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s25BorrowingIteratorProtocolP7ElementQa","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/BorrowingIteratorProtocol/Element","text":"Element"},{"kind":"text","text":">"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"If the underlying type stores its elements in one or more blocks of"},{"type":"text","text":" "},{"type":"text","text":"contiguous memory, then the returned span typically directly"},{"type":"text","text":" "},{"type":"text","text":"addresses one of those buffers. On the other hand, if the underlying type"},{"type":"text","text":" "},{"type":"text","text":"materializes its elements on demand, then the returned span addresses"},{"type":"text","text":" "},{"type":"text","text":"a temporary buffer managed by the iterator itself. Consequently, the returned"},{"type":"text","text":" "},{"type":"text","text":"span is tied to this particular invocation of "},{"type":"codeVoice","code":"nextSpan"},{"type":"text","text":", and it cannot"},{"type":"text","text":" "},{"type":"text","text":"survive beyond the next invocation of this method."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the iterator has not yet reached the end of the underlying elements,"},{"type":"text","text":" "},{"type":"text","text":"then this method returns a non-empty span of at most "},{"type":"codeVoice","code":"maximumCount"},{"type":"text","text":" "},{"type":"text","text":"elements and updates the iterator’s current position to the element"},{"type":"text","text":" "},{"type":"text","text":"following the last item in the returned span. The "},{"type":"codeVoice","code":"maximumCount"},{"type":"text","text":" "},{"type":"text","text":"argument allows callers to avoid getting more items than they are"},{"type":"text","text":" "},{"type":"text","text":"able to process in one go, simplifying usage, and"},{"type":"text","text":" "},{"type":"text","text":"avoiding materializing more elements than needed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the iterator’s current position is at the end of the container, then"},{"type":"text","text":" "},{"type":"text","text":"this method returns an empty span without updating the position."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method can be used to efficiently process the items of a container"},{"type":"text","text":" "},{"type":"text","text":"in bulk, by directly iterating over its piecewise contiguous pieces of"},{"text":" ","type":"text"},{"type":"text","text":"storage:"}]},{"syntax":"swift","code":["var it = items.makeBorrowingIterator()","while true {","  let span = it.nextSpan(maximumCount: .max)","  if span.isEmpty { break }","  // Process items in `span`","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The spans returned by this method are not guaranteed to be disjunct.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Iterators that materialize elements on demand typically reuse the same"},{"type":"text","text":" "},{"type":"text","text":"buffer over and over again; and even some proper containers may link to a"},{"text":" ","type":"text"},{"text":"single storage chunk (or parts of a storage chunk) multiple times, for","type":"text"},{"text":" ","type":"text"},{"text":"example to repeat their contents.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Returns a span over the next group of elements that are ready to by visited,"},{"type":"text","text":" "},{"type":"text","text":"up to the specifed maximum."}],"references":{"doc://com.apple.Swift/documentation/Swift/BorrowingIteratorProtocol/nextSpan(maximumCount:)":{"required":true,"type":"topic","abstract":[{"type":"text","text":"Returns a span over the next group of elements that are ready to by visited,"},{"type":"text","text":" "},{"type":"text","text":"up to the specifed maximum."}],"title":"nextSpan(maximumCount:)","role":"symbol","url":"/documentation/swift/borrowingiteratorprotocol/nextspan(maximumcount:)","identifier":"doc://com.apple.Swift/documentation/Swift/BorrowingIteratorProtocol/nextSpan(maximumCount:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"nextSpan","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"maximumCount"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4SpanV","kind":"typeIdentifier","text":"Span"},{"kind":"text","text":"<"},{"text":"Element","preciseIdentifier":"s:s25BorrowingIteratorProtocolP7ElementQa","kind":"typeIdentifier"},{"text":">","kind":"text"}]},"doc://com.apple.Swift/documentation/Swift/Span":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Span"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Span"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Span","url":"/documentation/swift/span","kind":"symbol","abstract":[{"type":"codeVoice","code":"Span<Element>"},{"type":"text","text":" represents a contiguous region of memory"},{"type":"text","text":" "},{"type":"text","text":"which contains initialized instances of "},{"type":"codeVoice","code":"Element"},{"type":"text","text":"."}],"title":"Span"},"doc://com.apple.Swift/documentation/Swift/BorrowingIteratorProtocol/Element":{"role":"symbol","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Element"},{"kind":"text","text":" : ~Copyable"}],"title":"Element","required":true,"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/BorrowingIteratorProtocol/Element","kind":"symbol","url":"/documentation/swift/borrowingiteratorprotocol/element","abstract":[]},"doc://com.apple.Swift/documentation/Swift/Int":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Int","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Int"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Int","url":"/documentation/swift/int","kind":"symbol","abstract":[{"type":"text","text":"A signed integer value type."}],"title":"Int"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/BorrowingIteratorProtocol":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BorrowingIteratorProtocol","kind":"identifier"}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/BorrowingIteratorProtocol","title":"BorrowingIteratorProtocol","abstract":[{"type":"text","text":"A type that provides borrowed access to the values of a borrowing sequence."}],"navigatorTitle":[{"text":"BorrowingIteratorProtocol","kind":"identifier"}],"type":"topic","role":"symbol","url":"/documentation/swift/borrowingiteratorprotocol"}}}