{"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/CaseIterable"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"relationshipsSections":[{"kind":"relationships","identifiers":["doc://com.apple.Swift/documentation/_RegexParser/AST/Atom/CharacterProperty/JavaSpecial","doc://com.apple.Swift/documentation/Swift/Unicode/BinaryProperty","doc://com.apple.Swift/documentation/Swift/Unicode/Block","doc://com.apple.Swift/documentation/Swift/Unicode/ExtendedGeneralCategory","doc://com.apple.Swift/documentation/Swift/Unicode/POSIXProperty","doc://com.apple.Swift/documentation/Swift/Unicode/Script"],"type":"conformingTypes","title":"Conforming Types"}],"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/RawRepresentable"],"generated":true,"anchor":"Raw-Representation","title":"Raw Representation"}],"metadata":{"role":"symbol","externalID":"s:s12CaseIterableP","modules":[{"name":"Swift"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CaseIterable","kind":"identifier"}],"roleHeading":"Protocol","navigatorTitle":[{"text":"CaseIterable","kind":"identifier"}],"symbolKind":"protocol","title":"CaseIterable"},"abstract":[{"type":"text","text":"A type that provides a collection of all of its values."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CaseIterable","kind":"identifier"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"Types that conform to the ","type":"text"},{"type":"codeVoice","code":"CaseIterable"},{"text":" protocol are typically","type":"text"},{"text":" ","type":"text"},{"text":"enumerations without associated values. When using a ","type":"text"},{"type":"codeVoice","code":"CaseIterable"},{"text":" type,","type":"text"},{"text":" ","type":"text"},{"text":"you can access a collection of all of the type’s cases by using the type’s","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"allCases"},{"text":" property.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, the ","type":"text"},{"type":"codeVoice","code":"CompassDirection"},{"text":" enumeration declared in this example","type":"text"},{"text":" ","type":"text"},{"text":"conforms to ","type":"text"},{"type":"codeVoice","code":"CaseIterable"},{"text":". You access the number of cases and the cases","type":"text"},{"text":" ","type":"text"},{"text":"themselves through ","type":"text"},{"type":"codeVoice","code":"CompassDirection.allCases"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["enum CompassDirection: CaseIterable {","    case north, south, east, west","}","","print(\"There are \\(CompassDirection.allCases.count) directions.\")","// Prints \"There are 4 directions.\"","let caseList = CompassDirection.allCases","                               .map({ \"\\($0)\" })","                               .joined(separator: \", \")","// caseList == \"north, south, east, west\""]},{"type":"heading","anchor":"Conforming-to-the-CaseIterable-Protocol","level":1,"text":"Conforming to the CaseIterable Protocol"},{"inlineContent":[{"text":"The compiler can automatically provide an implementation of the","type":"text"},{"text":" ","type":"text"},{"code":"CaseIterable","type":"codeVoice"},{"text":" requirements for any enumeration without associated values","type":"text"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"code":"@available","type":"codeVoice"},{"text":" attributes on its cases. The synthesized ","type":"text"},{"code":"allCases","type":"codeVoice"},{"text":" ","type":"text"},{"text":"collection provides the cases in order of their declaration.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can take advantage of this compiler support when defining your own","type":"text"},{"text":" ","type":"text"},{"text":"custom enumeration by declaring conformance to ","type":"text"},{"code":"CaseIterable","type":"codeVoice"},{"text":" in the","type":"text"},{"text":" ","type":"text"},{"text":"enumeration’s original declaration. The ","type":"text"},{"code":"CompassDirection","type":"codeVoice"},{"text":" example above","type":"text"},{"text":" ","type":"text"},{"text":"demonstrates this automatic implementation.","type":"text"}],"type":"paragraph"}]}],"topicSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/CaseIterable/allCases-swift.type.property","doc://com.apple.Swift/documentation/Swift/CaseIterable/AllCases-swift.associatedtype"],"anchor":"Accessing-Cases","title":"Accessing Cases"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["/documentation/swift/caseiterable"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/Unicode/Block":{"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Block","kind":"identifier"}],"title":"Unicode.Block","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/Block","kind":"symbol","url":"/documentation/swift/unicode/block","abstract":[{"text":"A list of unicode character blocks, including ","type":"text"},{"type":"codeVoice","code":"No_Block"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"https://www.unicode.org/Public/UCD/latest/ucd/Blocks.txt","type":"text"}],"navigatorTitle":[{"text":"Block","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/CaseIterable":{"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"CaseIterable"}],"title":"CaseIterable","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/CaseIterable","type":"topic","url":"/documentation/swift/cas