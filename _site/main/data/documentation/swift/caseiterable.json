{"abstract":[{"type":"text","text":"A type that provides a collection of all of its values."}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"metadata":{"externalID":"s:s12CaseIterableP","symbolKind":"protocol","navigatorTitle":[{"text":"CaseIterable","kind":"identifier"}],"title":"CaseIterable","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CaseIterable","kind":"identifier"}],"modules":[{"name":"Swift"}],"role":"symbol","roleHeading":"Protocol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/caseiterable"]}],"relationshipsSections":[{"kind":"relationships","title":"Conforming Types","identifiers":["doc://com.apple.Swift/documentation/_RegexParser/AST/Atom/CharacterProperty/JavaSpecial","doc://com.apple.Swift/documentation/Swift/Unicode/BinaryProperty","doc://com.apple.Swift/documentation/Swift/Unicode/Block","doc://com.apple.Swift/documentation/Swift/Unicode/ExtendedGeneralCategory","doc://com.apple.Swift/documentation/Swift/Unicode/POSIXProperty","doc://com.apple.Swift/documentation/Swift/Unicode/Script"],"type":"conformingTypes"}],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/CaseIterable","interfaceLanguage":"swift"},"topicSections":[{"anchor":"Accessing-Cases","title":"Accessing Cases","identifiers":["doc://com.apple.Swift/documentation/Swift/CaseIterable/allCases-swift.type.property","doc://com.apple.Swift/documentation/Swift/CaseIterable/AllCases-swift.associatedtype"]}],"seeAlsoSections":[{"anchor":"Raw-Representation","title":"Raw Representation","identifiers":["doc://com.apple.Swift/documentation/Swift/RawRepresentable"],"generated":true}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"CaseIterable"}]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"text":"Types that conform to the ","type":"text"},{"type":"codeVoice","code":"CaseIterable"},{"text":" protocol are typically","type":"text"},{"text":" ","type":"text"},{"text":"enumerations without associated values. When using a ","type":"text"},{"type":"codeVoice","code":"CaseIterable"},{"text":" type,","type":"text"},{"text":" ","type":"text"},{"text":"you can access a collection of all of the type’s cases by using the type’s","type":"text"},{"text":" ","type":"text"},{"code":"allCases","type":"codeVoice"},{"text":" property.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, the "},{"code":"CompassDirection","type":"codeVoice"},{"type":"text","text":" enumeration declared in this example"},{"type":"text","text":" "},{"type":"text","text":"conforms to "},{"code":"CaseIterable","type":"codeVoice"},{"type":"text","text":". You access the number of cases and the cases"},{"type":"text","text":" "},{"type":"text","text":"themselves through "},{"code":"CompassDirection.allCases","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["enum CompassDirection: CaseIterable {","    case north, south, east, west","}","","print(\"There are \\(CompassDirection.allCases.count) directions.\")","// Prints \"There are 4 directions.\"","let caseList = CompassDirection.allCases","                               .map({ \"\\($0)\" })","                               .joined(separator: \", \")","// caseList == \"north, south, east, west\""]},{"level":1,"type":"heading","text":"Conforming to the CaseIterable Protocol","anchor":"Conforming-to-the-CaseIterable-Protocol"},{"type":"paragraph","inlineContent":[{"text":"The compiler can automatically provide an implementation of the","type":"text"},{"text":" ","type":"text"},{"code":"CaseIterable","type":"codeVoice"},{"type":"text","text":" requirements for any enumeration without associated values"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"@available"},{"type":"text","text":" attributes on its cases. The synthesized "},{"code":"allCases","type":"codeVoice"},{"type":"text","text":" "},{"text":"collection provides the cases in order of their declaration.","type":"text"}]},{"inlineContent":[{"type":"text","text":"You can take advantage of this compiler support when defining your own"},{"type":"text","text":" "},{"type":"text","text":"custom enumeration by declaring conformance to "},{"type":"codeVoice","code":"CaseIterable"},{"text":" in the","type":"text"},{"text":" ","type":"text"},{"text":"enumeration’s original declaration. The ","type":"text"},{"type":"codeVoice","code":"CompassDirection"},{"text":" example above","type":"text"},{"text":" ","type":"text"},{"text":"demonstrates this automatic implementation.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/CaseIterable/AllCases-swift.associatedtype":{"identifier":"doc://com.apple.Swift/documentation/Swift/CaseIterable/AllCases-swift.associatedtype","url":"/documentation/swift/caseiterable/allcases-swift.associatedtype","type":"topic","required":true,"kind":"symbol","role":"symbol","title":"AllCases","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"text":"AllCases","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"Collection","kind":"typeIdentifier","preciseIdentifier":"s:Sl"},{"text":" = [","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":"]","kind":"text"}],"abstract":[{"text":"A type that can represent a collection of all values of this type.","type":"text"}]},"doc://com.apple.Swift/documentation/_RegexParser/AST/Atom/CharacterProperty/JavaSpecial":{"navigatorTitle":[{"kind":"identifier","text":"JavaSpecial"}],"role":"symbol","url":"/documentation/_regexparser/ast/atom/characterproperty/javaspecial","title":