at index in the original","type":"text"},{"text":" ","type":"text"},{"text":"array.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""]},{"inlineContent":[{"text":"Always use the slice’s ","type":"text"},{"type":"codeVoice","code":"startIndex"},{"text":" property instead of assuming that its","type":"text"},{"text":" ","type":"text"},{"text":"indices start at a particular value. Attempting to access an element by","type":"text"},{"text":" ","type":"text"},{"text":"using an index outside the bounds of the slice’s indices may result in a","type":"text"},{"text":" ","type":"text"},{"text":"runtime error, even if that index is valid for the original collection.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"]},{"content":[{"inlineContent":[{"text":"O(1)","type":"text"}],"type":"paragraph"}],"style":"note","name":"Complexity","type":"aside"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/Collection":{"identifier":"doc://com.apple.Swift/documentation/Swift/Collection","abstract":[{"type":"text","text":"A sequence whose elements can be traversed multiple times,"},{"type":"text","text":" "},{"type":"text","text":"nondestructively, and accessed by an indexed subscript."}],"type":"topic","role":"symbol","url":"/documentation/swift/collection","navigatorTitle":[{"kind":"identifier","text":"Collection"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Collection"}],"title":"Collection"},"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound":{"url":"/documentation/swift/rangeexpression/bound","title":"Bound","type":"topic","required":true,"abstract":[{"type":"text","text":"