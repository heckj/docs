lection. To avoid the","type":"text"},{"text":" ","type":"text"},{"text":"unexpected copy, use the ","type":"text"},{"code":"index(after:)","type":"codeVoice"},{"text":" method starting with","type":"text"},{"text":" ","type":"text"},{"code":"startIndex","type":"codeVoice"},{"text":" to produce indices instead.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var c = MyFancyCollection([10, 20, 30, 40, 50])","var i = c.startIndex","while i != c.endIndex {","    c[i] /= 5","    i = c.index(after: i)","}","// c == MyFancyCollection([2, 4, 6, 8, 10])"],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/CollectionDifference"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/collectiondifference/indices"]}],"sections":[],"abstract":[{"type":"text","text":"The indices that are valid for subscripting the collection, in ascending"},{"type":"text","text":" "},{"type":"text","text":"order."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/CollectionDifference/indices","interfaceLanguage":"swift"},"references":{"doc://com.apple.Swift/documentation/Swift/DefaultIndices":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DefaultIndices"}],"type":"topic","title":"DefaultIndices","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/DefaultIndices","kind":"symbol","abstract":[{"type":"text","text":"A collection of indices for an arbitrary collection"}],"navigatorTitle":[{"text":"DefaultIndices","kind":"identifier"}],"url":"/documentation/swift/defaultindices"},"doc://com.apple.Swift/documentation/Swift/CollectionDifference/indices":{"abstract":[{"text":"The indices that are valid for subscripting the collection, in ascending","type":"text"},{"text":" ","type":"text"},{"text":"order.","type":"text"