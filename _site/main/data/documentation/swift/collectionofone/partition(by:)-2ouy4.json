{"abstract":[{"text":"Reorders the elements of the collection such that all the elements","type":"text"},{"text":" ","type":"text"},{"text":"that match the given predicate are after all the elements that don’t","type":"text"},{"text":" ","type":"text"},{"text":"match.","type":"text"}],"metadata":{"extendedModule":"Swift","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"partition"},{"kind":"text","text":"("},{"kind":"externalParam","text":"by"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:SM7ElementQa","kind":"typeIdentifier","text":"Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":") "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:SM5IndexQa","kind":"typeIdentifier","text":"Index"}],"role":"symbol","roleHeading":"Instance Method","title":"partition(by:)","symbolKind":"method","modules":[{"name":"Swift"}],"externalID":"s:SMsE9partition2by5IndexQzSb7ElementQzKXE_tKF::SYNTHESIZED::s:s15CollectionOfOneV"},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/CollectionOfOne/partition(by:)-2ouy4","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/CollectionOfOne"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"mutating","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"partition"},{"kind":"text","text":"("},{"kind":"externalParam","text":"by"},{"kind":"text","text":" "},{"kind":"internalParam","text":"belongsInSecondPartition"},{"kind":"text","text":": ("},{"identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Element","kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:SM7ElementQa"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Bool","kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":") "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Index","kind":"typeIdentifier","text":"Index","preciseIdentifier":"s:SM5IndexQa"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"belongsInSecondPartition","content":[{"type":"paragraph","inlineContent":[{"text":"A predicate used to partition","type":"text"},{"text":" ","type":"text"},{"text":"the collection. All elements satisfying this predicate are ordered","type":"text"},{"text":" ","type":"text"},{"text":"after all elements not satisfying it.","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"inlineContent":[{"type":"text","text":"The index of the first element in the reordered collection"},{"type":"text","text":" "},{"type":"text","text":"that matches "},{"type":"codeVoice","code":"belongsInSecondPartition"},{"text":". If no elements in the","type":"text"},{"text":" ","type":"text"},{"text":"collection match ","type":"text"},{"type":"codeVoice","code":"belongsInSecondPartition"},{"type":"text","text":", the returned index is"},{"type":"text","text":" "},{"type":"text","text":"equal to the collection’s "},{"type":"codeVoice","code":"endIndex"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"After partitioning a collection, there is a pivot index ","type":"text"},{"code":"p","type":"codeVoice"},{"text":" where","type":"text"},{"text":" ","type":"text"},{"text":"no element before ","type":"text"},{"code":"p","type":"codeVoice"},{"text":" satisfies the ","type":"text"},{"code":"belongsInSecondPartition","type":"codeVoice"},{"text":" ","type":"text"},{"text":"predicate and every element at or after ","type":"text"},{"code":"p","type":"codeVoice"},{"text":" satisfies","type":"text"},{"text":" ","type":"text"},{"code":"belongsInSecondPartition","type":"codeVoice"},{"text":". This operation isn’t guaranteed to be","type":"text"},{"text":" ","type":"text"},{"text":"stable, so the relative ordering of elements within the partitions might","type":"text"},{"text":" ","type":"text"},{"text":"change.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the following example, an array of numbers is partitioned by a"},{"type":"text","text":" "},{"type":"text","text":"predicate that matches elements greater than 30."}],"type":"paragraph"},{"syntax":"swift","code":["var numbers = [30, 40, 20, 30, 30, 60, 10]","let p = numbers.partition(by: { $0 > 30 })","// p == 5","// numbers == [30, 10, 20, 30, 30, 60, 40]"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"code":"numbers","type":"codeVoice"},{"text":" array is now arranged in two partitions. The first","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"partition, "},{"type":"codeVoice","code":"numbers[..<p]"},{"type":"text","text":", is made up of the elements that"},{"type":"text","text":" "},{"text":"are not greater than 30. The second partition, ","type":"text"},{"code":"numbers[p...]","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"is made up of the elements that ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"are"}]},{"type":"text","text":" greater than 30."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let first = numbers[..<p]","// first == [30, 10, 20, 30, 30]","let second = numbers[p...]","// second == [60, 40]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the order of elements in both partitions changed."},{"type":"text","text":" "},{"type":"text","text":"That is, "},{"code":"40","type":"codeVoice"},{"text":" appears before ","type":"text"},{"code":"60","type":"codeVoice"},{"type":"text","text":" in the original collection,"},{"type":"text","text":" "},{"type":"text","text":"but, after calling "},{"code":"partition(by:)","type":"codeVoice"},{"text":", ","type":"text"},{"code":"60","type":"codeVoice"},{"type":"text","text":" appears before "},{"code":"40","type":"codeVoice"},{"type":"text","text":"."}]},{"name":"Complexity","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the length of the collection."}]}],"type":"aside","style":"note"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/collectionofone/partition(by:)-2ouy4"]}],"references":{"doc://com.apple.Swift/documentation/Swift/Bool":{"title":"Bool","abstract":[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","url":"/documentation/swift/bool","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Bool","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Bool"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift/MutableCollection/Index":{"required":true,"role":"symbol","url":"/documentation/swift/mutablecollection/index","identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Index","kind":"symbol","type":"topic","title":"Index","fragments":[{"kind":"keyword",