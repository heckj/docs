{"abstract":[{"text":"Returns a view presenting the elements of the collection in reverse","type":"text"},{"text":" ","type":"text"},{"text":"order.","type":"text"}],"metadata":{"extendedModule":"Swift","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reversed","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ReversedCollection","preciseIdentifier":"s:s18ReversedCollectionV","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"role":"symbol","roleHeading":"Instance Method","title":"reversed()","symbolKind":"method","modules":[{"name":"Swift"}],"externalID":"s:SKsE8reverseds18ReversedCollectionVyxGyF::SYNTHESIZED::s:s15CollectionOfOneV"},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/CollectionOfOne/reversed()"},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/CollectionOfOne"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reversed"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"ReversedCollection","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection","preciseIdentifier":"s:s18ReversedCollectionV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"You can reverse a collection without allocating new space for its","type":"text"},{"text":" ","type":"text"},{"text":"elements by calling this ","type":"text"},{"code":"reversed()","type":"codeVoice"},{"text":" method. A ","type":"text"},{"code":"ReversedCollection","type":"codeVoice"},{"text":" ","type":"text"},{"text":"instance wraps an underlying collection and provides access to its","type":"text"},{"text":" ","type":"text"},{"text":"elements in reverse order. This example prints the characters of a","type":"text"},{"text":" ","type":"text"},{"text":"string in reverse order:","type":"text"}],"type":"paragraph"},{"code":["let word = \"Backwards\"","for char in word.reversed() {","    print(char, terminator: \"\")","}","// Prints \"sdrawkcaB\""],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need a reversed collection of the same type, you may be able to"},{"type":"text","text":" "},{"type":"text","text":"use the collection’s sequence-based or collection-based initializer. For"},{"type":"text","text":" "},{"type":"text","text":"example, to get the reversed version of a string, reverse its"},{"type":"text","text":" "},{"type":"text","text":"characters and initialize a new "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instance from the result."}]},{"code":["let reversedWord = String(word.reversed())","print(reversedWord)","// Prints \"sdrawkcaB\""],"syntax":"swift","type":"codeListing"},{"name":"Complexity","style":"note","type":"aside","content":[{"inlineContent":[{"text":"O(1)","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"paths":["/documentation/swift/collectionofone/reversed()"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/CollectionOfOne":{"url":"/documentation/swift/collectionofone","type":"topic","abstract":[{"text":"A collection containing a single element.","type":"text"}],"kind":"symbol","title":"CollectionOfOne","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"CollectionOfOne","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"CollectionOfOne"}],"identifier":"doc://com.apple.Swift/documentation/Swift/CollectionOfOne"},"doc:/