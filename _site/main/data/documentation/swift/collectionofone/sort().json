{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/CollectionOfOne"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/collectionofone/sort()"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"sort"},{"kind":"text","text":"()"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"You can sort any mutable collection of elements that conform to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Comparable"},{"text":" protocol by calling this method. Elements are sorted in","type":"text"},{"text":" ","type":"text"},{"text":"ascending order.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Here’s an example of sorting a list of students’ names. Strings in Swift"},{"type":"text","text":" "},{"type":"text","text":"conform to the "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":" protocol, so the names are sorted in"},{"type":"text","text":" "},{"type":"text","text":"ascending order according to the less-than operator ("},{"type":"codeVoice","code":"<"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var students = [\"Kofi\", \"Abena\", \"Peter\", \"Kweku\", \"Akosua\"]","students.sort()","print(students)","// Prints \"[\"Abena\", \"Akosua\", \"Kofi\", \"Kweku\", \"Peter\"]\""]},{"inlineContent":[{"type":"text","text":"To sort the elements of your collection in descending order, pass the"},{"text":" ","type":"text"},{"type":"text","text":"greater-than operator ("},{"type":"codeVoice","code":">"},{"type":"text","text":") to the "},{"type":"codeVoice","code":"sort(by:)"},{"type":"text","text":" method."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["students.sort(by: >)","print(students)","// Prints \"[\"Peter\", \"Kweku\", \"Kofi\", \"Akosua\", \"Abena\"]\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The sorting algorithm is guaranteed to be stable. A stable sort"},{"type":"text","text":" "},{"type":"text","text":"preserves the relative order of elements that compare as equal."}]},{"name":"Complexity","type":"aside","style":"note","content":[{"inlineContent":[{"text":"O(","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":" log ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" is the length of the collection.","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"kind":"symbol","metadata":{"modules":[{"name":"Swift"}],"extendedModule":"Swift","title":"sort()","role":"symbol","roleHeading":"Instance Method","externalID":"s:SMsSkRzSL7ElementSTRpzrlE4sortyyF::SYNTHESIZED::s:s15CollectionOfOneV","conformance":{"constraints":[{"type":"codeVoice","code":"Self"},{"text":" conforms to ","type":"text"},{"code":"RandomAccessCollection","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Element"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":"."}],"conformancePrefix":[{"type":"text","text":"Conforms when"}],"availabilityPrefix":[{"type":"text","text":"Available when"}]},"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"sort"},{"text":"()","kind":"text"}],"symbolKind":"method"},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/CollectionOfOne/sort()"},"abstract":[{"text":"Sorts the collection in place.","type":"text"}]