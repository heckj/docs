{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ContiguousArray"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"mutating","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"append","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"newElement","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:s15ContiguousArrayV7Elementxmfp"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The element to append to the array.","type":"text"}]}],"name":"newElement"}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use this method to append a single element to the end of a mutable array."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["var numbers = [1, 2, 3, 4, 5]","numbers.append(100)","print(numbers)","// Prints \"[1, 2, 3, 4, 5, 100]\""]},{"inlineContent":[{"type":"text","text":"Because arrays increase their allocated capacity using an exponential"},{"type":"text","text":" "},{"type":"text","text":"strategy, appending a single element to an array is an O(1) operation"},{"type":"text","text":" "},{"type":"text","text":"when averaged over many calls to the "},{"type":"codeVoice","code":"append(_:)"},{"type":"text","text":" method. When an array"},{"type":"text","text":" "},{"type":"text","text":"has additional capacity and is not sharing its storage with another"},{"type":"text","text":" "},{"type":"text","text":"instance, appending an element is O(1). When an array needs to"},{"type":"text","text":" "},{"type":"text","text":"reallocate storage before appending or its storage is shared with"},{"type":"text","text":" "},{"type":"text","text":"another copy, appending is O("},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the length of the array."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O(1) on average, over many calls to "},{"code":"append(_:)","type":"codeVoice"},{"type":"text","text":" on the"},{"type":"text","text":" "},{"type":"text","text":"same array."}]}],"style":"note","type":"aside","name":"Complexity"}],"kind":"content"}],"abstract":[{"type":"text","text":"Adds a new element at the end of the array."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"extendedModule":"Swift","role":"symbol","title":"append(_:)","symbolKind":"method","modules":[{"name":"Swift"}],"externalID":"s:s15ContiguousArrayV6appendyyxnF","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"append"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:s15ContiguousArrayV7Elementxmfp","text":"Element"},{"kind":"text","text":")"}],"roleHeading":"Instance Method"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/contiguousarray/append(_:)"]}],"sections":[],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ContiguousArray/append(_:)","interfaceLanguage":"swift"},"references":{"doc://com.apple.Swift/documentation/Swift/ContiguousArray/append(_:)":{"type":"topic","url":"/documentation/swift/contiguousarray/append(_:)","identifier":"doc://com.apple.Swift/documentation/Swift/ContiguousArray/append(_:)","kind":"symbol","role":"symbol","title":"append(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"append"},{"kind":"text","text":"("},{"preciseIdentifier":"s:s15ContiguousArrayV7Elementxmfp","kind":"typeIdentifier","text":"Element"},{"kind":"text","text":")"}],"abstract":[{"text":"Adds a new element at the end of the array.","type":"text"}]},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/ContiguousArray":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ContiguousArray","kind":"identifier"}],"abstract":[{"text":"A contiguously stored array.","type":"text"}],"role":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/ContiguousArray","kind":"symbol","title":"ContiguousArray","navigatorTitle":[{"kind":"identifier","text":"ContiguousArray"}],"url":"/documentation/swift/contiguousarray"}}}