{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ContiguousArray/capacity","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ContiguousArray"]]},"metadata":{"role":"symbol","externalID":"s:s15ContiguousArrayV8capacitySivp","modules":[{"name":"Swift"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"capacity"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"roleHeading":"Instance Property","extendedModule":"Swift","symbolKind":"property","title":"capacity"},"abstract":[{"type":"text","text":"The total number of elements that the array can contain without"},{"type":"text","text":" "},{"type":"text","text":"allocating new storage."}],"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"capacity"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Int","text":"Int"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Every array reserves a specific amount of memory to hold its contents."},{"type":"text","text":" "},{"type":"text","text":"When you add elements to an array and that array begins to exceed its"},{"type":"text","text":" "},{"type":"text","text":"reserved capacity, the array allocates a larger region of memory and"},{"type":"text","text":" "},{"type":"text","text":"copies its elements into the new storage. The new storage is a multiple"},{"type":"text","text":" "},{"type":"text","text":"of the old storage’s size. This exponential growth strategy means that"},{"type":"text","text":" "},{"type":"text","text":"appending an element happens in constant time, averaging the performance"},{"type":"text","text":" "},{"type":"text","text":"of many append operations. Append operations that trigger reallocation"},{"type":"text","text":" "},{"type":"text","text":"have a performance cost, but they occur less and less often as the array"},{"type":"text","text":" "},{"type":"text","text":"grows larger."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example creates an array of integers from an array literal,"},{"type":"text","text":" "},{"type":"text","text":"then appends the elements of another collection. Before appending, the"},{"type":"text","text":" "},{"type":"text","text":"array allocates new storage that is large enough store the resulting"},{"type":"text","text":" "},{"type":"text","text":"elements."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["var numbers = [10, 20, 30, 40, 50]","// numbers.count == 5","// numbers.capacity == 5","","numbers.append(contentsOf: stride(from: 60, through: 100, by: 10))","// numbers.count == 10","// numbers.capacity == 10"]}]}],"variants":[{"paths":["/documentation/swift/contiguousarray/capacity"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.apple.Swift/documentation/Swift/ContiguousArray":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ContiguousArray","type":"topic","title":"ContiguousArray","kind":"symbol","url":"/documentation/swift/contiguousarray","navigatorTitle":[{"kind":"identifier","text":"ContiguousArray"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ContiguousArray","kind":"identifier"}],"abstract":[{"type":"text","text":"A contiguously stored array."}]},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/Int":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Int","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Int"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Int","url":"/documentation/swift/int","kind":"symbol","abstract":[{"type":"text","text":"A signed integer value type."}],"title":"Int"},"doc://com.apple.Swift/documentation/Swift/ContiguousArray/capacity":{"identifier":"doc://com.apple.Swift/documentation/Swift/ContiguousArray/capacity","kind":"symbol","role":"symbol","type":"topic","url":"/documentation/swift/contiguousarray/capacity","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"capacity"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"abstract":[{"text":"The total number of elements that the array can contain without","type":"text"},{"text":" ","type":"text"},{"text":"allocating new storage.","type":"text"}],"title":"capacity"}}}