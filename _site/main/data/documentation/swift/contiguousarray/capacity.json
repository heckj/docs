{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ContiguousArray/capacity","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"capacity","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every array reserves a specific amount of memory to hold its contents."},{"type":"text","text":" "},{"type":"text","text":"When you add elements to an array and that array begins to exceed its"},{"type":"text","text":" "},{"type":"text","text":"reserved capacity, the array allocates a larger region of memory and"},{"type":"text","text":" "},{"type":"text","text":"copies its elements into the new storage. The new storage is a multiple"},{"type":"text","text":" "},{"type":"text","text":"of the old storage’s size. This exponential growth strategy means that"},{"type":"text","text":" "},{"type":"text","text":"appending an element happens in constant time, averaging the performance"},{"type":"text","text":" "},{"type":"text","text":"of many append operations. Append operations that trigger reallocation"},{"type":"text","text":" "},{"type":"text","text":"have a performance cost, but they occur less and less often as the array"},{"type":"text","text":" "},{"type":"text","text":"grows larger."}]},{"inlineContent":[{"text":"The following example creates an array of integers from an array literal,","type":"text"},{"text":" ","type":"text"},{"text":"then appends the elements of another collection. Before appending, the","type":"text"},{"text":" ","type":"text"},{"text":"array allocates new storage that is large enough store the resulting","type":"text"},{"text":" ","type":"text"},{"text":"elements.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var numbers = [10, 20, 30, 40, 50]","// numbers.count == 5","// numbers.capacity == 5","","numbers.append(contentsOf: stride(from: 60, through: 100, by: 10))","// numbers.count == 10","// numbers.capacity == 10"],"type":"codeListing"}]}],"metadata":{"roleHeading":"Instance Property","symbolKind":"property","modules":[{"name":"Swift"}],"externalID":"s:s15ContiguousArrayV8capacitySivp","title":"capacity","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"capacity","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"extendedModule":"Swift","role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ContiguousArray"]]},"variants":[{"paths":["/documentation/swift/contiguousarray/capacity"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"The total number of elements that the array can contain without","type":"text"},{"text":" ","type":"text"},{"text":"allocating new storage.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://com.apple.Swift/documentation/Swift/ContiguousArray":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ContiguousArray","kind":"identifier"}],"abstract":[{"text":"A contiguously stored array.","type":"text"}],"role":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/ContiguousArray","kind":"symbol","title":"ContiguousArray","navigatorTitle":[{"kind":"identifier","text":"ContiguousArray"}],"url":"/documentation/swift/contiguousarray"},"doc://com.apple.Swift/documentation/Swift/Int":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Int