{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/contiguousarray/reversed()"]}],"sections":[],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ContiguousArray/reversed()","interfaceLanguage":"swift"},"abstract":[{"text":"Returns a view presenting the elements of the collection in reverse","type":"text"},{"text":" ","type":"text"},{"text":"order.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reversed"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:s18ReversedCollectionV","kind":"typeIdentifier","text":"ReversedCollection","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can reverse a collection without allocating new space for its"},{"type":"text","text":" "},{"type":"text","text":"elements by calling this "},{"type":"codeVoice","code":"reversed()"},{"type":"text","text":" method. A "},{"type":"codeVoice","code":"ReversedCollection"},{"type":"text","text":" "},{"type":"text","text":"instance wraps an underlying collection and provides access to its"},{"type":"text","text":" "},{"type":"text","text":"elements in reverse order. This example prints the characters of a"},{"type":"text","text":" "},{"type":"text","text":"string in reverse order:"}]},{"type":"codeListing","code":["let word = \"Backwards\"","for char in word.reversed() {","    print(char, terminator: \"\")","}","// Prints \"sdrawkcaB\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need a reversed collection of the same type, you may be able to"},{"type":"text","text":" "},{"type":"text","text":"use the collection’s sequence-based or collection-based initializer. For"},{"type":"text","text":" "},{"type":"text","text":"example, to get the reversed version of a string, reverse its"},{"type":"text","text":" "},{"type":"text","text":"characters and initialize a new "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instance from the result."}]},{"type":"codeListing","code":["let reversedWord = String(word.reversed())","print(reversedWord)","// Prints \"sdrawkcaB\""],"syntax":"swift"},{"style":"note","type":"aside","name":"Complexity","content":[{"type":"paragraph","inlineContent":[{"text":"O(1)","type":"text"}]}]}]}],"metadata":{"symbolKind":"method","modules":[{"name":"Swift"}],"roleHeading":"Instance Method","title":"reversed()","externalID":"s:SKsE8reverseds18ReversedCollectionVyxGyF::SYNTHESIZED::s:s15ContiguousArrayV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"reversed","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:s18ReversedCollectionV","text":"ReversedCollection","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"extendedModule":"Swift","role":"symbol"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ContiguousArray"]]},"references":{"doc://com.apple.Swift/documentation/Swift/ContiguousArray":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ContiguousArray","type":"topic","title":"ContiguousArray","kind":"symbol","url":"/documentation/swift/contiguousarray","navigatorTitle":[{"kind":"identifier","text":"ContiguousArray"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ContiguousArray","kind":"identifier"}],"abstract":[{"type":"text","text":"A contiguously stored array."}]},"doc://com.apple.Sw