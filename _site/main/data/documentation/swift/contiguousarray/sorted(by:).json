://com.apple.Swift/documentation/Swift/Bool","url":"/documentation/swift/bool","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Bool","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Bool"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/ContiguousArray":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ContiguousArray","kind":"identifier"}],"abstract":[{"text":"A contiguously stored array.","type":"text"}],"role":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/ContiguousArray","kind":"symbol","title":"ContiguousArray","navigatorTitle":[{"kind":"identifier","text":"ContiguousArray"}],"url":"/documentation/swift/contiguousarray"}}}