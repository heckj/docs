t":"is ","type":"text"},{"type":"codeVoice","code":"Int.max"},{"text":".","type":"text"}]}],"name":"maxSplits"},{"name":"omittingEmptySubsequences","content":[{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", an empty subsequence is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returned in the result for each consecutive pair of "},{"type":"codeVoice","code":"separator"},{"type":"text","text":" "},{"text":"elements in the collection and for each instance of ","type":"text"},{"type":"codeVoice","code":"separator"},{"text":" at","type":"text"},{"type":"text","text":" "},{"text":"the start or end of the collection. If ","type":"text"},{"type":"codeVoice","code":"true"},{"text":", only nonempty","type":"text"},{"type":"text","text":" "},{"text":"subsequences are returned. The default value is ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"An array of subsequences, split from this collection’s"},{"type":"text","text":" "},{"type":"text","text":"elements."}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The resulting array consists of at most "},{"type":"codeVoice","code":"maxSplits + 1"},{"type":"text","text":" subsequences."},{"type":"text","text":" "},{"type":"text","text":"Elements that are used to split the collection are not returned as part"},{"type":"text","text":" "},{"type":"text","text":"of any subsequence."}],"type":"paragraph"},{"inlineContent":[{"text":"The following examples show the effects of the ","type":"text"},{"type":"codeVoice","code":"maxSplits"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"omittingEmptySubsequences","type":"codeVoic