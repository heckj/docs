:". Always use the slice’s "},{"code":"startIndex","type":"codeVoice"},{"type":"text","text":" and "},{"code":"endIndex","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"properties instead of assuming that its indices start or end at a"},{"type":"text","text":" "},{"type":"text","text":"particular value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example demonstrates getting a slice of an array of strings, finding"},{"type":"text","text":" "},{"type":"text","text":"the index of one of the strings in the slice, and then using that index"},{"type":"text","text":" "},{"type":"text","text":"in the original array."}]},{"type":"codeListing","code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2 ..< streets.endIndex]","print(streetsSlice)","// Prints \"[\"Channing\", \"Douglas\", \"Evarts\"]\"","","let i = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[i!])","// Prints \"Evarts\""],"syntax":"swift"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/contiguousarray/subscript(_:)-41wt7"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Accesses a contiguous subrange of the array’s elements."}],"metadata":{"roleHeading":"Instance Subscript","extendedModule":"Swift","title":"subscript(_:)","modules":[{"name":"Swift"}],"externalID":"s:s15ContiguousArrayVys0B5SliceVyxGSnySiGcip","fragments":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sn","text":"Range","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":">) -> "},{"preciseIdentifier":"s:s10ArraySliceV","text":"ArraySlice","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s15ContiguousArrayV7Elementxmfp","text":"Element","kind":"typeIdentifier"},{"text":">","kind