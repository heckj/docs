{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ContiguousArray"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"("},{"kind":"internalParam","text":"bounds"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Range","identifier":"doc://com.apple.Swift/documentation/Swift/Range","preciseIdentifier":"s:Sn"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Int","identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","text":"ArraySlice","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice","preciseIdentifier":"s:s10ArraySliceV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:s15ContiguousArrayV7Elementxmfp"},{"kind":"text","text":"> { "},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"parameters":[{"name":"bounds","content":[{"inlineContent":[{"type":"text","text":"A range of integers. The bounds of the range must be"},{"type":"text","text":" "},{"type":"text","text":"valid indices of the array."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"text":"The returned ","type":"text"},{"type":"codeVoice","code":"ArraySlice"},{"text":" instance uses the same indices for the same","type":"text"},{"text":" ","type":"text"},{"text":"elements as the original array. In particular, that slice, unlike an","type":"text"},{"text":" ","type":"text"},{"text":"array, may have a nonzero ","type":"text"},{"type":"codeVoice","code":"startIndex"},{"text":" and an ","type":"text"},{"type":"codeVoice","code":"endIndex"},{"text":" that is not","type":"text"},{"text":" ","type":"text"},{"text":"equal to ","type":"text"},{"type":"codeVoice","code":"count"},{"text":". Always use the slice’s ","type":"text"},{"type":"codeVoice","code":"startIndex"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"endIndex"},{"text":" ","type":"text"},{"text":"properties instead of assuming that its indices start or end at a","type":"text"},{"text":" ","type":"text"},{"text":"particular value.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This example demonstrates getting a slice of an array of strings, finding","type":"text"},{"text":" ","type":"text"},{"text":"the index of one of the strings in the slice, and then using that index","type":"text"},{"text":" ","type":"text"},{"text":"in the original array.","type":"text"}],"type":"paragraph"},{"code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2 ..< streets.endIndex]","print(streetsSlice)","// Prints \"[\"Channing\", \"Douglas\", \"Evarts\"]\"","","let i = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[i!])","// Prints \"Evarts\""],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"abstract":[{"text":"Accesses a contiguous subrange of the array’s elements.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","metadata":{"extendedModule":"Swift","role":"symbol","title":"subscript(_:)","symbolKind":"subscript","modules":[{"name":"Swift"}],"externalID":"s:s15ContiguousArrayVys0B5SliceVyxGSnySiGcip","fragments":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sn","text":"Range","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"preciseIdentifier":"s:s10ArraySliceV","text":"ArraySlice","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s15ContiguousArrayV7Elementxmfp","text":"Element","kind":"typeIdentifier"},{"te