"},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The range expression is converted to a concrete subrange relative to this","type":"text"},{"text":" ","type":"text"},{"text":"collection. For example, using a ","type":"text"},{"type":"codeVoice","code":"PartialRangeFrom"},{"text":" range expression","type":"text"},{"text":" ","type":"text"},{"text":"with an array accesses the subrange from the start of the range","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"expression until the end of the array."}]},{"syntax":"swift","type":"codeListing","code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2...]","print(streetsSlice)","// [\"Channing\", \"Douglas\", \"Evarts\"]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The accessed slice uses the same indices for the same elements as the"},{"type":"text","text":" "},{"type":"text","text":"original collection uses. This example searches "},{"type":"codeVoice","code":"streetsSlice"},{"type":"text","text":" for one"},{"text":" ","type":"text"},{"type":"text","text":"of the strings in the slice, and then uses that index in the original"},{"type":"text","text":" "},{"type":"text","text":"array."}]},{"syntax":"swift","code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""],"type":"codeListing"},{"inlineContent":[{"text":"Always use the slice’s ","type":"text"},{"type":"codeVoice","code":"startIndex"},{"text":" property instead of assuming that its","type":"text"},{"type":"text","text":" "},{"text":"indices start at a particular value. Attempting to access an element by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"using an index outside the bounds of the slice’s indices may result in a"},{"type":"text","text":" "},{"text":"runtime error, even if that index is valid for the original collection.","type":"text"}],"type":"paragraph"},{"code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"],"type":"codeListing","syntax":"swift"},{"content":[{"inlineContent":[{"type":"text","text":"O(1)"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Complexity"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ContiguousArray/subscript(_:)-997ec","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","metadata":{"role":"symbol","externalID":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip::SYNTHESIZED::s:s15ContiguousArrayV","symbolKind":"subscript","extendedModule":"Swift","roleHeading":"Instance Subscript","modules":[{"name":"Swift"}],"title":"subscript(_:)","fragments":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"R","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp","text":"R","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sl11SubSequenceQa","text":"SubSequence","kind":"typeIdentifier"}]},"references":{"doc://com.apple.Swift/documentation/Swift/Collection/Index":{"required":true,"url":"/documentation/swift/collection/index","role":"symbol","title":"Index","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Index","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SL","text":"Comparable","kind":"typeIdentifier"}],"kind":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","abstract":[{"type":"text","text":"A type that represents a position in the collection."}]},"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence":{"title":"SubSequence","kind":"symbol","abstract":[{"type":"text","text":"A collection representing a contiguous subrange of 