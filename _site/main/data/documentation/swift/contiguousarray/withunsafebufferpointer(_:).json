,"kind":"keyword"},{"kind":"text","text":" "},{"text":"E","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:s5ErrorP","text":"Error","identifier":"doc://com.apple.Swift/documentation/Swift/Error","kind":"typeIdentifier"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A closure with an ","type":"text"},{"type":"codeVoice","code":"UnsafeBufferPointer"},{"text":" parameter that","type":"text"},{"text":" ","type":"text"},{"text":"points to the contiguous storage for the array.  If","type":"text"},{"text":" ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" has a return value, that value is also used as the return value","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the "},{"type":"codeVoice","code":"withUnsafeBufferPointer(_:)"},{"type":"text","text":" method. The pointer argument is"},{"type":"text","text":" "},{"type":"text","text":"valid only for the duration of the method’s execution."}]}],"name":"body"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"The return value, if any, of the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure parameter."}],"type":"paragraph"}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Often, the optimizer can eliminate bounds checks within an array"},{"type":"text","text":" "},{"type":"text","text":"algorithm, but when that fails, invoking the same algorithm on the"},{"type":"text","text":" "},{"text":"buffer pointer passed into your closure lets you trade safety for speed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows how you can iterate over the contents of the"},{"type":"text","text":" "},{"type":"text","text":"buffer pointer:"}]},{"type":"codeListing","syntax":"swift","code":["let numbers = [1, 2, 3, 4, 5]","let sum = numbers.withUnsafeBufferPointer { buffer -> Int in","    var result = 0","    for i in stride(from: buffer.startIndex, to: buffer.endIndex, by: 2) {","        result += buffer[i]","    }","    return result","}","// 'sum' == 9"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The pointer passed as an argument to "},{"code":"body","type":"codeVoice"},{"text":" is valid only during the","type":"text"},{"text":" ","type":"text"},{"text":"execution of ","type":"text"},{"code":"withUnsafeBufferPointer(_:)","type":"codeVoice"},{"text":". Do not store or return the","type":"text"},{"text":" ","type":"text"},{"text":"pointer for later use.","type":"text"}]}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/ContiguousArray":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ContiguousArray","kind":"identifier"}],"abstract":[{"text":"A contiguously stored array.","type":"text"}],"role":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/ContiguousArray","kind":"symbol","title":"ContiguousArray","navigatorTitle":[{"kind":"identifier","text":"ContiguousArray"}],"url":"/documentation/swift/contiguousarray"},"doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer":{"abstract":[{"text":"A nonowning collection interface to a buffer of","type":"text"},{"type":"text","text":" "},{"text":"elements stored contiguously in memory.","type":"text"}],"kind":"symbol","title":"UnsafeBufferPointer","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer","url":"/documentation/swift/unsafebufferpointer","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnsafeBufferPointer"}],"navigatorTitle":[{"kind":"identifier","text":"UnsafeBufferPointer"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift/Error":{"type":"topic","identifi