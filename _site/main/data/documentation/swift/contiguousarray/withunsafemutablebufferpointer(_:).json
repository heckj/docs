:"s:s5ErrorP","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Error","text":"Error"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure with an "},{"code":"UnsafeMutableBufferPointer","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"parameter that points to the contiguous storage for the array."},{"type":"text","text":" "},{"type":"text","text":"If "},{"code":"body","type":"codeVoice"},{"type":"text","text":" has a return value, that value is also"},{"type":"text","text":" "},{"type":"text","text":"used as the return value for the "},{"code":"withUnsafeMutableBufferPointer(_:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"method. The pointer argument is valid only for the duration of the"},{"type":"text","text":" "},{"type":"text","text":"method’s execution."}]}],"name":"body"}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value, if any, of the "},{"code":"body","type":"codeVoice"},{"type":"text","text":" closure parameter."}]}],"kind":"content"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Often, the optimizer can eliminate bounds checks within an array"},{"type":"text","text":" "},{"type":"text","text":"algorithm, but when that fails, invoking the same algorithm on the"},{"type":"text","text":" "},{"type":"text","text":"buffer pointer passed into your closure lets you trade safety for speed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows how modifying the contents of the"},{"type":"text","text":" "},{"code":"UnsafeMutableBufferPointer","type":"codeVoice"},{"type":"text","text":" argument to "},{"code":"body","type":"codeVoice"},{"type":"text","text":" alters the contents of"},{"type":"text","text":" "},{"type":"text","text":"the array:"}]},{"type":"codeListing","syntax":"swift","code":["var numbers = [1, 2, 3, 4, 5]","numbers.withUnsafeMutableBufferPointer { buffer in","    for i in stride(from: buffer.startIndex, to: buffer.endIndex - 1, by: 2) {","        buffer.swapAt(i, i + 1)","    }","}","print(numbers)","// Prints \"[2, 1, 4, 3, 5]\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The pointer passed as an argument to "},{"code":"body","type":"codeVoice"},{"type":"text","text":" is valid only during the"},{"type":"text","text":" "},{"type":"text","text":"execution of "},{"code":"withUnsafeMutableBufferPointer(_:)","type":"codeVoice"},{"type":"text","text":". Do not store or"},{"type":"text","text":" "},{"type":"text","text":"return the pointer for later use."}]},{"style":"warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not rely on anything about the array that is the target of"},{"type":"text","text":" "},{"type":"text","text":"this method during execution of the "},{"code":"body","type":"codeVoice"},{"type":"text","text":" closure; it might not"},{"type":"text","text":" "},{"type":"text","text":"appear to have its correct value. Instead, use only the"},{"type":"text","text":" "},{"code":"UnsafeMutableBufferPointer","type":"codeVoice"},{"type":"text","text":" argument to "},{"code":"body","type":"codeVoice"},{"type":"text","text":"."}]}],"name":"Warning"}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ContiguousArray"]]},"variants":[{"paths":["/documentation/swift/contiguousarray/withunsafemutablebufferpointer(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"symbol","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" 