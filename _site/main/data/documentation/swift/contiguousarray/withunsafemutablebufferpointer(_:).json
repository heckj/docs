 into your closure lets you trade safety for speed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows how modifying the contents of the"},{"text":" ","type":"text"},{"code":"UnsafeMutableBufferPointer","type":"codeVoice"},{"text":" argument to ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" alters the contents of","type":"text"},{"text":" ","type":"text"},{"text":"the array:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var numbers = [1, 2, 3, 4, 5]","numbers.withUnsafeMutableBufferPointer { buffer in","    for i in stride(from: buffer.startIndex, to: buffer.endIndex - 1, by: 2) {","        buffer.swapAt(i, i + 1)","    }","}","print(numbers)","// Prints \"[2, 1, 4, 3, 5]\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The pointer passed as an argument to "},{"code":"body","type":"codeVoice"},{"type":"text","text":" is valid only during the"},{"type":"text","text":" "},{"text":"execution of ","type":"text"},{"type":"codeVoice","code":"withUnsafeMutableBufferPointer(_:)"},{"type":"text","text":". Do not store or"},{"type":"text","text":" "},{"text":"return the pointer for later use.","type":"text"}]},{"name":"Warning","type":"aside","style":"warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not rely on anything about the array that is the target of"},{"text":" ","type":"text"},{"text":"this method during execution of the ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" closure; it might not","type":"text"},{"text":" ","type":"text"},{"text":"appear to have its correct value. Instead, use only the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"UnsafeMutableBufferPointer"},{"type":"text","text":" argument to "},{"type":"codeVoice","code":"body"},{"text":".","type":"text"}]}]}]}],"variants":[{"paths":["/documentation/swift/contiguousarray/withunsafemutablebufferpointer(_:)"],"traits":[{"interface