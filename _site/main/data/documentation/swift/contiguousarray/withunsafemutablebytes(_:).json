{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withUnsafeMutableBytes"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawBufferPointer","text":"UnsafeMutableRawBufferPointer","preciseIdentifier":"s:Sw"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:s15ContiguousArrayV22withUnsafeMutableBytesyqd__qd__SwKXEKlF1RL_qd__mfp","kind":"typeIdentifier","text":"R"},{"kind":"text","text":") "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:s15ContiguousArrayV22withUnsafeMutableBytesyqd__qd__SwKXEKlF1RL_qd__mfp","kind":"typeIdentifier","text":"R"}]}]},{"kind":"parameters","parameters":[{"name":"body","content":[{"type":"paragraph","inlineContent":[{"text":"A closure with an ","type":"text"},{"type":"codeVoice","code":"UnsafeMutableRawBufferPointer"},{"text":" ","type":"text"},{"text":"parameter that points to the contiguous storage for the array.","type":"text"},{"text":" ","type":"text"},{"text":"If no such storage exists, it is created. If ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" has a return value, that value is also","type":"text"},{"text":" ","type":"text"},{"text":"used as the return value for the ","type":"text"},{"type":"codeVoice","code":"withUnsafeMutableBytes(_:)"},{"text":" method.","type":"text"},{"text":" ","type":"text"},{"text":"The argument is valid only for the duration of the closure’s","type":"text"},{"text":" ","type":"text"},{"text":"execution.","type":"