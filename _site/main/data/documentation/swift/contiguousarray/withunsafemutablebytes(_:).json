text","text":"The pointer passed as an argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" is valid only for the"},{"type":"text","text":" "},{"type":"text","text":"lifetime of the closure. Do not escape it from the closure for later"},{"type":"text","text":" "},{"type":"text","text":"use."}],"type":"paragraph"},{"name":"Warning","style":"warning","content":[{"type":"paragraph","inlineContent":[{"text":"Do not rely on anything about the array that is the target of","type":"text"},{"text":" ","type":"text"},{"text":"this method during execution of the ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" closure; it might not","type":"text"},{"text":" ","type":"text"},{"text":"appear to have its correct value. Instead, use only the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"UnsafeMutableRawBufferPointer"},{"text":" argument to ","type":"text"},{"type":"codeVoice","code":"body"},{"text":".","type":"text"}]}],"type":"aside"}]}],"kind":"symbol","variants":[{"paths":["/documentation/swift/contiguousarray/withunsafemutablebytes(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ContiguousArray"]]},"abstract":[{"type":"text","text":"Calls the given closure with a pointer to the underlying bytes of the"},{"text":" ","type":"text"},{"text":"array’s mutable contiguous storage.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"symbol","roleHeading":"Instance Method","title":"withUnsafeMutableBytes(_:)","externalID":"s:s15ContiguousArrayV22withUnsafeMutableBytesyqd__qd__SwKXEKlF","extendedModule":"Swift","symbolKind":"method","modules":[{"name":"Swift"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withUnsafeMutableBytes"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">(("},{"kind":