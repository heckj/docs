  destBytes.copyBytes(from: srcBytes)","    }","}","// numbers == [1, 2]"],"type":"codeListing","syntax":"swift"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This example shows the behavior on a little-endian platform.","type":"text"}]}],"type":"aside","style":"note"},{"inlineContent":[{"text":"The pointer passed as an argument to ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" is valid only for the","type":"text"},{"text":" ","type":"text"},{"text":"lifetime of the closure. Do not escape it from the closure for later","type":"text"},{"text":" ","type":"text"},{"text":"use.","type":"text"}],"type":"paragraph"},{"style":"warning","name":"Warning","content":[{"inlineContent":[{"type":"text","text":"Do not rely on anything about the array that is the target of"},{"type":"text","text":" "},{"type":"text","text":"this method during execution of the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure; it might not"},{"type":"text","text":" "},{"type":"text","text":"appear to have its correct value. Instead, use only the"},{"type":"text","text":" "},{"type":"codeVoice","code":"UnsafeMutableRawBufferPointer"},{"type":"text","text":" argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"aside"}]}],"kind":"symbol","metadata":{"extendedModule":"Swift","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withUnsafeMutableBytes","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">(("},{"kind":"typeIdentifier","preciseIdentifier":"s:Sw","text":"UnsafeMutableRawBufferPointer"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"R","kind":"typeIdentifier","preciseIdentifier":"s:s15ContiguousArrayV22withUnsafeMutableBytesyqd__qd__SwKXEKlF1RL_qd__mfp"},{"text":") ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind"