":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSView"},{"type":"text","text":" and "},{"type":"codeVoice","code":"UIView"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Playground logging may also be able to support specialized descriptions"},{"type":"text","text":" "},{"type":"text","text":"of other types."}]},{"type":"heading","anchor":"Conforming-to-the-CustomPlaygroundDisplayConvertible-Protocol","text":"Conforming to the CustomPlaygroundDisplayConvertible Protocol","level":2},{"type":"paragraph","inlineContent":[{"text":"To add ","type":"text"},{"code":"CustomPlaygroundDisplayConvertible","type":"codeVoice"},{"text":" conformance to your custom type,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implement the "},{"code":"playgroundDescription","type":"codeVoice"},{"text":" property. If your implementation","type":"text"},{"text":" ","type":"text"},{"text":"returns an instance of one of the types above, that type’s specialized","type":"text"},{"text":" ","type":"text"},{"text":"description is used. If you return any other type, a structured description","type":"text"},{"text":" ","type":"text"},{"text":"is generated.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If your type has value semantics, the "},{"type":"codeVoice","code":"playgroundDescription"},{"type":"text","text":" should be"},{"text":" ","type":"text"},{"text":"unaffected by subsequent mutations, if possible.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If your type’s ","type":"text"},{"type":"codeVoice","code":"playgroundDescription"},{"type":"text","text":" returns an instance which itself"},{"type":"text","text":" "},{"type":"text","text":"conforms to "},{"code":"CustomPlaygroundDisplayConvertible","type":"codeVoice"},{"text":", then that type’s","type":"text"},{"text":" ","type":"text"},{"code":"playgroundDescription","type":"codeVoice"},{"type":"text","text":" will be used, and so on