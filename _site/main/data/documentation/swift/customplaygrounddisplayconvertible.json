{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"kind":"symbol","abstract":[{"text":"A type that supplies a custom description for playground logging.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"CustomPlaygroundDisplayConvertible"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"inlineContent":[{"type":"text","text":"Playground logging can generate, at a minimum, a structured description"},{"type":"text","text":" "},{"type":"text","text":"of any type. If you want to provide a custom description of your type to be"},{"type":"text","text":" "},{"type":"text","text":"logged in place of the default description, conform to the"},{"type":"text","text":" "},{"code":"CustomPlaygroundDisplayConvertible","type":"codeVoice"},{"type":"text","text":" protocol."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Playground logging generates a richer, more specialized description of core"},{"type":"text","text":" "},{"type":"text","text":"types. For example, the contents of a "},{"type":"codeVoice","code":"String"},{"type":"text","text":" are logged, as are the"},{"type":"text","text":" "},{"type":"text","text":"components of an "},{"type":"codeVoice","code":"NSColor"},{"type":"text","text":" or "},{"type":"codeVoice","code":"UIColor"},{"type":"text","text":". The current playground logging"},{"type":"text","text":" "},{"type":"text","text":"implementation logs specialized descriptions of at least the following"},{"type":"text","text":" "},{"type":"text","text":"types:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"String","type":"codeVoice"},{"type":"text","text":" and "},{"code":"NSString","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"Int","type":"