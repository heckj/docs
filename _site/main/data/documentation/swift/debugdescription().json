{"schemaVersion":{"minor":3,"major":0,"patch":0},"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/CustomReflectable","doc://com.apple.Swift/documentation/Swift/CustomLeafReflectable","doc://com.apple.Swift/documentation/Swift/CustomPlaygroundDisplayConvertible","doc://com.apple.Swift/documentation/Swift/PlaygroundQuickLook"],"anchor":"Customizing-Your-Types-Reflection","generated":true,"title":"Customizing Your Type’s Reflection"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/debugdescription()"]}],"sections":[],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/DebugDescription()","interfaceLanguage":"swift"},"abstract":[{"text":"Converts description definitions to a debugger Type Summary.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@attached","kind":"attribute"},{"text":"(member) ","kind":"text"},{"text":"@attached","kind":"attribute"},{"text":"(memberAttribute) ","kind":"text"},{"text":"macro","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DebugDescription","kind":"identifier"},{"text":"()","kind":"text"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This macro converts compatible description implementations written in Swift","type":"text"},{"type":"text","text":" "},{"text":"to an LLDB format known as a Type Summary. A Type Summary is LLDB’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"equivalent to "},{"code":"debugDescription","type":"codeVoice"},{"type":"text","text":", with the distinction that it does not"},{"text":" ","type":"text"},{"type":"text","text":"execute code inside the debugged process. By avoiding code execution,"},{"text":" ","type":"text"},{"type":"text","text":"descriptions can be produced faster, without potential side effects, and"},{"text":" ","type":"text"},{"type":"text","text":"shown in situations where code execution is not performed, such as the"},{"text":" ","type":"text"},{"type":"text","text":"variable list of an IDE."}]},{"type":"paragraph","inlineContent":[{"text":"Consider this an example. This ","type":"text"},{"code":"Team","type":"codeVoice"},{"text":" struct has a ","type":"text"},{"code":"debugDescription","type":"codeVoice"},{"text":" which","type":"text"},{"text":" ","type":"text"},{"text":"summarizes some key details, such as the team’s name. The debugger only","type":"text"},{"type":"text","text":" "},{"text":"computes this string on demand - typically via the ","type":"text"},{"code":"po","type":"codeVoice"},{"text":" command. By applying","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"DebugDescription","type":"codeVoice"},{"text":" macro, a matching Type Summary is constructed. This","type":"text"},{"text":" ","type":"text"},{"text":"allows the user to show a string like “Rams [11-2]”, without executing","type":"text"},{"text":" ","type":"text"},{"code":"debugDescription","type":"codeVoice"},{"text":". This improves the usability, performance, and","type":"text"},{"text":" ","type":"text"},{"text":"reliability of the debugging experience.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@DebugDescription","struct Team: CustomDebugStringConvertible {","   var name: String","   var wins, losses: Int","","   var debugDescription: String {","       \"\\(name) [\\(wins)-\\(losses)]\"","   }","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"DebugDescription","type":"codeVoice"},{"text":" macro supports both ","type":"text"},{"code":"debugDescription","type":"codeVoice"},{"text":", ","type":"text"},{"code":"description","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"as well as a third option: a property named ","type":"text"},{"code":"lldbDescription","type":"codeVoice"},{"text":". The first","type":"text"},{"text":" ","type":"text"},{"text":"two are implemented when conforming to the ","type":"text"},{"code":"CustomDebugStringConvertible","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"CustomStringConvertible","type":"codeVoice"},{"text":" protocols. The additional ","type":"text"},{"code":"lldbDescription","type":"codeVoice"},{"text":" ","type":"text"},{"text":"property is useful when both ","type":"text"},{"code":"debugDescription","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"description","type":"codeVoice"},{"text":" are","type":"text"},{"text":" ","type":"text"},{"text":"implemented, but don’t meet the requirements of the ","type":"text"},{"code":"DebugDescription","type":"codeVoice"},{"text":" ","type":"text"},{"text":"macro. If ","type":"text"},{"code":"lldbDescription","type":"codeVoice"},{"text":" is implemented, ","type":"text"},{"code":"DebugDescription","type":"codeVoice"},{"text":" choose it","type":"text"},{"text":" ","type":"text"},{"text":"over ","type":"text"},{"code":"debugDescription","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"description","type":"codeVoice"},{"text":". Likewise, ","type":"text"},{"code":"debugDescription","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"preferred over ","type":"text"},{"code":"description","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","level":3,"text":"Description Requirements","anchor":"Description-Requirements"},{"type":"paragraph","inlineContent":[{"text":"The description implementation has the following requirements:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The body of the description implementation must be a single string"},{"type":"text","text":" "},{"type":"text","text":"expression. String concatenation is not supported, use string interpolation"},{"type":"text","text":" "},{"type":"text","text":"instead."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"String interpolation can reference stored properties only, functions calls"},{"type":"text","text":" "},{"type":"text","text":"and other arbitrary computation are not supported. Of note, conditional"},{"type":"text","text":" "},{"type":"text","text":"logic and computed properties are not supported."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Overloaded string interpolation cannot be used."}]}]}]}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"metadata":{"symbolKind":"macro","externalID":"s:s16DebugDescriptionyycfm","roleHeading":"Macro","title":"DebugDescription()","modules":[{"name":"Swift"}],"fragments":[{"kind":"keyword","text":"macro"},{"text":" ","kind":"text"},{"text":"DebugDescription","kind":"identifier"},{"text":"()","kind":"text"}],"role":"symbol"},"references":{"doc://com.apple.Swift/documentation/Swift/DebugDescription()":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/DebugDescription()","type":"topic","title":"DebugDescription()","kind":"symbol","url":"/documentation/swift/debugdescription()","fragments":[{"kind":"keyword","text":"macro"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DebugDescription"},{"text":"()","kind":"text"}],"abstract":[{"type":"text","text":"Converts description definitions to a debugger Type Summary."}]},"doc://com.apple.Swift/documentation/Swift/CustomPlaygroundDisplayConvertible":{"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"CustomPlaygroundDisplayConvertible"}],"title":"CustomPlaygroundDisplayConvertible","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/CustomPlaygroundDisplayConvertible","kind":"symbol","url":"/documentation/swift/customplaygrounddisplayconvertible","abstract":[{"type":"text","text":"A type that supplies a custom description for playground logging."}],"navigatorTitle":[{"kind":"identifier","text":"CustomPlaygroundDisplayConvertible"}]},"doc://com.apple.Swift/documentation/Swift/CustomReflectable":{"type":"topic","abstract":[{"type":"text","text":"A type that explicitly supplies its own mirror."}],"title":"CustomReflectable","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/CustomReflectable","url":"/documentation/swift/customreflectable","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"CustomReflectable"}],"navigatorTitle":[{"kind":"identifier","text":"CustomReflectable"}]},"doc://com.apple.Swift/documentation/Swift/CustomLeafReflectable":{"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"CustomLeafReflectable"}],"title":"CustomLeafReflectable","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/CustomLeafReflectable","type":"topic","url":"/documentation/swift/customleafreflectable","abstract":[{"type":"text","text":"A type that explicitly supplies its own mirror, but whose"},{"type":"text","text":" "},{"type":"text","text":"descendant classes are not represented in the mirror unless they"},{"type":"text","text":" "},{"type":"text","text":"also override "},{"type":"codeVoice","code":"customMirror"},{"type":"text","text":"."}],"navigatorTitle":[{"kind":"identifier","text":"CustomLeafReflectable"}]},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/PlaygroundQuickLook":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/PlaygroundQuickLook","type":"topic","title":"PlaygroundQuickLook","kind":"symbol","url":"/documentation/swift/playgroundquicklook","navigatorTitle":[{"kind":"identifier","text":"PlaygroundQuickLook"}],"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"PlaygroundQuickLook"}],"abstract":[{"type":"text","text":"The sum of types that can be used as a Quick Look representation."}]}}}