{"abstract":[{"text":"Returns a subsequence from the start of the collection through the","type":"text"},{"text":" ","type":"text"},{"text":"specified position.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"prefix","kind":"identifier"},{"text":"(","kind":"text"},{"text":"through","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"position","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Index","preciseIdentifier":"s:Sl5IndexQa","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index"},{"text":") -> ","kind":"text"},{"text":"SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"position","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The index of the last element to include in the"},{"type":"text","text":" "},{"type":"text","text":"resulting subsequence. "},{"type":"codeVoice","code":"position"},{"type":"text","text":" must be a valid index of the collection"},{"type":"text","text":" "},{"type":"text","text":"that is not equal to the "},{"type":"codeVoice","code":"endIndex"},{"type":"text","text":" property."}]}]}]},{"kind":"content","content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A subsequence up to, and including, the given position."}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"The resulting subsequence ","type":"text"},{"inlineContent":[{"type":"text","text":"includes"}],"type":"emphasis"},{"type":"text","text":" the element at the position"},{"type":"text","text":" "},{"type":"text","text":"specified by the "},{"code":"through","type":"codeVoice"},{"type":"text","text":" parameter."},{"type":"text","text":" "},{"type":"text","text":"The following example searches for the index of the number "},{"code":"40","type":"codeVoice"},{"type":"text","text":" in an"},{"type":"text","text":" "},{"type":"text","text":"array of integers, and then prints the prefix of the array up to, and"},{"type":"text","text":" "},{"type":"text","text":"including, that index:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let numbers = [10, 20, 30, 40, 50, 60]","if let i = numbers.firstIndex(of: 40) {","    print(numbers.prefix(through: i))","}","// Prints \"[10, 20, 30, 40]\""]},{"type":"paragraph","inlineContent":[{"text":"Using the ","type":"text"},{"type":"codeVoice","code":"prefix(through:)"},{"type":"text","text":" method is equivalent to using a partial"},{"type":"text","text":" "},{"type":"text","text":"closed range as the collection’s subscript. The subscript notation is"},{"type":"text","text":" "},{"type":"text","text":"preferred over "},{"type":"codeVoice","code":"prefix(through:)"},{"type":"text","text":"."}]},{"code":["if let i = numbers.firstIndex(of: 40) {","    print(numbers[...i])","}","// Prints \"[10, 20, 30, 40]\""],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"O(1)","type":"text"}]}],"type":"aside","name":"Complexity","style":"note"}]}],"variants":[{"paths":["/documentation/swift/defaultindices/prefix(through:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"prefix(through:)","modules":[{"name":"Swift"}],"role":"symbol","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"prefix","kind":"identifier"},{"text":"(","kind":"text"},{"text":"through","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa","