{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/DefaultIndices/subscript(_:)-4h7sp","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">("},{"kind":"internalParam","text":"r"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp","text":"R"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa","text":"SubSequence"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"R"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression","preciseIdentifier":"s:SX","text":"RangeExpression"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","preciseIdentifier":"s:Sl5IndexQa","text":"Index"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"R"},{"kind":"text","text":"."},{"identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound","kind":"typeIdentifier","text":"Bound","preciseIdentifier":"s:SX5BoundQa"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The range expression is converted to a concrete subrange relative to this"},{"type":"text","text":" "},{"type":"text","text":"collection. For example, using a "},{"type":"codeVoice","code":"PartialRangeFrom"},{"type":"text","text":" range expression"},{"type":"text","text":" "},{"type":"text","text":"with an array accesses the subrange from the start of the range"},{"type":"text","text":" "},{"type":"text","text":"expression until the end of the array."}],"type":"paragraph"},{"code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2...]","print(streetsSlice)","// [\"Channing\", \"Douglas\", \"Evarts\"]"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The accessed slice uses the same indices for the same elements as the","type":"text"},{"text":" ","type":"text"},{"text":"original collection uses. This example searches ","type":"text"},{"code":"streetsSlice","type":"codeVoice"},{"text":" for one","type":"text"},{"text":" ","type":"text"},{"text":"of the strings in the slice, and then uses that index in the original","type":"text"},{"text":" ","type":"text"},{"text":"array.","type":"text"}],"type":"paragraph"},{"code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Always use the slice’s ","type":"text"},{"type":"codeVoice","code":"startIndex"},{"text":" property instead of assuming that its","type":"text"},{"text":" ","type":"text"},{"text":"indices start at a particular value. Attempting to access an element by","type":"text"},{"text":" ","type":"text"},{"text":"using an index outside the bounds of the slice’s indices may result in a","type":"text"},{"text":" ","type":"text"},{"text":"runtime error, even if that index is valid for the original collection.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O(1)"}]}],"type":"aside","style":"note","name":"Complexity"}]}],"metadata":{"roleHeading":"Instance Subscript","symbolKind":"subscript","modules":[{"name":"Swift"}],"externalID":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip::SYNTHESIZED::s:SI","title":"subscript(_:)","fragments":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"R","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"R","kind":"typeIdentifier","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp"},{"text":") -> ","kind":"text"},{"text":"SubSequence","kind":"typeIdentifier","preciseIdentifier":"s:Sl11SubSequenceQa"}],"extendedModule":"Swift","role":"symbol"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/DefaultIndices"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/defaultindices/subscript(_:)-4h7sp"]}],"sections":[],"abstract":[{"type":"text","text":"Accesses the contiguous subrange of the collection’s elements specified"},{"type":"text","text":" "},{"type":"text","text":"by a range expression."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.apple.Swift/documentation/Swift/Collection/Index":{"required":true,"url":"/documentation/swift/collection/index","role":"symbol","title":"Index","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Index","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SL","text":"Comparable","kind":"typeIdentifier"}],"kind":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","abstract":[{"type":"text","text":"A type that represents a position in the collection."}]},"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence":{"title":"SubSequence","kind":"symbol","abstract":[{"type":"text","text":"A collection representing a contiguous subrange of this collection’s"},