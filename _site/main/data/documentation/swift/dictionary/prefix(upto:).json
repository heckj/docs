{"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/dictionary/prefix(upto:)"]}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Dictionary/prefix(upTo:)"},"abstract":[{"type":"text","text":"Returns a subsequence from the start of the collection up to, but not"},{"type":"text","text":" "},{"type":"text","text":"including, the specified position."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"prefix"},{"kind":"text","text":"("},{"kind":"externalParam","text":"upTo"},{"kind":"text","text":" "},{"kind":"internalParam","text":"end"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Index","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","preciseIdentifier":"s:Sl5IndexQa"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"SubSequence","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The “past the end” index of the resulting subsequence."},{"type":"text","text":" "},{"type":"codeVoice","code":"end"},{"type":"text","text":" must be a valid index of the collection."}]}],"name":"end"}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A subsequence up to, but not including, the "},{"type":"codeVoice","code":"end"},{"type":"text","text":" position."}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The resulting subsequence "},