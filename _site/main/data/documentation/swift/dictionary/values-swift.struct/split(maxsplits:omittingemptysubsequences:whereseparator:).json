":"any subsequence.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following examples show the effects of the ","type":"text"},{"code":"maxSplits","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"omittingEmptySubsequences","type":"codeVoice"},{"text":" parameters when splitting a string using a","type":"text"},{"text":" ","type":"text"},{"text":"closure that matches spaces. The first use of ","type":"text"},{"code":"split","type":"codeVoice"},{"text":" returns each word","type":"text"},{"text":" ","type":"text"},{"text":"that was originally separated by one or more spaces.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let line = \"BLANCHE:   I don't want realism. I want magic!\"","print(line.split(whereSeparator: { $0 == \" \" }))","// Prints \"[\"BLANCHE:\", \"I\", \"don\\'t\", \"want\", \"realism.\", \"I\", \"want\", \"magic!\"]\""]},{"type":"paragraph","inlineContent":[{"text":"The second example passes ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" for the ","type":"text"},{"code":"maxSplits","type":"codeVoice"},{"text":" parameter, so the","type":"text"},{"text":" ","type":"text"},{"text":"original string is split just once, into two new strings.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["print(line.split(maxSplits: 1, whereSeparator: { $0 == \" \" }))","// Prints \"[\"BLANCHE:\", \"  I don\\'t want realism. I want magic!\"]\""]},{"type":"paragraph","inlineContent":[{"text":"The final example passes ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" for the ","type":"text"},{"code":"omittingEmptySubsequences","type":"codeVoice"},{"text":" ","type":"text"},{"text":"parameter, so the returned array contains empty strings where spaces","type":"text"},{"text":" ","type":"text"},{"text":"were repeated.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["print(line.split(omittingEmptySubsequences: false, whereSeparator: { $0 == \" \" }))","// Prints \"[\"BLANCHE:\", \"\", \"\", \"I\", \"don\\'t\", \"want\", \"realism.\", \"I\", \"want\", \"magic!\"]\""]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":"), where "},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" is the length of the collection."}]}],"name":"Complexity"}]}],"variants":[{"paths":["/documentation/swift/dictionary/values-swift.struct/split(maxsplits:omittingemptysubsequences:whereseparator:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Dictionary","doc://com.apple.Swift/documentation/Swift/Dictionary/Values-swift.struct"]]},"references":{"doc://com.apple.Swift/documentation/Swift/Dictionary":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Dictionary"}],"role":"symbol","abstract":[{"text":"A collection whose elements are key-value pairs.","type":"text"}],"url":"/documentation/swift/dictionary","identifier":"doc://com.apple.Swift/documentation/Swift/Dictionary","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Dictionary"}],"title":"Dictionary"},"doc://com.apple.Swift/documentation/Swift/Dictionary/Values-swift.struct":{"abstract":[{"type":"text","text":"A view of a dictionary’s values."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Values","kind":"identifier"}],"role":"symbol","url":"/documentation/swift/dictionary/values-swift.struct","title":"Dictionary.Values","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Values"}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Dictionary/Values-swift.struct","con