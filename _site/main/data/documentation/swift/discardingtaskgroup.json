s":[],"seeAlsoSections":[{"title":"Tasks","generated":true,"anchor":"Tasks","identifiers":["doc://com.apple.Swift/documentation/Swift/Task","doc://com.apple.Swift/documentation/Swift/TaskGroup","doc://com.apple.Swift/documentation/Swift/withTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","doc://com.apple.Swift/documentation/Swift/withThrowingTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/TaskPriority","doc://com.apple.Swift/documentation/Swift/withDiscardingTaskGroup(returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup","doc://com.apple.Swift/documentation/Swift/withThrowingDiscardingTaskGroup(returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/UnsafeCurrentTask"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DiscardingTaskGroup","kind":"identifier"}]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"To create a discarding task group,","type":"text"},{"text":" ","type":"text"},{"text":"call the ","type":"text"},{"code":"withDiscardingTaskGroup(returning:body:)","type":"codeVoice"},{"text":" method.","type":"text"}]},{"inlineContent":[{"text":"Don’t use a task group from outside the task where you created it.","type":"text"},{"text":" ","type":"text"},{"text":"In most cases,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the Swift type system prevents a task group from escaping like that"},{"type":"text","text":" "},{"type":"text","text":"because adding a child task to a task group is a mutating operation,"},{"type":"text","text":" "},{"type":"text","text":"and mutation operations can’t be performed"},{"type":"text","text":" "},{"type":"text","text":"from a concurrent execution context like a child task."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Refer to "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true},{"text":" documentation for detailed discussion of semantics shared between all task groups.","type":"text"}],"type":"paragraph"},{"anchor":"Discarding-behavior","level":3,"type":"heading","text":"Discarding behavior"},{"inlineContent":[{"type":"text","text":"A discarding task group eagerly discards and releases its child tasks as"},{"type":"text","text":" "},{"type":"text","text":"soon as they complete. This allows for the efficient releasing of memory used"},{"type":"text","text":" "},{"type":"text","text":"by those tasks, which are not retained for future "},{"type":"codeVoice","code":"next()"},{"type":"text","text":" calls, as would"},{"type":"text","text":" "},{"type":"text","text":"be the case with a "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Cancellation behavior","type":"heading","level":3,"anchor":"Cancellation-behavior"},{"inlineContent":[{"type":"text","text":"A discarding task group becomes canceled in one of the following ways:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"when "},{"isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup/cancelAll()","type":"reference"},{"type":"text","text":" is invoked on it,"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"when the "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Task","isActive":true,"type":"reference"},{"type":"text","text":" running this task group is canceled."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Since a "},{"type":"codeVoice","code":"DiscardingTaskGroup"},{"type":"text","text":" is a structured concurrency primitive, cancellation is"},{"text":" ","type":"text"},{"type":"text","text":"automatically propagated through all of its child-tasks (and their child"},{"type":"text","text":" "},{"type":"text","text":"tasks)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A canceled task group can still keep adding tasks, however they will start"},{"type":"text","text":" "},{"type":"text","text":"being immediately canceled, and may act accordingly to this. To avoid adding"},{"type":"text","text":" "},{"type":"text","text":"new tasks to an already canceled task group, use "},{"type":"codeVoice","code":"addTaskUnlessCancelled(priority:body:)"},{"text":" ","type":"text"},{"text":"rather than the plain ","type":"text"},{"code":"addTask(priority:body:)","type":"codeVoice"},{"type":"text","text":" which adds tasks unconditionally."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For information about the language-level concurrency model that "},{"code":"DiscardingTaskGroup","type":"codeVoice"},{"text":" is part of,","type":"text"},{"text":" ","type":"text"},{"text":"see ","type":"text"},{"isActive":true,"identifier":"https://docs.swift.org/swift-book/LanguageGuide/Concurrency.html","type":"reference"},{"type":"text","text":" in "},{"type":"reference","identifier":"https://docs.swift.org/swift-book/","isActive":true},{"type":"text","text":"."}]},{"type":"aside","name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","type":"reference"}],"type":"paragraph"}],"style":"note"},{"type":"aside","name":"See Also","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","isActive":true,"type":"reference"}]}],"style":"note"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","tex