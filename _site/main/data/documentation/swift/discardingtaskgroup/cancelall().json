{"metadata":{"modules":[{"name":"Swift","relatedModules":[]}],"symbolKind":"method","roleHeading":"Instance Method","externalID":"s:12_Concurrency19DiscardingTaskGroupV9cancelAllyyF","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"cancelAll"},{"kind":"text","text":"()"}],"title":"cancelAll()"},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup/cancelAll()"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup"]]},"abstract":[{"type":"text","text":"Cancel all of the remaining tasks in the group."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"cancelAll"},{"kind":"text","text":"()"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"If you add a task to a group after canceling the group,"},{"type":"text","text":" "},{"type":"text","text":"that task is canceled immediately after being added to the group."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Immediately canceled child tasks should therefore cooperatively check for and"},{"type":"text","text":" "},{"type":"text","text":"react  to cancellation, e.g. by throwing an "},{"type":"codeVoice","code":"CancellationError"},{"type":"text","text":" at their"},{"type":"text","text":" "},{"type":"text","text":"earliest convenience, or otherwise handling the cancellation."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"There are no restrictions on where you can call this method."},{"type":"text","text":" "},{"type":"text","text":"Code inside a child task or even another task can cancel a group,"},{"type":"text","text":" "},{"type":"text","text":"however one s