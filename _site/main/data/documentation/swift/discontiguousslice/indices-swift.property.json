{"abstract":[{"text":"The indices that are valid for subscripting the collection, in ascending","type":"text"},{"text":" ","type":"text"},{"text":"order.","type":"text"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/DiscontiguousSlice"]]},"metadata":{"externalID":"s:SlsSIyxG7IndicesRtzrlE7indicesAAvp::SYNTHESIZED::s:s18DiscontiguousSliceV","symbolKind":"property","title":"indices","conformance":{"constraints":[{"type":"codeVoice","code":"Indices"},{"type":"text","text":" is "},{"type":"codeVoice","code":"DefaultIndices<Self>"},{"type":"text","text":"."}],"conformancePrefix":[{"type":"text","text":"Conforms when"}],"availabilityPrefix":[{"type":"text","text":"Available when"}]},"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"indices"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"DefaultIndices","preciseIdentifier":"s:SI"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}],"modules":[{"name":"Swift"}],"role":"symbol","extendedModule":"Swift","roleHeading":"Instance Property"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/discontiguousslice/indices-swift.property"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/DiscontiguousSlice/indices-swift.property"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"indices","kind":"identifier"},{"text":": ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/DefaultIndices","text":"DefaultIndices","preciseIdentifier":"s:SI","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":"> { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A collection’s "},{"type":"codeVoice","code":"indices"},{"type":"text","text":" property can hold a strong reference to the"},{"type":"text","text":" "},{"type":"text","text":"collection itself, causing the collection to be non-uniquely referenced."},{"type":"text","text":" "},{"type":"text","text":"If you mutate the collection while iterating over its indices, a strong"},{"type":"text","text":" "},{"type":"text","text":"reference can cause an unexpected copy of the collection. To avoid the"},{"type":"text","text":" "},{"type":"text","text":"unexpected copy, use the "},{"type":"codeVoice","code":"index(after:)"},{"type":"text","text":" method starting with"},{"type":"text","text":" "},{"type":"codeVoice","code":"startIndex"},{"type":"text","text":" to produce indices instead."}]},{"code":["var c = MyFancyCollection([10, 20, 30, 40, 50])","var i = c.startIndex","while i != c.endIndex {","    c[i] /= 5","    i = c.index(after: i)","}","// c == MyFancyCollection([2, 4, 6, 8, 10])"],"type":"codeListing","syntax":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/DefaultIndices":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DefaultIndices"}],"type":"topic","title":"DefaultIndices","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/DefaultIndices","kind":"symbol","abstract":[{"type":"text","text":"A collection of indices for an arbitrary collection"}],"navigatorTitle":[{"text":"DefaultIndices","kind":"identifier"}],"url":"/documentation/swift/defaultindices"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collectio