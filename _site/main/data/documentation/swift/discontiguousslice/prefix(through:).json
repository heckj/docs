text":" parameter.","type":"text"},{"text":" ","type":"text"},{"text":"The following example searches for the index of the number ","type":"text"},{"type":"codeVoice","code":"40"},{"text":" in an","type":"text"},{"text":" ","type":"text"},{"text":"array of integers, and then prints the prefix of the array up to, and","type":"text"},{"text":" ","type":"text"},{"text":"including, that index:","type":"text"}]},{"code":["let numbers = [10, 20, 30, 40, 50, 60]","if let i = numbers.firstIndex(of: 40) {","    print(numbers.prefix(through: i))","}","// Prints \"[10, 20, 30, 40]\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using the "},{"code":"prefix(through:)","type":"codeVoice"},{"text":" method is equivalent to using a partial","type":"text"},{"text":" ","type":"text"},{"text":"closed range as the collection’s subscript. The subscript notation is","type":"text"},{"text":" ","type":"text"},{"text":"preferred over ","type":"text"},{"code":"prefix(through:)","type":"codeVoice"},{"text":".","type":"text"}]},{"code":["if let i = numbers.firstIndex(of: 40) {","    print(numbers[...i])","}","// Prints \"[10, 20, 30, 40]\""],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O(1)"}]}],"style":"note","name":"Complexity","type":"aside"}],"kind":"content"}],"abstract":[{"type":"text","text":"Returns a subsequence from the start of the collection through the"},{"type":"text","text":" "},{"type":"text","text":"specified position."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"extendedModule":"Swift","role":"symbol","title":"prefix(through:)","symbolKind":"method","modules":[{"name":"Swift"}],"externalID":"s:SlsE6prefix7through11SubSequenceQz5IndexQz_tF::SYNTHESIZED::s:s18DiscontiguousSliceV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"prefix","kind":"identifier"},{"text":"(","kind":"text"},{"text":"through","kind"