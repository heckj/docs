:"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can sort any sequence of elements that conform to the "},{"code":"Comparable","type":"codeVoice"},{"text":" ","type":"text"},{"text":"protocol by calling this method. Elements are sorted in ascending order.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Here’s an example of sorting a list of students’ names. Strings in Swift"},{"text":" ","type":"text"},{"text":"conform to the ","type":"text"},{"code":"Comparable","type":"codeVoice"},{"text":" protocol, so the names are sorted in","type":"text"},{"text":" ","type":"text"},{"text":"ascending order according to the less-than operator (","type":"text"},{"code":"<","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let students: Set = [\"Kofi\", \"Abena\", \"Peter\", \"Kweku\", \"Akosua\"]","let sortedStudents = students.sorted()","print(sortedStudents)","// Prints \"[\"Abena\", \"Akosua\", \"Kofi\", \"Kweku\", \"Peter\"]\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To sort the elements of your sequence in descending order, pass the"},{"type":"text","text":" "},{"type":"text","text":"greater-than operator ("},{"code":">","type":"codeVoice"},{"type":"text","text":") to the "},{"code":"sorted(by:)","type":"codeVoice"},{"type":"text","text":" method."}]},{"type":"codeListing","code":["let descendingStudents = students.sorted(by: >)","print(descendingStudents)","// Prints \"[\"Peter\", \"Kweku\", \"Kofi\", \"Akosua\", \"Abena\"]\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The sorting algorithm is guaranteed to be stable. A stable sort"},{"type":"text","text":" "},{"type":"text","text":"preserves the relative order of elements that compare as equal."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" log ","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"text":" is the length of the sequence.","type":"text"}]}],"name":"Complexity","style":"note"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/DiscontiguousSlice/sorted()":{"conformance":{"availabilityPrefix":[{"type":"text","text":"Available when"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"type":"codeVoice","code":"Element"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":"."}]},"role":"symbol","url":"/documentation/swift/discontiguousslice/sorted()","title":"sorted()","identifier":"doc://com.apple.Swift/documentation/Swift/DiscontiguousSlice/sorted()","type":"topic","abstract":[{"text":"Returns the elements of the sequence, sorted.","type":"text"}],"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sorted","kind":"identifier"},{"text":"() -> [","kind":"text"},{"preciseIdentifier":"s:ST7ElementQa","text":"Element","kind":"typeIdentifier"},{"text":"]","kind":"text"}]},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/DiscontiguousSlice":{"url":"/documentation/swift/discontiguousslice","role":"symbol","title":"DiscontiguousSlice","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiscontiguousSlice"}],"type":"topic","kind":"symbol","navigatorTitle":[{"text":"DiscontiguousSlice","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Discontiguous