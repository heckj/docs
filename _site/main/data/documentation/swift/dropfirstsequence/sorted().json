{"abstract":[{"text":"Returns the elements of the sequence, sorted.","type":"text"}],"metadata":{"role":"symbol","modules":[{"name":"Swift"}],"title":"sorted()","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sorted","kind":"identifier"},{"text":"() -> [","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa"},{"text":"]","kind":"text"}],"conformance":{"availabilityPrefix":[{"type":"text","text":"Available when"}],"constraints":[{"type":"codeVoice","code":"Element"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":"."}],"conformancePrefix":[{"type":"text","text":"Conforms when"}]},"externalID":"s:STsSL7ElementRpzrlE6sortedSayABGyF::SYNTHESIZED::s:s17DropFirstSequenceV","extendedModule":"Swift"},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/DropFirstSequence/sorted()"},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/DropFirstSequence"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"sorted"},{"kind":"text","text":"() -> ["},{"kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa","text":"Element","identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element"},{"kind":"text","text":"]"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"A sorted array of the sequence’s elements.","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"You can sort any sequence of elements that conform to the ","type":"text"},{"code":"Comparable","type":"codeVoice"},{"text":" ","type":"text"},{"text":"protocol by calling this method. Elements are sorted in ascending order.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Here’s an example of sorting a list of students’ names. Strings in Swift"},{"type":"text","text":" "},{"type":"text","text":"conform to the "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":" protocol, so the names are sorted in"},{"type":"text","text":" "},{"type":"text","text":"ascending order according to the less-than operator ("},{"type":"codeVoice","code":"<"},{"type":"text","text":")."}],"type":"paragraph"},{"syntax":"swift","code":["let students: Set = [\"Kofi\", \"Abena\", \"Peter\", \"Kweku\", \"Akosua\"]","let sortedStudents = students.sorted()","print(sortedStudents)","// Prints \"[\"Abena\", \"Akosua\", \"Kofi\", \"Kweku\", \"Peter\"]\""],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"To sort the elements of your sequence in descending order, pass the","type":"text"},{"text":" ","type":"text"},{"text":"greater-than operator (","type":"text"},{"code":">","type":"codeVoice"},{"type":"text","text":") to the "},{"type":"codeVoice","code":"sorted(by:)"},{"text":" method.","type":"text"}]},{"code":["let descendingStudents = students.sorted(by: >)","print(descendingStudents)","// Prints \"[\"Peter\", \"Kweku\", \"Kofi\", \"Akosua\", \"Abena\"]\""],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The sorting algorithm is guaranteed to be stable. A stable sort","type":"text"},{"type":"text","text":" "},{"type":"text","text":"preserves the relative order of elements that compare as equal."}],"type":"paragraph"},{"style":"note","name":"Complexity","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" log "},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"type":"text","text":" is the length of the sequence."}]}],"type":"aside"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/dropfirstsequence/sorted()"]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","url":"/documentation/swift/sequence/element","title":"Element","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"A type representing the sequence’s elements."}],"required":true,"kind":"symbol","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/DropFirstSequence/sorted()":{"role":"symbol","abstract":[{"type":"text","text":"Returns the elements of the sequence, sorted."}],"identifier":"doc://com.apple.Swift/documentation/Swift/DropFirstSequence/sorted()","title":"sorted()","type":"topic","kind":"symbol","url":"/documentation/swift/dropfirstsequence/sorted()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"sorted","kind":"identifier"},{"kind":"text","text":"() -> ["},{"kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa","text":"Element"},{"text":"]","kind":"text"}],"conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"availabilityPrefix":[{"type":"text","text":"Available when"}],"constraints":[{"type":"codeVoice","code":"Element"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Comparable"},{"type":"text","tex