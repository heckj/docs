apple.Swift/documentation/Swift/Bool":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","type":"topic","title":"Bool","kind":"symbol","url":"/documentation/swift/bool","navigatorTitle":[{"kind":"identifier","text":"Bool"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Bool"}],"abstract":[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]},"doc://com.apple.Swift/documentation/Swift/DropFirstSequence":{"navigatorTitle":[{"kind":"identifier","text":"DropFirstSequence"}],"url":"/documentation/swift/dropfirstsequence","title":"DropFirstSequence","abstract":[{"type":"text","text":"A sequence that lazily consumes and drops "},{"type":"codeVoice","code":"n"},{"type":"text","text":" elements from an underlying"},{"type":"text","text":" "},{"type":"codeVoice","code":"Base"},{"type":"text","text":" iterator before possibly returning the first available element."}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DropFirstSequence"}],"identifier":"doc://com.apple.Swift/documentation/Swift/DropFirstSequence","role":"symbol","kind":"symbol"}}}