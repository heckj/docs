"text"},{"code":"allowEmptySlices","type":"codeVoice"},{"text":" parameter, so","type":"text"},{"text":" ","type":"text"},{"text":"the returned array contains empty strings where spaces were repeated.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["print(","    line.split(","        omittingEmptySubsequences: false,","        whereSeparator: { $0 == \" \" }","    ).map(String.init))","// Prints \"[\"BLANCHE:\", \"\", \"\", \"I\", \"don\\'t\", \"want\", \"realism.\", \"I\", \"want\", \"magic!\"]\""]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"O(","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":" is the length of the sequence.","type":"text"}]}],"type":"aside","name":"Complexity"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/DropFirstSequence"]]},"references":{"doc://com.apple.Swift/documentation/Swift/DropFirstSequence":{"navigatorTitle":[{"kind":"identifier","text":"DropFirstSequence"}],"url":"/documentation/swift/dropfirstsequence","title":"DropFirstSequence","abstract":[{"type":"text","text":"A sequence that lazily consumes and drops "},{"type":"codeVoice","code":"n"},{"type":"text","text":" elements from an underlying"},{"type":"text","text":" "},{"type":"codeVoice","code":"Base"},{"type":"text","text":" iterator before possibly returning the first available element."}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DropFirstSequence"}],"identifier":"doc://com.apple.Swift/documentation/Swift/DropFirstSequence","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"title":"Element","fragments":[{"kind":"keyword","text":"