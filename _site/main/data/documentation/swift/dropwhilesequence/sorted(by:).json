hat lazily consumes and drops "},{"type":"codeVoice","code":"n"},{"type":"text","text":" elements from an underlying"},{"type":"text","text":" "},{"type":"codeVoice","code":"Base"},{"type":"text","text":" iterator before possibly returning the first available element."}],"role":"symbol","url":"/documentation/swift/dropwhilesequence","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DropWhileSequence"}],"identifier":"doc://com.apple.Swift/documentation/Swift/DropWhileSequence","title":"DropWhileSequence","type":"topic"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"title":"Element","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Element"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","type":"topic","required":true,"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"A type representing the sequence’s elements."}],"url":"/documentation/swift/sequence/element"}}}