symbol"},"doc://com.apple.Swift/documentation/Swift/Bool":{"title":"Bool","abstract":[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","url":"/documentation/swift/bool","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Bool","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Bool"}],"type":"topic"}}}