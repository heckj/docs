rings in the slice, and then uses that index in the original"},{"text":" ","type":"text"},{"type":"text","text":"array."}]},{"code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always use the slice’s "},{"type":"codeVoice","code":"startIndex"},{"text":" property instead of assuming that its","type":"text"},{"type":"text","text":" "},{"text":"indices start at a particular value. Attempting to access an element by","type":"text"},{"type":"text","text":" "},{"text":"using an index outside the bounds of the slice’s indices may result in a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"runtime error, even if that index is valid for the original collection."}]},{"type":"codeListing","syntax":"swift","code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"]},{"type":"aside","name":"Complexity","style":"note","content":[{"inlineContent":[{"text":"O(1)","type":"text"}],"type":"paragraph"}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.apple.Swift/documentation/Swift/EmptyCollection/subscript(_:)-2eo9o":{"type":"topic","title":"subscript(_:)","identifier":"doc://com.apple.Swift/documentation/Swift/EmptyCollection/subscript(_:)-2eo9o","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Accesses the contiguous subrange of the collection’s elements specified"},{"type":"text","text":" "},{"type":"text","text":"by a range expression."}],"url":"/documentation/swift/emptycollection/subscript(_:)-2eo9o","fragments":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"R","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp","text":"R"},