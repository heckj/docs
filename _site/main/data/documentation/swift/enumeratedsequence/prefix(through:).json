{"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["/documentation/swift/enumeratedsequence/prefix(through:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/EnumeratedSequence/prefix(through:)"},"abstract":[{"type":"text","text":"Returns a subsequence from the start of the collection through the"},{"type":"text","text":" "},{"type":"text","text":"specified position."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"prefix","kind":"identifier"},{"text":"(","kind":"text"},{"text":"through","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"position","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Index","preciseIdentifier":"s:Sl5IndexQa","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","kind":"typeIdentifier"}]}],"kind":"declarations"},{"parameters":[{"name":"position","content":[{"inlineContent":[{"text":"The index of the last element to include in the","type":"text"},{"text":" ","type":"text"},{"text":"resulting subsequence. ","type":"text"},{"code":"position","type":"codeVoice"},{"text":" must be a valid index of the collection","type":"text"},{"text":" ","type":"text"},{"text":"that is not equal to the ","type":"text"},{"code":"endIndex","type":"codeVoice"},{"text":" property.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A subsequence up to, and including, the given position.","type":"text"}]}]},{"kind":"content","content":[{"a