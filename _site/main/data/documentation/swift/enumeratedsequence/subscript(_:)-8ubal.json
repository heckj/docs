{"abstract":[{"type":"text","text":"Accesses the contiguous subrange of the collection’s elements specified"},{"type":"text","text":" "},{"type":"text","text":"by a range expression."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"R","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"r","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"R","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"SubSequence","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"R","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression","preciseIdentifier":"s:SX","text":"RangeExpression"},{"kind":"text","text":", "},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:Sl5IndexQa","text":"Index","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index"},{"text":" == ","kind":"text"},{"text":"R","kind":"typeIdentifier"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound","text":"Bound","preciseIdentifier":"s:SX5BoundQa"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"The range expression is converted to a concrete subrange relative to this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"collection. For example, using a "},{"type":"codeVoice","code":"PartialRangeFrom"},{"type":"text","text":" range expression"},{"type":"text","text":" "},{"type":"text","text":"with an array accesses the subrange from the start of the range"},{"type":"text","text":" "},{"type":"text","text":"expression until the end of the array."}]},{"code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2...]","print(streetsSlice)","// [\"Channing\", \"Douglas\", \"Evarts\"]"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The accessed slice uses the same indices for the same elements as the"},{"type":"text","text":" "},{"type":"text","text":"original collection uses. This example searches "},{"code":"streetsSlice","type":"codeVoice"},{"type":"text","text":" for one"},{"type":"text","text":" "},{"type":"text","text":"of the strings in the slice, and then uses that index in the original"},{"type":"text","text":" "},{"type":"text","text":"array."}]},{"code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always use the slice’s "},{"type":"codeVoice","code":"startIndex"},{"type":"text","text":" property instead of assuming that its"},{"type":"text","text":" "},{"type":"text","text":"indices start at a particular value. Attempting to access an element by"},{"type":"text","text":" "},{"type":"text","text":"using an index outside the bounds of the slice’s indices may result in a"},{"type":"text","text":" "},{"type":"text","text":"runtime error, even if that index is valid for the original collection."}]},{"code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"],"syntax":"swift","type":"codeListing"},{"content":[{"inlineContent":[{"type":"text","text":"O(1)"}],"type"