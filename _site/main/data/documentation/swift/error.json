{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/error"]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Error","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"Swift"}],"roleHeading":"Protocol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Error","kind":"identifier"}],"symbolKind":"protocol","navigatorTitle":[{"text":"Error","kind":"identifier"}],"title":"Error","externalID":"s:s5ErrorP"},"seeAlsoSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/Result"],"anchor":"Errors","title":"Errors"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","identifiers":["doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype"],"title":"Inherits From"},{"kind":"relationships","type":"inheritedBy","identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActorSystemError","doc://com.apple.Swift/documentation/_RegexParser/LocatedErrorProtocol"],"title":"Inherited By"},{"kind":"relationships","type":"conformingTypes","identifiers":["doc://com.apple.Swift/documentation/Swift/CancellationError","doc://com.apple.Swift/documentation/Swift/DecodingError","doc://com.apple.Swift/documentation/_RegexParser/DelimiterLexError","doc://com.apple.Swift/documentation/Runtime/DemanglingError","doc://com.apple.Swift/documentation/Distributed/DistributedActorCodingError","doc://com.apple.Swift/documentation/Swift/EncodingError","doc://com.apple.Swift/documentation/Distributed/ExecuteDistributedTargetError","doc://com.apple.Swift/documentation/Distributed/LocalTestingDistributedActorSystemError","doc://com.apple.Swift/documentation/Swift/Never","doc://com.apple.Swift/documentation/_RegexParser/Source/LocatedError","doc://com.apple.Swift/documentation/Swift/Unicode/UTF8/ValidationError","doc://com.apple.Swift/documentation/Swift/Unicode/UTF8/ValidationError/Kind-swift.struct","doc://com.apple.Swift/documentation/_RegexParser/Unreachable","doc://com.apple.Swift/documentation/_RegexParser/Unsupported"],"title":"Conforming Types"}],"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"A type representing an error value that can be thrown."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Error"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"Sendable","identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","preciseIdentifier":"s:s8SendableP"}]}]},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any type that declares conformance to the "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" protocol can be used to"},{"type":"text","text":" "},{"type":"text","text":"represent an error in Swift’s error handling system. Because the "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" "},{"type":"text","text":"protocol has no requirements of its own, you can declare conformance on"},{"type":"text","text":" "},{"type":"text","text":"any custom type you create."}]},{"type":"heading","text":"Using Enumerations as Errors","anchor":"Using-Enumerations-as-Errors","level":1},{"type":"paragraph","inlineContent":[{"type":"text","text":"Swift’s enumerations are well suited to represent simple errors. Create an"},{"type":"text","text":" "},{"type":"text","text":"enumeration that conforms to the "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" protocol with a case for each"},{"type":"text","text":" "},{"type":"text","text":"possible error. If there are additional details about the error that could"},{"type":"text","text":" "},{"type":"text","text":"be helpful for recovery, use associated values to include that"},{"type":"text","text":" "},{"type":"text","text":"information."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows an "},{"type":"codeVoice","code":"IntParsingError"},{"type":"text","text":" enumeration that captures"},{"type":"text","text":" "},{"type":"text","text":"two different kinds of errors that can occur when parsing an integer from"},{"type":"text","text":" "},{"type":"text","text":"a string: overflow, where the value represented by the string is too large"},{"type":"text","text":" "},{"type":"text","text":"for the integer data type, and invalid input, where nonnumeric characters"},{"type":"text","text":" "},{"type":"text","text":"are found within the input."}]},{"type":"codeListing","syntax":"swift","code":["enum IntParsingError: Error {","    case overflow","    case invalidInput(Character)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"invalidInput"},{"type":"text","text":" case includes the invalid character as an associated"},{"type":"text","text":" "},{"type":"text","text":"value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The next code sample shows a possible extension to the "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" type that"},{"type":"text","text":" "},{"type":"text","text":"parses the integer value of a "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instance, throwing an error when"},{"type":"text","text":" "},{"type":"text","text":"there is a problem during parsing."}]},{"type":"codeListing","syntax":"swift","code":["extension Int {","    init(validating input: String) throws {","        // ...","        let c = _nextCharacter(from: input)","        if !_isValid(c) {","            throw IntParsingError.invalidInput(c)","        }","        // ...","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When calling the new "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" initializer within a "},{"type":"codeVoice","code":"do"},{"type":"text","text":" statement, you can use"},{"type":"text","text":" "},{"type":"text","text":"pattern matching to match specific cases of your custom error type and"},{"type":"text","text":" "},{"type":"text","text":"access their associated values, as in the example below."}]},{"type":"codeListing","syntax":"swift","code":["do {","    let price = try Int(validating: \"$100\")","} catch IntParsingError.invalidInput(let invalid) {","    print(\"Invalid character: '\\(invalid)'\")","} catch IntParsingError.overflow {","    print(\"Overflow error\")","} catch {","    print(\"Other error\")","}","// Prints \"Invalid character: '$'\""]},{"type":"heading","text":"Including More Data in Errors","anchor":"Including-More-Data-in-Errors","level":1},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sometimes you may want different error states to include the same common"},{"type":"text","text":" "},{"type":"text","text":"data, such as the position in a file or some of your application’s state."},{"type":"text","text":" "},{"type":"text","text":"When you do, use a structure to represent errors. The following example"},{"type":"text","text":" "},{"type":"text","text":"uses a structure to represent an error when parsing an XML document,"},{"type":"text","text":" "},{"type":"text","text":"including the line and column numbers where the error occurred:"}]},{"type":"codeListing","syntax":"swift","code":["struct XMLParsingError: Error {","    enum Kind {","        case invalidCharacter","        case mismatchedTag","        case internalError","    }","","    let line: Int","    let column: Int","    let kind: Kind","}","","func parse(_ source: String) throws -> XMLDoc {","    // ...","    throw XMLParsingError(line: 19, column: 5, kind: .mismatchedTag)","    // ...","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once again, use pattern matching to conditionally catch errors. Here’s how"},{"type":"text","text":" "},{"type":"text","text":"you can catch any "},{"code":"XMLParsingError","type":"codeVoice"},{"type":"text","text":" errors thrown by the "},{"code":"parse(_:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"function:"}]},{"type":"codeListing","syntax":"swift","code":["do {","    let xmlDoc = try parse(myXMLData)","} catch let e as XMLParsingError {","    print(\"Parsing error: \\(e.kind) [\\(e.line):\\(e.column)]\")","} catch {","    print(\"Other error: \\(error)\")","}","// Prints \"Parsing error: mismatchedTag [19:5]\""]}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/EncodingError":{"role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"EncodingError"}],"title":"EncodingError","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/EncodingError","type":"topic","url":"/documentation/swift/encodingerror","abstract":[{"type":"text","text":"An error that occurs during the encoding of a value."}],"navigatorTitle":[{"kind":"identifier","text":"EncodingError"}]},"doc://com.apple.Swift/documentation/Swift/Result":{"navigatorTitle":[{"kind":"identifier","text":"Result"}],"title":"Result","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Result"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Result","type":"topic","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"A value that represents either a success or a failure, including an"},{"type":"text","text":" "},{"type":"text","text":"associated value in each case."}],"url":"/documentation/swift/result"},"doc://com.apple.Swift/documentation/Swift/Sendable":{"type":"topic","abstract":[{"type":"text","text":"A thread-safe type whose values can be shared across arbitrary isolation"},{"type":"text","text":" "},{"type":"text","text":"domains without introducing a risk of data races."}],"title":"Sendable","role":"symbol","url":"/documentation/swift/sendable","identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Sendable"}],"navigatorTitle":[{"kind":"identifier","text":"Sendable"}]},"doc://com.apple.Swift/documentation/Swift/Never":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"Never"}],"abstract":[{"type":"text","text":"A type that has no values and can’t be constructed."}],"identifier":"doc://com.apple.Swift/documentation/Swift/Never","title":"Never","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Never"}],"url":"/documentation/swift/never","type":"topic"},"doc://com.apple.Swift/documentation/Runtime/DemanglingError":{"identifier":"doc://com.apple.Swift/documentation/Runtime/DemanglingError","abstract":[{"type":"text","text":"Error thrown to indicate failure to demangle a Swift symbol."}],"type":"topic","role":"symbol","url":"/documentation/runtime/demanglingerror","navigatorTitle":[{"kind":"identifier","text":"DemanglingError"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DemanglingError"}],"title":"DemanglingError"},"doc://com.apple.Swift/documentation/Swift/SendableMetatype":{"type":"topic","abstract":[{"type":"text","text":"A type whose metatype can be shared across arbitrary isolation domains"},{"type":"text","text":" "},{"type":"text","text":"without introducing a risk of data races."}],"title":"SendableMetatype","role":"symbol","url":"/documentation/swift/sendablemetatype","identifier":"doc://com.apple.Swift/documentation/Swift/SendableMetatype","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Sendabl