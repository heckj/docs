{"seeAlsoSections":[{"generated":true,"title":"Errors","anchor":"Errors","identifiers":["doc://com.apple.Swift/documentation/Swift/Result"]}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype"],"type":"inheritsFrom"},{"kind":"relationships","title":"Inherited By","identifiers":["doc://com.apple.Swift/documentation/Distributed/DistributedActorSystemError","doc://com.apple.Swift/documentation/_RegexParser/LocatedErrorProtocol"],"type":"inheritedBy"},{"kind":"relationships","title":"Conforming Types","identifiers":["doc://com.apple.Swift/documentation/Swift/CancellationError","doc://com.apple.Swift/documentation/Swift/DecodingError","doc://com.apple.Swift/documentation/_RegexParser/DelimiterLexError","doc://com.apple.Swift/documentation/Distributed/DistributedActorCodingError","doc://com.apple.Swift/documentation/Swift/EncodingError","doc://com.apple.Swift/documentation/Distributed/ExecuteDistributedTargetError","doc://com.apple.Swift/documentation/Distributed/LocalTestingDistributedActorSystemError","doc://com.apple.Swift/documentation/Swift/Never","doc://com.apple.Swift/documentation/_RegexParser/Source/LocatedError","doc://com.apple.Swift/documentation/Swift/Unicode/UTF8/ValidationError","doc://com.apple.Swift/documentation/Swift/Unicode/UTF8/ValidationError/Kind-swift.struct","doc://com.apple.Swift/documentation/_RegexParser/Unreachable","doc://com.apple.Swift/documentation/_RegexParser/Unsupported"],"type":"conformingTypes"}],"abstract":[{"type":"text","text":"A type representing an error value that can be thrown."}],"metadata":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Error"}],"role":"symbol","roleHeading":"Protocol","navigatorTitle":[{"kind":"identifier","text":"Error"}],"title":"Error","symbolKind":"protocol","modules":[{"name":"Swift"}],"externalID":"s:s5ErrorP"},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Error","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"Error","kind":"identifier"},{"text":" : ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","text":"Sendable","kind":"typeIdentifier","preciseIdentifier":"s:s8SendableP"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any type that declares conformance to the "},{"code":"Error","type":"codeVoice"},{"type":"text","text":" protocol can be used to"},{"type":"text","text":" "},{"type":"text","text":"represent an error in Swift’s error handling system. Because the "},{"code":"Error","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"protocol has no requirements of its own, you can declare conformance on"},{"text":" ","type":"text"},{"type":"text","text":"any custom type you create."}]},{"type":"heading","anchor":"Using-Enumerations-as-Errors","text":"Using Enumerations as Errors","level":1},{"type":"paragraph","inlineContent":[{"text":"Swift’s enumerations are well suited to represent simple errors. Create an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"enumeration that conforms to the "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" protocol with a case for each"},{"type":"text","text":" "},{"type":"text","text":"possible error. If there are additional details about the error that could"},{"type":"text","text":" "},{"type":"text","text":"be helpful for recovery, use associated values to include that"},{"type":"text","text":" "},{"type":"text","text":"information."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows an "},{"type":"codeVoice","code":"IntParsingError"},{"text":" enumeration that captures","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"two different kinds of errors that can occur when parsing an integer from"},{"type":"text","text":" "},{"type":"text","text":"a string: overflow, where the value represented by the string is too large"},{"type":"text","text":" "},{"type":"text","text":"for the integer data type, and invalid input, where nonnumeric characters"},{"type":"text","text":" "},{"type":"text","text":"are found within the input."}]},{"type":"codeListing","syntax":"swift","code":["enum IntParsingError: Error {","    case overflow","    case invalidInput(Character)","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"invalidInput","type":"codeVoice"},{"text":" case includes the invalid character as an associated","type":"text"},{"text":" ","type":"text"},{"text":"value.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The next code sample shows a possible extension to the ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" type that","type":"text"},{"text":" ","type":"text"},{"text":"parses the integer value of a ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" instance, throwing an error when","type":"text"},{"text":" ","type":"text"},{"text":"there is a problem during parsing.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["extension Int {","    init(validating input: String) throws {","        // ...","        let c = _nextCharacter(from: input)","        if !_isValid(c) {","            throw IntParsingError.invalidInput(c)","        }","        // ...","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"When calling the new ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" initializer within a ","type":"text"},{"code":"do","type":"codeVoice"},{"text":" statement, you can use","type":"text"},{"text":" ","type":"text"},{"text":"pattern matching to match specific cases of your custom error type and","type":"text"},{"text":" ","type":"text"},{"text":"access their associated values, as in the example below.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["do {","    let price = try Int(validating: \"$100\")","} catch IntParsingError.invalidInput(let invalid) {","    print(\"Invalid character: '\\(invalid)'\")","} catch IntParsingError.overflow {","    print(\"Overflow error\")","} catch {","    print(\"Other error\")","}","// Prints \"Invalid character: '$'\""]},{"type":"heading","text":"Including More Data in Errors","anchor":"Including-More-Data-in-Errors","level":1},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sometimes you may want different error states to include the same common"},{"type":"text","text":" "},{"type":"text","text":"data, such as the position in a file or some of your application’s state."},{"type":"text","text":" "},{"type":"text","text":"When you do, use a structure to represent errors. The following example"},{"type":"text","text":" "},{"type":"text","text":"uses a structure to represent an error when parsing an XML document,"},{"type":"text","text":" "},{"type":"text","text":"including the line and column numbers where the error occurred:"}]},{"syntax":"swift","type":"codeListing","code":["struct XMLParsingError: Error {","    enum Kind {","        case invalidCharacter","        case mismatchedTag","        case internalError","    }","","    let line: Int","    let column: Int","    let kind: Kind","}","","func parse(_ source: String) throws -> XMLDoc {","    // ...","    throw XMLParsingError(line: 19, column: 5, kind: .mismatchedTag)","    // ...","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once again, use pattern matching to conditionally catch errors. Here’s how"},{"type":"text","text":" "},{"text":"you can catch any ","type":"text"},{"code":"XMLParsingError","type":"codeVoice"},{"text":" errors thrown by the ","type":"text"},{"code":"parse(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"function:","type":"text"}]},{"syntax":"swift","code":["do {","    let xmlDoc = try parse(myXMLData)","} catch let e as XMLParsingError {","    print(\"Parsing error: \\(e.kind) [\\(e.line):\\(e.column)]\")","} catch {","    print(\"Other error: \\(error)\")","}","// Prints \"Parsing error: mismatchedTag [19:5]\""],"type":"codeListing"}]}],"variants":[{"paths":["/documentation/swift/error"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystemError":{"type":"topic","title":"DistributedActorSystemError","identifier":"doc://com.apple.Swift/documentation/Distributed/DistributedActorSystemError","kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistributedActorSystemError","kind":"identifier"}],"navigatorTitle":[{"text":"DistributedActorSystemError","kind":"identifier"}],"url":"/documentation/distributed/distributedactorsystemerror","abstract":[{"text":"Error protocol to which errors thrown by any ","type":"text"},{"type":"codeVoice","code":"DistributedActorSystem"},{"text":" should conform.","type":"text"}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/EncodingError":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"EncodingError"}],"abstract":[{"text":"An error that occurs during the encoding of a value.","type":"text"}],"role":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/EncodingE