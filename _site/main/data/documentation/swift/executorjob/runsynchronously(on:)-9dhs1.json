{"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ExecutorJob"]]},"abstract":[{"text":"Run this job on the passed in executor.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"runSynchronously","kind":"identifier"},{"text":"(","kind":"text"},{"text":"on","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"executor","kind":"internalParam"},{"text":": ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/UnownedSerialExecutor","preciseIdentifier":"s:Sce","text":"UnownedSerialExecutor","kind":"typeIdentifier"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The executor this job will be semantically running on.","type":"text"}]}],"name":"executor"}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"This operation runs the job on the calling thread and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"blocks"}]},{"type":"text","text":" until the job completes."},{"type":"text","text":" "},{"text":"The intended use of this method is for an executor to determine when and where it","type":"text"},{"text":" ","type":"text"},{"text":"wants to run the job and then call this method on it.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The passed in executor reference is used to establish the executor context for the job,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and should be the same executor as the one semantically calling the "},{"type":"codeVoice","code":"runSynchronously"},{"type":"text","text":" method."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This operation consumes the job, p