"DifferentiableView","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/SIMD32":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"SIMD32","kind":"identifier"}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/SIMD32","title":"SIMD32","abstract":[{"text":"A vector of 32 scalar values.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"SIMD32"}],"type":"topic","role":"symbol","url":"/documentation/swift/simd32"},"doc://com.apple.Swift/documentation/Swift/Set":{"navigatorTitle":[{"text":"Set","kind":"identifier"}],"url":"/documentation/swift/set","abstract":[{"text":"An unordered collection of unique elements.","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Set","type":"topic","title":"Set","kind":"symbol","role":"symbol","conformance":{"availabilityPrefix":[{"text":"Available when","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}],"constraints":[{"code":"Element","type":"codeVoice"},{"text":" conforms to ","type":"text"},{"code":"Copyable","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Escapable","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":".","type":"text"}]},"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Set","kind":"identifier"}]}}}