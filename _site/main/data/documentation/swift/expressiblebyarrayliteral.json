{"abstract":[{"text":"A type that can be initialized using an array literal.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"modules":[{"name":"Swift"}],"externalID":"s:s25ExpressibleByArrayLiteralP","roleHeading":"Protocol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ExpressibleByArrayLiteral","kind":"identifier"}],"title":"ExpressibleByArrayLiteral","navigatorTitle":[{"text":"ExpressibleByArrayLiteral","kind":"identifier"}],"symbolKind":"protocol"},"sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"relationshipsSections":[{"title":"Inherited By","identifiers":["doc://com.apple.Swift/documentation/Cxx/CxxSet","doc://com.apple.Swift/documentation/Cxx/CxxUniqueSet","doc://com.apple.Swift/documentation/Cxx/CxxVector","doc://com.apple.Swift/documentation/Swift/OptionSet","doc://com.apple.Swift/documentation/Swift/SIMD","doc://com.apple.Swift/documentation/Swift/SetAlgebra"],"kind":"relationships","type":"inheritedBy"},{"title":"Conforming Types","identifiers":["doc://com.apple.Swift/documentation/Swift/Array","doc://com.apple.Swift/documentation/Swift/Array/DifferentiableView","doc://com.apple.Swift/documentation/Swift/ArraySlice","doc://com.apple.Swift/documentation/Runtime/Backtrace/SymbolicationOptions","doc://com.apple.Swift/documentation/_RegexParser/CaptureList","doc://com.apple.Swift/documentation/Swift/ContiguousArray","doc://com.apple.Swift/documentation/Observation/ObservationTracking/Options","doc://com.apple.Swift/documentation/Swift/SIMD16","doc://com.apple.Swift/documentation/Swift/SIMD2","doc://com.apple.Swift/documentation/Swift/SIMD3","doc://com.apple.Swift/documentation/Swift/SIMD32","doc://com.apple.Swift/documentation/Swift/SIMD4","doc://com.apple.Swift/documentation/Swift/SIMD64","doc://com.apple.Swift/documentation/Swift/SIMD8","doc://com.apple.Swift/documentation/Swift/SIMDMask","doc://com.apple.Swift/documentation/Runtime/SectionCharacteristics","doc://com.apple.Swift/documentation/Swift/Set","doc://com.apple.Swift/documentation/_RegexParser/SyntaxOptions"],"kind":"relationships","type":"conformingTypes"}],"seeAlsoSections":[{"title":"Collection Literals","identifiers":["doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral"],"generated":true,"anchor":"Collection-Literals"}],"topicSections":[{"title":"Associated Types","identifiers":["doc://com.apple.Swift/documentation/Swift/ExpressibleByArrayLiteral/ArrayLiteralElement"],"anchor":"Associated-Types","generated":true},{"title":"Initializers","identifiers":["doc://com.apple.Swift/documentation/Swift/ExpressibleByArrayLiteral/init(arrayLiteral:)"],"generated":true,"anchor":"Initializers"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/expressiblebyarrayliteral"]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/ExpressibleByArrayLiteral"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"ExpressibleByArrayLiteral","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An array literal is a simple way of expressing a list of values. Simply"},{"type":"text","text":" "},{"type":"text","text":"surround a comma-separated list of values, instances, or literals with"},{"text":" ","type":"text"},{"type":"text","text":"square brackets to create an array literal. You can use an array literal"},{"type":"text","text":" "},{"type":"text","text":"anywhere an instance of an "},{"type":"codeVoice","code":"ExpressibleByArrayLiteral"},{"type":"text","text":" type is expected: as"},{"type":"text","text":" "},{"type":"text","text":"a value assigned to a variable or constant, as a parameter to a method or"},{"type":"text","text":" "},{"type":"text","text":"initializer, or even as the subject of a nonmutating operation like"},{"type":"text","text":" "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" or "},{"type":"codeVoice","code":"filter(_:)"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Arrays, sets, and option sets all conform to "},{"type":"codeVoice","code":"ExpressibleByArrayLiteral"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and your own custom types can as well. Here’s an example of creating a set"},{"type":"text","text":" "},{"type":"text","text":"and an array using array literals:"}]},{"type":"codeListing","syntax":"swift","code":["let employeesSet: Set<String> = [\"Amir\", \"Jihye\", \"Dave\", \"Alessia\", \"Dave\"]","print(employeesSet)","// Prints \"[\"Amir\", \"Dave\", \"Jihye\", \"Alessia\"]\"","","let employeesArray: [String] = [\"Amir\", \"Jihye\", \"Dave\", \"Alessia\", \"Dave\"]","print(employeesArray)","// Prints \"[\"Amir\", \"Jihye\", \"Dave\", \"Alessia\", \"Dave\"]\""]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"Set","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Array","type":"codeVoice"},{"text":" types each handle array literals in their own way to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"create new instances. In this case, the newly created set drops the"},{"type":"text","text":" "},{"type":"text","text":"duplicate value (“Dave”) and doesn’t maintain the order of the array"},{"type":"text","text":" "},{"type":"text","text":"literal’s elements. The new array, on the other hand, matches the order"},{"text":" ","type":"text"},{"text":"and number of elements provided.","type":"text"}]},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"An array literal is not the same as an ","type":"text"},{"code":"Array","type":"codeVoice"},{"text":" instance. You can’t","type":"text"},{"text":" ","type":"text"},{"text":"initialize a type that conforms to ","type":"text"},{"type":"codeVoice","code":"ExpressibleByArrayLiteral"},{"text":" simply by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"assigning an existing array."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let anotherSet: Set = employeesArray","// error: cannot convert value of type '[String]' to specified type 'Set'"]}],"type":"aside"},{"anchor":"Type-Inference-of-Array-Literals","text":"Type Inference of Array Literals","type":"heading","level":1},{"type":"paragraph","inlineContent":[{"text":"Whenever possible, Swift’s compiler infers the full intended type of your","type":"text"},{"text":" ","type":"text"},{"text":"array literal. Because ","type":"text"},{"type":"codeVoice","code":"Array"},{"text":" is the default type for an array literal,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"without writing any other code, you can declare an array with a particular"},{"type":"text","text":" "},{"type":"text","text":"element type by providing one or more values."}]},{"type":"paragraph","inlineContent":[{"text":"In this example, the compiler infers the full type of each array literal.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let integers = [1, 2, 3]","// 'integers' has type '[Int]'","","let strings = [\"a\", \"b\", \"c\"]","// 'strings' has type '[String]'"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An empty array literal alone doesn’t provide enough information for the"},{"text":" ","type":"text"},{"type":"text","text":"compiler to infer the intended type of the "},{"code":"Array","type":"codeVoice"},{"type":"text","text":" instance. When using an"},{"text":" ","type":"text"},{"type":"text","text":"empty array literal, specify the type of the variable or constant."}]},{"type":"codeListing","syntax":"swift","code":["var emptyArray: [Bool] = []","// 'emptyArray' has type '[Bool]'"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because many functions and initializers fully specify the types of their"},{"text":" ","type":"text"},{"type":"text","text":"parameters, you can often use an array literal with or without elements as"},{"text":" ","type":"text"},{"type":"text","text":"a parameter. For example, the "},{"code":"sum(_:)","type":"codeVoice"},{"type":"text","text":" function shown here takes an "},{"code":"Int","type":"codeVoice"},{"text":" ","type":"text"},{"text":"array as a parameter:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func sum(values: [Int]) -> Int {","    return values.reduce(0, +)","}","","let sumOfFour = sum([5, 10, 15, 20])","// 'sumOfFour' == 50","","let sumOfNone = sum([])","// 'sumOfNone' == 0"]},{"inlineContent":[{"text":"When you call a function that does not fully specify its parameters’ types,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"use the type-cast operator ("},{"code":"as","type":"codeVoice"},{"type":"text","text":") to specify the type of an array literal."},{"text":" ","type":"text"},{"type":"text","text":"For example, the "},{"code":"log(name:value:)","type":"codeVoice"},{"type":"text","text":" function shown here has an"},{"text":" ","type":"text"},{"text":"unconstrained generic ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" parameter."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func log<T>(name name: String, value: T) {","    print(\"\\(name): \\(value)\")","}","","log(name: \"Four integers\", value: [5, 10, 15, 20])","// Prints \"Four integers: [5, 10, 15, 20]\"","","log(name: \"Zero integers\", value: [] as [Int])","// Prints \"Zero integers: []\""]},{"text":"Conforming to ExpressibleByArrayLiteral","level":1,"anchor":"Conforming-to-ExpressibleByArrayLiteral","type":"heading"},{"inlineContent":[{"type":"text","text":"Add the capability to be initialized with an array literal to your own"},{"text":" ","type":"text"},{"text":"custom types by declaring an ","type":"text"},{"code":"init(arrayLiteral:)","type":"codeVoice"},{"text":" initializer. The","type":"text"},{"text":" ","type":"text"},{"text":"following example shows the array literal initializer for a hypothetical","type":"text"},{"text":" ","type":"text"},{"code":"OrderedSet","type":"codeVoice"},{"text":" type, which has setlike semantics but maintains the order of","type":"text"},{"text":" ","type":"text"},{"text":"its elements.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct OrderedSet<Element: Hashable>: Collection, SetAlgebra {","    // implementation details","}","","extension OrderedSet: ExpressibleByArrayLiteral {","    init(arrayLiteral: Element...) {","        self.init()","        for element in arrayLiteral {","            self.append(element)","        }","    }","}"]}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/SIMDMask":{"navigatorTitle":[{"text":"SIMDMask","kind":"identifier"}],"abstract":[],"role":"symbol","url":"/documentation/swift/simdmask","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SIMDMask"}],"title":"SIMDMask","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/SIMDMask"},"doc://com.apple.Swift/documentation/Runtime/SectionCharacteristics":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Runtime/SectionCharacteristics","type":"topic","title":"SectionCharacteristics","kind":"symbol","url":"/documentation/runtime/sectioncharacteristics","navigatorTitle":[{"kind":"identifier","text":"SectionCharacteristics"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SectionCharacteristics"}],"abstract":[]},"doc://com.apple.Swift/documentation/Swift/SIMD2":{"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"SIMD2","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"A vector of two scalar values."}],"url":"/documentation/swift/simd2","identifier":"doc://com.apple.Swift/documentation/Swift/SIMD2","kind":"symbol","type":"topic","navigatorTitle":[{"text":"SIMD2","kind":"identifier"}],"title":"SIMD2"},"doc://com.apple.Swift/documentation/_RegexParser/CaptureList":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CaptureList","kind":"identifier"}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/_RegexParser/CaptureList","title":"CaptureList","abstract":[],"navigatorTitle":[{"text":"CaptureList","kind":"identifier"}],"type":"topic","role":"symbol","url":"/documentation/_regexparser/capturelist"},"doc://com.apple.Swift/documentation/Swift/SIMD64":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SIMD64"}],"title":"SIMD64","kind":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/SIMD64","url":"/documentation/swift/simd64","abstract":[{"type":"text","text":"A vector of 64 scalar values."}],"navigatorTitle":[{"kind":"identifier","text":"SIMD64"}]},"doc://com.apple.Swift/documentation/Swift/Array":{"identifier":"doc://com.apple.Swift/documentation/Swift/Array","kind":"symbol","role":"symbol","type":"topic","url":"/documentation/swift/array","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Array","kind":"identifier"}],"conformance":{"conformancePrefix":[{"text":"Conforms when","type":"text"}],"constraints":[{"type":"codeVoice","code":"Element"},{"text":" conforms to ","type":"text"},{"type":"codeVoice","code":"Copyable"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Escapable"},{"type":"text","text":"."}],"availabilityPrefix":[{"text":"Available when","type":"text"}]},"abstract":[{"text":"An ordered, random-access collection.","type":"text"}],"navigatorTitle":[{"text":"Array","kind"