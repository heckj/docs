{"sections":[],"topicSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral/Key","doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral/Value"],"anchor":"Associated-Types","generated":true,"title":"Associated Types"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral/init(dictionaryLiteral:)"],"anchor":"Initializers","generated":true,"title":"Initializers"}],"abstract":[{"text":"A type that can be initialized using a dictionary literal.","type":"text"}],"metadata":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ExpressibleByDictionaryLiteral","kind":"identifier"}],"role":"symbol","externalID":"s:s30ExpressibleByDictionaryLiteralP","symbolKind":"protocol","roleHeading":"Protocol","navigatorTitle":[{"text":"ExpressibleByDictionaryLiteral","kind":"identifier"}],"modules":[{"name":"Swift"}],"title":"ExpressibleByDictionaryLiteral"},"relationshipsSections":[{"identifiers":["doc://com.apple.Swift/documentation/Cxx/CxxDictionary"],"kind":"relationships","type":"inheritedBy","title":"Inherited By"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/Dictionary","doc://com.apple.Swift/documentation/Swift/KeyValuePairs"],"kind":"relationships","type":"conformingTypes","title":"Conforming Types"}],"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/ExpressibleByArrayLiteral"],"anchor":"Collection-Literals","generated":true,"title":"Collection Literals"}],"variants":[{"paths":["/documentation/swift/expressiblebydictionaryliteral"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ExpressibleByDictionaryLiteral"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A dictionary literal is a simple way of writing a list of key-value pairs."},{"type":"text","text":" "},{"type":"text","text":"You write each key-value pair with a colon ("},{"code":":","type":"codeVoice"},{"type":"text","text":") separating the key and"},{"type":"text","text":" "},{"type":"text","text":"the value. The dictionary literal is made up of one or more key-value"},{"type":"text","text":" "},{"type":"text","text":"pairs, separated by commas and surrounded with square brackets."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To declare a dictionary, assign a dictionary literal to a variable or"},{"type":"text","text":" "},{"type":"text","text":"constant:"}]},{"syntax":"swift","type":"codeListing","code":["let countryCodes = [\"BR\": \"Brazil\", \"GH\": \"Ghana\",","                    \"JP\": \"Japan\", \"US\": \"United States\"]","// 'countryCodes' has type '[String: String]'","","print(countryCodes[\"BR\"]!)","// Prints \"Brazil\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the context provides enough type information, you can use a special"},{"type":"text","text":" "},{"type":"text","text":"form of the dictionary literal, square brackets surrounding a single"},{"type":"text","text":" "},{"type":"text","text":"colon, to initialize an empty dictionary."}]},{"syntax":"swift","type":"codeListing","code":["var frequencies: [String: Int] = [:]","print(frequencies.count)","// Prints \"0\""]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"text","text":" "},{"type":"text","text":"A dictionary literal is "},{"type":"emphasis","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" the same as an instance of "},{"type":"codeVoice","code":"Dictionary"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You can’t initialize a type that conforms to "},{"type":"codeVoice","code":"ExpressibleByDictionaryLiteral"},{"type":"text","text":" "},{"type":"text","text":"simply by assigning an instance of "},{"type":"codeVoice","code":"Dictionary"},{"type":"text","text":", "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":", or similar."}]}],"style":"note","type":"aside"},{"text":"Conforming to the ExpressibleByDictionaryLiteral Protocol","level":1,"anchor":"Conforming-to-the-ExpressibleByDictionaryLiteral-Protocol","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To add the capability to be initialized with a dictionary literal to your"},{"type":"text","text":" "},{"type":"text","text":"own custom types, declare an "},{"code":"init(dictionaryLiteral:)","type":"codeVoice"},{"type":"text","text":" initializer. The"},{"type":"text","text":" "},{"type":"text","text":"following example shows the dictionary literal initializer for a"},{"type":"text","text":" "},{"type":"text","text":"hypothetical "},{"code":"CountedSet","type":"codeVoice"},{"type":"text","text":" type, which uses setlike semantics while keeping"},{"type":"text","text":" "},{"type":"text","text":"track of the count for duplicate elements:"}]},{"syntax":"swift","type":"codeListing","code":["struct CountedSet<Element: Hashable>: Collection, SetAlgebra {","    // implementation details","","    /// Updates the count stored in the set for the given element,","    /// adding the element if necessary.","    ///","    /// - Parameter n: The new count for `element`. `n` must be greater","    ///   than or equal to zero.","    /// - Parameter element: The element to set the new count on.","    mutating func updateCount(_ n: Int, for element: Element)","}","","extension CountedSet: ExpressibleByDictionaryLiteral {","    init(dictionaryLiteral elements: (Element, Int)...) {","        self.init()","        for (element, count) in elements {","            self.updateCount(count, for: element)","        }","    }","}"]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"references":{"doc://com.apple.Swift/documentation/Cxx/CxxDictionary":{"abstract":[{"type":"text","text":"A C++ type that represents a dictionary."}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"CxxDictionary"}],"role":"symbol","url":"/documentation/cxx/cxxdictionary","title":"CxxDictionary","type":"topic","navigatorTitle":[{"kind":"identifier","text":"CxxDictionary"}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Cxx/CxxDictionary"},"doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral/Value":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral/Value","type":"topic","title":"Value","kind":"symbol","url":"/documentation/swift/expressiblebydictionaryliteral/value","required":true,"fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Value"}],"abstract":[{"text":"The value type of a dictionary literal.","type":"text"}]},"doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral/Key":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral/Key","type":"topic","title":"Key","kind":"symbol","url":"/documentation/swift/expressiblebydictionaryliteral/key","required":true,"fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Key"}],"abstract":[{"text":"The key type of a dictionary literal.","type":"text"}]},"doc://com.apple.Swift/documentation/Swift/ExpressibleByDictionaryLiteral":{"navigatorTitle":[{"kind":"identifier","text":"ExpressibleByDictionaryLiteral"}],"url":"/documentation/swift/expressiblebydictionaryliteral","abstract":[{"text":"A 