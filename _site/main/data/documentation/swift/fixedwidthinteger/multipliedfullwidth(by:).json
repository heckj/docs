{"sections":[],"variants":[{"paths":["/documentation/swift/fixedwidthinteger/multipliedfullwidth(by:)"],"traits":[{"interfaceLanguage":"swift"}]}],"defaultImplementationsSections":[{"anchor":"FixedWidthInteger-Implementations","title":"FixedWidthInteger Implementations","identifiers":["doc://com.apple.Swift/documentation/Swift/FixedWidthInteger/multipliedFullWidth(by:)-3n598"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Returns a tuple containing the high and low parts of the result of"},{"type":"text","text":" "},{"type":"text","text":"multiplying this value by the given value."}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/FixedWidthInteger/multipliedFullWidth(by:)","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/FixedWidthInteger"]]},"metadata":{"required":true,"roleHeading":"Instance Method","role":"symbol","externalID":"s:s17FixedWidthIntegerP014multipliedFullB02byx4high_9MagnitudeQz3lowtx_tF","symbolKind":"method","title":"multipliedFullWidth(by:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"multipliedFullWidth"},{"kind":"text","text":"("},{"kind":"externalParam","text":"by"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":") -> (high"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", low"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:Sj9MagnitudeQa","text":"Magnitude"},{"kind":"text","text":")"}],"modules":[{"name":"Swift"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multipliedFullWidth","kind":"identifier"},{"text":"(","kind":"text"},{"text":"by","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"other","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":") -> (high","kind":"text"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", low","kind":"text"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Magnitude","identifier":"doc://com.apple.Swift/documentation/Swift/Numeric/Magnitude-swift.associatedtype","kind":"typeIdentifier","preciseIdentifier":"s:Sj9MagnitudeQa"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The value to multiply this value by."}]}],"name":"other"}]},{"content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"inlineContent":[{"type":"text","text":"A tuple containing the high and low parts of the result of"},{"type":"text","text":" "},{"type":"text","text":"multiplying this value and "},{"code":"other","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to calculate the full result of a product that would"},{"type":"text","text":" "},{"type":"text","text":"otherwise overflow. Unlike traditional truncating multiplication, the"},{"type":"text","text":" "},{"type":"codeVoice","code":"multipliedFullWidth(by:)"},{"type":"text","text":" method returns a tuple containing both the"},{"type":"text","text":" "},{"type":"codeVoice","code":"high"},{"type":"text","text":" and "},{"type":"codeVoice","code":"low"},{"type":"text","text":" parts of the product of this value and "},{"type":"codeVoice","code":"other"},{"type":"text","text":". The"},{"type":"text","text":" "},{"type":"text","text":"following example uses this method to multiply two "},{"type":"codeVoice","code":"Int8"},{"type":"text","text":" values that"},{"type":"text","text":" "},{"type":"text","text":"normally overflow when multiplied:"}]},{"code":["let x: Int8 = 48","let y: Int8 = -40","let result = x.multipliedFullWidth(by: y)","// result.high == -8","// result.low  == 128"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The product of ","type":"text"},{"type":"codeVoice","code":"x"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"y"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"-1920"},{"text":", which is too large to represent in","type":"text"},{"text":" ","type":"text"},{"text":"an ","type":"text"},{"type":"codeVoice","code":"Int8"},{"text":" instance. The ","type":"text"},{"type":"codeVoice","code":"high"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"low"},{"text":" components of the ","type":"text"},{"type":"codeVoice","code":"result"},{"text":" value","type":"text"},{"text":" ","type":"text"},{"text":"represent ","type":"text"},{"type":"codeVoice","code":"-1920"},{"type":"text","text":" when concatenated to form a double-width integer; that"},{"type":"text","text":" "},{"type":"text","text":"is, using "},{"type":"codeVoice","code":"result.high"},{"type":"text","text":" as the high byte and "},{"type":"codeVoice","code":"result.low"},{"type":"text","text":" as the low byte"},{"type":"text","text":" "},{"type":"text","text":"of an "},{"type":"codeVoice","code":"Int16"},{"type":"text","text":" instance."}],"type":"paragraph"},{"code":["let z = Int16(result.high) << 8 | Int16(result.low)","// z == -1920"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/FixedWidthInteger/multipliedFullWidth(by:)":{"defaultImplementations":1,"role":"symbol","url":"/documentation/swift/fixedwidthinteger/multipliedfullwidth(by:)","title":"multipliedFullWidth(by:)","identifier":"doc://com.apple.Swift/documentation/Swift/FixedWidthInt