 ","type":"text"},{"text":"space character (” “). The first use of ","type":"text"},{"code":"split","type":"codeVoice"},{"text":" returns each word that","type":"text"},{"text":" ","type":"text"},{"text":"was originally separated by one or more spaces.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let line = \"BLANCHE:   I don't want realism. I want magic!\"","print(line.split(separator: \" \"))","// Prints \"[\"BLANCHE:\", \"I\", \"don\\'t\", \"want\", \"realism.\", \"I\", \"want\", \"magic!\"]\""]},{"type":"paragraph","inlineContent":[{"text":"The second example passes ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" for the ","type":"text"},{"code":"maxSplits","type":"codeVoice"},{"text":" parameter, so the","type":"text"},{"text":" ","type":"text"},{"text":"original string is split just once, into two new strings.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["print(line.split(separator: \" \", maxSplits: 1))","// Prints \"[\"BLANCHE:\", \"  I don\\'t want realism. I want magic!\"]\""]},{"type":"paragraph","inlineContent":[{"text":"The final example passes ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" for the ","type":"text"},{"code":"omittingEmptySubsequences","type":"codeVoice"},{"text":" ","type":"text"},{"text":"parameter, so the returned array contains empty strings where spaces","type":"text"},{"text":" ","type":"text"},{"text":"were repeated.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["print(line.split(separator: \" \", omittingEmptySubsequences: false))","// Prints \"[\"BLANCHE:\", \"\", \"\", \"I\", \"don\\'t\", \"want\", \"realism.\", \"I\", \"want\", \"magic!\"]\""]},{"type":"aside","style":"note","name":"Complexity","content":[{"inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the length of the collection."}],"type":"paragraph"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/flattensequence/split(separator:maxsplits:omittingemptysubsequences:)-9yjf5"]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/FlattenSequence"]]},"references":{"doc://com.apple.Swift/documentation/Swift/FlattenSequence":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FlattenSequence","kind":"identifier"}],"title":"FlattenSequence","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/FlattenSequence","kind":"symbol","url":"/documentation/swift/flattensequence","abstract":[{"text":"A sequence consisting of all the elements contained in each segment","type":"text"},{"text":" ","type":"text"},{"text":"contained in some ","type":"text"},{"code":"Base","type":"codeVoice"},{"text":" sequence.","type":"text"}],"navigatorTitle":[{"text":"FlattenSequence","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/Collection/Element":{"url":"/documentation/swift/collection/element","required":true,"fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Element"}],"title":"Element","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Element","abstract":[],"role":"symbol","type":"topic"},"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence":{"url":"/documentation/swift/collection/subsequence","kind":"symbol","type":"topic","title":"SubSequence","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Sub