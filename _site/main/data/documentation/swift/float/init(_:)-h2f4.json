/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/Float/init(_:)-h2f4":{"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"?<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:SfySfSgxcSyRzlufc1SL_xmfp","text":"S"},{"kind":"text","text":")"}],"title":"init(_:)","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Float/init(_:)-h2f4","type":"topic","url":"/documentation/swift/float/init(_:)-h2f4","abstract":[{"type":"text","text":"Creates a new instance from the given string."}]},"doc://com.apple.Swift/documentation/Swift/Float":{"navigatorTitle":[{"text":"Float","kind":"identifier"}],"abstract":[{"text":"A single-precision (32-bit), floating-point value type.","type":"text"}],"role":"symbol","url":"/documentation/swift/float","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Float","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Float","type":"topic","title":"Float"}}}