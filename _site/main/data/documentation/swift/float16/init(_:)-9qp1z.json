{"abstract":[{"text":"Creates a new instance from the given string.","type":"text"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Float16"]]},"metadata":{"externalID":"s:s7Float16VyABSgxcSyRzlufc","symbolKind":"init","title":"init(_:)","fragments":[{"text":"init","kind":"identifier"},{"text":"?<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"S","kind":"typeIdentifier","preciseIdentifier":"s:s7Float16VyABSgxcSyRzlufc1SL_xmfp"},{"text":")","kind":"text"}],"modules":[{"name":"Swift"}],"role":"symbol","extendedModule":"Swift","roleHeading":"Initializer"},"variants":[{"paths":["/documentation/swift/float16/init(_:)-9qp1z"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Float16/init(_:)-9qp1z","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"text":"?<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"text","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"S","preciseIdentifier":"s:s7Float16VyABSgxcSyRzlufc1SL_xmfp","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"StringProtocol","preciseIdentifier":"s:Sy","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/StringProtocol"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"An input string to convert to a ","type":"text"},{"code":"Float16?","type":"codeVoice"},{"type":"text","text":" instance."}]}],"name":"text"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"The string passed as ","type":"text"},{"code":"text","type":"codeVoice"},{"text":" can represent a real number in decimal or","type":"text"},{"text":" ","type":"text"},{"text":"hexadecimal format or can be in a special format representing infinity","type":"text"},{"text":" ","type":"text"},{"text":"or NaN (“not a number”). If ","type":"text"},{"code":"text","type":"codeVoice"},{"text":" is not in a recognized format,","type":"text"},{"text":" ","type":"text"},{"text":"the optional initializer will fail and return ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"text"},{"type":"text","text":" string consists of an optional"},{"type":"text","text":" "},{"type":"text","text":"plus or minus sign character ("},{"type":"codeVoice","code":"+"},{"type":"text","text":" or "},{"type":"codeVoice","code":"-"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"followed by one of the following:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"decimal string"}]},{"type":"text","text":" contains a significand consisting of one"},{"type":"text","text":" "},{"type":"text","text":"or more decimal digits that may include a decimal point:"}]},{"code":["let c = Float16(\"-1.0\")","// c == -1.0","","let d = Float16(\"28.375\")","// d == 28.375"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"A decimal string may also include an exponent following the","type":"text"},{"text":" ","type":"text"},{"text":"significand, indicating the power of 10 by which the significand should","type":"text"},{"text":" ","type":"text"},{"text":"be multiplied. If included, the exponent is separated by a single","type":"text"},{"text":" ","type":"text"},{"text":"character, ","type":"text"},{"type":"codeVoice","code":"e"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"E"},{"text":", and consists of an optional plus or minus sign","type":"text"},{"text":" ","type":"text"},{"text":"character and a sequence of decimal digits.","type":"text"}],"type":"paragraph"},{"code":["let e = Float16(\"2837.5e-2\")","// e == 28.375"],"syntax":"swift","type":"codeListing"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"inlineContent":[{"type":"text","text":"hexadecimal string"}],"type":"emphasis"},{"text":" contains a significand consisting of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"0X"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"0x"},{"text":" followed by one or more hexadecimal digits that may","type":"text"},{"text":" ","type":"text"},{"text":"include a decimal point.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let f = Float16(\"0x1c.6\")","// f == 28.375"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A hexadecimal string may also include an exponent"},{"type":"text","text":" "},{"type":"text","text":"indicating the power of 2 by which the significand should"},{"text":" ","type":"text"},{"text":"be multiplied. If included, the exponent is separated by a single","type":"text"},{"text":" ","type":"text"},{"text":"character, ","type":"text"},{"type":"codeVoice","code":"p"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"P"},{"text":", and consists of an optional plus or minus sign","type":"text"},{"text":" ","type":"text"},{"text":"character and a sequence of decimal digits.","type":"text"}]},{"syntax":"swift","code":["let g = Float16(\"0x1.c6p4\")","// g == 28.375"],"type":"codeListing"}]},{"content":[{"inlineContent":[{"text":"The input strings ","type":"text"},{"type":"codeVoice","code":"\"inf\""},{"text":" or ","type":"text"},{"type":"codeVoice","code":"\"infinity\""},{"text":" (case insensitive)","type":"text"},{"text":" ","type":"text"},{"text":"are converted to an infinite result:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let i = Float16(\"inf\")","// i == Float16.infinity","","let j = Float16(\"-Infinity\")","// j == -Float16.infinity"],"type":"codeListing"}]},{"content":[{"inlineContent":[{"type":"text","text":"An input string of "},{"code":"\"nan\"","type":"codeVoice"},{"type":"text","text":" (case insensitive) is converted"},{"type":"text","text":" "},{"type":"text","text":"into a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"NaN"}]},{"type":"text","text":" value:"}],"type":"paragraph"},{"syntax":"swift","code":["let n = Float16(\"-nan\")","// n?.isNaN == true","// n?.sign == .minus"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"A NaN string may also include a payload in parentheses following the"},{"type":"text","text":" "},{"code":"\"nan\"","type":"codeVoice"},{"type":"text","text":" keyword. The payload consists of a sequence of decimal digits,"},{"type":"text","text":" "},{"text":"or the characters ","type":"text"},{"code":"0X","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"0x"},{"type":"text","text":" followed by a sequence of hexadecimal"},{"type":"text","text":" "},{"type":"text","text":"digits. If the payload contains any other characters, it is ignored."},{"type":"text","text":" "},{"type":"text","text":"If the value of the payload is larger than can be stored as the"},{"type":"text","text":" "},{"type":"text","text":"payload of a "},{"code":"Float16.nan","type":"codeVoice"},{"type":"text","text":", the least significant bits are used."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let p = Float16(\"nan(0x10)\")","// p?.isNaN == true","// String(p!) == \"nan(0x10)\""]}]}]},{"inlineContent":[{"type":"text","text":"A string in any other format than those described above"},{"type":"text","text":" "},{"type":"text","text":"or containing additional characters"},{"type":"text","text":" "},{"type":"text","text":"results in a "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" value. For example, the following conversions"},{"text":" ","type":"text"},{"text":"result in ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["  Float16(\" 5.0\")      // Includes whitespace","  Float16(\"±2.0\")      // Invalid character","  Float16(\"0x1.25e4\")  // Incorrect exponent format"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"A decimal or hexadecimal string is converted to a ","type":"text"},{"type":"codeVoice","code":"Float16"},{"text":" ","type":"text"},{"text":"instance using the IEEE 754 roundTiesToEven (default) rounding","type":"text"},{"text":" ","type":"text"},{"text":"attribute.","type":"text"},{"text":" ","type":"text"},{"text":"Values with absolute value smaller than ","type":"text"},{"type":"codeVoice","code":"Float16.leastNonzeroMagnitude"},{"type":"text","text":" "},{"type":"text","text":"are rounded to plus or minus zero."},{"type":"text","text":" "},{"type":"text","text":"Values with absolute value larger than "},{"type":"codeVoice","code":"Float16.greatestFiniteMagnitude"},{"type":"text","text":" "},{"type":"text","text":"are rounded to plus or minus infinity."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["  let y = Float16(\"1.23e-9999\")","  // y == 0.0","  // y?.sign == .plus","","  let z = Float16(\"-7.89e-7206\")","  // z == -0.0","  // z?.sign == .minus","","  let r = Float16(\"1.23e17802\")","  // r == Float16.infinity","","  let s = Float16(\"-7.89e7206\")","  // s == Float16.-infinity"]},{"content":[{"inlineContent":[{"text":"Prior to Swift 5.4, a decimal or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"hexadecimal input string whose value was too large to represent"},{"type":"text","text":" "},{"type":"text","text":"as a finite "},{"type":"codeVoice","code":"Float16"},{"type":"text","text":" instance returned "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" instead of"},{"type":"text","text":" "},{"type":"codeVoice","code":"Float16.infinity"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/StringProtocol":{"title":"StringProtocol","navigatorTitle":[{"kind":"identifier","text":"StringProtocol"}],"role":"symbol","kind":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/StringProtocol","abstract":[{"type":"text","text":"A type that can represent a string as a collection of characters."}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"StringProtocol"}],"url":"/documentation/swift/stringprotocol"},"doc://com.apple.Swift/documentation/Swift/Float16/init(_:)-9qp1z":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Creates a new instance from the given string."}],"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Float16/init(_:)-9qp1z","fragments":[{"text":"init","kind":"identifier"},{"text":"?<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:s7Float16VyABSgxcSyRzlufc1SL_xmfp","text":"S","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"/documentation/swift/float16/init(_:)-9qp1z","title":"init(_:)"},"doc://com.apple.Swift/documentation/Swift/Float16":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Float16"}],"abstract":[{"type":"text","text":"A half-precision (16-bit), floating-point value type."}],"identifier":"doc://com.apple.Swift/documentation/Swift/Float16","title":"Float16","type":"topic","kind":"symbol","url":"/documentation/swift/float16","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Floa