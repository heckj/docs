{"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Float16/init(_:)-9qp1z"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"type":"text","text":"Creates a new instance from the given string."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"?<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"text"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s7Float16VyABSgxcSyRzlufc1SL_xmfp","text":"S"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/StringProtocol","preciseIdentifier":"s:Sy","text":"StringProtocol"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"An input string to convert to a ","type":"text"},{"code":"Float16?","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"name":"text"}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The string passed as "},{"type":"codeVoice","code":"text"},{"type":"text","text":" can represent a real number in decimal or"},{"type":"text","text":" "},{"type":"text","text":"hexadecimal format or can be in a special format representing infinity"},{"type":"text","text":" "},{"type":"text","text":"or NaN (“not a number”). If "},{"type":"codeVoice","code":"text"},{"type":"text","text":" is not in a recognized format,"},{"type":"text","text":" "},{"type":"text","text":"the optional initializer will fail and return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"text"},{"type":"text","text":" string consists of an optional"},{"type":"text","text":" "},{"type":"text","text":"plus or minus sign character ("},{"type":"codeVoice","code":"+"},{"type":"text","text":" or "},{"type":"codeVoice","code":"-"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"followed by one of the following:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"decimal string"}]},{"type":"text","text":" contains a significand consisting of one"},{"type":"text","text":" "},{"type":"text","text":"or more decimal digits that may include a decimal point:"}]},{"type":"codeListing","code":["let c = Float16(\"-1.0\")","// c == -1.0","","let d = Float16(\"28.375\")","// d == 28.375"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A decimal string may also include an exponent following the"},{"type":"text","text":" "},{"type":"text","text":"significand, indicating the power of 10 by which the significand should"},{"type":"text","text":" "},{"type":"text","text":"be multiplied. If included, the exponent is separated by a single"},{"type":"text","text":" "},{"type":"text","text":"character, "},{"type":"codeVoice","code":"e"},{"type":"text","text":" or "},{"type":"codeVoice","code":"E"},{"type":"text","text":", and consists of an optional plus or minus sign"},{"type":"text","text":" "},{"type":"text","text":"character and a sequence of decimal digits."}]},{"type":"codeListing","code":["let e = Float16(\"2837.5e-2\")","// e == 28.375"],"syntax":"swift"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"hexadecimal string"}]},{"type":"text","text":" contains a significand consisting of"},{"type":"text","text":" "},{"type":"codeVoice","code":"0X"},{"type":"text","text":" or "},{"type":"codeVoice","code":"0x"},{"type":"text","text":" followed by one or more hexadecimal digits that may"},{"type":"text","text":" "},{"type":"text","text":"include a decimal point."}]},{"type":"codeListing","code":["let f = Float16(\"0x1c.6\")","// f == 28.375"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A hexadecimal string may also include an exponent"},{"type":"text","text":" "},{"type":"text","text":"indicating the power of 2 by which the significand should"},{"type":"text","text":" "},{"type":"text","text":"be multiplied. If included, the exponent is separated by a single"},{"type":"text","text":" "},{"type":"text","text":"character, "},{"type":"codeVoice","code":"p"},{"type":"text","text":" or "},{"type":"codeVoice","code":"P"},{"type":"text","text":", and consists of an optional plus or minus sign"},{"type":"text","text":" "},{"type":"text","text":"character and a sequence of decimal digits."}]},{"type":"codeListing","code":["let g = Float16(\"0x1.c6p4\")","// g == 28.375"],"syntax":"swift"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The input strings "},{"type":"codeVoice","code":"\"inf\""},{"type":"text","text":" or "},{"type":"codeVoice","code":"\"infinity\""},{"type":"text","text":" (case insensitive)"},{"type":"text","text":" "},{"type":"text","text":"are converted to an infinite result:"}]},{"type":"codeListing","code":["let i = Float16(\"inf\")","// i == Float16.infinity","","let j = Float16(\"-Infinity\")","// j == -Float16.infinity"],"syntax":"swift"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An input string of "},{"type":"codeVoice","code":"\"nan\""},{"type":"text","text":" (case insensitive) is converted"},{"type":"text","text":" "},{"type":"text","text":"into a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"NaN"}]},{"type":"text","text":" value:"}]},{"type":"codeListing","code":["let n = Float16(\"-nan\")","// n?.isNaN == true","// n?.sign == .minus"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A NaN string may also include a payload in parentheses following the"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"nan\""},{"type":"text","text":" keyword. The payload consists of a sequence of decimal digits,"},{"type":"text","text":" "},{"type":"text","text":"or the characters "},{"type":"codeVoice","code":"0X"},{"type":"text","text":" or "},{"type":"codeVoice","code":"0x"},{"type":"text","text":" followed by a sequence of hexadecimal"},{"type":"text","text":" "},{"type":"text","text":"digits. If the payload contains any other characters, it is ignored."},{"type":"text","text":" "},{"type":"text","text":"If the value of the payload is larger than can be stored as the"},{"type":"text","text":" "},{"type":"text","text":"payload of a "},{"type":"codeVoice","code":"Float16.nan"},{"type":"text","text":", the least significant bits are used."}]},{"type":"codeListing","code":["let p = Float16(\"nan(0x10)\")","// p?.isNaN == true","// String(p!) == \"nan(0x10)\""],"syntax":"swift"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An input string of "},{"type":"codeVoice","code":"\"snan\""},{"type":"text","text":" (case insensitive) is converted"},{"type":"text","text":" "},{"type":"text","text":"into a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"signaling NaN"}]},{"type":"text","text":" value.  This form permits an optional"},{"type":"text","text":" "},{"type":"text","text":"payload in the same format as for a non-signaling NaN."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A string in any other format than those described above"},{"type":"text","text":" "},{"type":"text","text":"or containing additional characters"},{"type":"text","text":" "},{"type":"text","text":"results in a "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" value. For example, the following conversions"},{"type":"text","text":" "},{"type":"text","text":"result in "},{"type":"codeVoice","code":"nil"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["  Float16(\" 5.0\")      // Includes whitespace","  Float16(\"±2.0\")      // Invalid character","  Float16(\"0x1.25e4\")  // Incorrect exponent format"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A decimal or hexadecimal string is converted to a "},{"type":"codeVoice","code":"Float16"},{"type":"text","text":" "},{"type":"text","text":"instance using the IEEE 754 roundTiesToEven (default) rounding"},{"type":"text","text":" "},{"type":"text","text":"attribute."},{"type":"text","text":" "},{"type":"text","text":"Values with absolute value smaller than one-half of "},{"type":"codeVoice","code":"Float16.leastNonzeroMagnitude"},{"type":"text","text":" "},{"type":"text","text":"are rounded to plus or minus zero."},{"type":"text","text":" "},{"type":"text","text":"Values with absolute value larger than "},{"type":"codeVoice","code":"Float16.greatestFiniteMagnitude"},{"type":"text","text":" "},{"type":"text","text":"are rounded to plus or minus infinity."}]},{"syntax":"swift","type":"codeListing","code":["  let y = Float16(\"1.23e-9999\")","  // y == 0.0","  // y?.sign == .plus","","  let z = Float16(\"-7.89e-7206\")","  // z == -0.0","  // z?.sign == .minus","","  let r = Float16(\"1.23e17802\")","  // r == Float16.infinity","","  let s = Float16(\"-7.89e7206\")","  // s == Float16.-infinity"]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"Prior to Swift 5.4, a decimal or"},{"type":"text","text":" "},{"type":"text","text":"hexadecimal input string whose value was too large to represent"},{"type":"text","text":" "},{"type":"text","text":"as a finite "},{"type":"codeVoice","code":"Float16"},{"type":"text","text":" instance returned "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" instead of"},{"type":"text","text":" "},{"type":"codeVoice","code":"Float16.infinity"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"Note","type":"aside"}]}],"variants":[{"paths":["/documentation/swift/float16/init(_:)-9qp1z"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"init(_:)","modules":[{"name":"Swift"}],"extendedModule":"Swift","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"?<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"S","preciseIdentifier":"s:s7Float16VyABSgxcSyRzlufc1SL_xmfp"},{"kind":"text","text":")"}],"roleHeading":"Initializer","symbolKind":"init","externalID":"s:s7Float16VyABSgxcSyRzlufc"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Float16"]]},"references":{"doc://com.apple.Swift/documentation/Swift/Float16/init(_:)-9qp1z":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"?<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:s7Float16VyABSgxcSyRzlufc1SL_xmfp","text":"S"},{"kind":"text","text":")"}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Float16/init(_:)-9qp1z","title":"init(_:)","abstract":[{"type":"text","text":"Creates a new instance from the given string."}],"type":"topic","role":"symbol","url":"/documentation/swift/float16/init(_:)-9qp1z"},"doc://com.apple.Swift/documentation/Swift/StringProtocol":{"url":"/documentation/swift/stringprotocol","type":"topic","kind":"symbol","title":"StringProtocol","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/StringProtocol","abstract":[{"text":"A type that can represent a string as a collection of characters.","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StringProtocol","kind":"identifier"}],"navigatorTitle":[{"text":"St