{"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"exponent","kind":"identifier"},{"text":": ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/FloatingPoint/Exponent-swift.associatedtype","text":"Exponent","kind":"typeIdentifier","preciseIdentifier":"s:SF8ExponentQa"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"exponent"}]},{"type":"text","text":" of a floating-point value is the integer part of the"},{"type":"text","text":" "},{"type":"text","text":"logarithm of the value’s magnitude. For a value "},{"type":"codeVoice","code":"x"},{"type":"text","text":" of a floating-point"},{"type":"text","text":" "},{"type":"text","text":"type "},{"type":"codeVoice","code":"F"},{"type":"text","text":", the magnitude can be calculated as the following, where "},{"type":"codeVoice","code":"**"},{"type":"text","text":" "},{"type":"text","text":"is exponentiation:"}],"type":"paragraph"},{"code":["x.significand * (F.radix ** x.exponent)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"In the next example, "},{"type":"codeVoice","code":"y"},{"type":"text","text":" has a value of "},{"type":"codeVoice","code":"21.5"},{"type":"text","text":", which is encoded as"},{"type":"text","text":" "},{"type":"codeVoice","code":"1.34375 * 2 ** 4"},{"type":"text","text":". The significand of "},{"type":"codeVoice","code":"y"},{"type":"text","text":" is therefore 1.34375."}],"type":"paragraph"},{"code":["let y: Double = 21.5","// y.significand == 1.34375","// y.exponent == 4","// Double.radix == 2"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"exponent"},{"type":"text","text":" property has the following edge cases:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"x","type":"codeVoice"},{"type":"text","text":" is zero, then "},{"code":"x.exponent","type":"codeVoice"},{"type":"text","text":" is "},{"code":"Int.min","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"x","type":"codeVoice"},{"type":"text","text":" is +/-infinity or NaN, then "},{"code":"x.exponent","type":"codeVoice"},{"type":"text","text":" is "},{"code":"Int.max","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"This property implements the "},{"type":"codeVoice","code":"logB"},{"type":"text","text":" operation defined by the "},{"type":"reference","identifier":"http://ieeexplore.ieee.org/servlet/opac?punumber=4610933","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]}],"sections":[],"variants":[{"paths":["/documentation/swift/floatingpoint/exponent-swift.property"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"The exponent of the floating-point value."}],"metadata":{"roleHeading":"Instance Property","title":"exponent","modules":[{"name":"Swift"}],"externalID":"s:SF8exponent8ExponentQzvp","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"exponent"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Exponent","preciseIdentifier":"s:SF8ExponentQa"}],"required":true,"role":"symbol","symbolKind":"property"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/FloatingPoint"]]},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/FloatingPoint/exponent-swift.property","interfaceLanguage":"swift"},