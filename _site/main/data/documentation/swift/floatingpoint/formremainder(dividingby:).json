{"metadata":{"externalID":"s:SF13formRemainder10dividingByyx_tF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"formRemainder","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"dividingBy"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":")"}],"roleHeading":"Instance Method","symbolKind":"method","role":"symbol","required":true,"modules":[{"name":"Swift"}],"title":"formRemainder(dividingBy:)"},"abstract":[{"type":"text","text":"Replaces this value with the remainder of itself divided by the given"},{"type":"text","text":" "},{"type":"text","text":"value."}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/FloatingPoint/formRemainder(dividingBy:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"mutating"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"formRemainder","kind":"identifier"},{"text":"(","kind":"text"},{"text":"dividingBy","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"other"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"other","content":[{"inlineContent":[{"type":"text","text":"The value to use when dividing this value."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"For two finite values ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"y","type":"codeVoice"},{"text":", the remainder ","type":"text"},{"code":"r","type":"codeVoice"},{"text":" of dividing ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" by","type":"text"},{"text":" ","type":"text"},{"code":"y","type":"codeVoice"},{"text":" satisfies ","type":"text"},{"code":"x == y * q + r","type":"codeVoice"},{"text":", where ","type":"text"},{"code":"q","type":"codeVoice"},{"text":" is the integer nearest to","type":"text"},{"text":" ","type":"text"},{"code":"x / y","type":"codeVoice"},{"text":". If ","type":"text"},{"code":"x / y","type":"codeVoice"},{"text":" is exactly halfway between two integers, ","type":"text"},{"code":"q","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"chosen to be even. Note that ","type":"text"},{"code":"q","type":"codeVoice"},{"text":" is ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"text":" ","type":"text"},{"code":"x / y","type":"codeVoice"},{"text":" computed in","type":"text"},{"text":" ","type":"text"},{"text":"floating-point arithmetic, and that ","type":"text"},{"code":"q","type":"codeVoice"},{"text":" may not be representable in any","type":"text"},{"text":" ","type":"text"},{"text":"available integer type.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following example calculates the remainder of dividing 8.625 by 0.75:","type":"text"}],"type":"paragraph"},{"code":["var x = 8.625","print(x / 0.75)","// Prints \"11.5\"","","let q = (x / 0.75).rounded(.toNearestOrEven)","// q == 12.0","x.formRemainder(dividingBy: 0.75)","// x == -0.375","","let x1 = 0.75 * q + x","// x1 == 8.625"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"If this value and ","type":"text"},{"code":"other","type":"codeVoice"},{"text":" are finite numbers, the remainder is in the","type":"text"},{"text":" ","type":"text"},{"text":"closed range ","type":"text"},{"code":"-abs(other / 2)...abs(other / 2)","type":"codeVoice"},{"text":". The","type":"text"},{"text":" ","type":"text"},{"code":"formRemainder(dividingBy:)","type":"codeVoice"},{"text":" method is always exact.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/f