d":"parameters"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Performing truncating division with floating-point values results in a"},{"type":"text","text":" "},{"type":"text","text":"truncated integer quotient and a remainder. For values "},{"type":"codeVoice","code":"x"},{"type":"text","text":" and "},{"type":"codeVoice","code":"y"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"their truncated integer quotient "},{"type":"codeVoice","code":"q"},{"type":"text","text":", the remainder "},{"type":"codeVoice","code":"r"},{"type":"text","text":" satisfies"},{"type":"text","text":" "},{"type":"codeVoice","code":"x == y * q + r"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example calculates the truncating remainder of dividing"},{"type":"text","text":" "},{"type":"text","text":"8.625 by 0.75:"}],"type":"paragraph"},{"code":["var x = 8.625","print(x / 0.75)","// Prints \"11.5\"","","let q = (x / 0.75).rounded(.towardZero)","// q == 11.0","x.formTruncatingRemainder(dividingBy: 0.75)","// x == 0.375","","let x1 = 0.75 * q + x","// x1 == 8.625"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If this value and "},{"type":"codeVoice","code":"other"},{"type":"text","text":" are both finite numbers, the truncating"},{"type":"text","text":" "},{"type":"text","text":"remainder has the same sign as this value and is strictly smaller in"},{"type":"text","text":" "},{"type":"text","text":"magnitude than "},{"type":"codeVoice","code":"other"},{"type":"text","text":". The "},{"type":"codeVoice","code":"formTruncatingRemainder(dividingBy:)"},{"type":"text","text":" "},{"type":"text","text":"method is always exact."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/FloatingPoint"]]},"