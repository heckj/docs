{"metadata":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"GlobalActor"}],"externalID":"s:12_Concurrency11GlobalActorP","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"GlobalActor"}],"symbolKind":"protocol","modules":[{"name":"Swift","relatedModules":[]}],"roleHeading":"Protocol","title":"GlobalActor"},"abstract":[{"type":"text","text":"A type that represents a globally-unique actor that can be used to isolate"},{"type":"text","text":" "},{"type":"text","text":"various declarations anywhere in the program."}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/GlobalActor","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"GlobalActor"}],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A type that conforms to the "},{"type":"codeVoice","code":"GlobalActor"},{"type":"text","text":" protocol and is marked with"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"@globalActor","type":"codeVoice"},{"type":"text","text":" attribute can be used as a custom attribute. Such types"},{"type":"text","text":" "},{"type":"text","text":"are called global actor types, and can be applied to any declaration to"},{"type":"text","text":" "},{"type":"text","text":"specify that such types are isolated to that global actor type. When using"},{"type":"text","text":" "},{"type":"text","text":"such a declaration from another actor (or from nonisolated code),"},{"type":"text","text":" "},{"type":"text","text":"synchronization is performed through the shared actor instance to ensure"},{"type":"text","text":" "},{"type":"text","text":"mutually-exclusive access to the declaration."}]},{"anchor":"Custom-Actor-Executors","level":2,"type":"heading","text":"Custom Actor Executors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A global actor uses a custom executor if it needs to customize its execution"},{"type":"text","text":" "},{"type":"text","text":"semantics, for example, by making sure all of its invocations are run on a"},{"type":"text","text":" "},{"type":"text","text":"specific thread or dispatch queue."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is done the same way as with normal non-global actors, by declaring a"},{"type":"text","text":" "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Actor/unownedExecutor","isActive":true,"type":"reference"},{"type":"text","text":" nonisolated property in the "},{"identifier":"doc://com.apple.Swift/documentation/Swift/GlobalActor/ActorType","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"underlying this global actor."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is "},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"type":"text","text":" necessary to override the "},{"identifier":"doc://com.apple.Swift/documentation/Swift/GlobalActor/sharedUnownedExecutor","isActive":true,"type":"reference"},{"type":"text","text":" static"},{"type":"text","text":" "},{"type":"text","text":"property of the global actor, as its default implementation already"},{"type":"text","text":" "},{"type":"text","text":"delegates to the "},{"type":"codeVoice","code":"shared.unownedExecutor"},{"type":"text","text":", which is the most reasonable"},{"type":"text","text":" "},{"type":"text","text":"and correct implementation of this protocol requirement."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can find out more about custom executors, by referring to the"},{"type":"text","text":" "},{"identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor","isActive":true,"type":"reference"},{"type":"text","text":" protocol’s documentation."}]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor"}],"type":"paragraph"}],"name":"See Also","type":"aside"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/globalactor"]}],"relationshipsSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/MainActor"],"kind":"relationships","title":"Conforming Types","type":"conformingTypes"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","seeAlsoSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/Actor","doc://com.apple.Swift/documentation/Swift/AnyActor","doc://com.apple.Swift/documentation/Swift/MainActor","doc://com.apple.Swift/documentation/Swift/SendableMetatype","doc://com.apple.Swift/documentation/Swift/ConcurrentValue","doc://com.apple.Swift/documentation/Swift/UnsafeSendable","doc://com.apple.Swift/documentation/Swift/UnsafeConcurrentValue","doc://com.apple.Swift/documentation/Swift/isolation()","doc://com.apple.Swift/documentation/Swift/extractIsolation(_:)"],"anchor":"Actors","title":"Actors"}],"topicSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/GlobalActor/ActorType"],"anchor":"Associated-Types","title":"Associated Types","generated":true},{"identifiers":["doc://com.apple.Swift/documentation/Swift/GlobalActor/shared","doc://com.apple.Swift/documentation/Swift/GlobalActor/sharedUnownedExecutor"],"anchor":"Type-Properties","title":"Type Properties","generated":true},{"identifiers":["doc://com.apple.Swift/documentation/Swift/GlobalActor/assertIsolated(_:file:line:)","doc://com.apple.Swift/documentation/Swift/GlobalActor/preconditionIsolated(_:file:line:)"],"title":"Type Methods","generated":true,"anchor":"Type-Methods"}],"sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documenta