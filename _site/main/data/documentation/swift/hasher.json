{"abstract":[{"type":"text","text":"The universal hash function used by "},{"type":"codeVoice","code":"Set"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Dictionary"},{"type":"text","text":"."}],"topicSections":[{"title":"Creating a Hasher","anchor":"Creating-a-Hasher","identifiers":["doc://com.apple.Swift/documentation/Swift/Hasher/init()"]},{"identifiers":["doc://com.apple.Swift/documentation/Swift/Hasher/combine(_:)","doc://com.apple.Swift/documentation/Swift/Hasher/combine(bytes:)"],"anchor":"Adding-Values","title":"Adding Values"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/Hasher/finalize()"],"anchor":"Finalizing-a-Hasher","title":"Finalizing a Hasher"}],"seeAlsoSections":[{"generated":true,"title":"Sets and Dictionaries","anchor":"Sets-and-Dictionaries","identifiers":["doc://com.apple.Swift/documentation/Swift/Hashable"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Hasher"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Hasher"},{"type":"text","text":" can be used to map an arbitrary sequence of bytes to an integer"},{"type":"text","text":" "},{"type":"text","text":"hash value. You can feed data to the hasher using a series of calls to"},{"type":"text","text":" "},{"type":"text","text":"mutating "},{"type":"codeVoice","code":"combine"},{"type":"text","text":" methods. When you’ve finished feeding the hasher, the"},{"type":"text","text":" "},{"text":"hash value can be retrieved by calling ","type":"text"},{"type":"codeVoice","code":"finalize()"},{"type":"text","text":":"}]},{"syntax":"swift","code":["var hasher = Hasher()","hasher.combine(23)","hasher.combine(\"Hello\")","let hashValue = hasher.finalize()"],"