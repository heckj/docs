{"kind":"symbol","metadata":{"role":"symbol","externalID":"s:s11InlineArrayV","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"InlineArray"}],"roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"InlineArray"}],"modules":[{"name":"Swift"}],"title":"InlineArray"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InlineArray","kind":"identifier"},{"text":"<let ","kind":"text"},{"text":"count","kind":"genericParameter"},{"text":" : ","kind":"text"},{"text":"Int","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"Element","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"typeIdentifier"},{"text":" : ~Copyable","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"code":"InlineArray","type":"codeVoice"},{"type":"text","text":" is a specialized container that doesn’t use a separate"},{"type":"text","text":" "},{"type":"text","text":"memory allocation just to store its elements. When a value is copied, all of"},{"type":"text","text":" "},{"type":"text","text":"its elements are copied eagerly, like those of a tuple. Use an "},{"code":"InlineArray","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"when you have a fixed number of elements and need to avoid a separate heap"},{"type":"text","text":" "},{"type":"text","text":"allocation."}]},{"level":2,"anchor":"Initializing-a-Value","type":"heading","text":"Initializing a Value"},{"type":"paragraph","inlineContent":[{"text":"When initializing a new ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" value, you must initialize all of its","type":"text"},{"text":" ","type":"text"},{"text":"elements. You can use an array literal just as with ","type":"text"},{"code":"Array","type":"codeVoice"},{"text":", rely on type","type":"text"},{"text":" ","type":"text"},{"text":"inference for the ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Element"},{"type":"text","text":" type, and spell the type with the"},{"type":"text","text":" "},{"type":"text","text":"shorthand "},{"type":"codeVoice","code":"[count of Element]"},{"type":"text","text":"."}]},{"code":["let a: InlineArray<3, Int> = [1, 2, 3]","let b: InlineArray<_, Int> = [1, 2, 3]","let c: InlineArray<3, _>   = [1, 2, 3]","let d: InlineArray         = [1, 2, 3]","","let e: [3 of Int]          = [1, 2, 3]","let f: [_ of Int]          = [1, 2, 3]","let g: [3 of _]            = [1, 2, 3]","let h: [_ of _]            = [1, 2, 3]"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"You can also use one of the type’s initializers to create a new value.","type":"text"}],"type":"paragraph"},{"anchor":"Accessing-Elements","text":"Accessing Elements","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Just as with "},{"code":"Array","type":"codeVoice"},{"type":"text","text":", you can read and modify an element in an "},{"code":"InlineArray","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"using a subscript. Unless you use the memory-unsafe "},{"code":"unchecked","type":"codeVoice"},{"type":"text","text":" subscript,"},{"type":"text","text":" "},{"type":"text","text":"any index you provide is subject to bounds checking; an invalid index"},{"type":"text","text":" "},{"type":"text","text":"triggers a runtime error in your program."}],"type":"paragraph"},{"code":["var values: [3 of Double] = [1, 1.5, 2]","print(values[0])  // Prints \