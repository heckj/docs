{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/int128/&__(_:_:)-227qu"]}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Int128/&__(_:_:)-227qu"},"abstract":[{"type":"text","text":"Returns the result of shifting a value’s binary representation the"},{"type":"text","text":" "},{"type":"text","text":"specified number of digits to the right, masking the shift amount to the"},{"type":"text","text":" "},{"type":"text","text":"type’s bit width."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"&>>"},{"kind":"text","text":" "},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Other"},{"kind":"text","text":">("},{"kind":"internalParam","text":"lhs"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"internalParam","text":"rhs"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s17FixedWidthIntegerPsE3aggoiyxx_qd__tSzRd__lFZ5OtherL_qd__mfp","text":"Other"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Other"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/BinaryInteger","preciseIdentifier":"s:Sz","text":"BinaryInteger"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The value to shift."}],"type":"paragraph"}],"name":"lhs"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The number of bits to shift "},{"type":"codeVoice","code":"lhs"},{"type":"text","text":" to the right. If "},{"type":"codeVoice","code":"rhs"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"outside the range "},{"code":"0..<lhs.bitWidth","type":"codeVoice"},{"type":"text","text":", it is masked to produce a"},{"type":"text","text":" "},{"type":"text","text":"value within that range."}]}],"name":"rhs"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the masking right shift operator ("},{"code":"&>>","type":"codeVoice"},{"type":"text","text":") when you need to perform a"},{"type":"text","text":" "},{"type":"text","text":"shift and are sure that the shift amount is in the range"},{"type":"text","text":" "},{"code":"0..<lhs.bitWidth","type":"codeVoice"},{"type":"text","text":". Before shifting, the masking right shift operator"},{"type":"text","text":" "},{"type":"text","text":"masks the shift to this range. The shift is performed using this masked"},{"type":"text","text":" "},{"type":"text","text":"value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example defines "},{"code":"x","type":"codeVoice"},{"type":"text","text":" as an instance of "},{"code":"UInt8","type":"codeVoice"},{"type":"text","text":", an 8-bit,"},{"type":"text","text":" "},{"type":"text","text":"unsigned integer type. If you use "},{"type":"codeVoice","code":"2"},{"type":"text","text":" as the right-hand-side value in an"},{"type":"text","text":" "},{"type":"text","text":"operation on "},{"type":"codeVoice","code":"x"},{"type":"text","text":", the shift amount requires no masking."}]},{"type":"codeListing","code":["let x: UInt8 = 30                 // 0b00011110","let y = x &>> 2","// y == 7                         // 0b00000111"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However, if you use "},{"type":"codeVoice","code":"8"},{"type":"text","text":" as the shift amount, the method first masks the"},{"type":"text","text":" "},{"type":"text","text":"shift amount to zero, and then performs the shift, resulting in no change"},{"type":"text","text":" "},{"type":"text","text":"to the original value."}]},{"type":"codeListing","code":["let z = x &>> 8","// z == 30                        // 0b00011110"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the bit width of the shifted integer type is a power of two, masking"},{"type":"text","text":" "},{"type":"text","text":"is performed using a bitmask; otherwise, masking is performed using a"},{"type":"text","text":" "},{"type":"text","text":"modulo operation."}]}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Int128"]]},"metadata":{"roleHeading":"Operator","extendedModule":"Swift","title":"&>>(_:_:)","modules":[{"name":"Swift"}],"externalID":"s:s17FixedWidthIntegerPsE3aggoiyxx_qd__tSzRd__lFZ::SYNTHESIZED::s:s6Int128V","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"&>>"},{"kind":"text","text":" "},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Other"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Other","preciseIdentifier":"s:s17FixedWidthIntegerPsE3aggoiyxx_qd__tSzRd__lFZ5OtherL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"}],"role":"symbol","symbolKind":"op"},"references":{"doc://com.apple.Swift/documentation/Swift/Int128":{"type":"topic","abstract":[{"text":"A 128-bit signed integer value type.","type":"text"}],"title":"Int128","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Int128","url":"/documentation/swift/int128","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Int128"}],"navigatorTitle":[{"kind":"identifier","text":"Int128"}]},"doc://com.apple.Swift/documentation/Swift/BinaryInteger":{"navigatorTitle":[{"kind":"identifier","text":"BinaryInteger"}],"url":"/documentation/swift/binaryinteger","title":"BinaryInteger","abstract":[{"type":"text","text":"An integer type with a binary representation."}],"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"BinaryInteger"}],"identifier":"doc://com.apple.Swift/documentation/Swift/BinaryInteger","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/Int128/&__(_:_:)-227qu":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"&>>","kind":"identifier"},{"text":" ","kind":"text"},{"text":"<","kind":"text"},{"text":"Other","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:s17FixedWidthIntegerPsE3aggoiyxx_qd__tSzRd__lFZ5OtherL_qd__mfp","text":"Other","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Int128/&__(_:_:)-227qu","title":"&>>(_:_:)","abstract":[{"type":"text","text":"Returns the result of shifting a value’s binary representation the"},{"type":"text","text":" "},{"type":"text","text":"specified number of digits to the right, masking the shift amount to the"},{"type":"text","text":" "},{"type":"text","text":"type’s bit width."}],"type":"topic","role":"symbol","url":"/documentation/swift/int128/&__(_:_:)-22