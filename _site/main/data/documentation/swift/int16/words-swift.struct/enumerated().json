ifier"}]},"doc://com.apple.Swift/documentation/Swift/Int16/Words-swift.struct":{"navigatorTitle":[{"kind":"identifier","text":"Words"}],"type":"topic","title":"Int16.Words","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Int16/Words-swift.struct","role":"symbol","abstract":[{"type":"text","text":"A type that represents the words of this integer."}],"url":"/documentation/swift/int16/words-swift.struct","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"Words","kind":"identifier"}]}}}