{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Int16/Words-swift.struct/reversed()","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reversed","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ReversedCollection","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection","kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"You can reverse a collection without allocating new space for its","type":"text"},{"type":"text","text":" "},{"text":"elements by calling this ","type":"text"},{"type":"codeVoice","code":"reversed()"},{"text":" method. A ","type":"text"},{"type":"codeVoice","code":"ReversedCollection"},{"text":" ","type":"text"},{"text":"instance wraps an underlying collection and provides access to its","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"elements in reverse order. This example prints the characters of a"},{"text":" ","type":"text"},{"type":"text","text":"string in reverse order:"}],"type":"paragraph"},{"type":"codeListing","code":["let word = \"Backwards\"","for char in word.reversed() {","    print(char, terminator: \"\")","}","// Prints \"sdrawkcaB\""],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need a reversed collection of the same type, you may be able to"},{"type":"text","text":" "},{"type":"text","text":"use the collection’s sequence-based or collection-based initializer. For"},{"type":"text","text":" "},{"type":"text","text":"example, to get the reversed version of a string, reverse its"},{"type":"text","text":" "},{"type":"text","text":"characters and initialize a new "},{"c