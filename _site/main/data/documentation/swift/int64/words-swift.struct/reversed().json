{"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Int64/Words-swift.struct/reversed()"},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Int64","doc://com.apple.Swift/documentation/Swift/Int64/Words-swift.struct"]]},"metadata":{"role":"symbol","externalID":"s:SKsE8reverseds18ReversedCollectionVyxGyF::SYNTHESIZED::s:s5Int64V5WordsV","modules":[{"name":"Swift"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reversed","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:s18ReversedCollectionV","text":"ReversedCollection","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"roleHeading":"Instance Method","extendedModule":"Swift","symbolKind":"method","title":"reversed()"},"abstract":[{"type":"text","text":"Returns a view presenting the elements of the collection in reverse"},{"type":"text","text":" "},{"type":"text","text":"order."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reversed"},{"kind":"text","text":"() -> "},{"identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection","kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV","text":"ReversedCollection"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"You can reverse a collection without allocating new space for its"},{"type":"text","text":" "},{"type":"text","text":"elements by calling this "},{"type":"codeVoice","code":"reversed()"},{"type":"text","text":" method. A "},{"type":"codeVoice","code":"ReversedCollecti