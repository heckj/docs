{"abstract":[{"type":"text","text":"Returns a view presenting the elements of the collection in reverse"},{"type":"text","text":" "},{"type":"text","text":"order."}],"kind":"symbol","variants":[{"paths":["/documentation/swift/int64/words-swift.struct/reversed()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Int64/Words-swift.struct/reversed()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Int64","doc://com.apple.Swift/documentation/Swift/Int64/Words-swift.struct"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reversed"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:s18ReversedCollectionV","kind":"typeIdentifier","text":"ReversedCollection","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"You can reverse a collection without allocating new space for its"},{"type":"text","text":" "},{"type":"text","text":"elements by calling this "},{"type":"codeVoice","code":"reversed()"},{"text":" method. A ","type":"text"},{"type":"codeVoice","code":"ReversedCollection"},{"text":" ","type":"text"},{"type":"text","text":"instance wraps an underlying collection and provides access to its"},{"type":"text","text":" "},{"type":"text","text":"elements in reverse order. This example prints the characters of a"},{"type":"text","text":" "},{"type":"text","text":"string in reverse order:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let word = \"Backwards\"","for char in word.reversed() {","    print(char, terminator: \"\")","}","// Prints \"sdrawkcaB\""]},{"inlineContent":[{"type":"text","text":"If you need a reversed collection of the same type, you may be able to"},{"type":"text","text":" "},{"type":"text","text":"use the collection’s sequence-based or collection-based initializer. For"},{"type":"text","text":" "},{"type":"text","text":"example, to get the reversed version of a string, reverse its"},{"type":"text","text":" "},{"type":"text","text":"characters and initialize a new "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instance from the result."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let reversedWord = String(word.reversed())","print(reversedWord)","// Prints \"sdrawkcaB\""]},{"content":[{"type":"paragraph","inlineContent":[{"text":"O(1)","type":"text"}]}],"type":"aside","name":"Complexity","style":"note"}]}],"metadata":{"role":"symbol","modules":[{"name":"Swift"}],"title":"reversed()","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reversed","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ReversedCollection","kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"externalID":"s:SKsE8reverseds18ReversedCollectionVyxGyF::SYNTHESIZED::s:s5Int64V5WordsV","extendedModule":"Swift"},"sections":[],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/ReversedCollection":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Reverse