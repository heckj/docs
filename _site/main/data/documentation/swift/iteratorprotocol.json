"},{"type":"text","text":"by a base iterator, concatenated using a given separator."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Iterator"}]},"doc://com.apple.Swift/documentation/Swift/LazyFilterSequence/Iterator":{"abstract":[{"type":"text","text":"An iterator over the elements traversed by some base iterator that also"},{"type":"text","text":" "},{"type":"text","text":"satisfy a given predicate."}],"type":"topic","kind":"symbol","title":"LazyFilterSequence.Iterator","url":"/documentation/swift/lazyfiltersequence/iterator","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Iterator","kind":"identifier"}],"navigatorTitle":[{"text":"Iterator","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/LazyFilterSequence/Iterator","conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"type":"codeVoice","code":"Base"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Sequence"},{"type":"text","text":"."}],"availabilityPrefix":[{"type":"text","text":"Available when"}]}},"doc://com.apple.Swift/documentation/Swift/LazyPrefixWhileSequence/Iterator":{"identifier":"doc://com.apple.Swift/documentation/Swift/LazyPrefixWhileSequence/Iterator","title":"LazyPrefixWhileSequence.Iterator","type":"topic","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Iterator","kind":"identifier"}],"navigatorTitle":[{"text":"Iterator","kind":"identifier"}],"conformance":{"constraints":[{"type":"codeVoice","code":"Base"},{"text":" conforms to ","type":"text"},{"type":"codeVoice","code":"Sequence"},{"text":".","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}]},"url":"/documentation/swift/lazyprefixwhilesequence/iterator","abstract":[{"type":"text","text":"An iterator over the init