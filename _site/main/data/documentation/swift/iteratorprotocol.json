xt"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}]},"role":"symbol","title":"Dictionary.Values.Iterator","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Iterator","kind":"identifier"}],"type":"topic","url":"/documentation/swift/dictionary/values-swift.struct/iterator"},"doc://com.apple.Swift/documentation/Swift/IteratorSequence":{"navigatorTitle":[{"text":"IteratorSequence","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/IteratorSequence","abstract":[{"text":"A sequence built around an iterator of type ","type":"text"},{"type":"codeVoice","code":"Base"},{"text":".","type":"text"}],"conformance":{"constraints":[{"type":"codeVoice","code":"Base"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"IteratorProtocol"},{"type":"text","text":"."}],"availabilityPrefix":[{"type":"text","text":"Available when"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}]},"role":"symbol","title":"IteratorSequence","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IteratorSequence","kind":"identifier"}],"type":"topic","url":"/documentation/swift/iteratorsequence"},"doc://com.apple.Swift/documentation/Swift/UnfoldSequence":{"url":"/documentation/swift/unfoldsequence","abstract":[{"text":"A sequence whose elements are produced via repeated applications of a","type":"text"},{"text":" ","type":"text"},{"text":"closure to some mutable state.","type":"text"}],"title":"UnfoldSequence","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnfoldSequence","kind":"identifier"}],"navigatorTitle":[{"text":"UnfoldSequence","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/UnfoldSequence"},"doc://com.apple.Swift/documentation/Swift/Set/Iterator":{"navigatorTitle":[{"kind":"identifier","text":"Iterator"}],"identifier":"doc://c