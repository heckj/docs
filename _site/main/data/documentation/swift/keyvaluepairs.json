erated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/KeyValuePairs/BidirectionalCollection-Implementations","doc://com.apple.Swift/documentation/Swift/KeyValuePairs/Collection-Implementations","doc://com.apple.Swift/documentation/Swift/KeyValuePairs/CustomDebugStringConvertible-Implementations","doc://com.apple.Swift/documentation/Swift/KeyValuePairs/CustomStringConvertible-Implementations","doc://com.apple.Swift/documentation/Swift/KeyValuePairs/RandomAccessCollection-Implementations","doc://com.apple.Swift/documentation/Swift/KeyValuePairs/Sequence-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"KeyValuePairs"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Key"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Value"},{"kind":"text","text":">"}]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" instance when you need an ordered collection of"},{"type":"text","text":" "},{"type":"text","text":"key-value pairs and don’t require the fast key lookup that the"},{"text":" ","type":"text"},{"code":"Dictionary","type":"codeVoice"},{"text":" type provides. Unlike key-value pairs in a true dictionary,","type":"text"},{"text":" ","type":"text"},{"text":"neither the key nor the value of a ","type":"text"},{"code":"KeyValuePairs","type":"codeVoice"},{"text":" instance must","type":"text"},{"text":" ","type":"text"},{"text":"conform to the ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":" protocol.","type":"text"}]},{"inlineContent":[{"text":"You initialize a ","type":"text"},{"code":"KeyValuePairs","type":"codeVoice"},{"text":" instance using a Swift dictionary","type":"text"},{"text":" ","type":"text"},{"text":"literal. Besides maintaining the order of the original dictionary literal,","type":"text"},{"text":" ","type":"text"},{"code":"KeyValuePairs","type":"codeVoice"},{"type":"text","text":" also allows duplicates keys. For example:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let recordTimes: KeyValuePairs = [\"Florence Griffith-Joyner\": 10.49,","                                      \"Evelyn Ashford\": 10.76,","                                      \"Evelyn Ashford\": 10.79,","                                      \"Marlies Gohr\": 10.81]","print(recordTimes.first!)","// Prints \"(key: \"Florence Griffith-Joyner\", value: 10.49)\""]},{"inlineContent":[{"type":"text","text":"Some operations that are efficient on a dictionary are slower when using"},{"type":"text","text":" "},{"code":"KeyValuePairs","type":"codeVoice"},{"text":". In particular, to find the value matching a key, you","type":"text"},{"text":" ","type":"text"},{"text":"must search through every element of the collection. The call to","type":"text"},{"text":" ","type":"text"},{"code":"firstIndex(where:)","type":"codeVoice"},{"text":" in the following example must traverse the whole","type":"text"},{"text":" ","type":"text"},{"text":"collection to find the element that matches the predicate:","type":"text"}],"type":"paragraph"},{"code":["let runner = \"Marlies Gohr\"","if let index = recordTimes.firstIndex(where: { $0.0 == runner }) {","    let time = recordTimes[index].1","    print(\"\\(runner) set a 100m record of \\(time) seconds.\")","} else {","    print(\"\\(runner) couldn't be found in the records.\")","}","// Prints \"Marlies Gohr set a 100m record of 10.81 seconds.\""],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Key-Value Pairs as a Function Parameter","anchor":"Key-Value-Pairs-as-a-Function-Parameter"},{"inlineContent":[{"text":"When calling a function with a ","type":"text"},{"type":"codeVoice","code":"KeyValuePairs"},{"text":" parameter, you can pass","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a Swift dictionary literal without causing a "},{"type":"codeVoice","code":"Dictionary"},{"type":"text","text":" to be created."},{"type":"text","text":" "},{"text":"This capability can be especially important when the order of elements in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the literal is significant."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, you could create an "},{"type":"codeVoice","code":"IntPairs"},{"type":"text","text":" structure that holds a list of"},{"type":"text","text":" "},{"type":"text","text":"two-integer tuples and use an initializer that accepts a"},{"type":"text","text":" "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" instance."}]},{"type":"codeListing","syntax":"swift","code":["struct IntPairs {","    var elements: [(Int, Int)]","","    init(_ elements: KeyValuePairs<Int, Int>) {","        self.elements = Array(elements)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you’re ready to create a new "},{"type":"codeVoice","code":"IntPairs"},{"type":"text","text":" instance, use a dictionary"},{"type":"text","text":" "},{"type":"text","text":"literal as the parameter to the "},{"type":"codeVoice","code":"IntPairs"},{"type":"text","text":" initializer. The"},{"type":"text","text":" "},{"code":"KeyValuePairs","type":"codeVoice"},{"type":"text","text":" instance preserves the order of the elements as"},{"type":"text","text":" "},{"type":"text","text":"passed."}]},{"syntax":"swift","code":["l