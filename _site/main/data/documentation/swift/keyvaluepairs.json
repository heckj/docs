{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@frozen"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"KeyValuePairs","kind":"identifier"},{"kind":"text","text":"<"},{"text":"Key","kind":"genericParameter"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Value"},{"kind":"text","text":">"}],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"Use a "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" instance when you need an ordered collection of"},{"type":"text","text":" "},{"type":"text","text":"key-value pairs and don’t require the fast key lookup that the"},{"type":"text","text":" "},{"type":"codeVoice","code":"Dictionary"},{"type":"text","text":" type provides. Unlike key-value pairs in a true dictionary,"},{"type":"text","text":" "},{"type":"text","text":"neither the key nor the value of a "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" instance must"},{"type":"text","text":" "},{"type":"text","text":"conform to the "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":" protocol."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You initialize a "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" instance using a Swift dictionary"},{"type":"text","text":" "},{"type":"text","text":"literal. Besides maintaining the order of the original dictionary literal,"},{"type":"text","text":" "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" also allows duplicates keys. For example:"}],"type":"paragraph"},{"code":["let recordTimes: KeyValuePairs = [\"Florence Griffith-Joyner\": 10.49,","                                      \"Evelyn Ashford\": 10.76,","                                      \"Evelyn Ashford\": 10.79,","                                      \"Marlies Gohr\": 10.81]","print(recordTimes.first!)","// Prints \"(key: \"Florence Griffith-Joyner\", value: 10.49)\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Some operations that are efficient on a dictionary are slower when using"},{"type":"text","text":" "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":". In particular, to find the value matching a key, you"},{"type":"text","text":" "},{"type":"text","text":"must search through every element of the collection. The call to"},{"type":"text","text":" "},{"type":"codeVoice","code":"firstIndex(where:)"},{"type":"text","text":" in the following example must traverse the whole"},{"type":"text","text":" "},{"type":"text","text":"collection to find the element that matches the predicate:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let runner = \"Marlies Gohr\"","if let index = recordTimes.firstIndex(where: { $0.0 == runner }) {","    let time = recordTimes[index].1","    print(\"\\(runner) set a 100m record of \\(time) seconds.\")","} else {","    print(\"\\(runner) couldn't be found in the records.\")","}","// Prints \"Marlies Gohr set a 100m record of 10.81 seconds.\""]},{"text":"Key-Value Pairs as a Function Parameter","anchor":"Key-Value-Pairs-as-a-Function-Parameter","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"When calling a function with a "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" parameter, you can pass"},{"type":"text","text":" "},{"type":"text","text":"a Swift dictionary literal without causing a "},{"type":"codeVoice","code":"Dictionary"},{"type":"text","text":" to be created."},{"type":"text","text":" "},{"type":"text","text":"This capability can be especially important when the order of elements in"},{"type":"text","text":" "},{"type":"text","text":"the literal is significant."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, you could create an "},{"type":"codeVoice","code":"IntPairs"},{"type":"text","text":" structure that holds a list of"},{"type":"text","text":" "},{"type":"text","text":"two-integer tuples and use an initializer that accepts a"},{"type":"text","text":" "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" instance."}],"type":"paragraph"},{"code":["struct IntPairs {","    var elements: [(Int, Int)]","","    init(_ elements: KeyValuePairs<Int, Int>) {","        self.elements = Array(elements)","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"When you’re ready to create a new "},{"type":"codeVoice","code":"IntPairs"},{"type":"text","text":" instance, use a dictionary"},{"type":"text","text":" "},{"type":"text","text":"literal as the parameter to the "},{"type":"codeVoice","code":"IntPairs"},{"type":"text","text":" initializer. The"},{"type":"text","text":" "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" instance preserves the order of the elements as"},{"type":"text","text":" "},{"type":"text","text":"passed."}],"type":"paragraph"},{"code":["let pairs = IntPairs([1: 2, 1: 1, 3: 4, 2: 1])","print(pairs.elements)","// Prints \"[(1, 2), (1, 1), (3, 4), (2, 1)]\""],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/repeatElement(_:count:)","doc://com.apple.Swift/documentation/Swift/CollectionOfOne","doc://com.apple.Swift/documentation/Swift/EmptyCollection","doc://com.apple.Swift/documentation/Swift/DictionaryLiteral"],"title":"Special-Use Collections","generated":true,"anchor":"Special-Use-Collections"}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/KeyValuePairs"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"abstract":[{"text":"A lightweight collection of key-value pairs.","type":"text"}],"r