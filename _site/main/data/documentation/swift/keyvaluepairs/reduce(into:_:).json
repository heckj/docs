text","text":"value with an element of the sequence."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"The final accumulated value. If the sequence has no elements,"},{"type":"text","text":" "},{"type":"text","text":"the result is "},{"code":"initialResult","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"code":"reduce(into:_:)","type":"codeVoice"},{"text":" method to produce a single value from the","type":"text"},{"text":" ","type":"text"},{"text":"elements of an entire sequence. For example, you can use this method on an","type":"text"},{"text":" ","type":"text"},{"text":"array of integers to filter adjacent equal entries or count frequencies.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This method is preferred over ","type":"text"},{"code":"reduce(_:_:)","type":"codeVoice"},{"text":" for efficiency when the","type":"text"},{"text":" ","type":"text"},{"text":"result is a copy-on-write type, for example an Array or a Dictionary.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"updateAccumulatingResult"},{"text":" closure is called sequentially with a","type":"text"},{"text":" ","type":"text"},{"text":"mutable accumulating value initialized to ","type":"text"},{"type":"codeVoice","code":"initialResult"},{"type":"text","text":" and each element"},{"type":"text","text":" "},{"text":"of the sequence. This example shows how to build a dictionary of letter","type":"text"},{"text":" ","type":"text"},{"text":"frequencies of a string.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let letters = \"abracadabra\"","let letterCount = letters.reduce(into: [:]) { counts, letter in","    counts[letter, default: 0] += 1","}","// letterCount == [\"a\": 5, \"b\": 2, \"r\": 2, \"c\": 1, \"d\": 1]"]},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"letters.reduce(into:_:)","type":"codeVoice"},{"text":" is called, the following steps occur:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The "},{"code":"updateAccumulatingResult","type":"codeVoice"},{"type":"text","text":" closure is called with the initial"},{"type":"text","text":" "},{"type":"text","text":"accumulating value—"},{"code":"[:]","type":"codeVoice"},{"type":"text","text":" in this case—and the first character of"},{"type":"text","text":" "},{"code":"letters","type":"codeVoice"},{"type":"text","text":", modifying the accumulating value by setting "},{"code":"1","type":"codeVoice"},{"type":"text","text":" for the key"},{"type":"text","text":" "},{"code":"\"a\"","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The closure is called again repeatedly with the updated accumulating","type":"text"},{"text":" ","type":"text"},{"text":"value and each element of the sequence.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When the sequence is exhausted, the accumulating value is returned to"},{"type":"text","text":" "},{"type":"text","text":"the caller."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"If the sequence has no elements, ","type":"text"},{"code":"updateAccumulatingResult","type":"codeVoice"},{"text":" is never","type":"text"},{"text":" ","type":"text"},{"text":"executed and ","type":"text"},{"code":"initialResult","type":"codeVoice"},{"text":" is the result of the call to","type":"text"},{"text":" ","type":"text"},{"code":"reduce(into:_:)","type":"codeVoice"},{"text":".","type":"text"}]},{"style":"note","type":"aside","name":"Complexity","content":[{"inlineContent":[{"text":"O(","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" is the length of the sequence.","type":"text"}],"type":"paragraph"}]}]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","url":"/documentation/swift/sequence/element","title":"Element","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"A type representing the sequence’s elements."}],"required":true,"kind":"symbol","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/KeyValuePairs/reduce(into:_:)":{"role":"symbol","url":"/documentation/swift/keyvaluepairs/reduce(into:_:)","title":"reduce(into:_:)","identifier":"doc://com.apple.Swift/documentation/Swift/KeyValuePairs/reduce(into:_:)","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Returns the result of combining the elements of the sequence using the"},{"type":"text","text":" "},{"type":"text","text":"given closure."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reduce","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"Result"},{"text":">(","kind":"text"},{"text":"into","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Result","kind":"typeIdentifier","preciseIdentifier":"s:STsE6reduce4into_qd__qd__n_yqd__z_7ElementQztKXEtKlF6ResultL_qd__mfp"},{"text":", (","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" 