{"abstract":[{"type":"text","text":"Returns a view presenting the elements of the collection in reverse"},{"type":"text","text":" "},{"type":"text","text":"order."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"reversed","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:s18ReversedCollectionV","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection","text":"ReversedCollection","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"You can reverse a collection without allocating new space for its","type":"text"},{"text":" ","type":"text"},{"text":"elements by calling this ","type":"text"},{"code":"reversed()","type":"codeVoice"},{"text":" method. A ","type":"text"},{"code":"ReversedCollection","type":"codeVoice"},{"text":" ","type":"text"},{"text":"instance wraps an underlying collection and provides access to its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"elements in reverse order. This example prints the characters of a"},{"type":"text","text":" "},{"type":"text","text":"string in reverse order:"}]},{"type":"codeListing","code":["let word = \"Backwards\"","for char in word.reversed() {","    print(char, terminator: \"\")","}","// Prints \"sdrawkcaB\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need a reversed collection of the same type, you may be able to"},{"type":"text","text":" "},{"text":"use the collection’s sequence-based or collection-based initializer. For","type":"text"},{"type":"text","text":" "},{"text":"example, to get the reversed version of a string, reverse its","type":"text"},{"type":"text","text":" "},{"text":"characters and initialize a new ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" instance from the result.","type":"text"}]},{"type":"codeListing","code":["let reversedWord = String(word.reversed())","print(reversedWord)","// Prints \"sdrawkcaB\""],"syntax":"swift"},{"name":"Complexity","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"O(1)","type":"text"}]}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/KeyValuePairs/reversed()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/KeyValuePairs"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/keyvaluepairs/reversed()"]}],"metadata":{"externalID":"s:SKsE8reverseds18ReversedCollectionVyxGyF::SYNTHESIZED::s:s13KeyValuePairsV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reversed"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV","text":"ReversedCollection"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}],"modules":[{"name":"Swift"}],"roleHeading":"Instance Method","symbolKind":"method","extendedModule":"Swift","role":"symbol","title":"reversed()"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","references":{"doc://com.apple.Swift/documentation/Swift/KeyValuePairs/reversed()":{"url":"/documentation/swift/keyvaluepairs/reversed()","title":"reversed()","abstract":[{"type":"text","text":"Returns a view presenting the elements of the collection in reverse"},{"type":"text","text":" "},{"type":"text","text":"order."}],"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reversed"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"ReversedCollection","preciseIdent