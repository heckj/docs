ssion"},{"type":"paragraph","inlineContent":[{"text":"A collection’s ","type":"text"},{"type":"codeVoice","code":"indices"},{"text":" property can hold a strong reference to the","type":"text"},{"text":" ","type":"text"},{"text":"collection itself, causing the collection to be non-uniquely referenced.","type":"text"},{"text":" ","type":"text"},{"text":"If you mutate the collection while iterating over its indices, a strong","type":"text"},{"text":" ","type":"text"},{"text":"reference can cause an unexpected copy of the collection. To avoid the","type":"text"},{"text":" ","type":"text"},{"text":"unexpected copy, use the ","type":"text"},{"type":"codeVoice","code":"index(after:)"},{"text":" method starting with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"startIndex"},{"text":" to produce indices instead.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var c = MyFancyCollection([10, 20, 30, 40, 50])","var i = c.startIndex","while i != c.endIndex {","    c[i] /= 5","    i = c.index(after: i)","}","// c == MyFancyCollection([2, 4, 6, 8, 10])"]}]}],"variants":[{"paths":["/documentation/swift/lazydropwhilesequence/indices"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/LazyDropWhileSequence":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/LazyDropWhileSequence","url":"/documentation/swift/lazydropwhilesequence","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"LazyDropWhileSequence","kind":"identifier"}],"title":"LazyDropWhileSequence","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LazyDropWhileSequence","kind":"identifier"}],"abstract":[{"text":"A sequence whose elements consist of the elements that follow the initial","type":"text"},{"text":" ","type":"text"},{"text":"consecutive elements of some base sequence that satisfy a given predicate.","type":"text"}]},"doc://com.apple.Swift/documentation/Swift":{"