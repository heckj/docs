FilterSequence":{"navigatorTitle":[{"kind":"identifier","text":"LazyFilterSequence"}],"url":"/documentation/swift/lazyfiltersequence","abstract":[{"type":"text","text":"A sequence whose elements consist of the elements of some base"},{"type":"text","text":" "},{"type":"text","text":"sequence that also satisfy a given predicate."}],"identifier":"doc://com.apple.Swift/documentation/Swift/LazyFilterSequence","type":"topic","title":"LazyFilterSequence","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LazyFilterSequence"}]},"doc://com.apple.Swift/documentation/Swift/EnumeratedSequence":{"url":"/documentation/swift/enumeratedsequence","title":"EnumeratedSequence","navigatorTitle":[{"kind":"identifier","text":"EnumeratedSequence"}],"type":"topic","role":"symbol","abstract":[{"type":"text","text":"An enumeration of the elements of a sequence or collection."}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"EnumeratedSequence","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/EnumeratedSequence","kind":"symbol"}}}