{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["/documentation/swift/lazyfiltersequence/sorted()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/LazyFilterSequence/sorted()"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"sorted"},{"kind":"text","text":"() -> ["},{"kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa","text":"Element","identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element"},{"kind":"text","text":"]"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"A sorted array of the sequence’s elements.","type":"text"}]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can sort any sequence of elements that conform to the "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":" "},{"type":"text","text":"protocol by calling this method. Elements are sorted in ascending order."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here’s an example of sorting a list of students’ names. Strings in Swift"},{"type":"text","text":" "},{"type":"text","text":"conform to the "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":" protocol, so the names are sorted in"},{"type":"text","text":" "},{"type":"text","text":"ascending order according to the less-than operator ("},{"type":"codeVoice","code":"<"},{"type":"text","text":")."}]},{"type":"codeListing","code":["let students: Set = [\"Kofi\", \"Abena\", \"Peter\", \"Kweku\", \"Akosua\"]","let sortedStudents = students.sorted()","print(sortedStudents)","// Prints \"[\"Abena\", \"Akosua\", \"Kofi\", \"Kweku\", \"Peter\"]\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To sort the elements of your sequence in descending order, pass the"},{"type":"text","text":" "},{"type":"text","text":"greater-than operator ("},{"code":">","type":"codeVoice"},{"type":"text","text":") to the "},{"code":"sorted(by:)","type":"codeVoice"},{"type":"text","text":" method."}]},{"type":"codeListing","code":["let descendingStudents = students.sorted(by: >)","print(descendingStudents)","// Prints \"[\"Peter\", \"Kweku\", \"Kofi\", \"Akosua\", \"Abena\"]\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The sorting algorithm is guaranteed to be stable. A stable sort"},{"type":"text","text":" "},{"type":"text","text":"preserves the relative order of elements that compare as equal."}]},{"type":"aside","style":"note","name":"Complexity","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":" log "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the length of the sequence."}]}]}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/LazyFilterSequence"]]},"kind":"symbol","abstract":[{"text":"Returns the elements of the sequence, sorted.","type":"text"}],"metadata":{"conformance":{"constraints":[{"code":"Element","type":"codeVoice"},{"text":" conforms to ","type":"text"},{"code":"Comparable","type":"codeVoice"},{"text":".","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}]},"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"sorted"},{"kind":"text","text":"() -> ["},{"kind":