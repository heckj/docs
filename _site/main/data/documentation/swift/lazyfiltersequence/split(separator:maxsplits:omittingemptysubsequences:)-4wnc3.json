\", \"\", \"I\", \"don\\'t\", \"want\", \"realism.\", \"I\", \"want\", \"magic!\"]\""]},{"content":[{"type":"paragraph","inlineContent":[{"text":"O(","type":"text"},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the length of the sequence."}]}],"style":"note","type":"aside","name":"Complexity"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/lazyfiltersequence/split(separator:maxsplits:omittingemptysubsequences:)-4wnc3"]}],"references":{"doc://com.apple.Swift/documentation/Swift/Int":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Int","title":"Int","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Int"}],"navigatorTitle":[{"kind":"identifier","text":"Int"}],"url":"/documentation/swift/int","abstract":[{"text":"A signed integer value type.","type":"text"}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","url":"/documentation/swift/sequence/element","title":"Element","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"A type representing the sequence’s elements."}],"required":true,"kind":"symbol","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/Bool":{"title":"Bool","abstract":[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","url":"/documentation/swift/bool","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"