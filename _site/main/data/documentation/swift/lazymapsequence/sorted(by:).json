cumentation/Swift/Bool":{"title":"Bool","abstract":[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","url":"/documentation/swift/bool","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Bool","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Bool"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift/LazyMapSequence":{"title":"LazyMapSequence","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"Sequence"},{"text":" whose elements consist of those in a ","type":"text"},{"type":"codeVoice","code":"Base"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Sequence"},{"text":" passed through a transform function returning ","type":"text"},{"type":"codeVoice","code":"Element"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"These elements are computed lazily, each time they’re read, by"},{"type":"text","text":" "},{"type":"text","text":"calling the transform function on a base element."}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/LazyMapSequence","url":"/documentation/swift/lazymapsequence","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"LazyMapSequence"}],"navigatorTitle":[{"kind":"identifier","text":"LazyMapSequence"}],"type":"topic"}}}