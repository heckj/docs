ted to a concrete subrange relative to this"},{"text":" ","type":"text"},{"text":"collection. For example, using a ","type":"text"},{"type":"codeVoice","code":"PartialRangeFrom"},{"text":" range expression","type":"text"},{"text":" ","type":"text"},{"text":"with an array accesses the subrange from the start of the range","type":"text"},{"type":"text","text":" "},{"text":"expression until the end of the array.","type":"text"}]},{"code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2...]","print(streetsSlice)","// [\"Channing\", \"Douglas\", \"Evarts\"]"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The accessed slice uses the same indices for the same elements as the"},{"type":"text","text":" "},{"text":"original collection uses. This example searches ","type":"text"},{"type":"codeVoice","code":"streetsSlice"},{"type":"text","text":" for one"},{"text":" ","type":"text"},{"type":"text","text":"of the strings in the slice, and then uses that index in the original"},{"type":"text","text":" "},{"type":"text","text":"array."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""]},{"inlineContent":[{"text":"Always use the slice’s ","type":"text"},{"code":"startIndex","type":"codeVoice"},{"text":" property instead of assuming that its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"indices start at a particular value. Attempting to access an element by"},{"type":"text","text":" "},{"type":"text","text":"using an index outside the bounds of the slice’s indices may result in a"},{"text":" ","type":"text"},{"type":"text","text":"runtime error, even if that index is valid for the original collection."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"