{"abstract":[{"type":"text","text":"The indices that are valid for subscripting the collection, in ascending"},{"type":"text","text":" "},{"type":"text","text":"order."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"indices"},{"kind":"text","text":": "},{"text":"DefaultIndices","identifier":"doc://com.apple.Swift/documentation/Swift/DefaultIndices","preciseIdentifier":"s:SI","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":"> { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"A collection’s "},{"type":"codeVoice","code":"indices"},{"type":"text","text":" property can hold a strong reference to the"},{"type":"text","text":" "},{"type":"text","text":"collection itself, causing the collection to be non-uniquely referenced."},{"type":"text","text":" "},{"type":"text","text":"If you mutate the collection while iterating over its indices, a strong"},{"type":"text","text":" "},{"type":"text","text":"reference can cause an unexpected copy of the collection. To avoid the"},{"type":"text","text":" "},{"type":"text","text":"unexpected copy, use the "},{"type":"codeVoice","code":"index(after:)"},{"type":"text","text":" method starting with"},{"type":"text","text":" "},{"type":"codeVoice","code":"startIndex"},{"type":"text","text":" to produce indices instead."}],"type":"paragraph"},{"syntax":"swift","code":["var c = MyFancyCollection([10, 20, 30, 40, 50])","var i = c.startIndex","while i != c.endIndex {","    c[i] /= 5","    i = c.index(after: i)","}","// c == MyFancyCollection([2, 4, 6, 8, 10])"],"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/lazyprefixwhil