","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Result","preciseIdentifier":"s:STsE6reduce4into_qd__qd__n_yqd__z_7ElementQztKXEtKlF6ResultL_qd__mfp","kind":"typeIdentifier"}]},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","url":"/documentation/swift/sequence/element","title":"Element","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"A type representing the sequence’s elements."}],"required":true,"kind":"symbol","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/LazySequence":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LazySequence"}],"url":"/documentation/swift/lazysequence","abstract":[{"type":"text","text":"A sequence containing the same elements as a "},{"type":"codeVoice","code":"Base"},{"type":"text","text":" sequence, but"},{"type":"text","text":" "},{"type":"text","text":"on which some operations such as "},{"type":"codeVoice","code":"map"},{"type":"text","text":" and "},{"type":"codeVoice","code":"filter"},{"type":"text","text":" are"},{"type":"text","text":" "},{"type":"text","text":"implemented lazily."}],"navigatorTitle":[{"kind":"identifier","text":"LazySequence"}],"title":"LazySequence","identifier":"doc://com.apple.Swift/documentation/Swift/LazySequence"}}}