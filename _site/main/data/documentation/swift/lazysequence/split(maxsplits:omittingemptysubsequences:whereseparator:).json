{"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/LazySequence"]]},"abstract":[{"type":"text","text":"Returns the longest possible subsequences of the sequence, in order, that"},{"type":"text","text":" "},{"text":"don’t contain elements satisfying the given predicate. Elements that are","type":"text"},{"text":" ","type":"text"},{"text":"used to split the sequence are not returned as part of any subsequence.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"split"},{"kind":"text","text":"("},{"kind":"externalParam","text":"maxSplits"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","identifier":"doc://com.apple.Swift/documentation/Swift/Int","text":"Int"},{"kind":"text","text":" = Int.max, "},{"kind":"externalParam","text":"omittingEmptySubsequences"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","text":"Bool"},{"kind":"text","text":" = true, "},{"kind":"externalParam","text":"whereSeparator"},{"kind":"text","text":" "},{"kind":"internalParam","text":"isSeparator"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","text":"Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","text":"Bool"},{"kind":"text","text":") "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> ["},{"kind":"typeIdentifier","preciseIdentifier":"s:s10ArraySliceV","identifier":"doc://com.apple.Swift/documentation/Swift/ArraySlice","text":"ArraySlice"},{"kind":"text","text":"<"},{"k