{"abstract":[{"text":"Accesses the contiguous subrange of the collection’s elements specified","type":"text"},{"text":" ","type":"text"},{"text":"by a range expression.","type":"text"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/lazysequence/subscript(_:)-9kt1v"]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/LazySequence/subscript(_:)-9kt1v","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/LazySequence"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"R","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"r","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp","text":"R","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sl11SubSequenceQa","text":"SubSequence","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"R","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SX","text":"RangeExpression","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression"},{"text":", ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","text":"Index","preciseIdentifier":"s:Sl5IndexQa"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"R"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound","text":"Bound","preciseIdentifier":"s:SX5BoundQa"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"The range expression is converted to a concrete subrange relative to this","type":"text"},{"text":" ","type":"text"},{"text":"collection. For example, using a ","type":"text"},{"type":"codeVoice","code":"PartialRangeFrom"},{"text":" range expression","type":"text"},{"text":" ","type":"text"},{"text":"with an array accesses the subrange from the start of the range","type":"text"},{"text":" ","type":"text"},{"text":"expression until the end of the array.","type":"text"}]},{"code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2...]","print(streetsSlice)","// [\"Channing\", \"Douglas\", \"Evarts\"]"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The accessed slice uses the same indices for the same elements as the"},{"type":"text","text":" "},{"type":"text","text":"original collection uses. This example searches "},{"type":"codeVoice","code":"streetsSlice"},{"type":"text","text":" for one"},{"type":"text","text":" "},{"type":"text","text":"of the strings in the slice, and then uses that index in the original"},{"type":"text","text":" "},{"type":"text","text":"array."}]},{"code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Always use the slice’s ","type":"text"},{"type":"codeVoice","code":"startIndex"},{"text":" property instead of assuming that its","type":"text"},{"text":" ","type":"text"},{"text":"indices start at a particular value. Attempting to access an element by","type":"text"},{"text":" ","type":"text"},{"text":"using an index outside the bounds of the slice’s indices may result in a","type":"text"},{"text":" ","type":"text"},{"text":"runtime error, even if that index is valid for the original collection.","type":"text"}]},{"code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"],"type":"codeListing","syntax":"swift"},{"name":"Complexity","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"O(1)"}],"type":"paragraph"}]}]}],"metadata":{"role":"symbol","modules":[{"name":"Swift"}],"title":"subscript(_:)","symbolKind":"subscript","roleHeading":"Instance Subscript","fragments":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"R","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa"}],"externalID":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip::SYNTHESIZED::s:s12LazySequenceV","extendedModule":"Swift"},"sections":[],"references":{"doc://com.apple.Swift/documentation/Swift/LazySequence/subscript(_:)-9kt1v":{"abstract":[{"text":"Accesses the contiguous subrange of the collection’s elements specified","type":"text"},{"type":"text","text":" "},{"text":"by a range expression.","type":"text"}],"title":"subscript(_:)","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/LazySequence/subscript(_:)-9kt1v","url":"/documentation/swift/lazysequence/subscript(_:)-9kt1v","type":"topic","fragments":[{"text":"subscript","kind":"keyword"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp","text":"R"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sl11SubSequenceQa","text":"SubSequence"}],"kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence":{"title":"SubSequence","kind":"symbol","abstract":[{"type":"text","text":"A collection representing a contiguous subrange of this collection’s"},{"type":"text","text":" "},{"type":"text","text":"elements. The subsequence shares indices with the original collection."}],"identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","url":"/documentation/swift/collection/subsequence","required":true,"role":"symbol","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"SubSequence"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:Sl","kind":"typeIdentifier","text":"Collection"},{"kind":"text","text":" = "},{"preciseIdentifier":"s:s5SliceV","kind":"typeIdentifier","text":"Slice"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound":{"identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound","title":"Bound","type":"topic","kind":"symbol","required":true,"fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Bound"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"Comparable","preciseIdentifier":"s:SL"}],"url":"/documentation/swift/rangeexpression/bound","abstract":[{"type":"text","text":"The type for which the expression describes a range."}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift/LazySequence":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LazySequence"}],"url":"/documentation/swift/lazysequence","abstract":[{"type":"text","text":"A sequence containing the same elements as a "},{"type":"codeVoi