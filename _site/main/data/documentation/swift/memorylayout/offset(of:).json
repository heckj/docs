{"abstract":[{"text":"Returns the offset of an inline stored property within a type’s in-memory","type":"text"},{"text":" ","type":"text"},{"text":"representation.","type":"text"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/memorylayout/offset(of:)"]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/MemoryLayout/offset(of:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/MemoryLayout"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"offset"},{"kind":"text","text":"("},{"text":"of","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"key","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s14PartialKeyPathC","text":"PartialKeyPath","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/PartialKeyPath"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s12MemoryLayoutO1Txmfp","text":"T","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Int"},{"text":"?","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A key path referring to storage that can be accessed"},{"type":"text","text":" "},{"type":"text","text":"through a value of type "},{"type":"codeVoice","code":"T"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"key"}]},{"kind":"content","content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"The offset in bytes from a pointer to a value of type ","type":"text"},{"type":"codeVoice","code":"T"},{"text":" to a","type":"text"},{"text":" ","type":"text"},{"text":"pointer to the storage referenced by ","type":"text"},{"type":"codeVoice","code":"key"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" if no such offset","type":"text"},{"text":" ","type":"text"},{"text":"is available for the storage referenced by ","type":"text"},{"type":"codeVoice","code":"key"},{"text":". If the value is","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", it can be because "},{"type":"codeVoice","code":"key"},{"type":"text","text":" is computed, has observers, requires"},{"type":"text","text":" "},{"type":"text","text":"reabstraction, or overlaps storage with other properties."}]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"You can use this method to find the distance in bytes that can be added","type":"text"},{"text":" ","type":"text"},{"text":"to a pointer of type ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" to get a pointer to the property referenced by","type":"text"},{"text":" ","type":"text"},{"code":"key","type":"codeVoice"},{"text":". The offset is available only if the given key refers to inline,","type":"text"},{"text":" ","type":"text"},{"text":"directly addressable storage within the in-memory representation of ","type":"text"},{"code":"T","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the return value of this method is non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then accessing the value"},{"type":"text","text":" "},{"type":"text","text":"by key path or by an offset pointer are equivalent. For example, for a"},{"type":"text","text":" "},{"type":"text","text":"variable "},{"type":"codeVoice","code":"root"},{"type":"text","text":" of type "},{"type":"codeVoice","code":"T"},{"type":"text","text":", a key path "},{"code":"key","type":"codeVoice"},{"type":"text","text":" of type"},{"type":"text","text":" "},{"type":"codeVoice","code":"WritableKeyPath<T, U>"},{"type":"text","text":", and a "},{"type":"codeVoice","code":"value"},{"type":"text","text":" of type "},{"type":"codeVoice","code":"U"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["// Mutation through the key path","root[keyPath: key] = value","","// Mutation through the offset pointer","withUnsafeMutableBytes(of: &root) { bytes in","    let offset = MemoryLayout<T>.offset(of: key)!","    let rawPointerToValue = bytes.baseAddress! + offset","    let pointerToValue = rawPointerToValue.assumingMemoryBound(to: U.self)","    pointerToValue.pointee = value","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"A property has inline, directly addressable storage when it is a stored"},{"type":"text","text":" "},{"type":"text","text":"property for which no additional work is required to extract or set the"},{"type":"text","text":" "},{"type":"text","text":"value. Properties are not directly accessible if they trigger any"},{"type":"text","text":" "},{"type":"codeVoice","code":"didSet"},{"type":"text","text":" or "},{"type":"codeVoice","code":"willSet"},{"type":"text","text":" accessors, perform any representation changes such"},{"type":"text","text":" "},{"type":"text","text":"as bridging or closure reabstraction, or mask the value out of"},{"type":"text","text":" "},{"type":"text","text":"overlapping storage as for packed bitfields. In addition, because class"},{"type":"text","text":" "},{"type":"text","text":"instance properties are always stored out-of-line, their positions are"},{"type":"text","text":" "},{"type":"text","text":"not accessible using "},{"type":"codeVoice","code":"offset(of:)"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"For example, in the ","type":"text"},{"code":"ProductCategory","type":"codeVoice"},{"text":" type defined here, only","type":"text"},{"text":" ","type":"text"},{"code":"\\.updateCounter","type":"codeVoice"},{"text":", ","type":"text"},{"code":"\\.identifier","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"\\.identifier.name","type":"codeVoice"},{"text":" refer to","type":"text"},{"type":"text","text":" "},{"text":"properties with inline, directly addressable storage:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct ProductCategory {","    struct Identifier {","        var name: String              // addressable","    }","","    var identifier: Identifier        // addressable","    var updateCounter: Int            // addressable","    var products: [Product] {         // not addressable: didSet handler","        didSet { updateCounter += 1 }","    }","    var productCount: Int {           // not addressable: computed property","        return products.count","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"When using ","type":"text"},{"code":"offset(of:)","type":"codeVoice"},{"text":" with a type imported from a library, don’t","type":"text"},{"text":" ","type":"text"},{"text":"assume that future versions of the library will have the same behavior.","type":"text"},{"text":" ","type":"text"},{"text":"If a property is converted from a stored property to a computed","type":"text"},{"text":" ","type":"text"},{"text":"property, the result of ","type":"text"},{"code":"offset(of:)","type":"codeVoice"},{"text":" changes to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":". That kind of","type":"text"},{"text":" ","type":"text"},{"text":"conversion is nonbreaking in other contexts, but would trigger a runtime","type":"text"},{"text":" ","type":"text"},{"text":"error if the result of ","type":"text"},{"code":"offset(of:)","type":"codeVoice"},{"text":" is force-unwrapped.","type":"text"}]}],"kind":"content"}],"metadata":{"title":"offset(of:)","modules":[{"name":"Swift"}],"role":"symbol","symbolKind":"method","roleHeading":"Type Method","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"offset"},{"kind":"text","text":"("},{"kind":"externalParam","text":"of"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"PartialKeyPath","preciseIdentifier":"s:s14PartialKeyPathC"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:s12MemoryLayoutO1Txmfp"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":"?"}],"externalID":"s:s12MemoryLayoutO6offset2ofSiSgs14PartialKeyPathCyxG_tFZ","extendedModule":"Swift"},"sections":[],"references":{"doc://com.apple.Swift/documentation/Swift/MemoryLayout/offset(of:)":{"identifier":"doc://com.apple.Swift/documentation/Swift/MemoryLayout/offset(of:)","abstract":[{"text":"Returns the offset of an inline stored property within a type’s in-memory","type":"text"},{"type":"text","text":" "},{"type":"text","text":"representation."}],"role":"symbol","title":"offset(of:)","kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"offset","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"of"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s14PartialKeyPathC","text":"PartialKeyPath"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:s12MemoryLayoutO1Txmfp","text":"T"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":"?"}],"url":"/documentation/swift/memorylayout/offset(of:)","type":"topic"},"doc://com.apple.Swift/documentation/Swift/PartialKeyPath":{"identifier":"doc://com.apple.Swift/documentation/Swift/PartialKeyPath","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"PartialKeyPath"}],"navigatorTitle":[{"kind":"identifier","text":"PartialKeyPath"}],"type":"topic","url":"/documentation/swift/partialkeypath","abstract":[{"type":"text","text":"A partially type-erased key path, from a concrete root type to any"},{"type":"text","text":" "},{"type":"text","text":"resulting value type."}],"title":"PartialKeyPath","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/Int":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Int","title":"Int","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Int"}],"navigatorTitle":[{"kind":"identifier","text":"Int"}],"url":"/documentation/swift/int","abstract":[{"text":"A signed integer value type.","type":"text"}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/MemoryLayout":{"abstract":[{"type":"text","text":"The memory layout of a type, describing its size, stride, and alignment."}],"title":"MemoryLayout","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/MemoryLayout","url":"/documentation/swift/memorylayout","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"MemoryLayout"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MemoryLayout"}]}}}