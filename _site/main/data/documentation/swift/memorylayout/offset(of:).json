{"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/memorylayout/offset(of:)"]}],"sections":[],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/MemoryLayout/offset(of:)","interfaceLanguage":"swift"},"abstract":[{"text":"Returns the offset of an inline stored property within a type’s in-memory","type":"text"},{"text":" ","type":"text"},{"text":"representation.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"offset","kind":"identifier"},{"text":"(","kind":"text"},{"text":"of","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"key","kind":"internalParam"},{"text":": ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/PartialKeyPath","preciseIdentifier":"s:s14PartialKeyPathC","text":"PartialKeyPath","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s12MemoryLayoutO1Txmfp","text":"T","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"key","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A key path referring to storage that can be accessed"},{"type":"text","text":" "},{"type":"text","text":"through a value of type "},{"type":"codeVoice","code":"T"},{"type":"text","text":"."}]}]}]},{"content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The offset in bytes from a pointer to a value of type "},{"type":"codeVoice","code":"T"},{"type":"text","text":" to a"},{"type":"text","text":" "},{"type":"text","text":"pointer to the storage referenced by "},{"type":"codeVoice","code":"key"},{"type":"text","text":", or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if no such offset"},{"type":"text","text":" "},{"type":"text","text":"is available for the storage referenced by "},{"type":"codeVoice","code":"key"},{"type":"text","text":". If the value is"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", it can be because "},{"type":"codeVoice","code":"key"},{"type":"text","text":" is computed, has observers, requires"},{"type":"text","text":" "},{"type":"text","text":"reabstraction, or overlaps storage with other properties."}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"You can use this method to find the distance in bytes that can be added"},{"type":"text","text":" "},{"type":"text","text":"to a pointer of type "},{"type":"codeVoice","code":"T"},{"type":"text","text":" to get a pointer to the property referenced by"},{"type":"text","text":" "},{"type":"codeVoice","code":"key"},{"type":"text","text":". The offset is available only if the given key refers to inline,"},{"type":"text","text":" "},{"type":"text","text":"directly addressable storage within the in-memory representation of "},{"type":"codeVoice","code":"T"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the return value of this method is non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then accessing the value"},{"type":"text","text":" "},{"type":"text","text":"by key path or by an offset pointer are equivalent. For example, for a"},{"type":"text","text":" "},{"type":"text","text":"variable "},{"type":"codeVoice","code":"root"},{"type":"text","text":" of type "},{"type":"codeVoice","code":"T"},{"type":"text","text":", a key path "},{"type":"codeVoice","code":"key"},{"type":"text","text":" of type"},{"type":"text","text":" "},{"type":"codeVoice","code":"WritableKeyPath<T, U>"},{"type":"text","text":", and a "},{"type":"codeVoice","code":"value"},{"type":"text","text":" of type "},{"type":"codeVoice","code":"U"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["// Mutation through the key path","root[keyPath: key] = value","","// Mutation through the offset pointer","withUnsafeMutableBytes(of: &root) { bytes in","    let offset = MemoryLayout<T>.offset(of: key)!","    let rawPointerToValue = bytes.baseAddress! + offset","    let pointerToValue = rawPointerToValue.assumingMemoryBound(to: U.self)","    pointerToValue.pointee = value","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"A property has inline, directly addressable storage when it is a stored"},{"type":"text","text":" "},{"type":"text","text":"property for which no additional work is required to extract or set the"},{"type":"text","text":" "},{"type":"text","text":"value. Properties are not directly accessible if they trigger any"},{"type":"text","text":" "},{"code":"didSet","type":"codeVoice"},{"type":"text","text":" or "},{"code":"willSet","type":"codeVoice"},{"type":"text","text":" accessors, perform any representation changes such"},{"type":"text","text":" "},{"type":"text","text":"as bridging or closure reabstraction, or mask the value out of"},{"type":"text","text":" "},{"type":"text","text":"overlapping storage as for packed bitfields. In addition, because class"},{"type":"text","text":" "},{"type":"text","text":"instance properties are always stored out-of-line, their positions are"},{"type":"text","text":" "},{"type":"text","text":"not accessible using "},{"code":"offset(of:)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, in the "},{"code":"ProductCategory","type":"codeVoice"},{"type":"text","text":" type defined here, only"},{"type":"text","text":" "},{"code":"\\.updateCounter","type":"codeVoice"},{"type":"text","text":", "},{"code":"\\.identifier","type":"codeVoice"},{"type":"text","text":", and "},{"code":"\\.identifier.name","type":"codeVoice"},{"type":"text","text":" refer to"},{"type":"text","text":" "},{"type":"text","text":"properties with inline, directly addressable storage:"}],"type":"paragraph"},{"code":["struct ProductCategory {","    struct Identifier {","        var name: String              // addressable","    }","","    var identifier: Identifier        // addressable","    var updateCounter: Int            // addressable","    var products: [Product] {         // not addressable: didSet handler","        didSet { updateCounter += 1 }","    }","    var productCount: Int {           // not addressable: computed property","        return products.count","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"When using "},{"code":"offset(of:)","type":"codeVoice"},{"type":"text","text":" with a type imported from a library, don’t"},{"type":"text","text":" "},{"type":"text","text":"assume that future versions of the library will have the same behavior."},{"type":"text","text":" "},{"type":"text","text":"If a property is converted from a stored property to a computed"},{"type":"text","text":" "},{"type":"text","text":"property, the result of "},{"code":"offset(of:)","type":"codeVoice"},{"type":"text","text":" changes to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":". That kind of"},{"type":"text","text":" "},{"type":"text","text":"conversion is nonbreaking in other contexts, but would trigger a runtime"},{"type":"text","text":" "},{"type":"text","text":"error if the result of "},{"code":"offset(of:)","type":"codeVoice"},{"type":"text","text":" is force-unwrapped."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"symbolKind":"method","modules":[{"name":"Swift"}],"roleHeading":"Type Method","title":"offset(of:)","externalID":"s:s12MemoryLayoutO6offset2ofSiSgs14PartialKeyPathCyxG_tFZ","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"offset","kind":"identifier"},{"text":"(","kind":"text"},{"text":"of","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"PartialKeyPath","preciseIdentifier":"s:s14PartialKeyPathC","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"T","preciseIdentifier":"s:s12MemoryLayoutO1Txmfp","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"extendedModule":"Swift","role":"symbol"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/MemoryLayout"]]},"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/MemoryLayout/offset(of:)":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/MemoryLayout/offset(of:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"offset","kind":"identifier"},{"text":"(","kind":"text"},{"text":"of","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"PartialKeyPath","kind":"typeIdentifier","preciseIdentifier":"s:s14PartialKeyPathC"},{"text":"<","kind":"text"},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:s12MemoryLayoutO1Txmfp"},{"text":">) -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":"?","kind":"text"}],"url":"/documentation/swift/memorylayout/offset(of:)","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Returns the offset of an inline stored property within a type’s in-memory"},{"type":"text","text":" "},{"type":"text","text":"representation."}],"title":"offset(of:)"},"doc://com.apple.Swift/documentation/Swift/MemoryLayout":{"identifier":"doc://com.apple.Swift/documentation/Swift/MemoryLayout","navigatorTitle":[{"kind":"identifier","text":"MemoryLayout"}],"abstract":[{"type":"text","text":"The memory layout of a type, describing its size, stride, and alignment."}],"type":"topic","title":"MemoryLayout","kind":"symbol","url":"/documentation/swift/memorylayout","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"MemoryLayout"}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift/PartialKeyPath":{"identifier":"doc://com.apple.Swift/documentation/Swift/PartialKeyPath","navigatorTitle":[{"kind":"identifier","text":"PartialKeyPath"}],"abstract":[{"text":"A partially type-erased key path, from a concrete root type to any","type":"text"},{"text":" ","type":"text"},{"text":"resulting value type.","type":"text"}],"type":"topic","title":"PartialKeyPath","kind":"symbol","url":"/documentation/swift/partialkeypath","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"PartialKeyPath","kind":"identifier"}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift/Int":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Int","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Int"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Int","url":"/documentation/swift/int","kind":"symbol","abstract":[{"type":"text","text":"A signed integer value type."}],"title":"Int"}}}