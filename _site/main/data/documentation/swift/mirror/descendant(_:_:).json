{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"symbolKind":"method","roleHeading":"Instance Method","role":"symbol","title":"descendant(_:_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"descendant","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:s10MirrorPathP","text":"MirrorPath","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:s10MirrorPathP","text":"MirrorPath","kind":"typeIdentifier"},{"text":"...) -> ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"?","kind":"text"}],"extendedModule":"Swift","modules":[{"name":"Swift"}],"externalID":"s:s6MirrorV10descendantyypSgs0A4Path_p_sAE_pdtF"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Mirror"]]},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Mirror/descendant(_:_:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Returns a specific descendant of the reflected subject, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if no"},{"type":"text","text":" "},{"type":"text","text":"such descendant exists."}],"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/MirrorPath"],"title":"Querying Descendants","generated":true,"anchor":"Querying-Descendants"}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"descendant"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"text":"first","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s10MirrorPathP","text":"MirrorPath","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/MirrorPath"},{"text":", ","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text"