{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"kind":"symbol","abstract":[{"type":"text","text":"A collection that supports subscript assignment."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"MutableCollection"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Element","identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Element","preciseIdentifier":"s:SM7ElementQa"},{"kind":"text","text":"> : "},{"kind":"typeIdentifier","text":"Collection","identifier":"doc://com.apple.Swift/documentation/Swift/Collection","preciseIdentifier":"s:Sl"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"SubSequence","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","kind":"typeIdentifier","preciseIdentifier":"s:Sl11SubSequenceQa"},{"text":" : ","kind":"text"},{"text":"MutableCollection","identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection","kind":"typeIdentifier","preciseIdentifier":"s:SM"}],"languages":["swift"]}]},{"content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Collections that conform to "},{"code":"MutableCollection","type":"codeVoice"},{"type":"text","text":" gain the ability to"},{"type":"text","text":" "},{"type":"text","text":"change the value of their elements. This example shows how you can"},{"type":"text","text":" "},{"text":"modify one of the names in an array of students.","type":"text"}]},{"type":"codeListing","code":["var students = [\"Ben\", \"Ivy\", \"Jordell\", \"Maxime\"]","if let i = students.firstIndex(of: \"Maxime\") {","    students[i] = \"Max\"","}","print(students)","// Prints \"[\"Ben\", \"Ivy\", \"Jordell\", \"Max\"]\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition to changing the value of an individual element, you can also"},{"type":"text","text":" "},{"type":"text","text":"change the values of a slice of elements in a mutable collection. For"},{"type":"text","text":" "},{"type":"text","text":"example, you can sort "},{"inlineContent":[{"type":"text","text":"part"}],"type":"emphasis"},{"type":"text","text":" of a mutable collection by calling the"},{"type":"text","text":" "},{"text":"mutable ","type":"text"},{"code":"sort()","type":"codeVoice"},{"type":"text","text":" method on a subscripted subsequence. Here’s an"},{"type":"text","text":" "},{"text":"example that sorts the first half of an array of integers:","type":"text"}]},{"code":["var numbers = [15, 40, 10, 30, 60, 25, 5, 100]","numbers[0..<4].sort()","print(numbers)","// Prints \"[10, 15, 30, 40, 60, 25, 5, 100]\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The "},{"code":"MutableCollection","type":"codeVoice"},{"type":"text","text":" protocol allows changing the values of a"},{"type":"text","text":" "},{"type":"text","text":"collection’s elements but not the length of the collection itself. For"},{"type":"text","text":" "},{"type":"text","text":"operations that require adding or removing elements, see the"},{"type":"text","text":" "},{"code":"RangeReplaceableCollection","type":"codeVoice"},{"type":"text","text":" protocol instead."}],"type":"paragraph"},{"anchor":"Conforming-to-the-MutableCollection-Protocol","level":1,"text":"Conforming to the MutableCollection Protocol","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To add conformance to the "},{"type":"codeVoice","code":"MutableCollection"},{"type":"text","text":" protocol to your own"},{"type":"text","text":" "},{"type":"text","text":"custom collection, upgrade your type’s subscript to support both read"},{"type":"text","text":" "},{"type":"text","text":"and write access."}]},{"type":"paragraph","inlineContent":[{"text":"A value stored into a subscript of a ","type":"text"},{"code":"MutableCollection","type":"codeVoice"},{"text":" instance must","type":"text"},{"text":" ","type":"text"},{"text":"subsequently be accessible at that same position. That is, for a mutable","type":"text"},{"text":" ","type":"text"},{"text":"collection instance ","type":"text"},{"type":"codeVoice","code":"a"},{"text":", index ","type":"text"},{"type":"codeVoice","code":"i"},{"text":", and value ","type":"text"},{"code":"x","type":"codeVoice"},{"type":"text","text":", the two sets of"},{"text":" ","type":"text"},{"text":"assignments in the following code sample must be equivalent:","type":"text"}]},{"code":["a[i] = x","let y = a[i]","","// Must be equivalent to:","a[i] = x","let y = x"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/MutableCollection"},"relationshipsSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/Collection","doc://com.apple.Swift/documentation/Swift/Sequence"],"kind":"relationships","title":"Inherits From","type":"inheritsFrom"},{"identifiers":["doc://com.apple.Swift/documentation/Cxx/CxxMutableRandomAccessCollection"],"kind":"relationships","title":"Inherited By","type":"inheritedBy"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/Array","doc://com.apple.Swift/documentation/Swift/ArraySlice","doc://com.apple.Swift/documentation/Swift/CollectionOfOne","doc://com.apple.Swift/documentation/Swift/ContiguousArray","doc://com.apple.Swift/documentation/Swift/Dictionary/Values-swift.struct","doc://com.apple.Swift/documentation/Swift/EmptyCollection","doc://com.apple.Swift/documentation/Swift/Slice","doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer","doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawBufferPointer"],"kind":"relationships","title":"Conforming Types