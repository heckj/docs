{"topicSections":[{"anchor":"Observable-conformance","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable"],"title":"Observable conformance"},{"anchor":"Fine-tuning","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationIgnored()","doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationTracked()"],"title":"Fine-tuning"},{"anchor":"Change-tracking","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Observation\/withObservationTracking(_:onChange:)","doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationRegistrar"],"title":"Change tracking"}],"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Observation-collection","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"Observation provides a robust, type-safe, and performant implementation of the","type":"text"},{"text":" ","type":"text"},{"text":"observer design pattern in Swift. This pattern allows an observable object to","type":"text"},{"text":" ","type":"text"},{"text":"maintain a list of observers and notify them of specific or general state","type":"text"},{"text":" ","type":"text"},{"text":"changes. This has the advantages of not directly coupling objects together and","type":"text"},{"text":" ","type":"text"},{"text":"allowing implicit distribution of updates across potential multiple observers.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The Observation frameworks provides the following capabilities:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Marking a type as observable"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Tracking changes within an instance of an observable type"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Observing and utilizing those changes elsewhere, such as in an app’s user"},{"type":"text","text":" "},{"type":"text","text":"interface"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"To declare a type as observable, attach the ","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","type":"reference","isActive":true},{"text":" macro","type":"text"},{"text":" ","type":"text"},{"text":"to the type declaration. This macro declares and implements conformance to the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","type":"reference","isActive":true},{"text":" protocol to the type at compile time.","type":"text"}],"type":"paragraph"},{"code":["@Observable","class Car {","    var name: String = \"\"","    var needsRepairs: Bool = false","    ","    init(name: String, needsRepairs: Bool = false) {","        self.name = name","        self.needsRepairs = needsRepairs","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"To track changes, use the "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/withObservationTracking(_:onChange:)","isActive":true},{"text":" function.","type":"text"},{"text":" ","type":"text"},{"text":"For example, in the following code, the function calls the ","type":"text"},{"code":"onChange","type":"codeVoice"},{"text":" closure","type":"text"},{"text":" ","type":"text"},{"text":"when a car’s name changes. However, it doesn’t call the closure when a car’s","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"needsRepair"},{"type":"text","text":" flag changes. That’s because the function only tracks properties"},{"type":"text","text":" "},{"type":"text","text":"read in its "},{"code":"apply","type":"codeVoice"},{"text":" closure, and the closure doesn’t read the ","type":"text"},{"code":"needsRepair","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"property."}],"type":"paragraph"},{"code":["func render() {","    withObservationTracking {","        for car in cars {","            print(car.name)","        }","    } onChange: {","        print(\"Schedule renderer.\")","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"modules":[{"name":"Swift"}],"title":"Observation","roleHeading":"API Collection","role":"collectionGroup"},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/observation-collection"]}],"sections":[],"abstract":[{"type":"text","text":"Make responsive apps that update the presentation when underlying data changes."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.apple.Swift/documentation/Observation/Observable":{"title":"Observable","abstract":[{"text":"A type that emits notifications to observers when underlying data changes.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","url":"\/documentation\/observation\/observable","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Observable","kind":"identifier"}],"navigatorTitle":[{"text":"Observable","kind":"identifier"}],"type":"topic"},"doc://com.apple.Swift/documentation/Observation/ObservationTracked()":{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationTracked()","url":"\/documentation\/observation\/observationtracked()","type":"topic","kind":"symbol","role":"symbol","title":"ObservationTracked()","fragments":[{"text":"macro","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ObservationTracked","kind":"identifier"},{"text":"()","kind":"text"}],"abstract":[{"text":"Synthesizes a property for accessors.","type":"text"}]},"doc://com.apple.Swift/documentation/