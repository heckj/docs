{"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Observation-collection","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Make responsive apps that update the presentation when underlying data changes."}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Observation provides a robust, type-safe, and performant implementation of the"},{"type":"text","text":" "},{"type":"text","text":"observer design pattern in Swift. This pattern allows an observable object to"},{"type":"text","text":" "},{"type":"text","text":"maintain a list of observers and notify them of specific or general state"},{"type":"text","text":" "},{"type":"text","text":"changes. This has the advantages of not directly coupling objects together and"},{"type":"text","text":" "},{"type":"text","text":"allowing implicit distribution of updates across potential multiple observers."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The Observation frameworks provides the following capabilities:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Marking a type as observable"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Tracking changes within an instance of an observable type"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Observing and utilizing those changes elsewhere, such as in an app’s user"},{"type":"text","text":" "},{"type":"text","text":"interface"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"To declare a type as observable, attach the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()"},{"type":"text","text":" macro"},{"type":"text","text":" "},{"type":"text","text":"to the type declaration. This macro declares and implements conformance to the"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","type":"reference","isActive":true},{"type":"text","text":" protocol to the type at compile time."}],"type":"paragraph"},{"code":["@Observable","class Car {","    var name: String = \"\"","    var needsRepairs: Bool = false","    ","    init(name: String, needsRepairs: Bool = false) {","        self.name = name","        self.needsRepairs = needsRepairs","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To track changes, use the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/withObservationTracking(_:onChange:)"},{"type":"text","text":" function."},{"type":"text","text":" "},{"type":"text","text":"For example, in the following code, the function calls the "},{"type":"codeVoice","code":"onChange"},{"type":"text","text":" closure"},{"type":"text","text":" "},{"type":"text","text":"when a car’s name changes. However, it doesn’t call the closure when a car’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"needsRepair"},{"type":"text","text":" flag changes. That’s because the function only tracks properties"},{"type":"text","text":" "},{"type":"text","text":"read in its "},{"type":"codeVoice","code":"apply"},{"type":"text","text":" closure, and the closure doesn’t read the "},{"type":"codeVoice","code":"needsRepair"},{"type":"text","text":" "},{"type":"text","text":"property."}]},{"type":"codeListing","syntax":"swift","code":["func render() {","    withObservationTracking {","        for car in cars {","            print(car.name)","        }","    } onChange: {","        print(\"Schedule renderer.\")","    }","}"]}],"kind":"content"}],"metadata":{"role":"collectionGroup","roleHeading":"API Collection","modules":[{"name":"Swift"}],"title":"Observation"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/observation-collection"]}],"topicSections":[{"anchor":"Observable-conformance","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable"],"title":"Observable conformance"},{"anchor":"Fine-tuning","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationIgnored()","doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationTracked()"],"title":"Fine-tuning"},{"anchor":"Change-tracking","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Observation\/withObservationTracking(_:onChange:)","doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationRegistrar"],"title":"Change tracking"}],"kind":"article","references":{"doc://com.apple.Swift/documentation/Observation/ObservationIgnored()":{"type":"topic","title":"ObservationIgnored()","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationIgnored()","role":"symbol","abstract":[{"text":"Disables observation tracking of a property.","type":"text"}],"url":"\/documentation\/observation\/observationignored()","fragments":[{"text":"macro","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ObservationIgnored","kind":"identifier"},{"text":"()","kind":"text"}]},"doc://com.apple.Swift/documentation/Observation/ObservationRegistrar":{"kind":"symbol","navigatorTitle":[{"text":"ObservationRegistrar","kind":"identifier"}],"abstract":[{"text":"Provides storage for tracking and access to data changes.","type":"text"}],"identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationRegistrar","title":"ObservationRegistrar","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ObservationRegistrar"}],"url":"\/documentation\/observation\/observationregistrar","type":"topic"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","url":"\/documentation\/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Observation/Observable":{"navigatorTitle":[{"kind":"identifier","text":"Observable"}],"type":"topic","title":"Observable","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","role":"symbol","abstract":[{"type":"text","text":"A type that emits notifications to observers when underlying data changes."}],"url":"\/documentation\/observation\/observable","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observable"}]},"doc://com.apple.Swift/documentation/Observation/Observable()":{"type":"topic","title":"Observable()","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","role":"symbol","abstract":[{"type":"text","text":"Defines and implements conformance of the Observable protocol."}],"url":"\/documentation\/observation\/observable()","fragments":[{"kind":"keyword","text":"macro"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observable"},{"kind":"text","text":"()"}]},"doc://com.apple.Swift/documentation/Observation/ObservationTracked()":{"type":"topic","title":"ObservationTracked()","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/ObservationTracked()","role":"symbol","abstract":[{"type":"text","text":"Synthesizes a property for accessors."}],"url":"\/documentation\/observation\/observationtracked()","fragments":[{"kind":"keyword","text":"macro"},{"kind":"text","text":" "},{"kind":"identifier","text":"ObservationTracked"},{"kind":"text","text":"()"}]},"doc://com.apple.Swift/documentation/Observation/withObservationTracking(_:onChange:)":{"type":"topic","title