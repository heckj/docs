{"topicSections":[{"abstract":[{"type":"text","text":"When creating your own option set, implement this initializer with a fixed-width"},{"type":"text","text":" "},{"type":"text","text":"integer, like "},{"type":"codeVoice","code":"Int"},{"type":"text","text":", as the "},{"type":"codeVoice","code":"RawValue"},{"type":"text","text":" type."}],"identifiers":["doc://com.apple.Swift/documentation/Swift/OptionSet/init(rawValue:)"],"title":"Required Initializer","anchor":"Required-Initializer"},{"title":"Element","identifiers":["doc://com.apple.Swift/documentation/Swift/OptionSet/Element"],"anchor":"Element"}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/OptionSet"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"metadata":{"externalID":"s:s9OptionSetP","role":"symbol","roleHeading":"Protocol","modules":[{"name":"Swift"}],"title":"OptionSet","navigatorTitle":[{"kind":"identifier","text":"OptionSet"}],"symbolKind":"protocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"OptionSet","kind":"identifier"}]},"kind":"symbol","sections":[],"relationshipsSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/Equatable","doc://com.apple.Swift/documentation/Swift/ExpressibleByArrayLiteral","doc://com.apple.Swift/documentation/Swift/RawRepresentable","doc://com.apple.Swift/documentation/Swift/SetAlgebra"],"type":"inheritsFrom","title":"Inherits From","kind":"relationships"},{"type":"conformingTypes","kind":"relationships","title":"Conforming Types","identifiers":["doc://com.apple.Swift/documentation/Runtime/Backtrace/SymbolicationOptions","doc://com.apple.Swift/documentation/Runtime/SectionCharacteristics","doc://com.apple.Swift/documentation/_RegexParser/SyntaxOptions"]}],"seeAlsoSections":[{"generated":true,"title":"Sets","identifiers":["doc://com.apple.Swift/documentation/Swift/Set"],"anchor":"Sets"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OptionSet"},{"kind":"text","text":" : "},{"identifier":"doc://com.apple.Swift/documentation/Swift/RawRepresentable","preciseIdentifier":"s:SY","text":"RawRepresentable","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:s10SetAlgebraP","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/SetAlgebra","text":"SetAlgebra"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"You use the ","type":"text"},{"code":"OptionSet","type":"codeVoice"},{"type":"text","text":" protocol to represent bitset types, where"},{"type":"text","text":" "},{"type":"text","text":"individual bits represent members of a set. Adopting this protocol in"},{"type":"text","text":" "},{"type":"text","text":"your custom types lets you perform set-related operations such as"},{"type":"text","text":" "},{"type":"text","text":"membership tests, unions, and intersections on those types. What’s more,"},{"type":"text","text":" "},{"type":"text","text":"when implemented using specific criteria, adoption of this protocol"},{"type":"text","text":" "},{"type":"text","text":"requires no extra work on your part."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When creating an option set, include a "},{"type":"codeVoice","code":"rawValue"},{"type":"text","text":" property in your type"},{"text":" ","type":"text"},{"type":"text","text":"declaration. For your type to automatically receive default implementations"},{"text":" ","type":"text"},{"type":"text","text":"for set-related operations, the "},{"type":"codeVoice","code":"rawValue"},{"type":"text","text":" property must be of a type that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the "},{"type":"codeVoice","code":"FixedWidthInteger"},{"type":"text","text":" protocol, such as "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"UInt8"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Next, create unique options as static properties of your custom type using"},{"type":"text","text":" "},{"type":"text","text":"unique powers of two (1, 2, 4, 8, 16, and so forth) for each individual"},{"type":"text","text":" "},{"text":"property’s raw value so that each property can be represented by a single","type":"text"},{"text":" ","type":"text"},{"text":"bit of the type’s raw value.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, consider a custom type called "},{"type":"codeVoice","code":"ShippingOptions"},{"type":"text","text":" that is an"},{"type":"text","text":" "},{"type":"text","text":"option set of the possible ways to ship a customer’s purchase."},{"type":"text","text":" "},{"code":"ShippingOptions","type":"codeVoice"},{"type":"text","text":" includes a "},{"code":"rawValue","type":"codeVoice"},{"type":"text","text":" property of type "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" that stores"},{"type":"text","text":" "},{"type":"text","text":"the bit mask of available shipping options. The static members "},{"code":"nextDay","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"secondDay","type":"codeVoice"},{"type":"text","text":", "},{"code":"priority","type":"codeVoice"},{"type":"text","text":", and "},{"code":"standard","type":"codeVoice"},{"type":"text","text":" are unique, individual options."}]},{"syntax":"swift","type":"codeListing","code":["struct ShippingOptions: OptionSet {","    let rawValue: Int","","    static let nextDay    = ShippingOptions(rawValue: 1 << 0)","    static let secondDay  = ShippingOptions(rawValue: 1 << 1)","    static let priority   = ShippingOptions(rawValue: 1 << 2)","    static let standard   = ShippingOptions(rawValue: 1 << 3)","","    static let express: ShippingOptions = [.nextDay, .secondDay]","    static let all: ShippingOptions = [.express, .priority, .standard]","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Declare additional preconfigured option set values as static properties"},{"type":"text","text":" "},{"type":"text","text":"initialized with an array literal containing other option values. In the"},{"type":"text","text":" "},{"type":"text","text":"example, because the "},{"code":"express","type":"codeVoice"},{"type":"text","text":" static property is assigned an array"},{"type":"text","text":" "},{"type":"text","text":"literal with the "},{"code":"nextDay","type":"codeVoice"},{"type":"text","text":" and "},{"code":"secondDay","type":"codeVoice"},{"text":" options, it will contain those","type":"text"},{"type":"text","text":" "},{"text":"two elements.","type":"text"}]},{"text":"Using an Option Set Type","level":1,"anchor":"Using-an-Option-Set-Type","type":"heading"},{"inlineContent":[{"text":"When you need to create an instance of an option set, assign one of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type’s static members to your variable or constant. Alternatively, to"},{"type":"text","text":" "},{"type":"text","text":"create an option set instance with multiple members, assign an array"},{"text":" ","type":"text"},{"text":"literal with multiple static members of the option set. To create an empty","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instance, assign an empty array literal to your variable."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let singleOption: ShippingOptions = .priority","let multipleOptions: ShippingOptions = [.nextDay, .secondDay, .priority]","let noOptions: ShippingOptions = []"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use set-related operations to check for membership and to add or remove"},{"type":"text","text":" "},{"type":"text","text":"members from an instance of your custom option set type. The following"},{"type":"text","text":" "},{"type":"text","text":"example shows how you can determine free shipping options based on a"},{"type":"text","text":" "},{"type":"text","text":"customer’s purchase price:"}]},{"type":"codeListing","syntax":"swift","code":["let purchasePrice = 87.55","","var freeOptions: ShippingOptions = []","if purchasePrice > 50 {","    freeOptions.insert(.priority)","}","","if freeOptions.contains(.priority) {","    print(\"You've earned free priority shipping!\")","} else {","    print(\"Add more to your cart for free priority shipping!\")","}","// Prints \"You've earned free priority shipping!\""]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/optionset"]}],"abstract":[{"type":"text","text":"A type that presents a mathematical set interface to a bit set."}],"references":{"doc://com.apple.Swift/documentation/Swift/SetAlgebra":{"navigatorTitle":[{"kind":"identifier","text":"SetAlgebra"}],"url":"/documentation/swift/setalgebra","abstract":[{"type":"text","text":"A type that provides mathematical set operations."}],"identifier":"doc://com.apple.Swift/documentation/Swift/SetAlgebra","type":"topic","kind":"symbol","title":"SetAlgebra","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SetAlgebra"}]},"doc://com.apple.Swift/documentation/Runtime/Backtrace/SymbolicationOptions":{"navigatorTitle":[{"kind":"identifier","text":"SymbolicationOptions"}],"url":"/documentation/runtime/backtrace/symbolicationoptions","abstract":[{"text":"Specifies options for the ","type":"text"},{"code":"symbolicated","type":"codeVoice"},{"text":" method.","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/Runtime/Backtrace/SymbolicationOptions","type":"topic","kind":"symbol","title":"Backtrace.SymbolicationOptions","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SymbolicationOptions"}]},"doc://com.apple.Swift/documentation/Swift/OptionSet/init(rawValue:)":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/OptionSet/init(rawValue:)","type":"topic","title":"init(rawValue:)","kind":"symbol","url":"/documentation/swift/optionset/init(rawvalue:)","required":true,"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"rawValue"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SY8RawValueQa","kind":"typeIdentifier","text":"RawValue"},{"kind":"text","text":")"}],"abstract":[{"type":"text","text":"Creates a new option set from the given raw value."}]},"doc://com.apple.Swift/documentation/Swift/Set":{"url":"/documentation/swift/set","navigatorTitle":[{"kind":"identifier","text":"Set"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Set"}],"title":"Set","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Set","abstract":[{"type":"text","text":"An unordered collection of unique elements."}],"role":"symbol","type":"topic"},"doc://com.apple.Swift/documentation/Swift/OptionSet/Element":{"url":"/documentation/swift/optionset/element","title":"Element","abstract":[{"type":"text","text":"The element type of the option set."}],"type":"topic","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Element"},{"kind":"text","text":" = "},{"kind":"typeIdentifier","text":"Self"}],"identifier":"doc://com.apple.Swift/documentation/Swift/OptionSet/Element","required":true,"kind":"symbol","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/Equatable":{"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Equatable","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"Equatable","kind":"i