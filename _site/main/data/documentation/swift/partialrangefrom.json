{"variants":[{"paths":["/documentation/swift/partialrangefrom"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"relationshipsSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/BitwiseCopyable","doc://com.apple.Swift/documentation/Swift/ConvertibleFromBytes","doc://com.apple.Swift/documentation/Swift/ConvertibleToBytes","doc://com.apple.Swift/documentation/Swift/Copyable","doc://com.apple.Swift/documentation/Swift/Decodable","doc://com.apple.Swift/documentation/Swift/Encodable","doc://com.apple.Swift/documentation/Swift/Escapable","doc://com.apple.Swift/documentation/Swift/RangeExpression","doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype","doc://com.apple.Swift/documentation/Swift/Sequence"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"A partial interval extending upward from a lower bound."}],"metadata":{"roleHeading":"Structure","title":"PartialRangeFrom","role":"symbol","modules":[{"name":"Swift"}],"externalID":"s:s16PartialRangeFromV","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"PartialRangeFrom"}],"navigatorTitle":[{"kind":"identifier","text":"PartialRangeFrom"}]},"seeAlsoSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeUpTo","doc://com.apple.Swift/documentation/Swift/PartialRangeThrough","doc://com.apple.Swift/documentation/Swift/RangeExpression","doc://com.apple.Swift/documentation/Swift/UnboundedRange_"],"title":"Range Expressions","anchor":"Range-Expressions"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PartialRangeFrom","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Bound","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Bound","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Comparable","identifier":"doc://com.apple.Swift/documentation/Swift/Comparable","kind":"typeIdentifier","preciseIdentifier":"s:SL"}]}]},{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"text":"You create ","type":"text"},{"code":"PartialRangeFrom","type":"codeVoice"},{"text":" instances by using the postfix range operator","type":"text"},{"text":" ","type":"text"},{"text":"(postfix ","type":"text"},{"code":"...","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let atLeastFive = 5..."]},{"inlineContent":[{"text":"You can use a partial range to quickly check if a value is contained in a","type":"text"},{"text":" ","type":"text"},{"text":"particular range of values. For example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["atLeastFive.contains(4)","// false","atLeastFive.contains(5)","// true","atLeastFive.contains(6)","// true"]},{"inlineContent":[{"text":"You can use a partial range of a collection’s indices to represent the","type":"text"},{"text":" ","type":"text"},{"text":"range from the partial range’s lower bound up to the end of the","type":"text"},{"text":" ","type":"text"},{"text":"collection.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let numbers = [10, 20, 30, 40, 50, 60, 70]","print(numbers[3...])","// Prints \"[40, 50, 60, 70]\""]},{"anchor":"Using-a-Partial-Range-as-a-Sequence","type":"heading","text":"Using a Partial Range as a Sequence","level":2},{"inlineContent":[{"text":"When a partial range uses integers as its lower and upper bounds, or any","type":"text"},{"text":" ","type":"text"},{"text":"other type that conforms to the ","type":"text"},{"code":"Strideable","type":"codeVoice"},{"text":" protocol with an integer","type":"text"},{"text":" ","type":"text"},{"text":"stride, you can use that range in a ","type":"text"},{"code":"for","type":"codeVoice"},{"text":"-","type":"text"},{"code":"in","type":"codeVoice"},{"text":" loop or with any sequence","type":"text"},{"text":" ","type":"text"},{"text":"method that doesn’t require that the sequence is finite. The elements of","type":"text"},{"text":" ","type":"text"},{"text":"a partial range are the consecutive values from its lower bound continuing","type":"text"},{"text":" ","type":"text"},{"text":"upward indefinitely.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func isTheMagicNumber(_ x: Int) -> Bool {","    return x == 3","}","","for x in 1... {","    if isTheMagicNumber(x) {","        print(\"\\(x) is the magic number!\")","        break","    } else {","        print(\"\\(x) wasn't it...\")","    }","}","// \"1 wasn't it...\"","// \"2 wasn't it...\"","// \"3 is the magic number!\""]},{"inlineContent":[{"text":"Because a ","type":"text"},{"type":"codeVoice","code":"PartialRangeFrom"},{"text":" sequence counts upward indefinitely, do not","type":"text"},{"text":" ","type":"text"},{"text":"use one with methods that read the entire sequence before returning, such","type":"text"},{"text":" ","type":"text"},{"text":"as ","type":"text"},{"type":"codeVoice","code":"map(_:)"},{"text":", ","type":"text"},{"type":"codeVoice","code":"filter(_:)"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"suffix(_:)"},{"text":". It is safe to use operations","type":"text"},{"text":" ","type":"text"},{"text":"that put an upper limit on the number of elements they access, such as","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"prefix(_:)"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"dropFirst(_:)"},{"text":", and operations that you can guarantee","type":"text"},{"text":" ","type":"text"},{"text":"will terminate, such as passing a closure you know will eventually return","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"first(where:)"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In the following example, the ","type":"text"},{"type":"codeVoice","code":"asciiTable"},{"text":" sequence is made by zipping","type":"text"},{"text":" ","type":"text"},{"text":"together the characters in the ","type":"text"},{"type":"codeVoice","code":"alphabet"},{"text":" string with a partial range","type":"text"},{"text":" ","type":"text"},{"text":"starting at 65, the ASCII value of the capital letter A. Iterating over","type":"text"},{"text":" ","type":"text"},{"text":"two zipped sequences continues only as long as the shorter of the two","type":"text"},{"text":" ","type":"text"},{"text":"sequences, so the iteration stops at the end of ","type":"text"},{"type":"codeVoice","code":"alphabet"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let alphabet = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\"","let asciiTable = zip(65..., alphabet)","for (code, letter) in asciiTable {","    print(code, letter)","}","// \"65 A\"","// \"66 B\"","// \"67 C\"","// ...","// \"89 Y\"","// \"90 Z\""]},{"inlineContent":[{"text":"The behavior of incrementing indefinitely is determined by the type of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Bound"},{"text":". For example, iterating over an instance of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"PartialRangeFrom<Int>"},{"text":" traps when the sequence’s next value would be","type":"text"},{"text":" ","type":"text"},{"text":"above ","type":"text"},{"type":"codeVoice","code":"Int.max"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"topicSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/init(_:)"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/lowerBound"],"title":"Instance Properties","anchor":"Instance-Properties"},{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/Decodable-Implementations","doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/Encodable-Implementations","doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/RangeExpression-Implementations","doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/Sequence-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"references":{"doc://com.apple.Swift/documentation/Swift/ConvertibleToBytes":{"navigatorTitle":[{"kind":"identifier","text":"ConvertibleToBytes"}],"conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"availabilityPrefix":[{"type":"text","text":"Available when"}],"constraints":[{"type":"codeVoice","code":"Bound"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ConvertibleToBytes"},{"type":"text","text":"."}]},"abstract":[{"type":"text","text":"A protocol for types whose memory can safely be read as individual raw bytes."}],"role":"symbol","url":"/documentation/swift/convertibletobytes","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConvertibleToBytes"}],"identifier":"doc://com.apple.Swift/documentation/Swift/ConvertibleToBytes","type":"topic","title":"ConvertibleToBytes"},"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/lowerBound":{"url":"/documentation/swift/partialrangefr