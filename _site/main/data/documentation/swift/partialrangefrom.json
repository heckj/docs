{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/init(_:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/lowerBound"]},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/Decodable-Implementations","doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/Encodable-Implementations","doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/RangeExpression-Implementations","doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/Sequence-Implementations"]}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc://com.apple.Swift/documentation/Swift/Copyable","doc://com.apple.Swift/documentation/Swift/Decodable","doc://com.apple.Swift/documentation/Swift/Encodable","doc://com.apple.Swift/documentation/Swift/Escapable","doc://com.apple.Swift/documentation/Swift/RangeExpression","doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype","doc://com.apple.Swift/documentation/Swift/Sequence"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/partialrangefrom"]}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"seeAlsoSections":[{"generated":true,"anchor":"Range-Expressions","title":"Range Expressions","identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeUpTo","doc://com.apple.Swift/documentation/Swift/PartialRangeThrough","doc://com.apple.Swift/documentation/Swift/RangeExpression","doc://com.apple.Swift/documentation/Swift/UnboundedRange_"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"PartialRangeFrom"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Bound"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"Bound","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Comparable","identifier":"doc://com.apple.Swift/documentation/Swift/Comparable","kind":"typeIdentifier","preciseIdentifier":"s:SL"}],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"You create "},{"type":"codeVoice","code":"PartialRangeFrom"},{"type":"text","text":" instances by using the postfix range operator"},{"type":"text","text":" "},{"type":"text","text":"(postfix "},{"type":"codeVoice","code":"..."},{"type":"text","text":")."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let atLeastFive = 5..."]},{"inlineContent":[{"text":"You can use a partial range to quickly check if a value is contained in a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"particular range of values. For example:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["atLeastFive.contains(4)","// false","atLeastFive.contains(5)","// true","atLeastFive.contains(6)","// true"]},{"inlineContent":[{"type":"text","text":"You can use a partial range of a collection’s indices to represent the"},{"type":"text","text":" "},{"type":"text","text":"range from the partial range’s lower bound up to the end of the"},{"type":"text","text":" "},{"type":"text","text":"collection."}],"type":"paragraph"},{"type":"codeListing","code":["let numbers = [10, 20, 30, 40, 50, 60, 70]","print(numbers[3...])","// Prints \"[40, 50, 60, 70]\""],"syntax":"swift"},{"level":2,"type":"heading","text":"Using a Partial Range as a Sequence","anchor":"Using-a-Partial-Range-as-a-Sequence"},{"type":"paragraph","inlineContent":[{"text":"When a partial range uses integers as its lower and upper bounds, or any","type":"text"},{"text":" ","type":"text"},{"text":"other type that conforms to the ","type":"text"},{"code":"Strideable","type":"codeVoice"},{"text":" protocol with an integer","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stride, you can use that range in a "},{"code":"for","type":"codeVoice"},{"text":"-","type":"text"},{"code":"in","type":"codeVoice"},{"type":"text","text":" loop or with any sequence"},{"type":"text","text":" "},{"type":"text","text":"method that doesn’t require that the sequence is finite. The elements of"},{"type":"text","text":" "},{"type":"text","text":"a partial range are the consecutive values from its lower bound continuing"},{"type":"text","text":" "},{"type":"text","text":"upward indefinitely."}]},{"code":["func isTheMagicNumber(_ x: Int) -> Bool {","    return x == 3","}","","for x in 1... {","    if isTheMagicNumber(x) {","        print(\"\\(x) is the magic number!\")","        break","    } else {","        print(\"\\(x) wasn't it...\")","    }","}","// \"1 wasn't it...\"","// \"2 wasn't it...\"","// \"3 is the magic number!\""],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Because a "},{"type":"codeVoice","code":"PartialRangeFrom"},{"type":"text","text":" sequence counts upward indefinitely, do not"},{"type":"text","text":" "},{"type":"text","text":"use one with methods that read the entire sequence before returning, such"},{"type":"text","text":" "},{"type":"text","text":"as "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":", "},{"type":"codeVoice","code":"filter(_:)"},{"type":"text","text":", or "},{"type":"codeVoice","code":"suffix(_:)"},{"type":"text","text":". It is safe to use operations"},{"type":"text","text":" "},{"text":"that put an upper limit on the number of elements they access, such as","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"prefix(_:)"},{"type":"text","text":" or "},{"type":"codeVoice","code":"dropFirst(_:)"},{"type":"text","text":", and operations that you can guarantee"},{"type":"text","text":" "},{"type":"text","text":"will terminate, such as passing a closure you know will eventually return"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":" to "},{"type":"codeVoice","code":"first(where:)"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the following example, the "},{"code":"asciiTable","type":"codeVoice"},{"type":"text","text":" sequence is made by zipping"},{"type":"text","text":" "},{"type":"text","text":"together the characters in the "},{"code":"alphabet","type":"codeVoice"},{"type":"text","text":" string with a partial range"},{"type":"text","text":" "},{"type":"text","text":"starting at 65, the ASCII value of the capital letter A. Iterating over"},{"type":"text","text":" "},{"type":"text","text":"two zipped sequences continues only as long as the shorter of the two"},{"type":"text","text":" "},{"type":"text","text":"sequences, so the iteration stops at the end of "},{"type":"codeVoice","code":"alphabet"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["let alphabet = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\"","let asciiTable = zip(65..., alphabet)","for (code, letter) in asciiTable {","    print(code, letter)","}","// \"65 A\"","// \"66 B\"","// \"67 C\"","// ...","// \"89 Y\"","// \"90 Z\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The behavior of incrementing indefinitely is determined by the type of"},{"type":"text","text":" "},{"type":"codeVoice","code":"Bound"},{"type":"text","text":". For example, iterating over an instance of"},{"type":"text","text":" "},{"type":"codeVoice","code":"PartialRangeFrom<Int>"},{"type":"text","text":" traps when the sequence’s next value would be"},{"type":"text","text":" "},{"type":"text","text":"above "},{"type":"codeVoice","code":"Int.max"},{"type":"text","text":"."}]}],"kind":"content"}],"kind":"symbol","metadata":{"modules":[{"name":"Swift"}],"role":"symbol","title":"PartialRangeFrom","externalID":"s:s16PartialRangeFromV","roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"PartialRangeFrom"}],"navigatorTitle":[{"kind":"identifier","text":"PartialRangeFrom"}],"symbolKind":"struct"},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"A partial interval extending upward from a lower bound."}],"references":{"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/Decodable-Implementations":{"abstract":[],"type":"topic","title":"Decodable Implementations","kind":"article","identifier":"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/Decodable-Implementations","role":"collectionGroup","url":"/documentation/swift/partialrangefrom/decodable-implementations"},"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/init(_:)":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/init(_:)","url":"/documentation/swift/partialrangefrom/init(_:)","kind":"symbol","role":"symbol","title":"init(_:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:s16PartialRangeFromV5Boundxmfp","text":"Bound"},{"kind":"text","text":")"}],"abstract":[]},"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/lowerBound":{"role":"symbol","url":"/documentation/swift/partialrangefrom/lowerbound","identifier":"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom/lowerBound","title":"lowerBound","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"lowerBound"},{"kin