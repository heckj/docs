{"relationshipsSections":[{"identifiers":["doc://com.apple.Swift/documentation/StdlibUnittest/LinearCongruentialGenerator","doc://com.apple.Swift/documentation/Swift/SystemRandomNumberGenerator"],"kind":"relationships","title":"Conforming Types","type":"conformingTypes"}],"abstract":[{"text":"A type that provides uniformly distributed random data.","type":"text"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/randomnumbergenerator"]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/RandomNumberGenerator","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RandomNumberGenerator","kind":"identifier"}],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"When you call methods that use random data, such as creating new random","type":"text"},{"text":" ","type":"text"},{"text":"values or shuffling a collection, you can pass a ","type":"text"},{"code":"RandomNumberGenerator","type":"codeVoice"},{"text":" ","type":"text"},{"text":"type to be used as the source for randomness. When you don’t pass a","type":"text"},{"text":" ","type":"text"},{"text":"generator, the default ","type":"text"},{"code":"SystemRandomNumberGenerator","type":"codeVoice"},{"text":" type is used.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When providing new APIs that use randomness, provide a version that accepts"},{"type":"text","text":" "},{"type":"text","text":"a generator conforming to the "},{"code":"RandomNumberGenerator","type":"codeVoice"},{"text":" protocol as well as a","type":"text"},{"text":" ","type":"text"},{"text":"version that uses the default system generator. For example, this ","type":"text"},{"type":"codeVoice","code":"Weekday"},{"text":" ","type":"text"},{"text":"enumeration provides static methods that return a random day of the week:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["enum Weekday: CaseIterable {","    case sunday, monday, tuesday, wednesday, thursday, friday, saturday","","    static func random<G: RandomNumberGenerator>(using generator: inout G) -> Weekday {","        return Weekday.allCases.randomElement(using: &generator)!","    }","","    static func random() -> Weekday {","        var g = SystemRandomNumberGenerator()","        return Weekday.random(using: &g)","    }","}"],"type":"codeListing"},{"level":1,"text":"Conforming to the RandomNumberGenerator Protocol","type":"heading","anchor":"Conforming-to-the-RandomNumberGenerator-Protocol"},{"inlineContent":[{"text":"A custom ","type":"text"},{"type":"codeVoice","code":"RandomNumberGenerator"},{"text":" type can have different characteristics","type":"text"},{"text":" ","type":"text"},{"text":"than the default ","type":"text"},{"type":"codeVoice","code":"SystemRandomNumberGenerator"},{"text":" type. For example, a","type":"text"},{"text":" ","type":"text"},{"text":"seedable generator can be used to generate a repeatable sequence of random","type":"text"},{"text":" ","type":"text"},{"text":"values for testing purposes.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To make a custom type conform to the ","type":"text"},{"code":"RandomNumberGenerator","type":"codeVoice"},{"text":" protocol,","type":"text"},{"text":" ","type":"text"},{"text":"implement the required ","type":"text"},{"code":"next()","type":"codeVoice"},{"text":" method. Each call to ","type":"text"},{"code":"next()","type":"codeVoice"},{"text":" must produce","type":"text"},{"text":" ","type":"text"},{"text":"a uniform and independent random value.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Types that conform to ","type":"text"},{"type":"