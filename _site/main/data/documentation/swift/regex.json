{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Regex"},{"text":"<","kind":"text"},{"text":"Output","kind":"genericParameter"},{"text":">","kind":"text"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Regular expressions are a concise way of describing a pattern, which can"},{"type":"text","text":" "},{"type":"text","text":"help you match or extract portions of a string. You can create a "},{"code":"Regex","type":"codeVoice"},{"text":" ","type":"text"},{"text":"instance using regular expression syntax, either in a regex literal or a","type":"text"},{"text":" ","type":"text"},{"text":"string.","type":"text"}]},{"syntax":"swift","code":["// 'keyAndValue' is created using a regex literal","let keyAndValue = /(.+?): (.+)/","// 'simpleDigits' is created from a pattern in a string","let simpleDigits = try Regex(\"[0-9]+\")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can use a "},{"type":"codeVoice","code":"Regex"},{"type":"text","text":" to search for a pattern in a string or substring."},{"type":"text","text":" "},{"text":"Call ","type":"text"},{"code":"contains(_:)","type":"codeVoice"},{"type":"text","text":" to check for the presence of a pattern, or"},{"type":"text","text":" "},{"type":"codeVoice","code":"firstMatch(of:)"},{"type":"text","text":" or "},{"type":"codeVoice","code":"matches(of:)"},{"type":"text","text":" to find matches."}],"type":"paragraph"},{"code":["let setting = \"color: 161 103 230\"","if setting.contains(simpleDigits) {","    print(\"'\\(setting)' contains some digits.\")","}","// Prints \"'color: 161 103 230' contains some digits.\""],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"When you find a match, the resulting "},{"type":"reference","identifier":"do