ind":"text","text":"<"},{"preciseIdentifier":"s:17_StringProcessing5RegexV0C6Outputa","kind":"typeIdentifier","text":"RegexOutput"},{"kind":"text","text":">"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The semantics to use during matching."}],"type":"paragraph"}],"name":"semanticLevel"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modified regular expression."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When matching with grapheme cluster semantics (the default),"},{"type":"text","text":" "},{"type":"text","text":"metacharacters like "},{"type":"codeVoice","code":"."},{"type":"text","text":" and "},{"type":"codeVoice","code":"\\w"},{"type":"text","text":", custom character classes, and character"},{"type":"text","text":" "},{"type":"text","text":"class instances like "},{"type":"codeVoice","code":".any"},{"type":"text","text":" match a grapheme cluster when possible,"},{"type":"text","text":" "},{"type":"text","text":"corresponding with the default string representation. In addition,"},{"type":"text","text":" "},{"type":"text","text":"matching with grapheme cluster semantics compares characters using their"},{"type":"text","text":" "},{"type":"text","text":"canonical representation, corresponding with how strings comparison works."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When matching with Unicode scalar semantics, metacharacters and character"},{"type":"text","text":" "},{"type":"text","text":"classes always match a single Unicode scalar value, even if that scalar"},{"type":"text","text":" "},{"type":"text","text":"comprises part of a grapheme cluster."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"These semantic levels can lead to different results, especially when"},{"type":"text","text":" "},{"type":"text","text":"working with strings that have decomposed characters. In the following"},{"type":"text","text":" "},{"type":"text","text":"example, "},{"type":"codeVoice","code":"queRegex"},{"type":"text","text":" matches any 3-character string that begins with "},{"type":"codeVoice","code":"\"q\""},{"type":"text","text":"."}]},{"type":"codeListing","code":["let composed = \"qué\"","let decomposed = \"que\\u{301}\"","","let queRegex = /^q..$/","","print(composed.contains(queRegex))","// Prints \"true\"","print(decomposed.contains(queRegex))","// Prints \"true\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using Unicode scalar semantics, however, the regular expression only"},{"type":"text","text":" "},{"type":"text","text":"matches the composed version of the string, because each "},{"type":"codeVoice","code":"."},{"type":"text","text":" matches a"},{"type":"text","text":" "},{"type":"text","text":"single Unicode scalar value."}]},{"type":"codeListing","code":["let queRegexScalar = queRegex.matchingSemantics(.unicodeScalar)","print(composed.contains(queRegexScalar))","// Prints \"true\"","print(decomposed.contains(queRegexScalar))","// Prints \"false\""],"syntax":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Regex"]]},"references":{"doc://com.apple.Swift/documentation/Swift/Regex/matchingSemantics(_:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"matchingSemantics"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"RegexSemanticLevel","preciseIdentifier":"s:17_StringProcessing18RegexSemanticLevelV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Regex","preciseIdentifier":"s:17_StringProcessing5RegexV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"RegexOutput","preciseIdentifier":"s:17_StringProcessing5RegexV0C6Outputa"},{"kind":"text","text":">"}],"role":"symbol","abstract":[{"type":"text","text":"Returns a regular expression that matches with the specified semantic"},{"type":"text","text":" "},{"type":"text","text":"level."}],"url":"/documentation/swift/regex/matchingsemantics(_:)","identifier":"doc://com.apple.Swift/documentation/Swift/Regex/matchingSemantics(_:)","kind":"symbol","type":"topic","title":"matchingSemantics(_:)"},"doc://com.apple.Swift/documentation/Swift/Regex":{"navigatorTitle":[{"kind":"identifier","text":"Regex"}],"url":"/documentation/swift/regex","title":"Regex","abstract":[{"text":"A regular expression.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Regex"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Regex","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/RegexSemanticLevel":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RegexSemanticLevel"}],"navigatorTitle":[{"kind":"identifier","text":"RegexSemanticLevel"}],"url":"/documentation/swift/regexsemanticlevel","identifier":"doc://com.apple.Swift/documentation/Swift/RegexSemanticLevel","role":"symbol","abstract":[{"type":"text","text":"A semantic level to use during regex matching."}],"type":"topic","title":"RegexSemanticLevel","kind":"symbol"}}}