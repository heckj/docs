{"kind":"article","metadata":{"roleHeading":"API Collection","role":"collectionGroup","title":"RegexBuilder","modules":[{"name":"Swift"}]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Regular expressions, also known as regexes,","type":"text"},{"text":" ","type":"text"},{"text":"are a powerful tool for matching patterns in text.","type":"text"},{"text":" ","type":"text"},{"text":"Swift supports several ways to create a regular expression,","type":"text"},{"text":" ","type":"text"},{"text":"including from a string, as a literal, and using this DSL.","type":"text"},{"text":" ","type":"text"},{"text":"For example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let word = OneOrMore(.word)","let emailPattern = Regex {","    Capture {","        ZeroOrMore {","            word","            \".\"","        }","        word","    }","    \"@\"","    Capture {","        word","        OneOrMore {","            \".\"","            word","        }","    }","}","","let text = \"My email is my.name@example.com.\"","if let match = text.firstMatch(of: emailPattern) {","    let (wholeMatch, name, domain) = match.output","    \/\/ wholeMatch is \"my.name@example.com\"","    \/\/ name is \"my.name\"","    \/\/ domain is \"example.com\"","}"]}]}],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"variants":[{"paths":["\/documentation\/swift\/regexbuilder-collection"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"type":"text","text":"Use an expressive domain-specific language to build regular expressions,"},{"type":"text","text":" "},{"type":"text","text":"for operations like searching and replacing in text."}],"topicSections":[{"title":"Components","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/RegexComponent","doc:\/\/com.apple.Swift\/documentation\/RegexBuilder\/CharacterClass",