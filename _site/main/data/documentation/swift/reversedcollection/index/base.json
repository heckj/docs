{"sections":[],"abstract":[{"text":"The position after this position in the underlying collection.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index/base"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"base","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Base","kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV4Basexmfp"},{"text":".","kind":"text"},{"text":"Index","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","preciseIdentifier":"s:Sl5IndexQa","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To find the position that corresponds with this index in the original,"},{"type":"text","text":" "},{"type":"text","text":"underlying collection, use that collection’s "},{"code":"index(before:)","type":"codeVoice"},{"type":"text","text":" method"},{"text":" ","type":"text"},{"type":"text","text":"with the "},{"code":"base","type":"codeVoice"},{"type":"text","text":" property."}]},{"type":"paragraph","inlineContent":[{"text":"The following example declares a function that returns the index of the","type":"text"},{"type":"text","text":" "},{"text":"last even number in the passed array, if one is found. First, the","type":"text"},{"text":" ","type":"text"},{"text":"function finds the position of the last even number as a ","type":"text"},{"type":"codeVoice","code":"ReversedIndex"},{"text":" ","type":"text"},{"text":"in a reversed view of the array of numbers. Next, the function calls the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"array’s "},{"type":"codeVoice","code":"index(before:)"},{"text":" method to return the correct position in the","type":"text"},{"text":" ","type":"text"},{"text":"passed array.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func indexOfLastEven(_ numbers: [Int]) -> Int? {","    let reversedNumbers = numbers.reversed()","    guard let i = reversedNumbers.firstIndex(where: { $0 % 2 == 0 })","        else { return nil }","","    return numbers.index(before: i.base)","}","","let numbers = [10, 20, 13, 19, 30, 52, 17, 40, 51]","if let lastEven = indexOfLastEven(numbers) {","    print(\"Last even number: \\(numbers[lastEven])\")","}","// Prints \"Last even number: 40\""]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","variants":[{"paths":["/documentation/swift/reversedcollection/index/base"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ReversedCollection","doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index"]]},"metadata":{"fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"base","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Base","preciseIdentifier":"s:s18ReversedCollectionV4Basexmfp"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Index","preciseIdentifier":"s:Sl5IndexQa"}],"symbolKind":"property","externalID":"s:s18ReversedCollectionV5IndexV4baseACQzvp","modules":[{"name":"Swift"}],"role":"symbol","roleHeading":"Instance Property","title":"base"},"references":{"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Index"}],"role":"symbol","url":"/documentation/swift/reversedcollection/index","abstract":[{"text":"An index that traverses the same positions as an underlying index,","type":"text"},{"text":" ","type":"text"},{"text":"with inverted traversal direction.","type":"text"}],"conformance":{"conformancePrefix":[{"text":"Conforms when","type":"text"}],"constraints":[{"code":"Base","type":"codeVoice"},{"text":" conforms to ","type":"text"},{"code":"BidirectionalCollection","type":"codeVoice"},{"text":".","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}]},"identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Index"}],"title":"ReversedCollection.Index"},"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index/base":{"url":"/documentation/swift/reversedcollection/index/base","abstract":[{"text":"The position after this position in the underlying collection.","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index/base","type":"topic","kind":"symbol","title":"base","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"base"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV4Basexmfp","text":"Base"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa","text":"Index"}]},"doc://com.apple.Swift/documentation/Swift/Collection/Index":{"url":"/documentation/swift/collection/index","required":true,"fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Index"},{"kind":"text","text":" : "},{"text":"Comparable","kind":"typeIdentifier","preciseIdentifier":"s:SL"}],"title":"Index","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","abstract":[{"type":"text","text":"A type that represents a position in the collection."}],"role":"symbol","type":"topic"},"doc://com.apple.Swift/documentation/Swift/ReversedCollection":{"type":"topic","abstract":[{"type":"text","text":"A collection that presents the elements of its base collection"},{"type":"text","text":" "},{"type":"text","text":"in reverse order."}],"title":"ReversedCollection","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection","url":"/documentation/swift/reversedcollection","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ReversedCollection","kind":"identifier"}],"navigatorTitle":[{"text":"ReversedCollection","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"}}}