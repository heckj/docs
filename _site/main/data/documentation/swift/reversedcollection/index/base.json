{"abstract":[{"type":"text","text":"The position after this position in the underlying collection."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"base"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s18ReversedCollectionV4Basexmfp","kind":"typeIdentifier","text":"Base"},{"kind":"text","text":"."},{"preciseIdentifier":"s:Sl5IndexQa","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","text":"Index"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"To find the position that corresponds with this index in the original,"},{"type":"text","text":" "},{"type":"text","text":"underlying collection, use that collection’s "},{"code":"index(before:)","type":"codeVoice"},{"text":" method","type":"text"},{"text":" ","type":"text"},{"text":"with the ","type":"text"},{"code":"base","type":"codeVoice"},{"text":" property.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following example declares a function that returns the index of the","type":"text"},{"text":" ","type":"text"},{"text":"last even number in the passed array, if one is found. First, the","type":"text"},{"text":" ","type":"text"},{"text":"function finds the position of the last even number as a ","type":"text"},{"code":"ReversedIndex","type":"codeVoice"},{"text":" ","type":"text"},{"text":"in a reversed view of the array of numbers. Next, the function calls the","type":"text"},{"text":" ","type":"text"},{"text":"array’s ","type":"text"},{"code":"index(before:)","type":"codeVoice"},{"text":" method to return the correct position in the","type":"text"},{"text":" ","type":"text"},{"text":"passed array.","type":"text"}],"type":"paragraph"},{"code":["func indexOfLastEven(_ numbers: [Int]) -> Int? {","    let reversedNumbers = numbers.reversed()","    guard let i = reversedNumbers.firstIndex(where: { $0 % 2 == 0 })","        else { return nil }","","    return numbers.index(before: i.base)","}","","let numbers = [10, 20, 13, 19, 30, 52, 17, 40, 51]","if let lastEven = indexOfLastEven(numbers) {","    print(\"Last even number: \\(numbers[lastEven])\")","}","// Prints \"Last even number: 40\""],"syntax":"swift","type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/reversedcollection/index/base"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"base","modules":[{"name":"Swift"}],"roleHeading":"Instance Property","symbolKind":"property","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"base","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s18ReversedCollectionV4Basexmfp","text":"Base","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:Sl5IndexQa","text":"Index","kind":"typeIdentifier"}],"externalID":"s:s18ReversedCollectionV5IndexV4baseACQzvp"},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index/base","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ReversedCollection","doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index"]]},"kind":"symbol","references":{"doc://com.apple.Swift/documentation/Swift/Collection/Index":{"required":true,"url":"/documentation/swift/collection/index","role":"symbol","title":"Index","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Index","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SL","text":"Comparable","kind":"typeIdentifier"}],"kind":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","abstract":[{"type":"text","text":"A type that represents a position in the collection."}]},"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index/base":{"url":"/documentation/swift/reversedcollection/index/base","type":"topic","title":"base","abstract":[{"type":"text","text":"The position after this position in the underlying collection."}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"base"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV4Basexmfp","text":"Base"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa","text":"Index"}],"identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index/base"},"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index":{"url":"/documentation/swift/reversedcollection/index","role":"symbol","title":"ReversedCollection.Index","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Index","kind":"identifier"}],"kind":"symbol","type":"topic","conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"availabilityPrefix":[{"type":"text","text":"Available when"}],"constraints":[{"type":"codeVoice","code":"Base"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"BidirectionalCollection"},{"type":"text","text":"."}]},"navigatorTitle":[{"text":"Index","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection/Index","abstract":[{"text":"An index that traverses the same positions as an underlying index,","type":"text"},{"text":" ","type":"text"},{"text":"with inverted traversal direction.","type":"text"}]},"doc://com.apple.Swift/documentation/Swift/ReversedCollection":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ReversedCollection"}],"title":"ReversedCollection","type":"topic","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection","kind":"symbol","abstract":[{"type":"text","text":"A collection that presents the elements of its base collection"},{"type":"text","text":" "},{"type":"text","text":"in reverse order."}],"navigatorTitle":[{"kind":"identifier","text":"ReversedCollection"}],"url":"/documentation/swift/reversedcollection"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"}}}