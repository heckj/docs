ext":" }"}]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"A collection’s ","type":"text"},{"code":"indices","type":"codeVoice"},{"text":" property can hold a strong reference to the","type":"text"},{"text":" ","type":"text"},{"text":"collection itself, causing the collection to be non-uniquely referenced.","type":"text"},{"text":" ","type":"text"},{"text":"If you mutate the collection while iterating over its indices, a strong","type":"text"},{"text":" ","type":"text"},{"text":"reference can cause an unexpected copy of the collection. To avoid the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"unexpected copy, use the "},{"type":"codeVoice","code":"index(after:)"},{"text":" method starting with","type":"text"},{"text":" ","type":"text"},{"code":"startIndex","type":"codeVoice"},{"text":" to produce indices instead.","type":"text"}]},{"type":"codeListing","code":["var c = MyFancyCollection([10, 20, 30, 40, 50])","var i = c.startIndex","while i != c.endIndex {","    c[i] /= 5","    i = c.index(after: i)","}","// c == MyFancyCollection([2, 4, 6, 8, 10])"],"syntax":"swift"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/DefaultIndices":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DefaultIndices"}],"type":"topic","title":"DefaultIndices","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/DefaultIndices","kind":"symbol","abstract":[{"type":"text","text":"A collection of indices for an arbitrary collection"}],"navigatorTitle":[{"text":"DefaultIndices","kind":"identifier"}],"url":"/docume