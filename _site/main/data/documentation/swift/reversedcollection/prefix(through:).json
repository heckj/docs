{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ReversedCollection"]]},"kind":"symbol","abstract":[{"type":"text","text":"Returns a subsequence from the start of the collection through the"},{"type":"text","text":" "},{"type":"text","text":"specified position."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"prefix","kind":"identifier"},{"text":"(","kind":"text"},{"text":"through","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"position","kind":"internalParam"},{"text":": ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","text":"Index","kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa"},{"text":") -> ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","text":"SubSequence","kind":"typeIdentifier","preciseIdentifier":"s:Sl11SubSequenceQa"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The index of the last element to include in the","type":"text"},{"text":" ","type":"text"},{"text":"resulting subsequence. ","type":"text"},{"code":"position","type":"codeVoice"},{"text":" must be a valid index of the collection","type":"text"},{"text":" ","type":"text"},{"text":"that is not equal to the ","type":"text"},{"code":"endIndex","type":"codeVoice"},{"text":" property.","type":"text"}],"type":"paragraph"}],"name":"position"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"inlineContent":[{"type":"text","text":"A subsequence up to, and including, the given position."}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The resulting subsequence "},{"inlineContent":[{"type":"text","text":"includes"}],"type":"emphasis"},{"type":"text","text":" the element at the position"},{"type":"text","text":" "},{"type":"text","text":"specified by the "},{"code":"through","type":"codeVoice"},{"type":"text","text":" parameter."},{"type":"text","text":" "},{"type":"text","text":"The following example searches for the index of the number "},{"code":"40","type":"codeVoice"},{"type":"text","text":" in an"},{"type":"text","text":" "},{"type":"text","text":"array of integers, and then prints the prefix of the array up to, and"},{"type":"text","text":" "},{"type":"text","text":"including, that index:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let numbers = [10, 20, 30, 40, 50, 60]","if let i = numbers.firstIndex(of: 40) {","    print(numbers.prefix(through: i))","}","// Prints \"[10, 20, 30, 40]\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using the "},{"code":"prefix(through:)","type":"codeVoice"},{"type":"text","text":" method is equivalent to using a partial"},{"type":"text","text":" "},{"type":"text","text":"closed range as the collection’s subscript. The subscript notation is"},{"type":"text","text":" "},{"type":"text","text":"preferred over "},{"code":"prefix(through:)","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["if let i = numbers.firstIndex(of: 40) {","    print(numbers[...i])","}","// Prints \"[10, 20, 30, 40]\""]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O(1)"}]}],"type":"aside","style":"note","name":"Complexity"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/ReversedCollection/prefix(through:)"},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["/documentation/swift/reversedcollection/prefix(through:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","externalID":"s:SlsE6prefix7t