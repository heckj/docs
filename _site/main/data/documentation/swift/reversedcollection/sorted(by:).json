ciatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Element"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","type":"topic","required":true,"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"A type representing the sequence’s elements."}],"url":"/documentation/swift/sequence/element"},"doc://com.apple.Swift/documentation/Swift/Bool":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","type":"topic","title":"Bool","kind":"symbol","url":"/documentation/swift/bool","navigatorTitle":[{"kind":"identifier","text":"Bool"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Bool"}],"abstract":[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"}}}