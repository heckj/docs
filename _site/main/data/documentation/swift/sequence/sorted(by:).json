"},{"kind":"text","text":") "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> ["},{"preciseIdentifier":"s:ST7ElementQa","kind":"typeIdentifier","text":"Element"},{"kind":"text","text":"]"}]},"doc://com.apple.Swift/documentation/Swift/Bool":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","type":"topic","title":"Bool","kind":"symbol","url":"/documentation/swift/bool","navigatorTitle":[{"kind":"identifier","text":"Bool"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Bool"}],"abstract":[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]}}}