{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/SerialExecutor","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc://com.apple.Swift/documentation/Swift/Executor","doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype"],"kind":"relationships","title":"Inherits From"}],"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/Executor","doc://com.apple.Swift/documentation/Swift/ExecutorJob","doc://com.apple.Swift/documentation/Swift/TaskExecutor","doc://com.apple.Swift/documentation/Swift/PartialAsyncTask","doc://com.apple.Swift/documentation/Swift/UnownedJob","doc://com.apple.Swift/documentation/Swift/JobPriority","doc://com.apple.Swift/documentation/Swift/UnownedSerialExecutor","doc://com.apple.Swift/documentation/Swift/UnownedTaskExecutor","doc://com.apple.Swift/documentation/Swift/globalConcurrentExecutor","doc://com.apple.Swift/documentation/Swift/withTaskExecutorPreference(_:isolation:operation:)"],"anchor":"Executors","title":"Executors","generated":true}],"metadata":{"role":"symbol","externalID":"s:Scf","modules":[{"relatedModules":[],"name":"Swift"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"SerialExecutor"}],"roleHeading":"Protocol","navigatorTitle":[{"kind":"identifier","text":"SerialExecutor"}],"symbolKind":"protocol","title":"SerialExecutor"},"abstract":[{"type":"text","text":"A service that executes jobs."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SerialExecutor","kind":"identifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Executor","text":"Executor","preciseIdentifier":"s:ScF"}],"languages":["swift"]}]},{"content":[{"anchor":"Custom-Actor-Executors","level":3,"type":"heading","text":"Custom Actor Executors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, all actor types execute tasks on a shared global concurrent pool."},{"text":" ","type":"text"},{"type":"text","text":"The global pool does not guarantee any thread (or dispatch queue) affinity,"},{"type":"text","text":" "},{"type":"text","text":"so actors are free to use different threads as they execute tasks."}]},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"The runtime may perform various optimizations to minimize un-necessary","type":"text"},{"text":" ","type":"text"},{"text":"thread switching.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sometimes it is important to be able to customize the execution behavior"},{"type":"text","text":" "},{"type":"text","text":"of an actor. For example, when an actor is known to perform heavy blocking"},{"type":"text","text":" "},{"type":"text","text":"operations (such as IO), and we would like to keep this work "},{"type":"emphasis","inlineContent":[{"type":"text","text":"off"}]},{"type":"text","text":" the global"},{"type":"text","text":" "},{"type":"text","text":"shared pool, as blocking it may prevent other actors from being responsive."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can implement a custom executor, by conforming a type to the"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor","isActive":true},{"type":"text","text":" protocol, and implementing the "},{"type":"codeVoice","code":"enqueue(_:)"},{"type":"text","text":" method."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once implemented, you can configure an actor to use such executor by"},{"type":"text","text":" "},{"type":"text","text":"implementing the actor’s "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/Actor/unownedExecutor","isActive":true},{"type":"text","text":" computed property."},{"type":"text","text":" "},{"type":"text","text":"For example, you could accept an executor in the actor’s initializer,"},{"type":"text","text":" "},{"type":"text","text":"store it as a variable (in order to retain it for the duration of the"},{"type":"text","text":" "},{"type":"text","text":"actor’s lifetime), and return it from the "},{"type":"codeVoice","code":"unownedExecutor"},{"text":" computed","type":"text"},{"type":"text","text":" "},{"text":"property like this:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["actor MyActor {","  let myExecutor: MyExecutor","","  // accepts an executor to run this actor on.","  init(executor: MyExecutor) {","    self.myExecutor = executor","  }","","  nonisolated var unownedExecutor: UnownedSerialExecutor {","    self.myExecutor.asUnownedSerialExecutor()","  }","}"]},{"type":"paragraph","inlineContent":[{"text":"It is also possible to use a form of shared executor, either created as a","type":"text"},{"text":" ","type":"text"},{"text":"global or static property, which you can then re-use for every MyActor","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instance:"}]},{"type":"codeListing","syntax":"swift","code":["actor MyActor {","  // Serial executor reused by *all* instances of MyActor!","  static let sharedMyActorsExecutor = MyExecutor() // implements SerialExecutor","","","  nonisolated var unownedExecutor: UnownedSerialExecutor {","    Self.sharedMyActorsExecutor.asUnownedSerialExecutor()","  }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the example above, "},{"inlineContent":[{"text":"all","type":"text"}],"type":"emphasis"},{"type":"text","text":" “MyActor” instances would be using the same"},{"type":"text","text":" "},{"type":"text","text":"serial executor, which would result in only one of such actors ever being"},{"type":"text","text":" "},{"type":"text","text":"run at the same time. This may be useful if some of your code has some"},{"type":"text","text":" "},{"type":"text","text":"“specific thread” requirement when interoperating with non-Swift runtimes"},{"type":"text","text":" "},{"type":"text","text":"for example."}]},{"type":"paragraph","inlineContent":[{"text":"Since the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/UnownedSerialExecutor"},{"text":" returned by the ","type":"text"},{"code":"unownedExecutor","type":"codeVoice"},{"type":"text","text":" "},{"text":"property ","type":"text"},{"inlineContent":[{"type":"text","text":"does not"}],"type":"emphasis"},{"text":" retain the executor, you must make sure the lifetime of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it extends beyond the lifetime of any actor or task using it, as otherwise"},{"type":"text","text":" "},{"type":"text","text":"it may attempt to enqueue work on a released executor object, causing a crash."},{"type":"text","text":" "},{"type":"text","text":"The executor returned by unownedExecutor "},{"inlineContent":[{"text":"must","type":"text"}],"type":"emphasis"},{"type":"text","text":" always be the same object,"},{"type":"text","text":" "},{"type":"text","text":"and returning different executors can lead to unexpected behavior."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, you can also use existing serial executor implementations,"},{"type":"text","text":" "},{"type":"text","text":"such as Dispatch’s "},{"code":"DispatchSerialQueue","type":"codeVoice"},{"type":"text","text":" or others."}]}],"kind":"content"}],"topicSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/SerialExecutor/isMainExecutor"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"identifiers":["doc://com.apple.Swift/documentation/Swift/SerialExecuto