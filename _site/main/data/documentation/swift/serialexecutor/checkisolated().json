{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/serialexecutor/checkisolated()"]}],"defaultImplementationsSections":[{"anchor":"SerialExecutor-Implementations","title":"SerialExecutor Implementations","identifiers":["doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()-76lg2"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Last resort “fallback” isolation check, called when the concurrency runtime","type":"text"},{"text":" ","type":"text"},{"text":"is comparing executors e.g. during ","type":"text"},{"code":"assumeIsolated()","type":"codeVoice"},{"text":" and is unable to prove","type":"text"},{"text":" ","type":"text"},{"text":"serial equivalence between the expected (this object), and the current executor.","type":"text"}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/SerialExecutor"]]},"metadata":{"required":true,"roleHeading":"Instance Method","role":"symbol","externalID":"s:Scf13checkIsolatedyyF","symbolKind":"method","title":"checkIsolated()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"checkIsolated","kind":"identifier"},{"text":"()","kind":"text"}],"modules":[{"relatedModules":[],"name":"Swift"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"checkIsolated","kind":"identifier"},{"text":"()","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"During executor comparison, the Swift concurrency runtime attempts to compare"},{"type":"text","text":" "},{"type":"text","text":"current and expected executors in a few ways (including “complex” equality"},{"type":"text","text":" "},{"type":"text","text":"between executors (see "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor/isSameExclusiveExecutionContext(other:)","isActive":true},{"type":"text","text":"), and if all"},{"type":"text","text":" "},{"type":"text","text":"those checks fail, this method is invoked on the expected executor."}]},{"inlineContent":[{"type":"text","text":"This method MUST crash if it is unable to prove that the current execution"},{"type":"text","text":" "},{"type":"text","text":"context belongs to this executor. At this point usual executor comparison would"},{"type":"text","text":" "},{"type":"text","text":"have already failed, though the executor may have some external tracking of"},{"type":"text","text":" "},{"type":"text","text":"threads it owns, and may be able to prove isolation nevertheless."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A default implementation is provided that unconditionally crashes the"},{"type":"text","text":" "},{"type":"text","text":"program, and prevents calling code from proceeding with potentially"},{"type":"text","text":" "},{"type":"text","text":"not thread-safe execution."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This method must crash and halt program execution if unable"},{"type":"text","text":" "},{"type":"text","text":"to prove the isolation of the calling context."}]}],"type":"aside","style":"warning","name":"Warning"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()":{"required":true,"role":"symbol","defaultImplementations":1,"abstract":[{"text":"Last resort “fallback” isolation check, called when the concurrency runtime","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is comparing executors e.g. during "},{"type":"codeVoice","code":"assumeIsolated()"},{"type":"text","text":" and is unable to prove"},{"type":"text","text":" "},{"type":"text","text":"serial equivalence between the expected (this object), and the current executor."}],"identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()","title":"checkIsolated()","type":"topic","kind":"symbol","url":"/documentation/swift/serialexecutor/checkisolated()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"checkIsolated"},{"text":"()","kind":"text"}]},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/SerialExecutor/isSameExclusiveExecutionContext(other:)":{"required":true,"abstract":[{"type":"text","text":"If this executor has complex equality semantics, and the runtime needs to"},{"text":" ","type":"text"},{"text":"compare two executors, it will first attempt the usual pointer-based","type":"text"},{"text":" ","type":"text"},{"text":"equality / check, / and if it fails it will compare the types of both","type":"text"},{"text":" ","type":"text"},{"text":"executors, if they are the same, / it will finally invoke this method,","type":"text"},{"text":" ","type":"text"},{"text":"in an","type":"text"},{"text":" ","type":"text"},{"text":"attempt to let the executor itself decide / if this and the ","type":"text"},{"code":"other","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"executor represent the same serial, exclusive, isolation context."}],"url":"/documentation/swift/serialexecutor/issameexclusiveexecutioncontext(other:)","type":"topic","kind":"symbol","title":"isSameExclusiveExecutionContext(other:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text