{"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/SerialExecutor"]]},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()","interfaceLanguage":"swift"},"defaultImplementationsSections":[{"title":"SerialExecutor Implementations","identifiers":["doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()-76lg2"],"anchor":"SerialExecutor-Implementations"}],"metadata":{"role":"symbol","externalID":"s:Scf13checkIsolatedyyF","modules":[{"name":"Swift","relatedModules":[]}],"required":true,"roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"checkIsolated","kind":"identifier"},{"text":"()","kind":"text"}],"symbolKind":"method","title":"checkIsolated()"},"abstract":[{"type":"text","text":"Last resort “fallback” isolation check, called when the concurrency runtime"},{"type":"text","text":" "},{"type":"text","text":"is comparing executors e.g. during "},{"type":"codeVoice","code":"assumeIsolated()"},{"type":"text","text":" and is unable to prove"},{"type":"text","text":" "},{"type":"text","text":"serial equivalence between the expected (this object), and the current executor."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"checkIsolated","kind":"identifier"},{"text":"()","kind":"text"}]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"During executor comparison, the Swift concurrency runtime attempts to compare"},{"type":"text","text":" "},{"type":"text","text":"current and expected executors in a few ways (including “complex” equality"},{"type":"text","text":" "},{"type":"text","text":"between executors (see "},{"isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor/isSameExclusiveExecutionContext(other:)","type":"reference"},{"text":"), and if all","type":"text"},{"type":"text","text":" "},{"type":"text","text":"those checks fail, this method is invoked on the expected executor."}]},{"type":"paragraph","inlineContent":[{"text":"This method MUST crash if it is unable to prove that the current execution","type":"text"},{"type":"text","text":" "},{"text":"context belongs to this executor. At this point usual executor comparison would","type":"text"},{"text":" ","type":"text"},{"text":"have already failed, though the executor may have some external tracking of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"threads it owns, and may be able to prove isolation nevertheless."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A default implementation is provided that unconditionally crashes the"},{"type":"text","text":" "},{"type":"text","text":"program, and prevents calling code from proceeding with potentially"},{"type":"text","text":" "},{"type":"text","text":"not thread-safe execution."}]},{"style":"warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This method must crash and halt program execution if unable"},{"type":"text","text":" "},{"type":"text","text":"to prove the isolation of the calling context."}]}],"name":"Warning"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/serialexecutor/checkisolated()"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()":{"identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()","kind":"symbol","role":"symbol","type":"topic","url":"/documentation/swift/serialexecutor/checkisolated()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"checkIsolated"},{"kind":"text","text":"()"}],"required":true,"abstract":[{"type":"text","text":"Last resort “fallback” isolation check, called when the concurrency runtime"},{"type":"text","text":" "},{"type":"text","text":"is comparing executors e.g. during "},{"code":"assumeIsolated()","type":"codeVoice"},{"type":"text","text":" and is unable to prove"},{"type":"text","text":" "},{"type":"text","text":"serial equivalence between the expected (this object), and the current executor."}],"defaultImplementations":1,"title":"checkIsolated()"},"doc://com.apple.Swift/documentation/Swift/SerialExecutor":{"navigatorTitle":[{"kind":"identifier","text":"SerialExecutor"}],"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"SerialExecutor"}],"abstract":[{"text":"A service that executes jobs.","type":"text"}],"url":"/documentation/swift/serialexecutor","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor","title":"SerialExecutor","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()-76lg2":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"checkIsolated"},{"kind":"text","text":"()"}],"role":"symbol","abstract":[],"url":"/documentation/swift/serialexecutor/checkisolated()-76lg2","identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor/checkIsolated()-76lg2","kind":"symbol","type":"topic","title":"checkIsolated()"},"doc://com.apple.Swift/documentation/Swift/SerialExecutor/isSameExclusiveExecutionContext(other:)":{"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/SerialExecutor/isSameExclusiveExecutionContext(other:)","role":"symbol","type":"topic","url":"/documentation/swift/serialexecutor/issameexclusiveexecutioncontext(other:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"isSameExclusiveExecutionContext"},{"kind":"text","text":"("},{"kind":"externalParam","text":"other"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"required":true,"abstract":[{"type":"text","text":"If this executor has complex equality semantics, and the runtime needs to"},{"text":" ","type":"text"},{"type":"text","text":"compare two executors, it will first attempt the usual pointer-based"},{"text":" ","type":"text"},{"type":"text","text":"equality / check, / and if it fails it will compare the types of both"},{"type":"text","text":" "},{"text":"executors, if they are the same, / it will finally invoke this method,","type":"text"},{"type":"text","text":" "},{"text":"in an","type":"text"},{"type":"text","text":" "},{"text":"attempt to let the executor itself decide / if this and the ","type":"text"},{"code":"other","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"executor represent the same serial, exclusive, isolation context."}],"defaultImplementations":2,"title":"isSameExclusiveExecutionContext(other:)"}}}