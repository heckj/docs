{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"base","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Base","kind":"typeIdentifier","preciseIdentifier":"s:s5SliceV4Basexmfp"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"You can use a slice’s "},{"type":"codeVoice","code":"base"},{"type":"text","text":" property to access its base collection. The"},{"type":"text","text":" "},{"type":"text","text":"following example declares "},{"type":"codeVoice","code":"singleDigits"},{"type":"text","text":", a range of single digit"},{"type":"text","text":" "},{"type":"text","text":"integers, and then drops the first element to create a slice of that"},{"type":"text","text":" "},{"type":"text","text":"range, "},{"type":"codeVoice","code":"singleNonZeroDigits"},{"type":"text","text":". The "},{"type":"codeVoice","code":"base"},{"type":"text","text":" property of the slice is equal"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"singleDigits"},{"type":"text","text":"."}],"type":"paragraph"},{"code":["let singleDigits = 0..<10","let singleNonZeroDigits = singleDigits.dropFirst()","// singleNonZeroDigits is a Slice<Range<Int>>","","print(singleNonZeroDigits.count)","// Prints \"9\"","print(singleNonZeroDigits.base.count)","// Prints \"10\"","print(singleDigits == singleNonZeroDigits.base)","// Prints \"true\""],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/slice/base"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"The underlying collection of the slice.","type":"text"}],"metadata":{"roleHeading":"Instance Property","ti