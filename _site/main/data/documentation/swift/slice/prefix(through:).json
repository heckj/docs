{"sections":[],"abstract":[{"text":"Returns a subsequence from the start of the collection through the","type":"text"},{"text":" ","type":"text"},{"text":"specified position.","type":"text"}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"prefix","kind":"identifier"},{"text":"(","kind":"text"},{"text":"through","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Index","kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa"},{"text":") -> ","kind":"text"},{"text":"SubSequence","kind":"typeIdentifier","preciseIdentifier":"s:Sl11SubSequenceQa"}],"role":"symbol","extendedModule":"Swift","externalID":"s:SlsE6prefix7through11SubSequenceQz5IndexQz_tF::SYNTHESIZED::s:s5SliceV","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"Swift"}],"title":"prefix(through:)"},"variants":[{"paths":["/documentation/swift/slice/prefix(through:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Slice/prefix(through:)"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"prefix"},{"kind":"text","text":"("},{"kind":"externalParam","text":"through"},{"kind":"text","text":" "},{"kind":"internalParam","text":"position"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","preciseIdentifier":"s:Sl5IndexQa","text":"Index"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa","text":"SubSequence"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The index of the last element to include in the"},{"type":"text","text":" "},{"type":"text","text":"resulting subsequence. "},{"type":"codeVoice","code":"position"},{"type":"text","text":" must be a valid index of the collection"},{"type":"text","text":" "},{"type":"text","text":"that is not equal to the "},{"type":"codeVoice","code":"endIndex"},{"type":"text","text":" property."}],"type":"paragraph"}],"name":"position"}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A subsequence up to, and including, the given position."}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The resulting subsequence "},{"inlineContent":[{"type":"text","text":"includes"}],"type":"emphasis"},{"type":"text","text":" the element at the position"},{"type":"text","text":" "},{"type":"text","text":"specified by the "},{"code":"through","type":"codeVoice"},{"type":"text","text":" parameter."},{"type":"text","text":" "},{"type":"text","text":"The following example searches for the index of the number "},{"code":"40","type":"codeVoice"},{"type":"text","text":" in an"},{"type":"text","text":" "},{"type":"text","text":"array of integers, and then prints the prefix of the array up to, and"},{"type":"text","text":" "},{"type":"text","text":"including, that index:"}]},{"code":["let numbers = [10, 20, 30, 40, 50, 60]","if let i = numbers.firstIndex(of: 40) {","    print(numbers.prefix(through: i))","}","// Prints \"[10, 20, 30, 40]\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using the "},{"code":"prefix(through:)","type":"codeVoice"},{"type":"text","text":" method is equivalent to using a partial"},{"type":"text","text":" "},{"type":"text","text":"closed range as the collection’s subscript. The subscript notation is"},{"type":"text","text":" "},{"type":"text","text":"preferred over "},{"code":"prefix(through:)","type":"codeVoice"},{"type":"text","text":"."}]},{"code":["if let i = numbers.firstIndex(of: 40) {","    print(numbers[...i])","}","// Prints \"[10, 20, 30, 40]\""],"type":"codeListing","syntax":"swift"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"O(1)"}],"type":"paragraph"}],"type":"aside","name":"Complexity"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Slice"]]},"references":{"doc://com.apple.Swift/documentation/Swift/Collection/Index":{"url":"/documentation/swift/collection/index","required":true,"fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Index"},{"kind":"text","text":" : "},{"text":"Comparable","kind":"typeIdentifier","preciseIdentifier":"s:SL"}],"title":"Index","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","abstract":[{"type":"text","text":"A type that represents a position in the collection."}],"role":"symbol","type":"topic"},"doc://com.apple.Swift/documentation/Swift/Slice/prefix(through:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"prefix"},{"kind":"text","text":"("},{"kind":"externalParam","text":"through"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Index","preciseIdentifier":"s:Sl5IndexQa"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa"}],"role":"symbol","url":"/documentation/swift/slice/prefix(through:)","abstract":[{"text":"Returns a subsequence from the start of the collection through the","type":"text"},{"text":" ","type":"text"},{"text":"specified position.","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Slice/prefix(through:)","kind":"symbol","type":"topic","title":"prefix(through:)"},"doc://com.apple.Swift/documentation/Swift/Sli