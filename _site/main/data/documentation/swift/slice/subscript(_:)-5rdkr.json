type":"text"}]},{"code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Always use the slice’s ","type":"text"},{"code":"startIndex","type":"codeVoice"},{"text":" property instead of assuming that its","type":"text"},{"text":" ","type":"text"},{"text":"indices start at a particular value. Attempting to access an element by","type":"text"},{"text":" ","type":"text"},{"text":"using an index outside the bounds of the slice’s indices may result in a","type":"text"},{"text":" ","type":"text"},{"text":"runtime error, even if that index is valid for the original collection.","type":"text"}]},{"code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O(1)"}]}],"name":"Complexity","style":"note","type":"aside"}]}],"variants":[{"paths":["/documentation/swift/slice/subscript(_:)-5rdkr"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound":{"url":"/documentation/swift/rangeexpression/bound","title":"Bound","type":"topic","required":true,"abstract":[{"type":"text","text":"The type for which the expression describes a range."}],"role":"symbol","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Bound","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"Comparable","preciseIdentifier":"s:SL","kind":"typeIdentifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps usin