iven closure while temporarily binding the memory referenced"},{"type":"text","text":" "},{"type":"text","text":"by this buffer slice to the given type."}]},"doc://com.apple.Swift/documentation/Swift/Error":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Error","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"A type representing an error value that can be thrown."}],"url":"/documentation/swift/error","identifier":"doc://com.apple.Swift/documentation/Swift/Error","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Error","kind":"identifier"}],"title":"Error"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/Slice":{"navigatorTitle":[{"kind":"identifier","text":"Slice"}],"url":"/documentation/swift/slice","abstract":[{"type":"text","text":"A view into a subsequence of elements of another collection."}],"identifier":"doc://com.apple.Swift/documentation/Swift/Slice","type":"topic","kind":"symbol","title":"Slice","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Slice"}]},"doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer":{"type":"topic","abstract":[{"text":"A nonowning collection interface to a buffer of","type":"text"},{"text":" ","type":"text"},{"text":"elements stored contiguously in memory.","type":"text"}],"title":"UnsafeBufferPointer","role":"symbol","url":"/documentation/swift/unsafebufferpointer","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnsafeBufferPointer","kind":"identifier"}],"navigatorTitle":[{"text":"Unsaf