 the ","type":"text"},{"type":"codeVoice","code":"Strideable"},{"type":"text","text":" protocol, such as integers or floating-point types."},{"type":"text","text":" "},{"type":"text","text":"Starting with "},{"type":"codeVoice","code":"start"},{"type":"text","text":", each successive value of the sequence adds "},{"type":"codeVoice","code":"stride"},{"type":"text","text":" "},{"type":"text","text":"until the next value would be beyond "},{"code":"end","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["for radians in stride(from: 0.0, through: .pi * 2, by: .pi / 2) {","    let degrees = Int(radians * 180 / .pi)","    print(\"Degrees: \\(degrees), radians: \\(radians)\")","}","// Degrees: 0, radians: 0.0","// Degrees: 90, radians: 1.5707963267949","// Degrees: 180, radians: 3.14159265358979","// Degrees: 270, radians: 4.71238898038469","// Degrees: 360, radians: 6.28318530717959"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"codeVoice","code":"stride(from:through:by:)"},{"type":"text","text":" to create a sequence that strides"},{"text":" ","type":"text"},{"text":"upward or downward. Pass a negative value as ","type":"text"},{"type":"codeVoice","code":"stride"},{"type":"text","text":" to create a sequence"},{"type":"text","text":" "},{"type":"text","text":"from a higher start to a lower end:"}]},{"type":"codeListing","code":["for countdown in stride(from: 3, through: 1, by: -1) {","    print(\"\\(countdown)...\")","}","// 3...","// 2...","// 1..."],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The value you pass as "},{"type":"codeVoice","code":"end"},{"type":"text","text":" is not guaranteed to be included in the"},{"type":"text","text":" "},{"type":"text","text":"sequence. If stepping from "},{"type":"codeVoice","code":"start"},{"type":"text","text":" by "},{"code":"stride","type":"codeVoice"},{"type":"text","text":" does not produce "},{"type":"codeVoice","code":"end"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the last value in the sequence will be one step before going beyond "},{"code":"end","type":"codeVoice"},{"text":".","type":"text"}]},{"code":["for multipleOfThree in stride(from: 3, through: 10, by: 3) {","    print(multipleOfThree)","}","// 3","// 6","// 9"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you pass a value as "},{"type":"codeVoice","code":"stride"},{"type":"text","text":" that moves away from "},{"type":"codeVoice","code":"end"},{"text":", the sequence","type":"text"},{"type":"text","text":" "},{"type":"text","text":"contains no values."}]},{"type":"codeListing","code":["for x in stride(from: 0, through: 10, by: -1) {","    print(x)","}","// Nothing is printed."],"syntax":"swift"}]}],"abstract":[{"text":"Returns a sequence from a starting value toward, and possibly including, an end","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"value, stepping by the specified amount."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"role":"symbol","title":"stride(from:through:by:)","symbolKind":"func","modules":[{"name":"Swift"}],"externalID":"s:s6stride4from7through2bys13StrideThroughVyxGx_x0E0QztSxRzlF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stride"},{"kind":"text","text":"<"},{"text":"T","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"from"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s6stride4from7through2bys13StrideThroughVyxGx_x0E0QztSxRzlF1TL_xmfp","text":"T"},{"kind":"text","text":", "},{"kind":"externalParam","text":"through"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:s6stride4from7through2bys13StrideThroughVyxGx_x0E0QztSxRzlF1TL_xmfp"},{"text":", ","kind":"text"},{"kind":"exter