:[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","url":"/documentation/swift/bool","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Bool","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Bool"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift/StrideTo":{"abstract":[{"text":"A sequence of values formed by striding over a half-open interval.","type":"text"}],"kind":"symbol","title":"StrideTo","identifier":"doc://com.apple.Swift/documentation/Swift/StrideTo","url":"/documentation/swift/strideto","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"StrideTo"}],"navigatorTitle":[{"kind":"identifier","text":"StrideTo"}],"type":"topic"}}}