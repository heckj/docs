:[{"text":"The string referenced by the resulting index.","type":"text"}]}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If the index passed as "},{"type":"codeVoice","code":"sourcePosition"},{"type":"text","text":" represents the start of an"},{"type":"text","text":" "},{"type":"text","text":"extended grapheme cluster—the element type of a string—then the"},{"type":"text","text":" "},{"type":"text","text":"initializer succeeds."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following example converts the position of the Unicode scalar ","type":"text"},{"code":"\"e\"","type":"codeVoice"},{"text":" ","type":"text"},{"text":"into its corresponding position in the string. The character at that","type":"text"},{"text":" ","type":"text"},{"text":"position is the composed ","type":"text"},{"type":"codeVoice","code":"\"é\""},{"text":" character.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let cafe = \"Cafe\\u{0301}\"","print(cafe)","// Prints \"Café\"","","let scalarsIndex = cafe.unicodeScalars.firstIndex(of: \"e\")!","let stringIndex = String.Index(scalarsIndex, within: cafe)!","","print(cafe[...stringIndex])","// Prints \"Café\""]},{"type":"paragraph","inlineContent":[{"text":"If the index passed as ","type":"text"},{"code":"sourcePosition","type":"codeVoice"},{"text":" doesn’t have an exact","type":"text"},{"text":" ","type":"text"},{"text":"corresponding position in ","type":"text"},{"code":"target","type":"codeVoice"},{"text":", the result of the initializer is","type":"text"},{"text":" ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":". For example, an attempt to convert the position of the combining","type":"text"},{"text":" ","type":"text"},{"text":"acute accent (","type":"text"},{"code":"\"\\u{0301}\"","type":"codeVoice"},{"text":") fails. Combining Unicode scalars do not have","type":"text"},{"text":" ","type":"text"},{"text":"their own position in a string.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let nextScalarsIndex = cafe.unicodeScalars.index(after: scalarsIndex)","let nextStringIndex = String.Index(nextScalarsIndex, within: cafe)","","print(nextStringIndex)","// Prints \"nil\""]}]}],"abstract":[{"text":"Creates an index in the given string that corresponds exactly to the","type":"text"},{"text":" ","type":"text"},{"text":"specified position.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","metadata":{"modules":[{"name":"Swift"}],"role":"symbol","roleHeading":"Initializer","extendedModule":"Swift","title":"init(_:within:)","symbolKind":"init","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"?<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Index","preciseIdentifier":"s:SS5IndexV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"within"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"S","preciseIdentifier":"s:SS5IndexV_6withinABSgAB_xtcSyRzlufc1SL_xmfp"},{"kind":"text","text":")"}],"externalID":"s:SS5IndexV_6withinABSgAB_xtcSyRzlufc"},"variants":[{"paths":["/documentation/swift/string/index/init(_:within:)-3eir6"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/String/Index/init(_:within:)-3eir6","interfaceLanguage":"swift"},"sections":[],"references":{"doc://com.apple.Swift/documentation/Swift/String":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"String"}],"url":"/documentation/swift/string","abstract":[{"type":"text","text":"A Unicode string value that is a collection of characters."}],"navigatorTitle":[{"kind":"identifier","text":"String"}],"title":"