{"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["/documentation/swift/string/index/init(_:within:)-3eir6"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/String/Index/init(_:within:)-3eir6","interfaceLanguage":"swift"},"abstract":[{"text":"Creates an index in the given string that corresponds exactly to the","type":"text"},{"text":" ","type":"text"},{"text":"specified position.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"text":"?<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"sourcePosition","kind":"internalParam"},{"text":": ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/String","preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":".","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/String/Index","preciseIdentifier":"s:SS5IndexV","text":"Index","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"within","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"target","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS5IndexV_6withinABSgAB_xtcSyRzlufc1SL_xmfp","text":"S","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/StringProtocol","preciseIdentifier":"s:Sy","text":"StringProtocol","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"sourcePosition","content":[{"inlineContent":[{"text":"A position in a view of the ","type":"text"},{"code":"target","type":"codeVoice"},{"text":" parameter.","type":"text"},{"text":" ","type":"text"},{"code":"sourcePosition","type":"codeVoice"},{"text":" must be a valid index of at least one of the views","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"code":"target","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"name":"target","content":[{"inlineContent":[{"text":"The string referenced by the resulting index.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If the index passed as "},{"type":"codeVoice","code":"sourcePosition"},{"type":"text","text":" represents the start of an"},{"type":"text","text":" "},{"type":"text","text":"extended grapheme cluster—the element type of a string—then the"},{"type":"text","text":" "},{"type":"text","text":"initializer succeeds."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example converts the position of the Unicode scalar "},{"type":"codeVoice","code":"\"e\""},{"type":"text","text":" "},{"type":"text","text":"into its corresponding position in the string. The character at that"},{"type":"text","text":" "},{"type":"text","text":"position is the composed "},{"type":"codeVoice","code":"\"é\""},{"type":"text","text":" character."}],"type":"paragraph"},{"type":"codeListing","code":["let cafe = \"Cafe\\u{0301}\"","print(cafe)","// Prints \"Café\"","","let scalarsIndex = cafe.unicodeScalars.firstIndex(of: \"e\")!","let stringIndex = String.Index(scalarsIndex, within: cafe)!","","print(cafe[...stringIndex])","// Prints \"Café\""],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"If the index passed as "},{"type":"codeVoice","code":"sourcePosition"},{"type":"text","text":" doesn’t have an exact"},{"type":"text","text":" "},{"type":"text","text":"corresponding position in "},{"type":"codeVoice","code":"target"},{"type":"text","text":", the result of the initializer is"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". For example, an attempt to convert the position of the combining"},{"type":"text","text":" "},{"type":"text","text":"acute accent ("},{"type":"codeVoice","code":"\"\\u{0301}\""},{"type":"text","text":") fails. Combining Unicode scalars do not have"},{"type":"text","text":" "},{"type":"text","text":"their own position in a string."}],"type":"paragraph"},{"type":"codeListing","code":["let nextScalarsIndex = cafe.unicodeScalars.index(after: scalarsIndex)","let nextStringIndex = String.Index(nextScalarsIndex, within: cafe)","","print(nextStringIndex)","// Prints \"nil\""],"syntax":"swift"}]}],"metadata":{"symbolKind":"init","modules":[{"name":"Swift"}],"roleHeading":"Initializer","title":"init(_:within:)","externalID":"s:SS5IndexV_6withinABSgAB_xtcSyRzlufc","fragments":[{"text":"init","kind":"identifier"},{"text":"?<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Index","preciseIdentifier":"s:SS5IndexV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"within","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"S","preciseIdentifier":"s:SS5IndexV_6withinABSgAB_xtcSyRzlufc1SL_xmfp","kind":"typeIdentifier"},{"text":")","kind":"text"}],"extendedModule":"Swift","role":"symbol"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/String","doc://com.apple.Swift/documentation/Swift/String/Index"]]},"references":{"doc://com.apple.Swift/documentation/Swift/String/Index/init(_:within:)-3eir6":{"identifier":"doc://com.apple.Swift/documentation/Swift/String/Index/init(_:within:)-3eir6","abstract":[{"type":"text","text":"Creates an index in the given string that corresponds exactly to the"},{"type":"text","text":" "},{"type":"text","text":"specified position."}],"title":"init(_:within:)","url":"/documentation/swift/string/