{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"?("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"idx"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String","identifier":"doc://com.apple.Swift/documentation/Swift/String"},{"text":".","kind":"text"},{"preciseIdentifier":"s:SS5IndexV","identifier":"doc://com.apple.Swift/documentation/Swift/String/Index","text":"Index","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"within"},{"kind":"text","text":" "},{"kind":"internalParam","text":"target"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/String","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/String/UTF8View","text":"UTF8View","preciseIdentifier":"s:SS8UTF8ViewV"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"idx","content":[{"type":"paragraph","inlineContent":[{"text":"A position in a ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" or one of its views.","type":"text"}]}]},{"name":"target","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"UTF8View","type":"codeVoice"},{"type":"text","text":" in which to find the new position."}]}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"The following example finds the position of a space in a string’s "},{"type":"codeVoice","code":"utf16"},{"type":"text","text":" "},{"type":"text","text":"view and then converts that position to an index in the string’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"utf8"},{"type":"text","text":" view."}],"type":"paragraph"},{"code":["let cafe = \"Café 🍵\"","","let utf16Index = cafe.utf16.firstIndex(of: 32)!","let utf8Index = String.UTF8View.Index(utf16Index, within: cafe.utf8)!","","print(Array(cafe.utf8[..<utf8Index]))","// Prints \"[67, 97, 102, 195, 169]\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the position passed in "},{"type":"codeVoice","code":"utf16Index"},{"type":"text","text":" doesn’t have an exact"},{"type":"text","text":" "},{"type":"text","text":"corresponding position in "},{"type":"codeVoice","code":"utf8"},{"text":", the result of the initializer is","type":"text"},{"text":" ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":". For example, because UTF-8 and UTF-16 represent high Unicode code","type":"text"},{"text":" ","type":"text"},{"text":"points differently, an attempt to convert the position of the trailing","type":"text"},{"text":" ","type":"text"},{"text":"surrogate of a UTF-16 surrogate pair fails.","type":"text"}]},{"inlineContent":[{"text":"The next example attempts to convert the indices of the two UTF-16 code","type":"text"},{"type":"text","text":" "},{"type":"text","text":"points that represent the teacup emoji ("},{"type":"codeVoice","code":"\"🍵\""},{"text":"). The index of the lead","type":"text"},{"text":" ","type":"text"},{"text":"surrogate is successfully converted to a position in ","type":"text"},{"type":"codeVoice","code":"utf8"},{"type":"text","text":", but the"},{"type":"text","text":" "},{"type":"text","text":"index of the trailing surrogate is not."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let emojiHigh = cafe.utf16.index(after: utf16Index)","print(String.UTF8View.Index(emojiHigh, within: cafe.utf8))","// Prints \"Optional(String.Index(...))\"","","let emojiLow = cafe.utf16.index(after: emojiHigh)","print(String.UTF8View.Index(emojiLow, within: cafe.utf8))","// Prints \"nil\""]}]}],"metadata":{"modules":[{"name":"Swift"}],"role":"symb