":"text","text":") to the "},{"type":"codeVoice","code":"sorted(by:)"},{"type":"text","text":" method."}]},{"syntax":"swift","type":"codeListing","code":["let descendingStudents = students.sorted(by: >)","print(descendingStudents)","// Prints \"[\"Peter\", \"Kweku\", \"Kofi\", \"Akosua\", \"Abena\"]\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The sorting algorithm is guaranteed to be stable. A stable sort"},{"type":"text","text":" "},{"type":"text","text":"preserves the relative order of elements that compare as equal."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"O(","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" log "},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" is the length of the sequence."}]}],"name":"Complexity","style":"note"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/string/unicodescalarview/sorted()"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"Returns the elements of the sequence, sorted.","type":"text"}],"metadata":{"conformance":{"constraints":[{"code":"Element","type":"codeVoice"},{"type":"text","text":" conforms to "},{"code":"Comparable","type":"codeVoice"},{"type":"text","text":"."}],"availabilityPrefix":[{"type":"text","text":"Available when"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}]},"roleHeading":"Instance Method","extendedModule":"Swift","title":"sorted()","modules":[{"name":"Swift"}],"externalID":"s:STsSL7ElementRpzrlE6sortedSayABGyF::SYNTHESIZED::s:SS17UnicodeScalarViewV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"sorted"},{"kind":"text","text":"() -> ["},{"kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa","text":"Elemen