:"streetsSlice"},{"type":"text","text":" for one"},{"type":"text","text":" "},{"type":"text","text":"of the strings in the slice, and then uses that index in the original"},{"type":"text","text":" "},{"type":"text","text":"array."}],"type":"paragraph"},{"code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Always use the slice’s ","type":"text"},{"code":"startIndex","type":"codeVoice"},{"text":" property instead of assuming that its","type":"text"},{"text":" ","type":"text"},{"text":"indices start at a particular value. Attempting to access an element by","type":"text"},{"text":" ","type":"text"},{"text":"using an index outside the bounds of the slice’s indices may result in a","type":"text"},{"text":" ","type":"text"},{"text":"runtime error, even if that index is valid for the original collection.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"],"syntax":"swift"},{"name":"Complexity","type":"aside","content":[{"inlineContent":[{"text":"O(1)","type":"text"}],"type":"paragraph"}],"style":"note"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/String/UnicodeScalarView/subscript(_:)-4i2sy":{"title":"subscript(_:)","kind":"symbol","abstract":[{"type":"text","text":"Accesses the contiguous subrange of the collection’s elements specified"},{"type":"text","text":" "},{"type":"text","text":"by a range expression."}],"identifier":"doc://com.apple.Swift/documentation/Swift/String/UnicodeScalarView/subscript(_:)-4i2sy","url":"/documentation/swift/string/unicodescalarview/subscript(_:)-4i2sy","role":"symbol","fragments":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"R","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:SlsEy11SubS