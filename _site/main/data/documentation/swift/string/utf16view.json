{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/String"]]},"topicSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/String/UTF16View/customPlaygroundQuickLook"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/String/UTF16View/BidirectionalCollection-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/Collection-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/CustomDebugStringConvertible-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/CustomReflectable-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/CustomStringConvertible-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/Sequence-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/string/utf16view"]}],"seeAlsoSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/Substring","doc://com.apple.Swift/documentation/Swift/StringProtocol","doc://com.apple.Swift/documentation/Swift/String/Index","doc://com.apple.Swift/documentation/Swift/String/CharacterView","doc://com.apple.Swift/documentation/Swift/String/UnicodeScalarView","doc://com.apple.Swift/documentation/Swift/String/UTF8View","doc://com.apple.Swift/documentation/Swift/String/Iterator","doc://com.apple.Swift/documentation/Swift/String/Output"],"anchor":"Related-String-Types","title":"Related String Types"}],"kind":"symbol","metadata":{"role":"symbol","modules":[{"name":"Swift"}],"roleHeading":"Structure","title":"String.UTF16View","extendedModule":"Swift","externalID":"s:SS9UTF16ViewV","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"UTF16View","kind":"identifier"}],"navigatorTitle":[{"text":"UTF16View","kind":"identifier"}]},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/String/UTF16View"},"sections":[],"relationshipsSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/BidirectionalCollection","doc://com.apple.Swift/documentation/Swift/Collection","doc://com.apple.Swift/documentation/Swift/Copyable","doc://com.apple.Swift/documentation/Swift/CustomDebugStringConvertible","doc://com.apple.Swift/documentation/Swift/CustomReflectable","doc://com.apple.Swift/documentation/Swift/CustomStringConvertible","doc://com.apple.Swift/documentation/Swift/Escapable","doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype","doc://com.apple.Swift/documentation/Swift/Sequence"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"abstract":[{"text":"A view of a string’s contents as a collection of UTF-16 code units.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UTF16View","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"inlineContent":[{"text":"You can access a string’s view of UTF-16 code units by using its ","type":"text"},{"type":"codeVoice","code":"utf16"},{"text":" ","type":"text"},{"text":"property. A string’s UTF-16 view encodes the string’s Unicode scalar","type":"text"},{"text":" ","type":"text"},{"text":"values as 16-bit integers.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let flowers = \"Flowers 💐\"","for v in flowers.utf16 {","    print(v)","}","// 70","// 108","// 111","// 119","// 101","// 114","// 115","// 32","// 55357","// 56464"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Unicode scalar values that make up a string’s contents can be up to 21"},{"type":"text","text":" "},{"type":"text","text":"bits long. The longer scalar values may need two "},{"code":"UInt16","type":"codeVoice"},{"type":"text","text":" values for"},{"type":"text","text":" "},{"type":"text","text":"storage. Those “pairs” of code units are called "},{"type":"emphasis","inlineContent":[{"text":"surrogate pairs","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"},{"code":["let flowermoji = \"💐\"","for v in flowermoji.unicodeScalars {","    print(v, v.value)","}","// 💐 128144","","for v in flowermoji.utf16 {","    print(v)","}","// 55357","// 56464"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"To convert a ","type":"text"},{"type":"codeVoice","code":"String.UTF16View"},{"text":" instance back into a string, use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" type’s ","type":"text"},{"code":"init(_:)","type":"codeVoice"},{"type":"text","text":" initializer."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let favemoji = \"My favorite emoji is 🎉\"","if let i = favemoji.utf16.firstIndex(where: { $0 >= 128 }) {","    let asciiPrefix = String(favemoji.utf16[..<i])!","    print(asciiPrefix)","}","// Prints \"My favorite emoji is \""]},{"text":"UTF16View Elements Match NSString Characters","type":"heading","level":1,"anchor":"UTF16View-Elements-Match-NSString-Characters"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The UTF-16 code units of a string’s "},{"type":"codeVoice","code":"utf16"},{"text":" view match the elements","type":"text"},{"type":"text","text":" "},{"text":"accessed through indexed ","type":"text"},{"code":"NSString","type":"codeVoice"},{"type":"text","text":" APIs."}]},{"code":["print(flowers.utf16.count)","// Prints \"10\"","","let nsflowers = flowers as NSString","print(nsflowers.length)","// Prints \"10\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Unlike ","type":"text"},{"code":"NSString","type":"codeVoice"},{"text":", however, ","type":"text"},{"type":"codeVoice","code":"String.UTF16View"},{"text":" does not use integer","type":"text"},{"text":" ","type":"text"},{"text":"indices. If you need to access a specific position in a UTF-16 view, use","type":"text"},{"text":" ","type":"text"},{"text":"Swift’s index manipulation methods. The following example accesses the","type":"text"},{"text":" ","type":"text"},{"text":"fourth code unit in both the ","type":"text"},{"type":"codeVoice","code":"flowers"},{"text":" and ","type":"text"},{"code":"nsflowers","type":"codeVoice"},{"text":" strings:","type":"text"}],"type":"paragraph"},{"code":["print(nsflowers.character(at: 3))","// Prints \"119\"","","let i = flowers.utf16.index(flowers.utf16.startIndex, offsetBy: 3)","print(flowers.utf16[i])","// Prints \"119\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Although the Swift overlay updates many Objective-C methods to return","type":"text"},{"text":" ","type":"text"},{"text":"native Swift indices and index ranges, some still return instances of","type":"text"},{"text":" ","type":"text"},{"code":"NSRange","type":"codeVoice"},{"text":". To convert an ","type":"text"},{"code":"NSRange","type":"codeVoice"},{"type":"text","text":" instance to a range of"},{"type":"text","text":" "},{"type":"codeVoice","code":"String.Index"},{"text":", use the ","type":"text"},{"type":"codeVoice","code":"Range(_:in:)"},{"text":" initializer, which takes an","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRange"},{"type":"text","text":" and a string as arguments."}]},{"type":"codeListing","code":["let snowy = \"❄️ Let it snow! ☃️\"","let nsrange = NSRange(location: 3, length: 12)","if let range = Range(nsrange, in: snowy) {","    print(snowy[range])","}","// Prints \"Let it snow!\""],"syntax":"swift"}]}],"schemaVersion":{"mino