{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/String/UTF16View"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","topicSections":[{"anchor":"Instance-Properties","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/String/UTF16View/customPlaygroundQuickLook"],"title":"Instance Properties"},{"anchor":"Instance-Methods","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/String/UTF16View/isTriviallyIdentical(to:)"],"title":"Instance Methods"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/String/UTF16View/BidirectionalCollection-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/Collection-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/CustomDebugStringConvertible-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/CustomReflectable-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/CustomStringConvertible-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF16View/Sequence-Implementations"],"title":"Default Implementations"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc://com.apple.Swift/documentation/Swift/BidirectionalCollection","doc://com.apple.Swift/documentation/Swift/Collection","doc://com.apple.Swift/documentation/Swift/Copyable","doc://com.apple.Swift/documentation/Swift/CustomDebugStringConvertible","doc://com.apple.Swift/documentation/Swift/CustomReflectable","doc://com.apple.Swift/documentation/Swift/CustomStringConvertible","doc://com.apple.Swift/documentation/Swift/Escapable","doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype","doc://com.apple.Swift/documentation/Swift/Sequence"],"title":"Conforms To"}],"abstract":[{"type":"text","text":"A view of a string’s contents as a collection of UTF-16 code units."}],"seeAlsoSections":[{"anchor":"Related-String-Types","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/Substring","doc://com.apple.Swift/documentation/Swift/StringProtocol","doc://com.apple.Swift/documentation/Swift/String/Index","doc://com.apple.Swift/documentation/Swift/String/CharacterView","doc://com.apple.Swift/documentation/Swift/String/UnicodeScalarView","doc://com.apple.Swift/documentation/Swift/String/UTF8View","doc://com.apple.Swift/documentation/Swift/String/Iterator","doc://com.apple.Swift/documentation/Swift/String/Output"],"title":"Related String Types"}],"metadata":{"modules":[{"name":"Swift"}],"externalID":"s:SS9UTF16ViewV","navigatorTitle":[{"text":"UTF16View","kind":"identifier"}],"title":"String.UTF16View","role":"symbol","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"UTF16View","kind":"identifier"}],"roleHeading":"Structure","extendedModule":"Swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"UTF16View"}],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can access a string’s view of UTF-16 code units by using its "},{"type":"codeVoice","code":"utf16"},{"type":"text","text":" "},{"type":"text","text":"property. A string’s UTF-16 view encodes the string’s Unicode scalar"},{"type":"text","text":" "},{"type":"text","text":"values as 16-bit integers."}]},{"type":"codeListing","syntax":"swift","code":["let flowers = \"Flowers 💐\"","for v in flowers.utf16 {","    print(v)","}","// 70","// 108","// 111","// 119","// 101","// 114","// 115","// 32","// 55357","// 56464"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unicode scalar values that make up a string’s contents can be up to 21"},{"type":"text","text":" "},{"type":"text","text":"bits long. The longer scalar values may need two "},{"type":"codeVoice","code":"UInt16"},{"type":"text","text":" values for"},{"type":"text","text":" "},{"type":"text","text":"storage. Those “pairs” of code units are called "},{"type":"emphasis","inlineContent":[{"type":"text","text":"surrogate pairs"}]},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["let flowermoji = \"💐\"","for v in flowermoji.unicodeScalars {","    print(v, v.value)","}","// 💐 128144","","for v in flowermoji.utf16 {","    print(v)","}","// 55357","// 56464"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To convert a "},{"type":"codeVoice","code":"String.UTF16View"},{"type":"text","text":" instance back into a string, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"String"},{"type":"text","text":" type’s "},{"type":"codeVoice","code":"init(_:)"},{"type":"text","text":" initializer."}]},{"type":"codeListing","syntax":"swift","code":["let favemoji = \"My favorite emoji is 🎉\"","if let i = favemoji.utf16.firstIndex(where: { $0 >= 128 }) {","    let asciiPrefix = String(favemoji.utf16[..<i])!","    print(asciiPrefix)","}","// Prints \"My favorite emoji is \""]},{"type":"heading","text":"UTF16View Elements Match NSString Characters","level":1,"anchor":"UTF16View-Elements-Match-NSString-Characters"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The UTF-16 code units of a string’s "},{"type":"codeVoice","code":"utf16"},{"type":"text","text":" view match the elements"},{"type":"text","text":" "},{"type":"text","text":"accessed through indexed "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":" APIs."}]},{"type":"codeListing","syntax":"swift","code":["print(flowers.utf16.count)","// Prints \"10\"","","let nsflowers = flowers as NSString","print(nsflowers.length)","// Prints \"10\""]},{"inlineContent":[{"type":"text","text":"Unlike "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":", however, "},{"type":"codeVoice","code":"String.UTF16View"},{"type":"text","text":" does not use integer"},{"type":"text","text":" "},{"type":"text","text":"indices. If you need to access a specific position in a UTF-16 view, use"},{"type":"text","text":" "},{"type":"text","text":"Swift’s index manipulation methods. The following example accesses the"},{"type":"text","text":" "},{"type":"text","text":"fourth code unit in both the "},{"type":"codeVoice","code":"flowers"},{"type":"text","text":" and "},{"type":"codeVoice","code":"nsflowers"},{"type":"text","text":" strings:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["print(nsflowers.character(at: 3))","// Prints \"119\"","","let i = flowers.utf16.index(flowers.utf16.startIndex, offsetBy: 3)","print(flowers.utf16[i])","// Prints \"119\""]},{"inlineContent":[{"type":"text","text":"Although the Swift overlay updates many Objective-C methods to return"},{"type":"text","text":" "},{"type":"text","text":"native Swift indices and index ranges, some still return instances of"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRange"},{"type":"text","text":". To convert an "},{"type":"codeVoice","code":"NSRange"},{"type":"text","text":" instance to a range of"},{"type":"text","text":" "},{"type":"codeVoice","code":"String.Index"},{"type":"text","text":", use the "},{"type":"codeVoice","code":"Range(_:in:)"},{"type":"text","text":" initializer, which takes an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRange"},{"type":"text","text":" and a string as arguments."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let snowy = \"❄️ Let it snow! ☃️\"","let nsrange = NSRange(location: 3, length: 12)","if let range = Range(nsrange, in: snowy) {","    print(snowy[range])","}","// Prints \"Let it snow!\""]}],"kind":"content"}],"variants":[{"traits":[{