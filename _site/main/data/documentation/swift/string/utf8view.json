{"seeAlsoSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/Substring","doc://com.apple.Swift/documentation/Swift/StringProtocol","doc://com.apple.Swift/documentation/Swift/String/Index","doc://com.apple.Swift/documentation/Swift/String/CharacterView","doc://com.apple.Swift/documentation/Swift/String/UnicodeScalarView","doc://com.apple.Swift/documentation/Swift/String/UTF16View","doc://com.apple.Swift/documentation/Swift/String/Iterator","doc://com.apple.Swift/documentation/Swift/String/Output"],"generated":true,"title":"Related String Types","anchor":"Related-String-Types"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UTF8View","kind":"identifier"}]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"You can access a string’s view of UTF-8 code units by using its ","type":"text"},{"code":"utf8","type":"codeVoice"},{"text":" ","type":"text"},{"text":"property. A string’s UTF-8 view encodes the string’s Unicode scalar","type":"text"},{"text":" ","type":"text"},{"text":"values as 8-bit integers.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let flowers = \"Flowers 💐\"","for v in flowers.utf8 {","    print(v)","}","// 70","// 108","// 111","// 119","// 101","// 114","// 115","// 32","// 240","// 159","// 146","// 144"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A string’s Unicode scalar values can be up to 21 bits in length. To"},{"type":"text","text":" "},{"text":"represent those scalar values using 8-bit integers, more than one UTF-8","type":"text"},{"text":" ","type":"text"},{"text":"code unit is often required.","type":"text"}]},{"type":"codeListing","code":["let flowermoji = \"💐\"","for v in flowermoji.unicodeScalars {","    print(v, v.value)","}","// 💐 128144","","for v in flowermoji.utf8 {","    print(v)","}","// 240","// 159","// 146","// 144"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the encoded representation of a Unicode scalar value, each UTF-8 code"},{"type":"text","text":" "},{"type":"text","text":"unit after the first is called a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"continuation byte"}]},{"type":"text","text":"."}]},{"text":"UTF8View Elements Match Encoded C Strings","type":"heading","level":1,"anchor":"UTF8View-Elements-Match-Encoded-C-Strings"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Swift streamlines interoperation with C string APIs by letting you pass a"},{"type":"text","text":" "},{"code":"String","type":"codeVoice"},{"type":"text","text":" instance to a function as an "},{"code":"Int8","type":"codeVoice"},{"type":"text","text":" or "},{"code":"UInt8","type":"codeVoice"},{"type":"text","text":" pointer. When you"},{"type":"text","text":" "},{"type":"text","text":"call a C function using a "},{"code":"String","type":"codeVoice"},{"type":"text","text":", Swift automatically creates a buffer"},{"type":"text","text":" "},{"type":"text","text":"of UTF-8 code units and passes a pointer to that buffer. The code units"},{"type":"text","text":" "},{"type":"text","text":"of that buffer match the code units in the string’s "},{"code":"utf8","type":"codeVoice"},{"type":"text","text":" view."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example uses the C "},{"code":"strncmp","type":"codeVoice"},{"type":"text","text":" function to compare the"},{"type":"text","text":" "},{"text":"beginning of two Swift strings. The ","type":"text"},{"code":"strncmp","type":"codeVoice"},{"text":" function takes two","type":"text"},{"text":" ","type":"text"},{"code":"const char*","type":"codeVoice"},{"text":" pointers and an integer specifying the number of characters","type":"text"},{"text":" ","type":"text"},{"text":"to compare. Because the strings are identical up to the 14th character,","type":"text"},{"text":" ","type":"text"},{"text":"comparing only those characters results in a return value of ","type":"text"},{"code":"0","type":"codeVoice"},{"text":".","type":"text"}]},{"syntax":"swift","code":["let s1 = \"They call me 'Bell'\"","let s2 = \"They call me 'Stacey'\"","","print(strncmp(s1, s2, 14))","// Prints \"0\"","print(String(s1.utf8.prefix(14))!)","// Prints \"They call me '\""],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Extending the compared character count to 15 includes the differing"},{"type":"text","text":" "},{"type":"text","text":"characters, so a nonzero result is returned."}]},{"syntax":"swift","code":["print(strncmp(s1, s2, 15))","// Prints \"-17\"","print(String(s1.utf8.prefix(15))!)","// Prints \"They call me 'B\""],"type":"codeListing"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/String"]]},"sections":[],"topicSections":[{"identifiers":["doc://com.apple.Swift/documentation/Swift/String/UTF8View/customPlaygroundQuickLook","doc://com.apple.Swift/documentation/Swift/String/UTF8View/span"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/String/UTF8View/BidirectionalCollection-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF8View/Collection-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF8View/CustomDebugStringConvertible-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF8View/CustomReflectable-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF8View/CustomStringConvertible-Implementations","doc://com.apple.Swift/documentation/Swift/String/UTF8View/Sequence-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations