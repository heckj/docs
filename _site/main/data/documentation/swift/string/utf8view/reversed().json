{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/string/utf8view/reversed()"]}],"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reversed"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection","preciseIdentifier":"s:s18ReversedCollectionV","text":"ReversedCollection"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can reverse a collection without allocating new space for its"},{"type":"text","text":" "},{"type":"text","text":"elements by calling this "},{"type":"codeVoice","code":"reversed()"},{"type":"text","text":" method. A "},{"type":"codeVoice","code":"ReversedCollection"},{"type":"text","text":" "},{"type":"text","text":"instance wraps an underlying collection and provides access to its"},{"type":"text","text":" "},{"type":"text","text":"elements in reverse order. This example prints the characters of a"},{"type":"text","text":" "},{"type":"text","text":"string in reverse order:"}]},{"syntax":"swift","type":"codeListing","code":["let word = \"Backwards\"","for char in word.reversed() {","    print(char, terminator: \"\")","}","// Prints \"sdrawkcaB\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need a reversed collection of the same type, you may be able to"},{"type":"text","text":" "},{"type":"text","text":"use the collection’s sequence-based or collection-based initializer. For"},{"type":"text","text":" "},{"type":"text","text":"example, to get the reversed version of a string, reverse its"},{"type":"text","text":" "},{"type":"text","text":"characters and initialize a new "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instance from the result."}]},{"syntax":"swift","type":"codeListing","code":["let reversedWord = String(word.reversed())","print(reversedWord)","// Prints \"sdrawkcaB\""]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"O(1)"}],"type":"paragraph"}],"name":"Complexity","type":"aside"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/String/UTF8View/reversed()"},"abstract":[{"type":"text","text":"Returns a view presenting the elements of the collection in reverse"},{"type":"text","text":" "},{"type":"text","text":"order."}],"metadata":{"roleHeading":"Instance Method","modules":[{"name":"Swift"}],"title":"reversed()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reversed"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV","text":"ReversedCollection"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}],"extendedModule":"Swift","role":"symbol","symbolKind":"method","externalID":"s:SKsE8reverseds18ReversedCollectionVyxGyF::SYNTHESIZED::s:SS8UTF8ViewV"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/String","doc://com.apple.Swift/documentation/Swift/String/UTF8View"]]},"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/ReversedCollection":{"type":"topic","abstract":[{"type":"text","text":"A collection that presents the elements of its base collection"},{"type":"text","text":" "