{"abstract":[{"text":"Returns the elements of the sequence, sorted.","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"modules":[{"name":"Swift"}],"externalID":"s:STsSL7ElementRpzrlE6sortedSayABGyF::SYNTHESIZED::s:SS8UTF8ViewV","roleHeading":"Instance Method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"sorted","kind":"identifier"},{"text":"() -> [","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa"},{"text":"]","kind":"text"}],"extendedModule":"Swift","title":"sorted()","symbolKind":"method","conformance":{"conformancePrefix":[{"text":"Conforms when","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}],"constraints":[{"code":"Element","type":"codeVoice"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":"."}]}},"sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/String","doc://com.apple.Swift/documentation/Swift/String/UTF8View"]]},"kind":"symbol","variants":[{"paths":["/documentation/swift/string/utf8view/sorted()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/String/UTF8View/sorted()","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"sorted","kind":"identifier"},{"kind":"text","text":"() -> ["},{"text":"Element","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","preciseIdentifier":"s:ST7ElementQa"},{"text":"]","kind":"text"}],"languages":["swift"]}]},{"content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"inlineContent":[{"type":"text","text":"A sorted array of the sequence’s elements."}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"You can sort any sequence of elements that conform to the ","type":"text"},{"code":"Comparable","type":"codeVoice"},{"text":" ","type":"text"},{"text":"protocol by calling this method. Elements are sorted in ascending order.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Here’s an example of sorting a list of students’ names. Strings in Swift","type":"text"},{"text":" ","type":"text"},{"text":"conform to the ","type":"text"},{"type":"codeVoice","code":"Comparable"},{"text":" protocol, so the names are sorted in","type":"text"},{"text":" ","type":"text"},{"text":"ascending order according to the less-than operator (","type":"text"},{"type":"codeVoice","code":"<"},{"text":").","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let students: Set = [\"Kofi\", \"Abena\", \"Peter\", \"Kweku\", \"Akosua\"]","let sortedStudents = students.sorted()","print(sortedStudents)","// Prints \"[\"Abena\", \"Akosua\", \"Kofi\", \"Kweku\", \"Peter\"]\""]},{"inlineContent":[{"type":"text","text":"To sort the elements of your sequence in descending order, pass the"},{"type":"text","text":" "},{"text":"greater-than operator (","type":"text"},{"type":"codeVoice","code":">"},{"type":"text","text":") to the "},{"code":"sorted(by:)","type":"codeVoice"},{"text":" method.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let descendingStudents = students.sorted(by: >)","print(descendingStudents)","// Prints \"[\"Peter\", \"Kweku\", \"Kofi\", \"Akosua\", \"Abena\"]\""]},{"inlineContent":[{"type":"text","text":"The sorting algorithm is guaranteed to be stable. A stable sort"},{"type":"text","text":" "},{"type":"text","text":"preserves the relative order of elements that compare as equal."}],"type":"paragraph"},{"name":"Complexity","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" log "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the length of the sequence."}]}]}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/String/UTF8View/sorted()":{"abstract":[{"type":"text","text":"Returns the elements of the sequence, sorted."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sorted","kind":"identifier"},{"text":"() -> [","kind":"text"},{"text":"Element","preciseIdentifier":"s:ST7ElementQa","kind":"typeIdentifier"},{"text":"]","kind":"text"}],"role":"symbol","url":"/documentation/swift/string/utf8view/sorted()","title":"sorted()","type":"topic","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/String/UTF8View/sorted()","conformance":{"availabilityPrefix":[{"type":"text","text":"Available when"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"code":"Element","type":"codeVoice"},{"text":" conforms to ","type":"text"},{"code":"Comparable","type":"codeVoice"},{"text":".","type":"text"}]}},"doc://com.apple.Swift/documentation/Swift/String/UTF8View":{"navigatorTitle":[{"kind":"identifier","text":"UTF8View"}],"url":"/documentation/swift/string/utf8view","title":"String.UTF8View","abstract":[{"type":"text","text":"A view of a string’s contents as a collection of UTF-8 code units."}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"UTF8View"}],"identifier":"doc://com.apple.Swift/documentation/Swift/String/UTF8View","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"title":"Element","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"iden