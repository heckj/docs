":[{"text":"The comparison is both case sensitive and Unicode safe. The","type":"text"},{"text":" ","type":"text"},{"text":"case-sensitive comparison will only match strings whose corresponding","type":"text"},{"text":" ","type":"text"},{"text":"characters have the same case.","type":"text"}],"type":"paragraph"},{"code":["let cafe = \"Café du Monde\"","","// Case sensitive","print(cafe.hasPrefix(\"café\"))","// Prints \"false\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The Unicode-safe comparison matches Unicode extended grapheme clusters","type":"text"},{"text":" ","type":"text"},{"text":"rather than the code points used to compose them. The example below uses","type":"text"},{"text":" ","type":"text"},{"text":"two strings with different forms of the ","type":"text"},{"type":"codeVoice","code":"\"é\""},{"text":" character—the first uses","type":"text"},{"text":" ","type":"text"},{"text":"the composed form and the second uses the decomposed form.","type":"text"}],"type":"paragraph"},{"code":["// Unicode safe","let composedCafe = \"Café\"","let decomposedCafe = \"Cafe\\u{0301}\"","","print(cafe.hasPrefix(composedCafe))","// Prints \"true\"","print(cafe.hasPrefix(decomposedCafe))","// Prints \"true\""],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"kind":"symbol","metadata":{"modules":[{"name":"Swift"}],"extendedModule":"Swift","title":"hasPrefix(_:)","roleHeading":"Instance Method","role":"symbol","externalID":"s:SysE9hasPrefixySbqd__SyRd__lF","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"hasPrefix","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"Prefix"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:SysE9hasPrefixySbqd__SyRd__lF0B0L_qd__mfp","text":"Prefix","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"symbolKind":"method"},"identifier":{"interfaceLanguage":"swift","url":"do