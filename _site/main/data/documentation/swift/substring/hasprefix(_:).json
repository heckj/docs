{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Substring"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hasPrefix"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Prefix"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"prefix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SysE9hasPrefixySbqd__SyRd__lF0B0L_qd__mfp","text":"Prefix"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool","identifier":"doc://com.apple.Swift/documentation/Swift/Bool"},{"kind":"text","text":" "},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Prefix","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:Sy","identifier":"doc://com.apple.Swift/documentation/Swift/StringProtocol","kind":"typeIdentifier","text":"StringProtocol"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A possible prefix to test against this string."}]}],"name":"prefix"}],"kind":"parameters"},{"content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"type":"text","text":""},{"code":"true","type":"codeVoice"},{"type":"text","text":" if the string begins with "},{"code":"prefix","type":"codeVoice"},{"type":"text","text":"; otherwise, "},{"code":"false","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The comparison is both case sensitive and Unicode safe. The"},{"type":"text","text":" "},{"type":"text","text":"case-sensitive comparison will only match strings who