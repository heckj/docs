{"abstract":[{"type":"text","text":"Returns a sequence of pairs ("},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" represents a"},{"type":"text","text":" "},{"type":"text","text":"consecutive integer starting at zero and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"type":"text","text":" represents an element of"},{"type":"text","text":" "},{"type":"text","text":"the sequence."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"enumerated","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"EnumeratedSequence","preciseIdentifier":"s:s18EnumeratedSequenceV","identifier":"doc://com.apple.Swift/documentation/Swift/EnumeratedSequence","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Return Value","level":2,"type":"heading","anchor":"return-value"},{"inlineContent":[{"text":"A sequence of pairs enumerating the sequence.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"This example enumerates the characters of the string “Swift” and prints"},{"type":"text","text":" "},{"type":"text","text":"each character along with its place in the string."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["for (n, c) in \"Swift\".enumerated() {","    print(\"\\(n): '\\(c)'\")","}","// Prints \"0: 'S'\"","// Prints \"1: 'w'\"","// Prints \"2: 'i'\"","// Prints \"3: 'f'\"","// Prints \"4: 't'\""]},{"inlineContent":[{"type":"text","text":"When you enumerate a collection, the integer part of each pair is a counter"},{"type":"text","text":" "},{"type":"text","text":"for the enumeration, but is not necessarily the index of the paired value."},{"type":"text","text":" "},{"type":"text","text":"These counters can be used as indices only in instances of zero-based,"},{"type":"text","text":" "},{"type":"text","text":"integer-indexed collections, such as "},{"type":"codeVoice","code":"Array"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ContiguousArray"},{"type":"text","text":". For"},{"type":"text","text":" "},{"type":"text","text":"other collections the counters may be out of range or of the wrong type"},{"type":"text","text":" "},{"type":"text","text":"to use as an index. To iterate over the elements of a collection with its"},{"type":"text","text":" "},{"type":"text","text":"indices, use the "},{"type":"codeVoice","code":"zip(_:_:)"},{"type":"text","text":" function."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This example iterates over the indices and elements of a set, building a"},{"type":"text","text":" "},{"type":"text","text":"list consisting of indices of names with five or fewer letters."}],"type":"paragraph"},{"code":["let names: Set = [\"Sofia\", \"Camilla\", \"Martina\", \"Mateo\", \"Nicolás\"]","var shorterIndices: [Set<String>.Index] = []","for (i, name) in zip(names.indices, names) {","    if name.count <= 5 {","        shorterIndices.append(i)","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Now that the ","type":"text"},{"code":"shorterIndices","type":"codeVoice"},{"text":" array holds the indices of the shorter","type":"text"},{"text":" ","type":"text"},{"text":"names in the ","type":"text"},{"code":"names","type":"codeVoice"},{"text":" set, you can use those indices to access elements in","type":"text"},{"text":" ","type":"text"},{"text":"the set.","type":"text"}],"type":"paragraph"},{"code":["for i in shorterIndices {","    print(names[i])","}","// Prints \"Sofia\"","// Prints \"Mateo\""],"syntax":"swift","type":"codeListing"},{"name":"Complexity","style":"note","content":[{"inlineContent":[{"type":"text","text":"O(1)"}],"type":"paragraph"}],"type":"aside"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/substring/unicodescalarview/enumerated()"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"title":"enumerated()","modules":[{"name":"Swift"}],"roleHeading":"Instance Method","symbolKind":"method","role":"symbol","extendedModule":"Swift","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"enumerated","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"EnumeratedSequence","preciseIdentifier":"s:s18EnumeratedSequenceV","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"externalID":"s:STsE10enumerateds18EnumeratedSequenceVyxGyF::SYNTHESIZED::s:Ss17UnicodeScalarViewV"},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Substring/UnicodeScalarView/enumerated()"},"sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Substring","doc://com.apple.Swift/documentation/Swift/Substring/UnicodeScalarView"]]},"kind":"symbol","references":{"doc://com.apple.Swift/documentation/Swift/Substring/UnicodeScalarView":{"title":"Substring.UnicodeScalarView","abstract":[],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Substring/UnicodeScalarView","url":"/documentation/swift/substring/unicodescalarview","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnicodeScalarView","kind":"identifier"}],"navigatorTitle":[{"text":"UnicodeScalarView","kind":"identifier"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift/EnumeratedSequence":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"EnumeratedSequence"}],"abstract":[{"text":"An enumeration of the elements of a sequence or collection.","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/Swift/EnumeratedSequence","title":"EnumeratedSequence","type":"topic","kind":"symbol","url":"/documentation/swift/enumeratedsequence","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EnumeratedSequence","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/Substring":{"url":"/documentation/swift/substring","type":"topic","title":"Substring","kind":"symbol","abstract":[{"type":"text","text":"A slice of a string."}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Substring","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Substring"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Substring"},"doc://com.apple.Swift/documentation/Swift/Substring/UnicodeScalarView/enumerated()":{"abstract":[{"text":"Returns a sequence of pairs (","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"text":"), where ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" represents a"},{"type":"text","text":" "},{"type":"text","text":"consecutive integer starting at zero and "},{"type":"emphasis","inlineContent":[{"text":"x","type":"text"}]},{"type":"text","text":" represents an element of"},{"type":"text","text":" "},{"text":"the sequence.","type":"text"}],"title":"enumerated()","role":"symbol","identifier":"doc://com.apple.Swift/doc