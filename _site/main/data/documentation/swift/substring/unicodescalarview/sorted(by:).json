identifier":"doc://com.apple.Swift/documentation/Swift/Sequence/Element","url":"/documentation/swift/sequence/element","title":"Element","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"A type representing the sequence’s elements."}],"required":true,"kind":"symbol","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/Substring/UnicodeScalarView":{"title":"Substring.UnicodeScalarView","abstract":[],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Substring/UnicodeScalarView","url":"/documentation/swift/substring/unicodescalarview","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnicodeScalarView","kind":"identifier"}],"navigatorTitle":[{"text":"UnicodeScalarView","kind":"identifier"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/Substring":{"url":"/documentation/swift/substring","type":"topic","title":"Substring","kind":"symbol","abstract":[{"type":"text","text":"A slice of a string."}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Substring","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Substring"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Substring"}}}