umentation/swift/substring","type":"topic","title":"Substring","kind":"symbol","abstract":[{"type":"text","text":"A slice of a string."}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Substring","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Substring"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Substring"}}}