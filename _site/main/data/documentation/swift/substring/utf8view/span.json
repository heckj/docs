y convert the string into its native UTF8 representation:","type":"text"},{"text":" ","type":"text"},{"text":"var nativeString = consume string","type":"text"},{"text":" ","type":"text"},{"text":"nativeString.makeContiguousUTF8()","type":"text"},{"text":" ","type":"text"},{"text":"for word in nativeString.split(separator: “ “) {","type":"text"},{"text":" ","type":"text"},{"text":"useSpan(word.span)","type":"text"},{"text":" ","type":"text"},{"text":"}","type":"text"},{"text":" ","type":"text"},{"text":"This second option has linear time complexity, as expected.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns: a "},{"code":"Span","type":"codeVoice"},{"type":"text","text":" over the UTF8 code units of this Substring."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Complexity: O(1) for native UTF8 Strings, O(n) for bridged UTF16 Strings."}]}],"kind":"content"}],"abstract":[{"text":"A span over the UTF8 code units that make up this substring.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","metadata":{"extendedModule":"Swift","role":"symbol","title":"span","symbolKind":"property","modules":[{"name":"Swift"}],"externalID":"s:Ss8UTF8ViewV4spans4SpanVys5UInt8VGvp","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"span"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s4SpanV","kind":"typeIdentifier","text":"Span"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s4UTF8a","kind":"typeIdentifier","text":"UTF8"},{"kind":"text","text":"."},{"preciseIdentifier":"s:s7UnicodeO4UTF8O8CodeUnita","kind":"typeIdentifier","text":"CodeUnit"},{"kind":"text","text":">"}],"roleHeading":"Instance Property"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/substring/utf8view/span"]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Substring/UTF8View/span"},"sections":[]