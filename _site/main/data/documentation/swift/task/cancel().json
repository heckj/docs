{"seeAlsoSections":[{"generated":true,"title":"Canceling Tasks","anchor":"Canceling-Tasks","identifiers":["doc://com.apple.Swift/documentation/Swift/CancellationError","doc://com.apple.Swift/documentation/Swift/Task/isCancelled-swift.property","doc://com.apple.Swift/documentation/Swift/Task/isCancelled-swift.type.property","doc://com.apple.Swift/documentation/Swift/Task/checkCancellation()","doc://com.apple.Swift/documentation/Swift/withTaskCancellationHandler(operation:onCancel:isolation:)"]}],"abstract":[{"type":"text","text":"Cancels this task."}],"metadata":{"role":"symbol","modules":[{"relatedModules":[],"name":"Swift"}],"extendedModule":"_Concurrency","title":"cancel()","conformance":{"availabilityPrefix":[{"text":"Available when","type":"text"}],"constraints":[{"type":"codeVoice","code":"Success"},{"text":" conforms to ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Failure"},{"type":"text","text":" conforms to "},{"code":"Error","type":"codeVoice"},{"type":"text","text":"."}],"conformancePrefix":[{"text":"Conforms when","type":"text"}]},"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancel","kind":"identifier"},{"text":"()","kind":"text"}],"symbolKind":"method","externalID":"s:ScT6cancelyyF","roleHeading":"Instance Method"},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Task/cancel()"},"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Task"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"cancel","kind":"identifier"},{"text":"()","kind":"text"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Cancelling a task has three primary effects:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It flags the task as canceled."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It causes any active cancellation handlers on the task to run, once."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It cancels any child tasks and task groups of the task, including"},{"text":" ","type":"text"},{"type":"text","text":"those created in the future. If those tasks have cancellation handlers,"},{"type":"text","text":" "},{"text":"they also are triggered.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"Task cancellation is cooperative and idempotent."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cancelling a task does not automatically cause arbitrary functions on the task"},{"type":"text","text":" "},{"type":"text","text":"to stop running or throw errors. A function "},{"inlineContent":[{"type":"text","text":"may"}],"type":"emphasis"},{"text":" choose to react","type":"text"},{"text":" ","type":"text"},{"text":"to cancellation by ending its work early, and it is conventional to","type":"text"},{"type":"text","text":" "},{"text":"signal that to callers by throwing ","type":"text"},{"type":"codeVoice","code":"CancellationError"},{"text":". However,","type":"text"},{"text":" ","type":"text"},{"text":"a function that doesn’t specifically check for cancellation will","type":"text"},{"text":" ","type":"text"},{"text":"run to completion normally, even if the task it is running on is","type":"text"},{"text":" ","type":"text"},{"text":"canceled. However, that function might still end early if it calls","type":"text"},{"type":"text","text":" "},{"type":"text","text":"other code that handles cancellation by throwing and that function doesn’t"},{"text":" ","type":"text"},{"type":"text","text":"handle the error."}]},{"type":"paragraph","inlineContent":[{"text":"It’s safe to cancel a task from any task or thread. It’s safe for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"multiple tasks or threads to cancel the same task at the same"},{"type":"text","text":" "},{"text":"time. Cancelling a task that has already been canceled has no","type":"text"},{"text":" ","type":"text"},{"text":"additional effect.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"cancel"},{"type":"text","text":" may need to acquire locks and synchronously run"},{"text":" ","type":"text"},{"type":"text","text":"arbitrary cancellation-handler code associated with the"},{"text":" ","type":"text"},{"type":"text","text":"canceled task. To reduce the risk of deadlock, it is"},{"type":"text","text":" "},{"text":"recommended that callers release any locks they might be","type":"text"},{"text":" ","type":"text"},{"text":"holding before they call cancel.","type":"text"}]},{"inlineContent":[{"text":"If the task has already run past the last point where it could have","type":"text"},{"text":" ","type":"text"},{"text":"performed a cancellation check, cancelling it may have no observable effects.","type":"text"}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"Task.checkCancellation()"}]}],"name":"See Also"},{"style":"note","type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"withTaskCancellationHandler(operation:onCancel:isolation:)","type":"codeVoice"}],"type":"paragraph"}],"name":"See Also"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/task/cancel()"]}],"references":{"doc://com.apple.Swift/documentation/Swift/Task":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Task"}],"abstract":[{"type":"text","text":"A 