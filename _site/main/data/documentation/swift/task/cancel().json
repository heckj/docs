{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Task"]]},"variants":[{"paths":["/documentation/swift/task/cancel()"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"title":"Canceling Tasks","generated":true,"anchor":"Canceling-Tasks","identifiers":["doc://com.apple.Swift/documentation/Swift/CancellationError","doc://com.apple.Swift/documentation/Swift/Task/isCancelled-swift.property","doc://com.apple.Swift/documentation/Swift/Task/isCancelled-swift.type.property","doc://com.apple.Swift/documentation/Swift/Task/checkCancellation()","doc://com.apple.Swift/documentation/Swift/withTaskCancellationHandler(operation:onCancel:isolation:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Task/cancel()"},"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Cancels this task."}],"metadata":{"modules":[{"name":"Swift","relatedModules":[]}],"externalID":"s:ScT6cancelyyF","conformance":{"availabilityPrefix":[{"type":"text","text":"Available when"}],"constraints":[{"code":"Success","type":"codeVoice"},{"type":"text","text":" conforms to "},{"code":"Sendable","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Failure","type":"codeVoice"},{"text":" conforms to ","type":"text"},{"code":"Error","type":"codeVoice"},{"text":".","type":"text"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}]},"title":"cancel()","role":"symbol","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"cancel"},{"kind":"text","text":"()"}],"roleHeading":"Instance Method","extendedModule":"_Concurrency"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"cancel"},{"kind":"text","text":"()"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Cancelling a task has three primary effects:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"It flags the task as canceled.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"It causes any active cancellation handlers on the task to run, once.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"It cancels any child tasks and task groups of the task, including","type":"text"},{"text":" ","type":"text"},{"text":"those created in the future. If those tasks have cancellation handlers,","type":"text"},{"text":" ","type":"text"},{"text":"they also are triggered.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Task cancellation is cooperative and idempotent."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Cancelling a task does not automatically cause arbitrary functions on the task"},{"type":"text","text":" "},{"type":"text","text":"to stop running or throw errors. A function "},{"inlineContent":[{"text":"may","type":"text"}],"type":"emphasis"},{"type":"text","text":" choose to react"},{"type":"text","text":" "},{"type":"text","text":"to cancellation by ending its work early, and it is conventional to"},{"type":"text","text":" "},{"type":"text","text":"signal that to callers by throwing "},{"code":"CancellationError","type":"codeVoice"},{"type":"text","text":". However,"},{"type":"text","text":" "},{"type":"text","text":"a function that doesn’t specifically check for cancellation will"},{"type":"text","text":" "},{"type":"text","text":"run to completion normally, even if the task it is running on is"},{"type":"text","text":" "},{"type":"text","text":"canceled. However, that function might still end early if it calls"},{"type":"text","text":" "},{"type":"text","text":"other code that handles cancellation by throwing and that function doesn’t"},{"type":"text","text":" "},{"type":"text","text":"handle the error."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It’s safe to cancel a task from any task or thread. It’s safe for"},{"text":" ","type":"text"},{"text":"multiple tasks or threads to cancel the same task at the same","type":"text"},{"text":" ","type":"text"},{"text":"time. Cancelling a task that has already been canceled has no","type":"text"},{"type":"text","text":" "},{"type":"text","text":"additional effect."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"cancel"},{"text":" may need to acquire locks and synchronously run","type":"text"},{"type":"text","text":" "},{"type":"text","text":"arbitrary cancellation-handler code associated with the"},{"type":"text","text":" "},{"type":"text","text":"canceled task. To reduce the risk of deadlock, it is"},{"text":" ","type":"text"},{"text":"recommended that callers release any locks they might be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"holding before they call cancel."}],"type":"paragraph"},{"inlineContent":[{"text":"If the task has already run past the last point where it could have","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"performed a cancellation check, cancelling it may have no observable effects."}],"type":"paragraph"},{"name":"See Also","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"Task.checkCancellation()"}],"type":"paragraph"}]},{"name":"See Also","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:isolation:)"}],"type":"paragraph"}]}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://com.apple.Swift/documentation/Swift/CancellationError":{"url":"/documentation/swift/cancellationerror","kind":"symbol","type":"topic","title":"CancellationError","role":"symbol","identifier":"