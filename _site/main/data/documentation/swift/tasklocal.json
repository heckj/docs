{"variants":[{"paths":["/documentation/swift/tasklocal"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/TaskLocal","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"TaskLocal","roleHeading":"Class","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TaskLocal","kind":"identifier"}],"symbolKind":"class","navigatorTitle":[{"text":"TaskLocal","kind":"identifier"}],"externalID":"s:12_Concurrency9TaskLocalC","modules":[{"relatedModules":[],"name":"Swift"}]},"seeAlsoSections":[{"title":"Task-Local Storage","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskLocal()"],"anchor":"Task-Local-Storage","generated":true}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc://com.apple.Swift/documentation/Swift/CustomStringConvertible","doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype"],"type":"conformsTo"}],"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Wrapper type that defines a task-local value key."}],"topicSections":[{"title":"Initializers","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskLocal/init(wrappedValue:)"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskLocal/description","doc://com.apple.Swift/documentation/Swift/TaskLocal/projectedValue","doc://com.apple.Swift/documentation/Swift/TaskLocal/wrappedValue"],"anchor":"Instance-Properties","generated":true},{"title":"Instance Methods","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskLocal/get()","doc://com.apple.Swift/documentation/Swift/TaskLocal/withValue(_:operation:file:line:)-5oj8d","doc://com.apple.Swift/documentation/Swift/TaskLocal/withValue(_:operation:file:line:)-79atg","doc://com.apple.Swift/documentation/Swift/TaskLocal/withValue(_:operation:isolation:file:line:)"],"anchor":"Instance-Methods","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TaskLocal","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Value","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Value","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:s8SendableP","identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","text":"Sendable","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A task-local value is a value that can be bound and read in the context of a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/Task","isActive":true},{"type":"text","text":". It is implicitly carried with the task, and is accessible by any"},{"type":"text","text":" "},{"type":"text","text":"child tasks it creates (such as TaskGroup or "},{"type":"codeVoice","code":"async let"},{"type":"text","text":" created tasks)."}]},{"text":"Task-local declarations","level":3,"anchor":"Task-local-declarations","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Task locals must be declared as static properties or global properties, like this:"}]},{"syntax":"swift","type":"codeListing","code":["enum Example {","    @TaskLocal","    static var traceID: TraceID?","}","","// Global task local properties are supported since Swift 6.0:","@TaskLocal","var contextualNumber: Int = 12"]},{"text":"Default values","level":3,"anchor":"Default-values","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reading a task local value when no value was bound to it results in returning"},{"type":"text","text":" "},{"type":"text","text":"its default value. For a task local declared as optional (such as e.g. "},{"type":"codeVoice","code":"TraceID?"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"this defaults to nil, however a different default value may be defined at declaration"},{"type":"text","text":" "},{"type":"text","text":"site of the task local, like this:"}]},{"syntax":"swift","type":"codeListing","code":["enum Example { ","    @TaskLocal","    static var traceID: TraceID = TraceID.default","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value is returned whenever the task-local is read"},{"type":"text","text":" "},{"type":"text","text":"from a context which either: has no task available to read the value from"},{"type":"text","text":" "},{"type":"text","text":"(e.g. a synchronous function, called without any asynchronous function in its call stack),"},{"type":"text","text":" "},{"type":"text","text":"or no value was bound within the scope of the current task or any of its parent tasks."}]},{"text":"Reading task-local values","level":3,"anchor":"Reading-task-local-values","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reading task local values is simple and looks the same as-if reading a normal"},{"type":"text","text":" "},{"type":"text","text":"static property:"}]},{"type":"codeListing","syntax":"swift","code":["guard let traceID = Example.traceID else {","  print(\"no trace id\")","  return","}","print(traceID)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is possible to perform task-local value reads from either asynchronous"},{"text":" ","type":"text"},{"type":"text","text":"or synchronous functions."}]},{"type":"heading","anchor":"Binding-task-local-values","level":3,"text":"Binding task-local values"},{"inlineContent":[{"type":"text","text":"Task local values cannot be "},{"type":"codeVoice","code":"set"},{"type":"text","text":" directly and must instead be bound using"},{"text":" ","type":"text"},{"text":"the scoped ","type":"text"},{"type":"codeVoice","code":"$traceID.withValue() { ... }"},{"type":"text","text":" operation. The value is only bound"},{"type":"text","text":" "},{"text":"for the duration of that scope, and is available to any child tasks which","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are created within that scope."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Detached tasks do not inherit task-local values, however tasks created using"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"Task { ... }"},{"type":"text","text":" initializer do inherit task-locals by copying them to the"},{"type":"text","text":" "},{"type":"text","text":"new asynchronous task, even though it is an un-structured task."}]},{"text":"Using task local values outside of tasks","level":3,"anchor":"Using-task-local-values-outside-of-tasks","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is possible to bind and read task local values outside of tasks."}]},{"type":"paragraph","inlineContent":[{"text":"This comes in handy within synchronous functions which are not guaranteed","type":"text"},{"type":"text","text":" "},{"text":"to be called from within a task. When binding a task-local value from","type":"text"},{"type":"text","text":" "},{"text":"outside of a task, the runtime will set a thread-local in which the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"storage mechanism as used within tasks will be used. This means that you"},{"text":" ","type":"text"},{"type":"text","text":"can reliably bind and read task local values without having to worry"},{"text":" ","type":"text"},{"text":"about the specific calling context, e.g.:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["func enter() {","    Example.$traceID.withValue(\"1234\") {","        read() // always \"1234\", regardless if enter() was called from inside a task or not:","    }    ","}","","func read() -> String {","    if let value = Self.traceID {","        \"\\(value)\" ","    } else { ","        \"<no value>\"","    }","}","","// 1) Call `enter` from non-Task code","//    e.g. synchronous main() or non-Task thread (e.g. a plain pthread)","enter()","","// 2) Call 'enter' from Task","Task { ","    enter()","}"]},{"type":"paragraph","inlineContent":[{"text":"In either cases listed above, the binding and reading of the task-local value works as expected.","type":"text"}]},{"type":"heading","anchor":"Task-local-values-without-tasks","level":3,"text":"Task local values, without tasks"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a task local value is bound in a context executing outside of a task (e.g. on a plain old Thread),"},{"text":" ","type":"text"},{"type":"text","text":"the task local will fall-back to managing a thread-local value for the scope of the "},{"code":"withValue","type":"codeVoice"},{"type":"text","text":" function."},{"text":" ","type":"text"},{"type":"text","text":"In other words, this task locals work as expected even if used in a context without an active swift concurrency task."}]},{"type":"heading","anchor":"Examples","level":3,"text":"Examples"},{"code":["enum Example {","    @TaskLocal","    static var traceID: TraceID?","}","","func read() -> String {","    if let value = Self.traceID {","        \"\\(value)\" ","    } else { ","        \"<no value>\"","    }","}","","await Example.$traceID.withValue(1234) { // bind the value","  print(\"traceID: \\(Example.traceID)\") // traceID: 1234","  read() // traceID: 1234","","  async let id = read() // async let child task, traceID: 1234","","  await withTaskGroup(of: String.self) { group in ","      group.addTask { read() } // task group child task, traceID: 1234","      return await group.next()!","  }","","  Task { // unstructured tasks do inherit task locals by copying","    read() // traceID: 1234","  }","","  Task.detached { // detached tasks do not inherit task-local values","    read() // traceID: nil","  }","}"],"type":"codeListing","syntax":"swift"},{"name":"See Also","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskLocal()","isActive":true}]}],"type":"aside"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/TaskLocal/withValue(_:operation:isolation:file:line:)":{"url":"/documentation/swift/tasklocal/withvalue(_:operation:isolation:file:line:)","abstract":[],"identifier":"doc://com.apple.Swift/documentation/Swift/TaskLocal/withValue(_:operation:isolation:file:line:)","type":"topic","deprecated":true,"kind":"symbol","title":"withValue(_:operation:isolation:file:line:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withValue","kind":"identifier"},{"text":"<","kind":"text"},{"text":"R","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:12_Concurrency9TaskLocalC5Valuexmfp","text":"Value","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"operation","kind":"externalParam"},{"text":": () ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:12_Concurrency9TaskLocalC9withValue_9operation9isolation4file4lineqd__x_qd__yYaKXEScA_pSgYiSSSutYaKlF1RL_qd__mfp","text":"R","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"isolation","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"isolated","kind":"keyword"},{"text":" (","kind":"text"},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:ScA","text