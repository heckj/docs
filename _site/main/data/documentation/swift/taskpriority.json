tion/Swift/RawRepresentable","doc://com.apple.Swift/documentation/Swift/Sendable","doc://com.apple.Swift/documentation/Swift/SendableMetatype"],"kind":"relationships","type":"conformsTo"}],"sections":[],"kind":"symbol","abstract":[{"text":"The priority of a task.","type":"text"}],"topicSections":[{"title":"Operators","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskPriority/!=(_:_:)"],"generated":true,"anchor":"Operators"},{"title":"Initializers","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskPriority/init(_:)","doc://com.apple.Swift/documentation/Swift/TaskPriority/init(rawValue:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskPriority/rawValue-swift.property"],"generated":true,"anchor":"Instance-Properties"},{"title":"Type Aliases","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskPriority/RawValue-swift.typealias"],"generated":true,"anchor":"Type-Aliases"},{"title":"Type Properties","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskPriority/background","doc://com.apple.Swift/documentation/Swift/TaskPriority/default","doc://com.apple.Swift/documentation/Swift/TaskPriority/high","doc://com.apple.Swift/documentation/Swift/TaskPriority/low","doc://com.apple.Swift/documentation/Swift/TaskPriority/medium","doc://com.apple.Swift/documentation/Swift/TaskPriority/unspecified","doc://com.apple.Swift/documentation/Swift/TaskPriority/userInitiated","doc://com.apple.Swift/documentation/Swift/TaskPriority/userInteractive","doc://com.apple.Swift/documentation/Swift/TaskPriority/utility"],"generated":true,"anchor":"Type-Properties"},{"title":"Default Implementations","identifiers":["doc://com.apple.Swift/documentation/Swift/TaskPriority/Comparable-Implementations","doc://com.apple.Swift/documentation/Swift/TaskPriority/CustomStringConvertible-Implementations","doc://com.apple.Swift/documentation/Swift/TaskPriority/Equatable-Implementations","doc://com.apple.Swift/documentation/Swift/TaskPriority/RawRepresentable-Implementations"],"anchor":"Default-Implementations","generated":true}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TaskPriority","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The executor determines how priority information affects the way tasks are scheduled.","type":"text"},{"text":" ","type":"text"},{"text":"The behavior varies depending on the executor currently being used.","type":"text"},{"text":" ","type":"text"},{"text":"Typically, executors attempt to run tasks with a higher priority","type":"text"},{"text":" ","type":"text"},{"text":"before tasks with a lower priority.","type":"text"},{"text":" ","type":"text"},{"text":"However, the semantics of how priority is treated are left up to each","type":"text"},{"text":" ","type":"text"},{"text":"platform and ","type":"text"},{"code":"Executor","type":"codeVoice"},{"text":" implementation.","type":"text"}]},{"inlineContent":[{"text":"Child tasks automatically inherit their parent task’s priority.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Detached tasks created by "},{"type":"codeVoice","code":"detach(priority:operation:)"},{"text":" don’t inherit task priority","type":"text"},{"type":"text","text":" "},{"text":"because they aren’t attached to the current task.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In some situations the priority of a task is elevated —"},{"text":" ","type":"text"},{"type":"text","text":"that is, the task is treated as it if had a higher priority,"},{"text":" ","type":"text"},{"type":"text","text":"without actually changing the priority of the task:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If a task runs on behalf of an actor,"},{"type":"text","text":" "},{"type":"text","text":"and a new higher-priority task is enqueued to the actor,"},{"type":"text","text":" "},{"type":"text","text":"then the actor’s current task is temporarily elevated"},{"type":"text","text":" "},{"type":"text","text":"to the priority of the enqueued task."},{"type":"text","text":" "},{"type":"text","text":"This priority elevation allows the new task"},{"type":"text","text":" "},{"type":"text","text":"to be processed at the priority it was enqueued with."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If a higher-priority task accesses the "},{"type":"codeVoice","code":"value"},{"type":"text","text":" property,"},{"type":"text","text":" "},{"type":"text","text":"then the priority of this task increases until the task completes."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In both cases, priority elevation helps you prevent a low-priority task"},{"text":" ","type":"text"},{"text":"from blocking the execution of a high priority task,","type":"text"},{"text":" ","type":"text"},{"text":"which is also known as ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"priority inversion"}]},{"text":".","type":"text"}]}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/Decodable":{"navigatorTitle":[{"kind":"identifier","text":"Decodable"}],"url":"/documentation/swift/decodable","abstract":[{"text":"A type that can decode itself from an external representation.","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Decodable","type":"topic","title":"Decodable","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Decodable"}]},"doc://com.apple.Swift/documentation/Swift/withThrowingDiscardingTaskGroup(returning:isolation:body:)":{"kind":"symbol","identif