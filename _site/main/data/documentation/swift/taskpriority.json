{"kind":"symbol","metadata":{"role":"symbol","externalID":"s:ScP","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TaskPriority","kind":"identifier"}],"roleHeading":"Structure","navigatorTitle":[{"text":"TaskPriority","kind":"identifier"}],"modules":[{"relatedModules":[],"name":"Swift"}],"title":"TaskPriority"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TaskPriority","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The executor determines how priority information affects the way tasks are scheduled."},{"type":"text","text":" "},{"type":"text","text":"The behavior varies depending on the executor currently being used."},{"type":"text","text":" "},{"type":"text","text":"Typically, executors attempt to run tasks with a higher priority"},{"type":"text","text":" "},{"text":"before tasks with a lower priority.","type":"text"},{"text":" ","type":"text"},{"text":"However, the semantics of how priority is treated are left up to each","type":"text"},{"text":" ","type":"text"},{"text":"platform and ","type":"text"},{"code":"Executor","type":"codeVoice"},{"text":" implementation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Child tasks automatically inherit their parent task’s priority.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Detached tasks created by "},{"type":"codeVoice","code":"detach(priority:operation:)"},{"type":"text","text":" don’t inherit task priority"},{"type":"text","text":" "},{"text":"because they aren’t attached to the current task.","type":"text"}]},{"inlineContent":[{"text":"In some situations the priority of a task is elevated —","type":"text"},{"type":"text","text":" "},{"text":"that is, the task is treated as it if had a higher priority,","type":"text"},{"text":" ","type":"text"},{"text":"without actually changing the priority of the task:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"If a task runs on behalf of an actor,","type":"text"},{"text":" ","type":"text"},{"text":"and a new higher-priority task is enqueued to the actor,","type":"text"},{"text":" ","type":"text"},{"text":"then the actor’s current task is temporarily elevated","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the priority of the enqueued task."},{"type":"text","text":" "},{"type":"text","text":"This priority elevation allows the new task"},{"type":"text","text":" "},{"type":"text","text":"to be processed at the priority it was enqueued with."}]}]},{"content":[{"inlineContent":[{"text":"If a higher-priority task calls the ","type":"text"},{"code":"get()","type":"codeVoice"},{"text":" method,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then the priority of this task increases until the task completes."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"In both cases, priority elevation helps you prevent a low-priority task"},{"type":"text","text":" "},{"type":"text","text":"from blocking the execution of a high priority task,"},{"type":"text","text":" "},{"type":"text","text":"which is also known as "},{"inlineContent":[{"text":"priority inversion","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"seeAlsoSections":[{"anchor":"Tasks","title":"Tasks","identifiers":["doc://com.apple.Swift/documentation/Swift/Task","doc://com.apple.Swift/documentation/Swift/TaskGroup","doc://com.apple.Swift/documentation/Swift/withTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","doc://com.apple.Swift/documentation/Swift