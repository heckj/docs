{"variants":[{"paths":["/documentation/swift/textoutputstream"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"abstract":[{"type":"text","text":"A type that can be the target of text-streaming operations."}],"topicSections":[{"anchor":"Instance-Methods","generated":true,"title":"Instance Methods","identifiers":["doc://com.apple.Swift/documentation/Swift/TextOutputStream/write(_:)"]}],"seeAlsoSections":[{"anchor":"Streams","generated":true,"title":"Streams","identifiers":["doc://com.apple.Swift/documentation/Swift/TextOutputStreamable"]}],"sections":[],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/TextOutputStream","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TextOutputStream"}],"languages":["swift"]}]},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"You can send the output of the standard library’s "},{"type":"codeVoice","code":"print(_:to:)"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"dump(_:to:)"},{"type":"text","text":" functions to an instance of a type that conforms to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"TextOutputStream"},{"type":"text","text":" protocol instead of to standard output. Swift’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"String"},{"type":"text","text":" type conforms to "},{"type":"codeVoice","code":"TextOutputStream"},{"text":" already, so you can capture","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the output from "},{"type":"codeVoice","code":"print(_:to:)"},{"type":"text","text":" and "},{"code":"dump(_:to:)","type":"codeVoice"},{"type":"text","text":" in a string instead of"},{"type":"text","text":" "},{"type":"text","text":"logging it to standard output."}],"type":"paragraph"},{"type":"codeListing","code":["var s = \"\"","for n in 1...5 {","    print(n, terminator: \"\", to: &s)","}","// s == \"12345\""],"syntax":"swift"},{"type":"heading","level":1,"anchor":"Conforming-to-the-TextOutputStream-Protocol","text":"Conforming to the TextOutputStream Protocol"},{"inlineContent":[{"type":"text","text":"To make your custom type conform to the "},{"type":"codeVoice","code":"TextOutputStream"},{"type":"text","text":" protocol,"},{"type":"text","text":" "},{"text":"implement the required ","type":"text"},{"type":"codeVoice","code":"write(_:)"},{"text":" method. Functions that use a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"TextOutputStream"},{"type":"text","text":" target may call "},{"code":"write(_:)","type":"codeVoice"},{"type":"text","text":" multiple times per writing"},{"text":" ","type":"text"},{"type":"text","text":"operation."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As an example, here’s an implementation of an output stream that converts"},{"type":"text","text":" "},{"type":"text","text":"any input to its plain ASCII representation before sending it to standard"},{"type":"text","text":" "},{"type":"text","text":"output."}],"type":"paragraph"},{"code":["struct ASCIILogger: TextOutputStream {","    mutating func write(_ string: String) {","        let ascii = string.unicodeScalars.lazy.map { scalar in","            scalar == \"\\n\"","              ? \"\\n\"","              : scalar.escaped(asASCII: true)","        }","        print(ascii.joined(separator: \"\"), terminator: \"\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"ASCIILogger","type":"codeVoice"},{"type":"text","text":" type’s "},{"code":"write(_:)","type":"codeVoice"},{"text":" method processes its string input by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"escaping each Unicode scalar, with the exception of "},{"code":"\"\\n\"","type":"codeVoice"},{"text":" line returns.","type":"text"},{"type":"text","text":" "},{"text":"By sending the output of the ","type":"text"},{"type":"codeVoice","code":"print(_:to:)"},{"type":"text","text":" function to an instance of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ASCIILogger"},{"type":"text","text":", you invoke its "},{"code":"write(_:)","type":"codeVoice"},{"type":"text","text":" method."}]},{"type":"codeListing","syntax":"swift","code":["let s = \"Hearts ♡ and Diamonds ♢\"","print(s)","// Prints \"Hearts ♡ and Diamonds ♢\"","","var asciiLogger = ASCIILogger()","print(s, to: &asciiLogger)","// Prints \"Hearts \\u{2661} and Diamonds \\u{2662}\""]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","metadata":{"externalID":"s:s16TextOutputStreamP","symbolKind":"protocol","roleHeading":"Protocol","title":"TextOutputStream","role":"symbol","modules":[{"name":"Swift"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TextOutputStream"}],"navigatorTitle":[{"kind":"identifier","text":"TextOutputStream"}]},"relationshipsSections":[{"title":"Inherited By","identifiers":["doc://com.apple.Swift/documentation/Swift/StringProtocol"],"type":"inheritedBy","kind":"relationships"},{"kind":"relationships","title":"Conforming Types","identifiers":["doc://com.apple.Swift/documentation/Swift/DefaultStringInterpolation","doc://com.apple.Swift/documentation/Swift/String","doc://com.apple.Swift/documentation/Swift/Substring"],"type":"conformingTypes"}],"references":{"doc://com.apple.Swift/documentation/Swift/Substring":{"navigatorTitle":[{"text":"Substring","kind":"identifier"}],"title":"Substring","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Substring","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Substring","type":"topic","role":"symbol","abstract":[{"t