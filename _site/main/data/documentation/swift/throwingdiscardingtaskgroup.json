{"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc://com.apple.Swift/documentation/Swift/BitwiseCopyable"]}],"sections":[],"seeAlsoSections":[{"generated":true,"anchor":"Tasks","title":"Tasks","identifiers":["doc://com.apple.Swift/documentation/Swift/Task","doc://com.apple.Swift/documentation/Swift/TaskGroup","doc://com.apple.Swift/documentation/Swift/withTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","doc://com.apple.Swift/documentation/Swift/withThrowingTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/TaskPriority","doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup","doc://com.apple.Swift/documentation/Swift/withDiscardingTaskGroup(returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/withThrowingDiscardingTaskGroup(returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/UnsafeCurrentTask"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/throwingdiscardingtaskgroup"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"A throwing discarding group that contains dynamically created child tasks.","type":"text"}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"metadata":{"roleHeading":"Structure","role":"symbol","externalID":"s:12_Concurrency27ThrowingDiscardingTaskGroupV","symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"ThrowingDiscardingTaskGroup"}],"title":"ThrowingDiscardingTaskGroup","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ThrowingDiscardingTaskGroup"}],"modules":[{"relatedModules":[],"name":"Swift"}]},"topicSections":[{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/isCancelled","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/isEmpty"]},{"generated":true,"anchor":"Instance-Methods","title":"Instance Methods","identifiers":["doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addImmediateTask(name:priority:executorPreference:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addImmediateTaskUnlessCancelled(name:priority:executorPreference:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTask(executorPreference:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTask(name:executorPreference:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTask(name:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTask(priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTaskUnlessCancelled(executorPreference:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTaskUnlessCancelled(name:executorPreference:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTaskUnlessCancelled(name:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTaskUnlessCancelled(priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ThrowingDiscardingTaskGroup","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Failure","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Failure","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Error","identifier":"doc://com.apple.Swift/documentation/Swift/Error","kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP"}],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a discarding task group,"},{"type":"text","text":" "},{"type":"text","text":"call the "},{"type":"codeVoice","code":"withDiscardingTaskGroup(returning:body:)"},{"type":"text","text":" method."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Don’t use a task group from outside the task where you created it."},{"type":"text","text":" "},{"type":"text","text":"In most cases,"},{"type":"text","text":" "},{"type":"text","text":"the Swift type system prevents a task group from escaping like that"},{"type":"text","text":" "},{"type":"text","text":"because adding a child task to a task group is a mutating operation,"},{"type":"text","text":" "},{"type":"text","text":"and mutation operations can’t be performed"},{"type":"text","text":" "},{"type":"text","text":"from a concurrent execution context like a child task."}]},{"type":"paragraph","inlineContent":[{"text":"Refer to ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true,"type":"reference"},{"text":" documentation for detailed discussion of semantics shared between all task groups.","type":"text"}]},{"type":"heading","level":3,"anchor":"Discarding-behavior","text":"Discarding behavior"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A discarding task group eagerly discards and releases its child tasks as"},{"type":"text","text":" "},{"type":"text","text":"soon as they complete. This allows for the efficient releasing of memory used"},{"type":"text","text":" "},{"type":"text","text":"by those tasks, which are not retained for future "},{"code":"next()","type":"codeVoice"},{"type":"text","text":" calls, as would"},{"type":"text","text":" "},{"type":"text","text":"be the case with a "},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup"},{"type":"text","text":"."}]},{"type":"heading","level":3,"anchor":"Cancellation-behavior","text":"Cancellation behavior"},{"type":"paragraph","inlineContent":[{"text":"A throwing discarding task group becomes canceled in one of the following ways:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"when ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()","isActive":true,"type":"reference"},{"text":" is invoked on it,","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"when an error is thrown out of the ","type":"text"},{"code":"withThrowingDiscardingTaskGroup { ... }","type":"codeVoice"},{"text":" closure,","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"when the "},{"isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/Task","type":"reference"},{"type":"text","text":" running this task group is canceled."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"But also, and uniquely in "},{"inlineContent":[{"text":"discarding","type":"text"}],"type":"emphasis"},{"type":"text","text":" task groups:"}]},{"items":[{"content":[{"inlineContent":[{"text":"when ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"any"}]},{"text":" of its child tasks throws.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The group becoming canceled automatically, and cancelling all of its child tasks,"},{"type":"text","text":" "},{"type":"text","text":"whenever "},{"type":"emphasis","inlineContent":[{"text":"any","type":"text"}]},{"type":"text","text":" child task throws an error is a behavior unique to discarding task groups,"},{"type":"text","text":" "},{"type":"text","text":"because achieving such semantics is not possible otherwise, due to the missing "},{"code":"next()","type":"codeVoice"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"on discarding groups. Accumulating task groups can implement this by manually polling "},{"type":"codeVoice","code":"next()"},{"type":"text","text":" "},{"type":"text","text":"and deciding to "},{"type":"codeVoice","code":"cancelAll()"},{"type":"text","text":" when they decide an error should cause the group to become canceled,"},{"type":"text","text":" "},{"type":"text","text":"however a discarding group cannot poll child tasks for results and therefore assumes that child"},{"type":"text","text":" "},{"type":"text","text":"task throws are an indication of a group wide failure. In order to avoid such behavior,"},{"type":"text","text":" "},{"type":"text","text":"use a "},{"identifier":"doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup","type":"reference","isActive":true},{"type":"text","text":" instead of a throwing one, or catch specific errors in"},{"type":"text","text":" "},{"type":"text","text":"operations submitted using "},{"type":"codeVoice","code":"addTask"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Since a ","type":"text"},{"type":"codeVoice","code":"ThrowingDiscardingTaskGroup"},{"text":" is a structured concurrency primitive, cancellation is","type":"text"},{"text":" ","type":"text"},{"text":"automatically propagated through all of its child-tasks (and their child","type":"text"},{"text":" ","type":"text"},{"text":"tasks).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A canceled task group can still keep adding tasks, however they will start","type":"text"},{"text":" ","type":"text"},{"text":"being immediately canceled, and may act accordingly to this. To avoid adding","type":"text"},{"text":" ","type":"text"},{"text":"new tasks to an already canceled task group, use ","type":"text"},{"code":"addTaskUnlessCancelled(priority:body:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"rather than the plain ","type":"text"},{"code":"addTask(priority:body:)","type":"codeVoice"},{"text":" which adds tasks unconditionally.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For information about the language-level concurrency model that ","type":"text"},{"type":"codeVoice","code":"DiscardingTaskGroup"},{"type":"text","text":" is part of,"},{"type":"text","text":" "},{"type":"text","text":"see "},{"type":"reference","identifier":"https://docs.swift.org/swift-book/LanguageGuide/Concurrency.html","isActive":true},{"type":"text","text":" in "},{"type":"reference","identifier":"https://docs.swift.org/swift-book/","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"name":"See Also","style":"note","content":[{"inlineContent":[{"type":"text","text":""},{"type":"reference","isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup"}],"type":"paragraph"}],"type":"aside"},{"name":"See Also","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","type":"reference","isActive":true}]}],"type":"aside"},{"name":"See Also","style":"note","content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup","type":"reference"}],"type":"paragraph"}],"type":"aside"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/do