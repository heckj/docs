{"abstract":[{"text":"A throwing discarding group that contains dynamically created child tasks.","type":"text"}],"metadata":{"modules":[{"name":"Swift","relatedModules":[]}],"externalID":"s:12_Concurrency27ThrowingDiscardingTaskGroupV","roleHeading":"Structure","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ThrowingDiscardingTaskGroup"}],"title":"ThrowingDiscardingTaskGroup","navigatorTitle":[{"kind":"identifier","text":"ThrowingDiscardingTaskGroup"}],"symbolKind":"struct"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc://com.apple.Swift/documentation/Swift/BitwiseCopyable"],"kind":"relationships","type":"conformsTo"}],"seeAlsoSections":[{"generated":true,"title":"Tasks","identifiers":["doc://com.apple.Swift/documentation/Swift/Task","doc://com.apple.Swift/documentation/Swift/TaskGroup","doc://com.apple.Swift/documentation/Swift/withTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","doc://com.apple.Swift/documentation/Swift/withThrowingTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/TaskPriority","doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup","doc://com.apple.Swift/documentation/Swift/withDiscardingTaskGroup(returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/withThrowingDiscardingTaskGroup(returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/UnsafeCurrentTask"],"anchor":"Tasks"}],"topicSections":[{"generated":true,"title":"Instance Properties","identifiers":["doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/isCancelled","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/isEmpty"],"anchor":"Instance-Properties"},{"anchor":"Instance-Methods","generated":true,"title":"Instance Methods","identifiers":["doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addImmediateTask(name:priority:executorPreference:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addImmediateTaskUnlessCancelled(name:priority:executorPreference:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTask(executorPreference:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTask(name:executorPreference:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTask(name:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTask(priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTaskUnlessCancelled(executorPreference:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTaskUnlessCancelled(name:executorPreference:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTaskUnlessCancelled(name:priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/addTaskUnlessCancelled(priority:operation:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()"]}],"kind":"symbol","variants":[{"paths":["/documentation/swift/throwingdiscardingtaskgroup"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ThrowingDiscardingTaskGroup","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Failure","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Failure","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Error","text":"Error","kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP"}]}]},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"To create a discarding task group,"},{"type":"text","text":" "},{"type":"text","text":"call the "},{"type":"codeVoice","code":"withDiscardingTaskGroup(returning:body:)"},{"type":"text","text":" method."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Don’t use a task group from outside the task where you created it."},{"type":"text","text":" "},{"type":"text","text":"In most cases,"},{"type":"text","text":" "},{"type":"text","text":"the Swift type system prevents a task group from escaping like that"},{"type":"text","text":" "},{"type":"text","text":"because adding a child task to a task group is a mutating operation,"},{"type":"text","text":" "},{"type":"text","text":"and mutation operations can’t be performed"},{"type":"text","text":" "},{"type":"text","text":"from a concurrent execution context like a child task."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Refer to "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true},{"type":"text","text":" documentation for detailed discussion of semantics shared between all task groups."}],"type":"paragraph"},{"text":"Discarding behavior","anchor":"Discarding-behavior","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"A discarding task group eagerly discards and releases its child tasks as"},{"type":"text","text":" "},{"type":"text","text":"soon as they complete. This allows for the efficient releasing of memory used"},{"type":"text","text":" "},{"type":"text","text":"by those tasks, which are not retained for future "},{"type":"codeVoice","code":"next()"},{"type":"text","text":" calls, as would"},{"type":"text","text":" "},{"type":"text","text":"be the case with a "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Cancellation behavior","anchor":"Cancellation-behavior","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"A throwing discarding task group becomes canceled in one of the following ways:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"when "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()","isActive":true},{"type":"text","text":" is invoked on it,"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"when an error is thrown out of the "},{"type":"codeVoice","code":"withThrowingDiscardingTaskGroup { ... }"},{"type":"text","text":" closure,"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"when the "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/Task","isActive":true},{"type":"text","text":" running this task group is canceled."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"But also, and uniquely in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"discarding"}]},{"type":"text","text":" task groups:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"when "},{"type":"emphasis","inlineContent":[{"type":"text","text":"any"}]},{"type":"text","text":" of its child tasks throws."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The group becoming canceled automatically, and cancelling all of its child tasks,"},{"type":"text","text":" "},{"type":"text","text":"whenever "},{"type":"emphasis","inlineContent":[{"type":"text","text":"any"}]},{"type":"text","text":" child task throws an error is a behavior unique to discarding task groups,"},{"type":"text","text":" "},{"type":"text","text":"because achieving such semantics is not possible otherwise, due to the missing "},{"type":"codeVoice","code":"next()"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"on discarding groups. Accumulating task groups can implement this by manually polling "},{"type":"codeVoice","code":"next()"},{"type":"text","text":" "},{"type":"text","text":"and deciding to "},{"type":"codeVoice","code":"cancelAll()"},{"type":"text","text":" when they decide an error should cause the group to become canceled,"},{"type":"text","text":" "},{"type":"text","text":"however a discarding group cannot poll child tasks for results and therefore assumes that child"},{"type":"text","text":" "},{"type":"text","text":"task throws are an indication of a group wide failure. In order to avoid such behavior,"},{"type":"text","text":" "},{"type":"text","text":"use a "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup","isActive":true},{"type":"text","text":" instead of a throwing one, or catch specific errors in"},{"type":"text","text":" "},{"type":"text","text":"operations submitted using "},{"type":"codeVoice","code":"addTask"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Since a "},{"type":"codeVoice","code":"ThrowingDiscardingTaskGroup"},{"type":"text","text":" is a structured concurrency primitive, cancellation is"},{"type":"text","text":" "},{"type":"text","text":"automatically propagated through all of its child-tasks (and their child"},{"type":"text","text":" "},{"type":"text","text":"tasks)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A canceled task group can still keep adding tasks, however they will start"},{"type":"text","text":" "},{"type":"text","text":"being immediately canceled, and may act accordingly to this. To avoid adding"},{"type":"text","text":" "},{"type":"text","text":"new tasks to an already canceled task group, use "},{"type":"codeVoice","code":"addTaskUnlessCancelled(priority:body:)"},{"type":"text","text":" "},{"type":"text","text":"rather than the plain "},{"type":"codeVoice","code":"addTask(priority:body:)"},{"type":"text","text":" which adds tasks unconditionally."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For information about the language-level concurrency model that "},{"type":"codeVoice","code":"DiscardingTaskGroup"},{"type":"text","text":" is part of,"},{"type":"text","text":" "},{"type":"text","text":"see "},{"type":"reference","identifier":"https://docs.swift.org/swift-book/LanguageGuide/Concurrency.html","isActive":true},{"type":"text","text":" in "},{"type":"reference","identifier":"https://docs.swift.org/swift-book/","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"name":"See Also","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup"}]}],"type":"aside"},{"name":"See Also","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup"}]}],"type":"aside"},{"name":"See Also","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup"}]}],"type":"aside"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/isCancelled":{"abstract":[{"text":"A Boolean value that indicates whether the group was canceled.","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isCancelled"},{"ki