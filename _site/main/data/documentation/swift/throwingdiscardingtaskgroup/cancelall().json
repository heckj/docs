{"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["/documentation/swift/throwingdiscardingtaskgroup/cancelall()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","modules":[{"relatedModules":[],"name":"Swift"}],"roleHeading":"Instance Method","title":"cancelAll()","externalID":"s:12_Concurrency27ThrowingDiscardingTaskGroupV9cancelAllyyF","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancelAll","kind":"identifier"},{"text":"()","kind":"text"}]},"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancelAll","kind":"identifier"},{"text":"()","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you add a task to a group after canceling the group,"},{"type":"text","text":" "},{"type":"text","text":"that task is canceled immediately after being added to the group."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Immediately canceled child tasks should therefore cooperatively check for and"},{"type":"text","text":" "},{"type":"text","text":"react  to cancellation, e.g. by throwing an "},{"type":"codeVoice","code":"CancellationError"},{"type":"text","text":" at their"},{"type":"text","text":" "},{"type":"text","text":"earliest convenience, or otherwise handling the cancellation."}]},{"inlineContent":[{"text":"There are no restrictions on where you can call this method.","type":"text"},{"text":" ","type":"text"},{"text":"Code inside a child task or even another task can cancel a group,","type":"text"},{"text":" ","type":"text"},{"text":"however one should be very careful to not keep a reference to the","type":"text"},{"text":" ","type":"text"},{"text":"group longer than the ","type":"text"},{"code":"with...TaskGroup(...) { ... }","type":"codeVoice"},{"text":" method body is executing.","type":"text"}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"Task.isCancelled","type":"codeVoice"}]}],"type":"aside","name":"See Also"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"ThrowingDiscardingTaskGroup.isCancelled"}]}],"type":"aside","name":"See Also"}]}],"abstract":[{"text":"Cancel all of the remaining tasks in the group.","type":"text"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup"]]},"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()":{"abstract":[{"type":"text","text":"Cancel all of the remaining tasks in the group."}],"type":"topic","title":"cancelAll()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"cancelAll"},{"kind":"text","text":"()"}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()","role":"symbol","url":"/documentation/swift/throwingdiscardingtaskgroup/cancelall()"},"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup":{"role":"symbol","navigatorTitle":[{"text":"ThrowingDiscardingTaskGroup","kind":"identifier"}],"abstract":[{"type":"text","text":"A throwing discarding group that contains dynamically created child tasks."}],"identif