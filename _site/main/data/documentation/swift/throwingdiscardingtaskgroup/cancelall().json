{"metadata":{"modules":[{"name":"Swift","relatedModules":[]}],"symbolKind":"method","roleHeading":"Instance Method","externalID":"s:12_Concurrency27ThrowingDiscardingTaskGroupV9cancelAllyyF","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancelAll","kind":"identifier"},{"text":"()","kind":"text"}],"title":"cancelAll()"},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup"]]},"abstract":[{"type":"text","text":"Cancel all of the remaining tasks in the group."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"cancelAll"},{"kind":"text","text":"()"}],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you add a task to a group after canceling the group,"},{"type":"text","text":" "},{"type":"text","text":"that task is canceled immediately after being added to the group."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Immediately canceled child tasks should therefore cooperatively check for and"},{"type":"text","text":" "},{"type":"text","text":"react  to cancellation, e.g. by throwing an "},{"type":"codeVoice","code":"CancellationError"},{"type":"text","text":" at their"},{"type":"text","text":" "},{"type":"text","text":"earliest convenience, or otherwise handling the cancellation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are no restrictions on where you can call this method."},{"type":"text","text":" "},{"type":"text","text":"Code inside a child task or even another task can cancel a group,"},{"type":"text","text":" "},{"type":"text","text":"however one should be very careful to not keep a reference to the"},{"type":"text","text":" "},{"type":"text","text":"group longer than the "},{"type":"codeVoice","code":"with...TaskGroup(...) { ... }"},{"type":"text","text":" method body is executing."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"Task.isCancelled"}]}],"style":"note","name":"See Also"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"ThrowingDiscardingTaskGroup.isCancelled"}]}],"style":"note","name":"See Also"}],"kind":"content"}],"variants":[{"paths":["/documentation/swift/throwingdiscardingtaskgroup/cancelall()"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"kind":"symbol","references":{"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()":{"url":"/documentation/swift/throwingdiscardingtaskgroup/cancelall()","kind":"symbol","type":"topic","title":"cancelAll()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancelAll","kind":"identifier"},{"text":"()","kind":"text"}],"identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup/cancelAll()","abstract":[{"type":"text","text":"Cancel all of the remaining tasks in the group."}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup":{"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup","role":"symbol","type":"topic","url":"/documentation/swift/throwingdiscardingtaskgroup","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ThrowingDiscardingTaskGroup","kind":"identifier"}],"abstract":[{"type":"text","text":"A throwing discarding group that contains dynamically created child tasks."}],"navigatorTitle":[{"text":"ThrowingDiscardingTaskGroup","k