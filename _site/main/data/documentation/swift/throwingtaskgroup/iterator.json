{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Iterator"}]}]},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The elements returned by this iterator"},{"type":"text","text":" "},{"type":"text","text":"appear in the order that the tasks "},{"inlineContent":[{"type":"text","text":"completed"}],"type":"emphasis"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"not in the order that those tasks were added to the task group."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This iterator terminates after all tasks have completed successfully,"},{"type":"text","text":" "},{"type":"text","text":"or after any task completes by throwing an error."},{"type":"text","text":" "},{"type":"text","text":"If a task completes by throwing an error,"},{"type":"text","text":" "},{"type":"text","text":"it doesn’t return any further task results."},{"type":"text","text":" "},{"type":"text","text":"After iterating over the results of each task,"},{"type":"text","text":" "},{"type":"text","text":"it’s valid to make a new iterator for the task group,"},{"type":"text","text":" "},{"type":"text","text":"which you can use to iterate over the results of new tasks you add to the group."},{"type":"text","text":" "},{"type":"text","text":"You can also make a new iterator to resume iteration"},{"type":"text","text":" "},{"type":"text","text":"after a child task throws an error."},{"type":"text","text":" "},{"type":"text","text":"For example:"}]},{"type":"codeListing","syntax":"swift","code":["group.addTask { 1 }","group.addTask { throw SomeError }","group.addTask { 2 }","","do {","    // Assuming the child tasks complete in order, this prints \"1\"","    // and then throws an error.","    for try await r in group { print(r) }","} catch {","    // Resolve the error.","}","","// Assuming the child tasks complete in order, this prints \"2\".","for try await r in group { print(r) }"]},{"type":"aside","name":"See Also","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"ThrowingTaskGroup.next()"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/throwingtaskgroup/iterator"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"anchor":"Instance-Methods","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/Iterator/cancel()","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/Iterator/next()","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/Iterator/next(isolation:)"],"title":"Instance Methods"},{"anchor":"Type-Aliases","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/Iterator/Element"],"title":"Type Aliases"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/Iterator/AsyncIteratorProtocol-Implementations"],"title":"Default Implementations"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc://com.apple.Swift/documentation/Swift/AsyncIteratorProtocol"],"title":"Conforms To"}],"abstract":[{"type":"text","text":"A type that provides an iteration interface"},{"type":"text","text":" "},{"type":"text","text":"over the results of tasks added to the group."}],"metadata":{"conformance":{"constraints":[{"type":"codeVoice","code":"ChildTaskResult"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Failure"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Error"},{"type":"text","text":"."}],"conformancePrefix":[{"type":"text","text"