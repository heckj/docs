es by throwing an error."},{"type":"text","text":" "},{"type":"text","text":"If a task completes by throwing an error,"},{"type":"text","text":" "},{"type":"text","text":"it doesn’t return any further task results."},{"type":"text","text":" "},{"type":"text","text":"After iterating over the results of each task,"},{"type":"text","text":" "},{"type":"text","text":"it’s valid to make a new iterator for the task group,"},{"type":"text","text":" "},{"type":"text","text":"which you can use to iterate over the results of new tasks you add to the group."},{"type":"text","text":" "},{"type":"text","text":"You can also make a new iterator to resume iteration"},{"type":"text","text":" "},{"type":"text","text":"after a child task throws an error."},{"type":"text","text":" "},{"type":"text","text":"For example:"}],"type":"paragraph"},{"code":["group.addTask { 1 }","group.addTask { throw SomeError }","group.addTask { 2 }","","do {","    // Assuming the child tasks complete in order, this prints \"1\"","    // and then throws an error.","    for try await r in group { print(r) }","} catch {","    // Resolve the error.","}","","// Assuming the child tasks complete in order, this prints \"2\".","for try await r in group { print(r) }"],"syntax":"swift","type":"codeListing"},{"name":"See Also","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"ThrowingTaskGroup.next()"}]}]}]}],"metadata":{"roleHeading":"Structure","symbolKind":"struct","modules":[{"name":"Swift","relatedModules":[]}],"externalID":"s:Scg8IteratorV","title":"ThrowingTaskGroup.Iterator","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Iterator","kind":"identifier"}],"navigatorTitle":[{"text":"Iterator","kind":"identifier"}],"extendedModule":"_Concurrency","conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"code":"ChildTaskResult","type":"codeVoice"},{"type":"text","