ent":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"code":"map(_:)","type":"codeVoice"},{"type":"text","text":" method to transform every element received from a base"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence. Typically, you use this to transform from one type"},{"type":"text","text":" "},{"type":"text","text":"of element to another."}]},{"type":"paragraph","inlineContent":[{"text":"In this example, an asynchronous sequence called ","type":"text"},{"code":"Counter","type":"codeVoice"},{"text":" produces ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" ","type":"text"},{"text":"values from ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"5","type":"codeVoice"},{"text":". The closure provided to the ","type":"text"},{"type":"codeVoice","code":"map(_:)"},{"text":" method","type":"text"},{"text":" ","type":"text"},{"text":"takes each ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" and looks up a corresponding ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" from a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"romanNumeralDict"},{"text":" dictionary. This means the outer ","type":"text"},{"type":"codeVoice","code":"for await in"},{"text":" loop","type":"text"},{"text":" ","type":"text"},{"text":"iterates over ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" instances instead of the underlying ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"that ","type":"text"},{"type":"codeVoice","code":"Counter"},{"text":" produces. Also, the dictionary doesn’t provide a key for","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"4"},{"text":", and the closure throws an error for any key it can’t look up, so","type":"text"},{"text":" ","type":"text"},{"text":"receiving this value from ","type":"text"},{"type":"codeVoice","code":"Counter"},{"text":" ends the modified sequence with an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}]},{"code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","// Prints \"I II III Error: MyError() \""],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/throwingtaskgroup/map(_:)-58nrv"]}],"references":{"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element":{"title":"Element","role":"symbol","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/AsyncSequence/Element","type":"topic","abstract":[{"text":"The type of element produced by this asynchronous sequence.","type":"text"}],"fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Element"}],"required":true,"url":"/documentation/swift/asyncsequence/element"},"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/dropFirst(_:)":{"identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/dropFirst(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"dropFirst","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:12_Concurrency22AsyncDropFirstSequenceV","text":"AsyncDropFirstSequence","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Se