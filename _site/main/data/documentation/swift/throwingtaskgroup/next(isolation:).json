(of:returning:body:)"},{"type":"text","text":" method,"},{"type":"text","text":" "},{"text":"then all remaining child tasks in that group are implicitly canceled.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Don’t call this method from outside the task"},{"text":" ","type":"text"},{"type":"text","text":"where this task group was created."},{"type":"text","text":" "},{"type":"text","text":"In most cases, the Swift type system prevents this mistake;"},{"type":"text","text":" "},{"type":"text","text":"for example, because the "},{"type":"codeVoice","code":"add(priority:operation:)"},{"type":"text","text":" method is mutating,"},{"type":"text","text":" "},{"text":"that method can’t be called from a concurrent execution context like a child task.","type":"text"}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The error thrown by the next child task that completes.","type":"text"}]}],"name":"Throws","style":"note"},{"content":[{"inlineContent":[{"type":"text","text":""},{"code":"nextResult()","type":"codeVoice"}],"type":"paragraph"}],"type":"aside","style":"note","name":"See Also"}]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/nextResult(isolation:)":{"abstract":[{"type":"text","text":"Wait for the next child task to complete,"},{"type":"text","text":" "},{"type":"text","text":"and return a result containing either"},{"type":"text","text":" "},{"type":"text","text":"the value that the child task returned or the error that it threw."}],"title":"nextResult(isolation:)","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/nextResult(isolation:)","url":"/d