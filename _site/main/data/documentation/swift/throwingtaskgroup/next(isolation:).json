aragraph"},{"inlineContent":[{"type":"text","text":"Don’t call this method from outside the task"},{"type":"text","text":" "},{"type":"text","text":"where this task group was created."},{"type":"text","text":" "},{"type":"text","text":"In most cases, the Swift type system prevents this mistake;"},{"type":"text","text":" "},{"type":"text","text":"for example, because the "},{"type":"codeVoice","code":"add(priority:operation:)"},{"type":"text","text":" method is mutating,"},{"type":"text","text":" "},{"type":"text","text":"that method can’t be called from a concurrent execution context like a child task."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The error thrown by the next child task that completes."}]}],"type":"aside","style":"note","name":"Throws"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"nextResult()"}]}],"type":"aside","style":"note","name":"See Also"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/throwingtaskgroup/next(isolation:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.apple.Swift/documentation/Swift/Actor":{"identifier":"doc://com.apple.Swift/documentation/Swift/Actor","navigatorTitle":[{"text":"Actor","kind":"identifier"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Common protocol to which all actors conform."}],"url":"/documentation/swift/actor","role":"symbol","title":"Actor","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Actor","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup":{"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","role":"symbol","type":"topic","url":"/documentation/swift/throwingtaskgroup","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ThrowingTaskGroup","kind":"i