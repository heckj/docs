{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/waitForAll()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup"]]},"kind":"symbol","metadata":{"role":"symbol","externalID":"s:Scg10waitForAllyyYaKF","modules":[{"name":"Swift","relatedModules":[]}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"waitForAll","kind":"identifier"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"}],"roleHeading":"Instance Method","symbolKind":"method","title":"waitForAll()"},"abstract":[{"type":"text","text":"Wait for all of the group’s remaining tasks to complete."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":"(nonsending) "},{"text":"mutating","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"waitForAll","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"throws"}]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If any of the tasks throw, the "},{"type":"emphasis","inlineContent":[{"text":"first","type":"text"}]},{"text":" error thrown is captured","type":"text"},{"text":" ","type":"text"},{"text":"and re-thrown by this method although the task group is ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"not","type":"text"}]},{"text":" canceled","type":"text"},{"text":" ","type":"text"},{"text":"when this happens.","type":"text"}]},{"type":"heading","anchor":"Cancelling-the-task-group-on-first-error","level":3,"text":"Cancelling the task group on first error"},{"inlineContent":[{"text":"If you want to cancel the task group, and all “sibling” tasks,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whenever any of child tasks throws an error, use the following pattern instead:"}],"type":"paragraph"},{"type":"codeListing","code":["while !group.isEmpty {","    do {","        try await group.next()","    } catch is CancellationError {","        // we decide that cancellation errors thrown by children,","        // should not cause cancellation of the entire group.","        continue;","    } catch {","        // other errors though we print and cancel the group,","        // and all of the remaining child tasks within it.","        print(\"Error: \\(error)\")","        group.cancelAll()","    }","}","assert(group.isEmpty())"],"syntax":"swift"},{"type":"aside","name":"Throws","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"first"}]},{"text":" error that was thrown by a child task during draining all the tasks.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This first error is stored until all other tasks have completed, and is re-thrown afterwards."}]}]}],"kind":"content"}],"variants":[{"paths":["/documentation/swift/throwingtaskgroup/waitforall()"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/waitForAll()":{"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup/waitForAll()","role":"symbol","type":"topic","url":"/documentation/swift/throwingtaskgroup/waitfora