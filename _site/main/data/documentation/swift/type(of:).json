{"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/type(of:)"]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/type(of:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"type","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Metatype"},{"kind":"text","text":">("},{"kind":"externalParam","text":"of"},{"kind":"text","text":" "},{"kind":"internalParam","text":"value"},{"kind":"text","text":": "},{"kind":"keyword","text":"borrowing"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:s4type2ofq_x_tRi_zRi0_zr0_lF1TL_xmfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Metatype","preciseIdentifier":"s:s4type2ofq_x_tRi_zRi0_zr0_lF8MetatypeL_q_mfp"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":" : ~Copyable, "},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":" : ~Escapable"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The value for which to find the dynamic type."}],"type":"paragraph"}],"name":"value"}]},{"content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"The dynamic type, which is a metatype instance.","type":"text"}]}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"You can use the "},{"type":"codeVoice","code":"type(of:)"},{"type":"text","text":" function to find the dynamic type of a value,"},{"type":"text","text":" "},{"type":"text","text":"particularly when the dynamic type is different from the static type. The"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"static type"}]},{"text":" of a value is the known, compile-time type of the value. The","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"dynamic type","type":"text"}],"type":"emphasis"},{"text":" of a value is the value’s actual type at run-time, which","type":"text"},{"text":" ","type":"text"},{"text":"can be a subtype of its concrete type.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the following code, the "},{"type":"codeVoice","code":"count"},{"type":"text","text":" variable has the same static and dynamic"},{"type":"text","text":" "},{"type":"text","text":"type: "},{"type":"codeVoice","code":"Int"},{"type":"text","text":". When "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is passed to the "},{"type":"codeVoice","code":"printInfo(_:)"},{"type":"text","text":" function,"},{"type":"text","text":" "},{"type":"text","text":"however, the "},{"type":"codeVoice","code":"value"},{"type":"text","text":" parameter has a static type of "},{"type":"codeVoice","code":"Any"},{"type":"text","text":" (the type"},{"type":"text","text":" "},{"type":"text","text":"declared for the parameter) and a dynamic type of "},{"type":"codeVoice","code":"Int"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["func printInfo(_ value: Any) {","    let t = type(of: value)","    print(\"'\\(value)' of type '\\(t)'\")","}","","let count: Int = 5","printInfo(count)","// '5' of type 'Int'"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The dynamic type returned from "},{"type":"codeVoice","code":"type(of:)"},{"type":"text","text":" is a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"concrete metatype"}]},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"T.Type"},{"text":") for a class, structure, enumeration, or other nonprotocol type","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"T"},{"text":", or an ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"existential metatype","type":"text"}]},{"text":" (","type":"text"},{"type":"codeVoice","code":"P.Type"},{"text":") for a protocol or protocol","type":"text"},{"text":" ","type":"text"},{"text":"composition ","type":"text"},{"type":"codeVoice","code":"P"},{"text":". When the static type of the value passed to ","type":"text"},{"type":"codeVoice","code":"type(of:)"},{"text":" ","type":"text"},{"text":"is constrained to a class or protocol, you can use that metatype to access","type":"text"},{"text":" ","type":"text"},{"text":"initializers or other static members of the class or protocol.","type":"text"}]},{"inlineContent":[{"text":"For example, the parameter passed as ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" to the ","type":"text"},{"type":"codeVoice","code":"printSmileyInfo(_:)"},{"text":" ","type":"text"},{"text":"function in the example below is an instance of the ","type":"text"},{"type":"codeVoice","code":"Smiley"},{"text":" class or one","type":"text"},{"text":" ","type":"text"},{"text":"of its subclasses. The function uses ","type":"text"},{"type":"codeVoice","code":"type(of:)"},{"type":"text","text":" to find the dynamic type"},{"type":"text","text":" "},{"text":"of ","type":"text"},{"type":"codeVoice","code":"value"},{"text":", which itself is an instance of the ","type":"text"},{"type":"codeVoice","code":"Smiley.Type"},{"text":" metatype.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class Smiley {","    class var text: String {","        return \":)\"","    }","}","","class EmojiSmiley: Smiley {","     override class var text: String {","        return \"😀\"","    }","}","","func printSmileyInfo(_ value: Smiley) {","    let smileyType = type(of: value)","    print(\"Smile!\", smileyType.text)","}","","let emojiSmiley = EmojiSmiley()","printSmileyInfo(emojiSmiley)","// Smile! 😀"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example, accessing the "},{"type":"codeVoice","code":"text"},{"type":"text","text":" property of the "},{"type":"codeVoice","code":"smileyType"},{"type":"text","text":" metatype"},{"type":"text","text":" "},{"type":"text","text":"retrieves the overridden value from the "},{"type":"codeVoice","code":"EmojiSmiley"},{"type":"text","text":" subclass, instead of"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"Smiley"},{"type":"text","text":" class’s original definition."}]},{"level":1,"type":"heading","anchor":"Finding-the-Dynamic-Type-in-a-Generic-Context","text":"Finding the Dynamic Type in a Generic Context"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Normally, you don’t need to be aware of the difference between concrete and"},{"type":"text","text":" "},{"type":"text","text":"existential metatypes, but calling "},{"type":"codeVoice","code":"type(of:)"},{"type":"text","text":" can yield unexpected"},{"type":"text","text":" "},{"type":"text","text":"results in a generic context with a type parameter bound to a protocol. In"},{"type":"text","text":" "},{"type":"text","text":"a case like this, where a generic parameter "},{"type":"codeVoice","code":"T"},{"type":"text","text":" is bound to a protocol"},{"type":"text","text":" "},{"type":"codeVoice","code":"P"},{"type":"text","text":", the type parameter is not statically known to be a protocol type in"},{"type":"text","text":" "},{"type":"text","text":"the body of the generic function. As a result, "},{"type":"codeVoice","code":"type(of:)"},{"type":"text","text":" can only"},{"type":"text","text":" "},{"type":"text","text":"produce the concrete metatype "},{"type":"codeVoice","code":"P.Protocol"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The following example defines a "},{"type":"codeVoice","code":"printGenericInfo(_:)"},{"type":"text","text":" function that takes"},{"type":"text","text":" "},{"type":"text","text":"a generic parameter and declares the "},{"type":"codeVoice","code":"String"},{"type":"text","text":" type’s conformance to a new"},{"type":"text","text":" "},{"type":"text","text":"protocol "},{"code":"P","type":"codeVoice"},{"text":". When ","type":"text"},{"code":"printGenericInfo(_:)","type":"codeVoice"},{"text":" is called with a string that has","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"P"},{"text":" as its static type, the call to ","type":"text"},{"code":"type(of:)","type":"codeVoice"},{"text":" returns ","type":"text"},{"type":"codeVoice","code":"P.self"},{"type":"text","text":" instead"},{"text":" ","type":"text"},{"type":"text","text":"of "},{"type":"codeVoice","code":"String.self"},{"type":"text","text":" (the dynamic type inside the parameter)."}],"type":"paragraph"},{"code":["func printGenericInfo<T>(_ value: T) {","    let t = type(of: value)","    print(\"'\\(value)' of type '\\(t)'\")","}","","protocol P {}","extension String: P {}","","let stringAsP: P = \"Hello!\"","printGenericInfo(stringAsP)","// 'Hello!' of type 'P'"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This unexpected result occurs because the call to ","type":"text"},{"code":"type(of: value)","type":"codeVoice"},{"text":" inside","type":"text"},{"text":" ","type":"text"},{"code":"printGenericInfo(_:)","type":"codeVoice"},{"text":" must return a metatype that is an instance of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"T.Type"},{"type":"text","text":", but "},{"type":"codeVoice","code":"String.self"},{"text":" (the expected dynamic type) is not an instance","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"code":"P.Type","type":"codeVoice"},{"type":"text","text":" (the concrete metatype of "},{"type":"codeVoice","code":"value"},{"text":"). To get the dynamic type","type":"text"},{"text":" ","type":"text"},{"text":"inside ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":" in this generic context, cast the parameter to "},{"type":"codeVoice","code":"Any"},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"code":"type(of:)","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"codeListing","code":["func betterPrintGenericInfo<T>(_ value: T) {","    let t = type(of: value as Any)","    print(\"'\\(value)' of type '\\(t)'\")","}","","betterPrintGenericInfo(stringAsP)","// 'Hello!' of type 'String'"],"syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"kind":"symbol","abstract":[{"text":"Returns the dynamic type of a value.","type":"text"}],"seeAlsoSections":[{"anchor":"Querying-Runtime-Values","title":"Querying Runtime Values","identifiers":["doc://com.apple.Swift/documentation/Swift/Mirror","doc://com.apple.Swift/documentation/Swift/ObjectIdentifier","doc://com.apple.Swift/documentation/Swift/==(_:_:)-958in","doc://com.apple.Swift/documentation/Swift/!=(_:_:)-18co7"],"generated":true}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"type"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Metatype"},{"kind":"text","text":">("},{"kind":"externalParam","text":"of"},{"kind":"text","text":": "},{"kind":"keyword","text":"borrowing"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4type2ofq_x_tRi_zRi0_zr0_lF1TL_xmfp","text":"T"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4type2ofq_x_tRi_zRi0_zr0_lF8MetatypeL_q_mfp","text":"Metatype"}],"title":"type(of:)","role":"symbol","externalID":"s:s4type2ofq_x_tRi_zRi0_zr0_lF","symbolKind":"func","roleHea