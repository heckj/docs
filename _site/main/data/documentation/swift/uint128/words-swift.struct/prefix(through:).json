{"abstract":[{"type":"text","text":"Returns a subsequence from the start of the collection through the"},{"type":"text","text":" "},{"type":"text","text":"specified position."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"prefix","kind":"identifier"},{"text":"(","kind":"text"},{"text":"through","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"position","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Index","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","preciseIdentifier":"s:Sl5IndexQa"},{"text":") -> ","kind":"text"},{"text":"SubSequence","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"position","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The index of the last element to include in the"},{"type":"text","text":" "},{"type":"text","text":"resulting subsequence. "},{"type":"codeVoice","code":"position"},{"type":"text","text":" must be a valid index of the collection"},{"type":"text","text":" "},{"type":"text","text":"that is not equal to the "},{"type":"codeVoice","code":"endIndex"},{"type":"text","text":" property."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"text":"A subsequence up to, and including, the given position.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"The resulting subsequence "},{"type":"emphasis","inlineContent":[{"type":"text","text":"includes"}]},{"type":"text","text":" the element at the position"},{"type":"text","text":" "},{"type":"text","text":"specified by the "