ext","text":" as the right-hand-side value in an"},{"type":"text","text":" "},{"type":"text","text":"operation on "},{"type":"codeVoice","code":"x"},{"type":"text","text":", the shift amount requires no masking."}],"type":"paragraph"},{"code":["var x: UInt8 = 30                 // 0b00011110","x &<<= 2","// x == 120                       // 0b01111000"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"However, if you pass "},{"type":"codeVoice","code":"19"},{"type":"text","text":" as "},{"type":"codeVoice","code":"rhs"},{"type":"text","text":", the method first bitmasks "},{"type":"codeVoice","code":"rhs"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"codeVoice","code":"3"},{"type":"text","text":", and then uses that masked value as the number of bits to shift "},{"type":"codeVoice","code":"lhs"},{"type":"text","text":"."}],"type":"paragraph"},{"code":["var y: UInt8 = 30                 // 0b00011110","y &<<= 19","// y == 240                       // 0b11110000"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UInt16"]]},"references":{"doc://com.apple.Swift/documentation/Swift/BinaryInteger":{"navigatorTitle":[{"kind":"identifier","text":"BinaryInteger"}],"url":"/documentation/swift/binaryinteger","title":"BinaryInteger","abstract":[{"type":"text","text":"An integer type with a binary representation."}],"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"BinaryInteger"}],"identifier":"doc://com.apple.Swift/documentation/Swift/BinaryInteger","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"te