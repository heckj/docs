xt","text":"Using the "},{"type":"codeVoice","code":"prefix(upTo:)"},{"type":"text","text":" method is equivalent to using a partial"},{"type":"text","text":" "},{"type":"text","text":"half-open range as the collection’s subscript. The subscript notation is"},{"type":"text","text":" "},{"type":"text","text":"preferred over "},{"type":"codeVoice","code":"prefix(upTo:)"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["if let i = numbers.firstIndex(of: 40) {","    print(numbers[..<i])","}","// Prints \"[10, 20, 30]\""],"type":"codeListing"},{"name":"Complexity","content":[{"inlineContent":[{"type":"text","text":"O(1)"}],"type":"paragraph"}],"style":"note","type":"aside"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/UInt16":{"url":"/documentation/swift/uint16","role":"symbol","title":"UInt16","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"UInt16"}],"kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"UInt16"}],"identifier":"doc://com.apple.Swift/documentation/Swift/UInt16","abstract":[{"type":"text","text":"A 16-bit unsigned integer value"},{"type":"text","text":" "},{"type":"text","text":"type."}]},"doc://com.apple.Swift/documentation/Swift/Collection/Index":{"required":true,"url":"/documentation/swift/collection/index","role":"symbol","title":"Index","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Index","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SL","text":"Comparable","kind":"typeIdentifier"}],"kind":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/