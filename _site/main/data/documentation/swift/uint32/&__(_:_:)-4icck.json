"},{"type":"codeVoice","code":"UInt8"},{"type":"text","text":", an 8-bit,"},{"type":"text","text":" "},{"type":"text","text":"unsigned integer type. If you use "},{"code":"2","type":"codeVoice"},{"type":"text","text":" as the right-hand-side value in an"},{"type":"text","text":" "},{"type":"text","text":"operation on "},{"code":"x","type":"codeVoice"},{"text":", the shift amount requires no masking.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let x: UInt8 = 30                 // 0b00011110","let y = x &>> 2","// y == 7                         // 0b00000111"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"However, if you use "},{"type":"codeVoice","code":"8"},{"type":"text","text":" as the shift amount, the method first masks the"},{"text":" ","type":"text"},{"text":"shift amount to zero, and then performs the shift, resulting in no change","type":"text"},{"text":" ","type":"text"},{"text":"to the original value.","type":"text"}]},{"code":["let z = x &>> 8","// z == 30                        // 0b00011110"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"If the bit width of the shifted integer type is a power of two, masking","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is performed using a bitmask; otherwise, masking is performed using a"},{"text":" ","type":"text"},{"type":"text","text":"modulo operation."}],"type":"paragraph"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/BinaryInteger":{"type":"topic","url":"/documentation/swift/binaryinteger","identifier":"doc://com.apple.Swift/documentation/Swift/BinaryInteger","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"BinaryInteger","kind":"identifier"}],"title":"BinaryInteger","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"BinaryInteger"}],"abstract":[{"text":"An integer type with a binary representation.","type":"text"}]},"doc://com.apple.Swift/documentation/Swift