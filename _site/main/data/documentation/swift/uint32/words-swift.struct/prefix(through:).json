ph"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"The resulting subsequence ","type":"text"},{"inlineContent":[{"text":"includes","type":"text"}],"type":"emphasis"},{"text":" the element at the position","type":"text"},{"text":" ","type":"text"},{"text":"specified by the ","type":"text"},{"type":"codeVoice","code":"through"},{"text":" parameter.","type":"text"},{"text":" ","type":"text"},{"text":"The following example searches for the index of the number ","type":"text"},{"type":"codeVoice","code":"40"},{"text":" in an","type":"text"},{"text":" ","type":"text"},{"text":"array of integers, and then prints the prefix of the array up to, and","type":"text"},{"text":" ","type":"text"},{"text":"including, that index:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let numbers = [10, 20, 30, 40, 50, 60]","if let i = numbers.firstIndex(of: 40) {","    print(numbers.prefix(through: i))","}","// Prints \"[10, 20, 30, 40]\""],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Using the "},{"type":"codeVoice","code":"prefix(through:)"},{"type":"text","text":" method is equivalent to using a partial"},{"text":" ","type":"text"},{"text":"closed range as the collection’s subscript. The subscript notation is","type":"text"},{"text":" ","type":"text"},{"text":"preferred over ","type":"text"},{"type":"codeVoice","code":"prefix(through:)"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["if let i = numbers.firstIndex(of: 40) {","    print(numbers[...i])","}","// Prints \"[10, 20, 30, 40]\""],"type":"codeListing"},{"name":"Complexity","content":[{"type":"paragraph","inlineContent":[{"text":"O(1)","type":"text"}]}],"style":"note","type":"aside"}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/UInt32/Words-swift.struct/prefix(through:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","metadata":{"role":"symbol","externalID