t":" ","type":"text"},{"text":"elements by calling this ","type":"text"},{"type":"codeVoice","code":"reversed()"},{"text":" method. A ","type":"text"},{"type":"codeVoice","code":"ReversedCollection"},{"text":" ","type":"text"},{"text":"instance wraps an underlying collection and provides access to its","type":"text"},{"text":" ","type":"text"},{"text":"elements in reverse order. This example prints the characters of a","type":"text"},{"text":" ","type":"text"},{"text":"string in reverse order:","type":"text"}],"type":"paragraph"},{"code":["let word = \"Backwards\"","for char in word.reversed() {","    print(char, terminator: \"\")","}","// Prints \"sdrawkcaB\""],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"If you need a reversed collection of the same type, you may be able to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use the collection’s sequence-based or collection-based initializer. For"},{"type":"text","text":" "},{"type":"text","text":"example, to get the reversed version of a string, reverse its"},{"type":"text","text":" "},{"type":"text","text":"characters and initialize a new "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instance from the result."}],"type":"paragraph"},{"code":["let reversedWord = String(word.reversed())","print(reversedWord)","// Prints \"sdrawkcaB\""],"syntax":"swift","type":"codeListing"},{"style":"note","name":"Complexity","content":[{"type":"paragraph","inlineContent":[{"text":"O(1)","type":"text"}]}],"type":"aside"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/ReversedCollection":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ReversedCollection"}],"title":"ReversedCollection","type":"topic","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection","kind":"symbol","abstract":[{"type":"text","text":"A collection that presents the elements of its base collection"},{"type":