":[{"type":"text","text":"The overflow addition operator ("},{"type":"codeVoice","code":"&+"},{"type":"text","text":") discards any bits that overflow the"},{"type":"text","text":" "},{"type":"text","text":"fixed width of the integer type. In the following example, the sum of"},{"type":"text","text":" "},{"type":"codeVoice","code":"100"},{"type":"text","text":" and "},{"type":"codeVoice","code":"121"},{"type":"text","text":" is greater than the maximum representable "},{"type":"codeVoice","code":"Int8"},{"type":"text","text":" value,"},{"type":"text","text":" "},{"type":"text","text":"so the result is the partial value after discarding the overflowing"},{"type":"text","text":" "},{"type":"text","text":"bits."}],"type":"paragraph"},{"code":["let x: Int8 = 10 &+ 21","// x == 31","let y: Int8 = 100 &+ 121","// y == -35 (after overflow)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"For more about arithmetic with overflow operators, see "},{"identifier":"https://docs.swift.org/swift-book/LanguageGuide/AdvancedOperators.html#ID37","isActive":true,"type":"reference"},{"type":"text","text":" in "},{"inlineContent":[{"identifier":"https://docs.swift.org/swift-book/","isActive":true,"type":"reference"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Returns the sum of the two given values, wrapping the result in case of"},{"type":"text","text":" "},{"type":"text","text":"any overflow."}],"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/UInt64":{"navigatorTitle":[{"kind":"identifier","text":"UInt64"}],"url":"/documentation/swift/uint64","title":"UInt64","