 as an instance of "},{"type":"codeVoice","code":"UInt8"},{"type":"text","text":", an 8-bit,"},{"type":"text","text":" "},{"type":"text","text":"unsigned integer type. If you use "},{"type":"codeVoice","code":"2"},{"type":"text","text":" as the right-hand-side value in an"},{"type":"text","text":" "},{"type":"text","text":"operation on "},{"type":"codeVoice","code":"x"},{"type":"text","text":", the shift amount requires no masking."}]},{"type":"codeListing","code":["var x: UInt8 = 30                 // 0b00011110","x &>>= 2","// x == 7                         // 0b00000111"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However, if you use "},{"type":"codeVoice","code":"19"},{"type":"text","text":" as "},{"type":"codeVoice","code":"rhs"},{"type":"text","text":", the operation first bitmasks "},{"type":"codeVoice","code":"rhs"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"codeVoice","code":"3"},{"type":"text","text":", and then uses that masked value as the number of bits to shift "},{"type":"codeVoice","code":"lhs"},{"type":"text","text":"."}]},{"type":"codeListing","code":["var y: UInt8 = 30                 // 0b00011110","y &>>= 19","// y == 3                         // 0b00000011"],"syntax":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/UInt8":{"navigatorTitle":[{"text":"UInt8","kind":"identifier"}],"url":"/documentation/swift/uint8","title":"UInt8","abstract":[{"type":"text","text":"An 8-bit unsigned integer value"},{"type":"text","text":" "},{"type":"text","text":"type."}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UInt8","kind":"identifier"}],"identifier":"d