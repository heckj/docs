{"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"abstract":[{"type":"text","text":"A range expression that represents the entire range of a collection."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnboundedRange_","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"You can use the unbounded range operator ("},{"code":"...","type":"codeVoice"},{"type":"text","text":") to create a slice of a"},{"type":"text","text":" "},{"type":"text","text":"collection that contains all of the collection’s elements. Slicing with an"},{"type":"text","text":" "},{"type":"text","text":"unbounded range is essentially a conversion of a collection instance into"},{"text":" ","type":"text"},{"text":"its slice type.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, the following code declares "},{"type":"codeVoice","code":"countLetterChanges(_:_:)"},{"type":"text","text":", a"},{"type":"text","text":" "},{"type":"text","text":"function that finds the number of changes required to change one"},{"type":"text","text":" "},{"type":"text","text":"word or phrase into another. The function uses a recursive approach to"},{"type":"text","text":" "},{"type":"text","text":"perform the same comparisons on smaller and smaller pieces of the original"},{"type":"text","text":" "},{"type":"text","text":"strings. In order to use recursion without making copies of the strings at"},{"type":"text","text":" "},{"type":"text","text":"each step, "},{"type":"codeVoice","code":"countLetterChanges(_:_:)"},{"type":"text","text":" uses "},{"type":"codeVoice","code":"Substring"},{"type":"text","text":", a string’s slice"},{"type":"text","text":" "},{"type":"text","text":"type, for its parameters."}],"type":"paragraph"},{"syntax":"swift","code":["func countLetterChanges(_ s1: Substring, _ s2: Substring) -> Int {","    if s1.isEmpty { return s2.count }","    if s2.isEmpty { return s1.count }","","    let cost = s1.first == s2.first ? 0 : 1","","    return min(","        countLetterChanges(s1.dropFirst(), s2) + 1,","        countLetterChanges(s1, s2.dropFirst()) + 1,","        countLetterChanges(s1.dropFirst(), s2.dropFirst()) + cost)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"To call "},{"type":"codeVoice","code":"countLetterChanges(_:_:)"},{"type":"text","text":" with two strings, use an unbounded"},{"type":"text","text":" "},{"type":"text","text":"range in each string’s subscript."}],"type":"paragraph"},{"syntax":"swift","code":["let word1 = \"grizzly\"","let word2 = \"grisly\"","let changes = countLetterChanges(word1[...], word2[...])","// changes == 2"],"type":"codeListing"}],"kind":"content"}],"sections":[],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/UnboundedRange_","interfaceLanguage":"swift"},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc://com.apple.Swift/documentation/Swift/BitwiseCopyable","doc://com.apple.Swift/documentation/Swift/Sendable"],"kind":"relationships","type":"conformsTo"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"generated":true,"anchor":"Range-Expressions","title":"Range Expressions","identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeUpTo","doc://com.apple.Swift/documentation/Swift/PartialRangeThrough","doc://com.apple.Swift/documentation/Swift/PartialRangeFrom","doc://com.apple.Swift/documentation/Swift/RangeExpression"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unboundedrange_"]}],"topicSections":[{"anchor":"Creating-an-Unbounded-Range","title":"Creating an Unbounded Range","identifiers":["doc://com.apple.Swift/documentation/Swift/UnboundedRange_/...(_:)","doc://com.apple.Swift/documentation/Swift/UnboundedRange"]}],"metadata":{"navigatorTitle":[{"text":"UnboundedRange_","kind":"identifier"}],"symbolKind":"enum","role":"symbol","roleHeading":"Enumeration","externalID":"s:s15UnboundedRange_O","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnboundedRange_","kind":"identifier"}],"modules":[{"name":"Swift"}],"title":"UnboundedRange_"},"references":{"doc://com.apple.Swift/documentation/Swift/UnboundedRange":{"role":"symbol","navigatorTitle":[{"text":"UnboundedRange","kind":"identifier"}],"abstract":[{"type":"text","text":"The type of an unbounded range operator."}],"identifier":"doc://com.apple.Swift/documentation/Swift/UnboundedRange","title":"UnboundedRange","kind":"symbol","type":"topic","url":"/documentation/swift/unboundedrange","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnboundedRange","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/Sendable":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Sendable"}],"type":"topic","title":"Sendable","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","kind":"symbol","abstract":[{"type":"text","text":"A thread-safe type whose values can be shared across arbitrary concurrent"},{"type":"text","text":" "},{"type":"text","text":"contexts without introducing a risk of data races. Values of the type may"},{"type":"text","text":" "},{"type":"text","text":"have no shared mutable state, or they may protect that state with a lock or"},{"type":"text","text":" "},{"type":"text","text":"by forcing it to only be accessed from a specific actor."}],"navigatorTitle":[{"kind":"identifier","text":"Sendable"}],"url":"/documentation/swift/sendable"},"doc://com.apple.Swift/documentation/Swift/UnboundedRange_/...(_:)":{"title":"...(_:)","abstract":[{"type":"text","text":"Creates an unbounded range expression."}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/UnboundedRange_/...(_:)","url":"/documentation/swift/unboundedrange_/'...(_:)","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"...","kind":"identifier"},{"text":" ","kind":"text"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:s15UnboundedRange_O","text":"UnboundedRange_","kind":"typeIdentifier"},{"text":")","kind":"text"}],"type":"topic"},"doc://com.apple.Swift/documentation/Swift/PartialRangeUpTo":{"navigatorTitle":[{"text":"PartialRangeUpTo","kind":"identifier"}],"role":"symbol","title":"PartialRangeUpTo","url":"/documentation/swift/partialrangeupto","identifier":"doc://com.apple.Swift/documentation/Swift/PartialRangeUpTo","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"A partial half-open interval up to, but not including, an upper bound."}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"PartialRangeUpTo","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/PartialRangeThrough":{"identifier":"doc://com.apple.Swift/documentation/Swift/PartialRangeThrough","title":"PartialRangeThrough","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"PartialRangeThrough"}],"navigatorTitle":[{"kind":"identifier","text":"PartialRangeThrough"}],"url":"/documentation/swift/partialrangethrough","abstract":[{"text":"A partial interval up to, and including, an upper bound.","type":"text"}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom":{"title":"PartialRangeFrom","abstract":[{"text":"A partial interval extending upward from a lower bound.","type":"text"}],"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/PartialRangeFrom","url":"/documentation/swift/partialrangefrom","role":"symbol","fragments":[{"