{"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"anchor":"Creating-an-Unbounded-Range","title":"Creating an Unbounded Range","identifiers":["doc://com.apple.Swift/documentation/Swift/UnboundedRange_/...(_:)","doc://com.apple.Swift/documentation/Swift/UnboundedRange"]}],"seeAlsoSections":[{"anchor":"Range-Expressions","generated":true,"title":"Range Expressions","identifiers":["doc://com.apple.Swift/documentation/Swift/PartialRangeUpTo","doc://com.apple.Swift/documentation/Swift/PartialRangeThrough","doc://com.apple.Swift/documentation/Swift/PartialRangeFrom","doc://com.apple.Swift/documentation/Swift/RangeExpression"]}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc://com.apple.Swift/documentation/Swift/BitwiseCopyable","doc://com.apple.Swift/documentation/Swift/Sendable"],"type":"conformsTo"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unboundedrange_"]}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/UnboundedRange_"},"abstract":[{"type":"text","text":"A range expression that represents the entire range of a collection."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnboundedRange_"}]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the unbounded range operator ("},{"type":"codeVoice","code":"..."},{"type":"text","text":") to create a slice of a"},{"type":"text","text":" "},{"type":"text","text":"collection that contains all of the collection’s elements. Slicing with an"},{"type":"text","text":" "},{"type":"text","text":"unbounded range is essentially a conversion of a collection instance into"},{"type":"text","text":" "},{"type":"text","text":"its slice type."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, the following code declares "},{"type":"codeVoice","code":"countLetterChanges(_:_:)"},{"type":"text","text":", a"},{"type":"text","text":" "},{"type":"text","text":"function that finds the number of changes required to change one"},{"type":"text","text":" "},{"type":"text","text":"word or phrase into another. The function uses a recursive approach to"},{"type":"text","text":" "},{"type":"text","text":"perform the same comparisons on smaller and smaller pieces of the original"},{"type":"text","text":" "},{"type":"text","text":"strings. In order to use recursion without making copies of the strings at"},{"type":"text","text":" "},{"type":"text","text":"each step, "},{"type":"codeVoice","code":"countLetterChanges(_:_:)"},{"type":"text","text":" uses "},{"type":"codeVoice","code":"Substring"},{"type":"text","text":", a string’s slice"},{"type":"text","text":" "},{"type":"text","text":"type, for its parameters."}]},{"code":["func countLetterChanges(_ s1: Substring, _ s2: Substring) -> Int {","    if s1.isEmpty { return s2.count }","    if s2.isEmpty { return s1.count }","","    let cost = s1.first == s2.first ? 0 : 1","","    return min(","        countLetterChanges(s1.dropFirst(), s2) + 1,","        countLetterChanges(s1, s2.dropFirst()) + 1,","        countLetterChanges(s1.dropFirst(), s2.dropFirst()) + cost)","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To call "},{"type":"codeVoice","code":"countLetterChanges(_:_:)"},{"type":"text","text":" with two strings, use an unbounded"},{"type":"text","text":" "},{"type":"text","text":"range in each string’s subscript."}]},{"code":["let word1 = \"grizzly\"","let word2 = \"grisly\"","let changes = countLetterChanges(word1[...], word2[...])","// changes == 2"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"symbolKind":"enum","externalID":"s:s15UnboundedRange_O","roleHeading":"Enumeration","modules":[{"name":"Swift"}],"title":"UnboundedRange_","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnboundedRange_"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"UnboundedRange_"}]},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"references":{"doc://com.apple.Swift/documentation/Swift/Sendable":{"type":"topic","abstract":[{"type":"text","text":"A thread-safe type whose values can be shared across arbitrary isolation"},{"type":"text","text":" "},{"type":"text","text":"domains without introducing a risk of data races."}],"title":"Sendable","role":"symbol","url":"/documentation/swift/sendable","identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Sendable"}],"navigatorTitle":[{"kind":"identifier","text":"Sendable"}]},"doc://com.apple.Swift/documentation/Swift/BitwiseCopyable":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/BitwiseCopyable","type":"topic","title":"BitwiseCopyable","kind":"symbol","url":"/documentation/swift/bitwisecopyable","navigatorTitle":[{"text":"BitwiseCopyable","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"BitwiseCopyable","kind":"identifier"}],"abstract":[]},"doc://com.apple.Swift/documentation/Swift/PartialRangeThrough":{"identifier":"doc://com.apple.Swift/documentation/Swift/PartialRangeThrough","abstract":[{"type":"text","text":"A partial interval up to, and including, an upper bound."}],"type":"topic","role":"symbol","url":"/documentation/swift/partialrangethrough","navigatorTitle":[{"text":"PartialRangeThrough","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text