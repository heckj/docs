xt":" "},{"kind":"identifier","text":"CanonicalCombiningClass"}],"modules":[{"name":"Swift"}],"role":"symbol","symbolKind":"struct","extendedModule":"Swift","title":"Unicode.CanonicalCombiningClass"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"CanonicalCombiningClass"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"Canonical combining classes are used by the ordering algorithm to"},{"type":"text","text":" "},{"type":"text","text":"determine if two sequences of combining marks should be considered"},{"type":"text","text":" "},{"type":"text","text":"canonically equivalent (that is, identical in interpretation). Two"},{"type":"text","text":" "},{"type":"text","text":"sequences are canonically equivalent if they are equal when sorting the"},{"type":"text","text":" "},{"type":"text","text":"scalars in ascending order by their combining class."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, consider the sequence "},{"type":"codeVoice","code":"\"\\u{0041}\\u{0301}\\u{0316}\""},{"type":"text","text":" (LATIN"},{"type":"text","text":" "},{"type":"text","text":"CAPITAL LETTER A, COMBINING ACUTE ACCENT, COMBINING GRAVE ACCENT BELOW)."},{"type":"text","text":" "},{"type":"text","text":"The combining classes of these scalars have the numeric values 0, 230, and"},{"type":"text","text":" "},{"type":"text","text":"220, respectively. Sorting these scalars by their combining classes yields"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"\\u{0041}\\u{0316}\\u{0301}\""},{"type":"text","text":", so two strings that differ only by the"},{"type":"text","text":" "},{"type":"text","text":"ordering of those scalars would compare as equal:"}],"type":"paragraph"},{"code":["let aboveBeforeBelow = \"\\u{0041}\\u{0301}\\u{0316}\"","let belowBeforeAbove = \"\\u{0041}\\u{0316}\\u{0301}\"","print(aboveBeforeBelow == belowBeforeAbove)","// Prints \"true\""],"type":"codeListing","syntax":"swift"},{"anchor":"Named-and-Unnamed-Combining-Classes","level":1,"type":"heading","text":"Named and Unnamed Combining Classes"},{"inlineContent":[{"type":"text","text":"Canonical combining classes are defined in the Unicode Standard as"},{"type":"text","text":" "},{"type":"text","text":"integers in the range "},{"type":"codeVoice","code":"0...254"},{"type":"text","text":". For convenience, the standard assigns"},{"type":"text","text":" "},{"type":"text","text":"symbolic names to a subset of these combining classes."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"CanonicalCombiningClass"},{"type":"text","text":" type conforms to "},{"type":"codeVoice","code":"RawRepresentable"},{"type":"text","text":" with a"},{"type":"text","text":" "},{"type":"text","text":"raw value of type "},{"type":"codeVoice","code":"UInt8"},{"type":"text","text":". You can create instances of the type by using"},{"type":"text","text":" "},{"type":"text","text":"the static members named after the symbolic names, or by using the"},{"type":"text","text":" "},{"type":"codeVoice","code":"init(rawValue:)"},{"type":"text","text":" initializer."}],"type":"paragraph"},{"code":["let overlayClass = Unicode.CanonicalCombiningClass(rawValue: 1)","let overlayClassIsOverlay = overlayClass == .overlay","// overlayClassIsOverlay == true"],"type":"codeListing","syntax":"swift"}]}],"kind":"symbol","seeAlsoSections":[{"generated":true,"title":"Unicode Scalar Classifications","identifiers":["doc://com.apple.Swift/documentation/Swift/Unicode/GeneralCategory","doc://com.apple.Swift/documentation/Swift/Unicode/NumericType"],"anchor":"Unicode-Scalar-Classifications"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Unicode"]]},"abstract":[{"ty