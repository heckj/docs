he reversed version of a string, reverse its"},{"type":"text","text":" "},{"type":"text","text":"characters and initialize a new "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instance from the result."}],"type":"paragraph"},{"syntax":"swift","code":["let reversedWord = String(word.reversed())","print(reversedWord)","// Prints \"sdrawkcaB\""],"type":"codeListing"},{"content":[{"inlineContent":[{"text":"O(1)","type":"text"}],"type":"paragraph"}],"name":"Complexity","type":"aside","style":"note"}]}],"abstract":[{"text":"Returns a view presenting the elements of the collection in reverse","type":"text"},{"text":" ","type":"text"},{"text":"order.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"extendedModule":"Swift","role":"symbol","title":"reversed()","symbolKind":"method","modules":[{"name":"Swift"}],"externalID":"s:SKsE8reverseds18ReversedCollectionVyxGyF::SYNTHESIZED::s:s7UnicodeO6ScalarV12_RegexParserE10AllScalarsV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reversed","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ReversedCollection","kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":">","kind":"text"}],"roleHeading":"Instance Method"},"kind":"symbol","variants":[{"paths":["/documentation/swift/unicode/scalar/allscalars-swift.struct/reversed()"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/AllScalars-swift.struct/reversed()","interfaceLanguage":"swift"},"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swif