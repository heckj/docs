{"abstract":[{"text":"A Boolean value indicating whether the scalar has an emoji","type":"text"},{"text":" ","type":"text"},{"text":"presentation, whether or not it is the default.","type":"text"}],"metadata":{"extendedModule":"Swift","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isEmoji","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"role":"symbol","roleHeading":"Instance Property","title":"isEmoji","symbolKind":"property","modules":[{"name":"Swift"}],"externalID":"s:s7UnicodeO6ScalarV10PropertiesV7isEmojiSbvp"},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/Properties-swift.struct/isEmoji"},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Unicode","doc://com.apple.Swift/documentation/Swift/Unicode/Scalar","doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/Properties-swift.struct"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isEmoji","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","text":"Bool","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property is true for scalars that are rendered as emoji by default"},{"type":"text","text":" "},{"type":"text","text":"and also for scalars that have a non-default emoji rendering when followed"},{"type":"text","text":" "},{"type":"text","text":"by U+FE0F VARIATION SELECTOR-16. Thi