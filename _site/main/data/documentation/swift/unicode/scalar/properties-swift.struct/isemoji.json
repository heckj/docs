{"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unicode/scalar/properties-swift.struct/isemoji"]}],"sections":[],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/Properties-swift.struct/isEmoji","interfaceLanguage":"swift"},"abstract":[{"text":"A Boolean value indicating whether the scalar has an emoji","type":"text"},{"text":" ","type":"text"},{"text":"presentation, whether or not it is the default.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isEmoji"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","text":"Bool"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property is true for scalars that are rendered as emoji by default"},{"type":"text","text":" "},{"type":"text","text":"and also for scalars that have a non-default emoji rendering when followed"},{"type":"text","text":" "},{"type":"text","text":"by U+FE0F VARIATION SELECTOR-16. This includes some scalars that are not"},{"type":"text","text":" "},{"type":"text","text":"typically considered to be emoji:"}]},{"code":["let scalars: [Unicode.Scalar] = [\"😎\", \"$\", \"0\"]","for s in scalars {","    print(s, \"-->\", s.properties.isEmoji)","}","// 😎 --> true","// $ --> false","// 0 --> true"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The final result is true because the ASCII digits have non-default emoji"},{"type":"text","text":" "},{"type":"text","text":"presentations; some platforms render these with an alternate appearance."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because of this behavior, testing "},{"type":"codeVoice","code":"isEmoji"},{"type":"text","text":" alone on a single scalar is"},{"type":"text","text":" "},{"type":"text","text":"insufficient to determine if a unit of text is rendered as an emoji; a"},{"type":"text","text":" "},{"type":"text","text":"correct test requires inspecting multiple scalars in a "},{"type":"codeVoice","code":"Character"},{"type":"text","text":". In"},{"type":"text","text":" "},{"type":"text","text":"addition to checking whether the base scalar has "},{"type":"codeVoice","code":"isEmoji == true"},{"type":"text","text":", you"},{"type":"text","text":" "},{"type":"text","text":"must also check its default presentation (see "},{"type":"codeVoice","code":"isEmojiPresentation"},{"type":"text","text":") and"},{"type":"text","text":" "},{"type":"text","text":"determine whether it is followed by a variation selector that would modify"},{"type":"text","text":" "},{"type":"text","text":"the presentation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property corresponds to the “Emoji” property in the"},{"type":"text","text":" "},{"identifier":"http://www.unicode.org/versions/latest/","type":"reference","isActive":true},{"type":"text","text":"."}]}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Unicode","doc://com.apple.Swift/documentation/Swift/Unicode/Scalar","doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/Properties-swift.struct"]]},"metadata":{"symbolKind":"property","modules":[{"name":"Swift"}],"roleHeading":"Instance Property","title":"isEmoji","externalID":"s:s7UnicodeO6ScalarV10PropertiesV7isEmojiSbvp","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isEmoji"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","pr