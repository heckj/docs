{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isJoinControl"},{"kind":"text","text":": "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}]},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"There are two scalars for which this property is "},{"type":"codeVoice","code":"true"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When U+200C ZERO WIDTH NON-JOINER is inserted between two characters, it","type":"text"},{"text":" ","type":"text"},{"text":"directs the rendering engine to render them separately/disconnected when","type":"text"},{"text":" ","type":"text"},{"text":"it might otherwise render them as a ligature. For example, a rendering","type":"text"},{"text":" ","type":"text"},{"text":"engine might display “fl” in English as a connected glyph; inserting the","type":"text"},{"text":" ","type":"text"},{"text":"zero width non-joiner would force them to be rendered as disconnected","type":"text"},{"text":" ","type":"text"},{"text":"glyphs.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"When U+200D ZERO WIDTH JOINER is inserted between two characters, it","type":"text"},{"text":" ","type":"text"},{"text":"directs the rendering engine to render them as a connected glyph when it","type":"text"},{"text":" ","type":"text"},{"text":"would otherwise render them independently. The zero width joiner is also","type":"text"},{"text":" ","type":"text"},{"text":"used to construct complex emoji from sequences of base emoji characters.","type":"text"},{"text":" ","type":"text"},{"text":"For example, the various “family” emoji are encoded as sequences of man,","type":"text"},{"text":" ","type":"text"},{"text":"woman, or child emoji that are interleaved with zero width joiners.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"This property corresponds to the “Join_Control” property in the"},{"type":"text","text":" "},{"identifier":"http://www.unicode.org/versions/latest/","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Unicode","doc://com.apple.Swift/documentation/Swift/Unicode/Scalar","doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/Properties-swift.struct"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unicode/scalar/properties-swift.struct/isjoincontrol"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"symbol","roleHeading":"Instance Property","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isJoinControl"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"externalID":"s:s7UnicodeO6ScalarV10PropertiesV13isJoinControlSbvp","title":"isJoinControl","extendedModule":"Swift","modules":[{"name":"Swift"}],"symbolKind":"property"},"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/Properties-swift.struct/isJoinControl"},"abstract":[{"type":"text","text":"A Boolean value indicating whether the scalar is a format control"},{"type":"text","text":" "},{"type":"text","text":"character that has a specific function in controlling cursive joining and"},{"type":"text","text":" "},{"type":"text","text":"ligation."}],"references":{"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/Properties-swift.struct/isJoinControl":{"kind"