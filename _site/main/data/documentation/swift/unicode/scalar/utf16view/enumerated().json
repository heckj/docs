ift/documentation/Swift/Unicode":{"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Unicode","kind":"identifier"}],"title":"Unicode","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Unicode","type":"topic","url":"/documentation/swift/unicode","abstract":[{"text":"A namespace for Unicode utilities.","type":"text"}],"navigatorTitle":[{"text":"Unicode","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/EnumeratedSequence":{"url":"/documentation/swift/enumeratedsequence","title":"EnumeratedSequence","navigatorTitle":[{"kind":"identifier","text":"EnumeratedSequence"}],"type":"topic","role":"symbol","abstract":[{"type":"text","text":"An enumeration of the elements of a sequence or collection."}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"EnumeratedSequence","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/EnumeratedSequence","kind":"symbol"}}}