":"limit"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let j = numbers.index(numbers.startIndex,","                      offsetBy: 10,","                      limitedBy: numbers.endIndex)","print(j)","// Prints \"nil\""]},{"inlineContent":[{"type":"text","text":"The value passed as "},{"code":"distance","type":"codeVoice"},{"type":"text","text":" must not offset "},{"code":"i","type":"codeVoice"},{"type":"text","text":" beyond the bounds of"},{"type":"text","text":" "},{"type":"text","text":"the collection, unless the index passed as "},{"code":"limit","type":"codeVoice"},{"type":"text","text":" prevents offsetting"},{"type":"text","text":" "},{"type":"text","text":"beyond those bounds."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"O(1)"}],"type":"paragraph"}],"type":"aside","name":"Complexity","style":"note"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar":{"navigatorTitle":[{"text":"Scalar","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar","abstract":[{"type":"text","text":"A Unicode scalar value."}],"role":"symbol","title":"Unicode.Scalar","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Scalar","kind":"identifier"}],"url":"/documentation/swift/unicode/scalar","type":"topic"},"doc://com.apple.Swift/documentation/Swift/RandomAccessCollection/Index":{"required":true,"url":"/documentation/swift/randomaccesscollection/index","role":"symbol","title":"Index","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Index","kind":"identifier"}]