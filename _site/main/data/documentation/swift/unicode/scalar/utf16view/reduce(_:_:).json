xhausted, the last value returned from the"},{"type":"text","text":" "},{"type":"text","text":"closure is returned to the caller."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"If the sequence has no elements, "},{"code":"nextPartialResult","type":"codeVoice"},{"type":"text","text":" is never executed"},{"type":"text","text":" "},{"type":"text","text":"and "},{"code":"initialResult","type":"codeVoice"},{"type":"text","text":" is the result of the call to "},{"code":"reduce(_:_:)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"O("},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":"), where "},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" is the length of the sequence."}],"type":"paragraph"}],"type":"aside","style":"note","name":"Complexity"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar":{"type":"topic","abstract":[{"text":"A Unicode scalar value.","type":"text"}],"title":"Unicode.Scalar","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar","url":"/documentation/swift/unicode/scalar","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Scalar"}],"navigatorTitle":[{"kind":"identifier","text":"Scalar"}]},"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/UTF16View":{"identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/UTF16View","navigatorTitle":[{"text":"UTF16View","kind":"identifier"}],"kind":"symbol","abstract":[],"type":"topic","url":"/documentation/swift/unicode/scalar/utf16view","role":"symbol","title":"Unicode.Scalar.UTF16View","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"UTF16View","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/Unicode":{"role":"symbol","fragmen