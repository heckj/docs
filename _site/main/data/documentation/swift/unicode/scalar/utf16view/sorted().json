pe":"text"},{"code":"sorted(by:)","type":"codeVoice"},{"text":" method.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let descendingStudents = students.sorted(by: >)","print(descendingStudents)","// Prints \"[\"Peter\", \"Kweku\", \"Kofi\", \"Akosua\", \"Abena\"]\""]},{"type":"paragraph","inlineContent":[{"text":"The sorting algorithm is guaranteed to be stable. A stable sort","type":"text"},{"text":" ","type":"text"},{"text":"preserves the relative order of elements that compare as equal.","type":"text"}]},{"type":"aside","name":"Complexity","style":"note","content":[{"inlineContent":[{"type":"text","text":"O("},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" log "},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" is the length of the sequence.","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unicode/scalar/utf16view/sorted()"]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Unicode","doc://com.apple.Swift/documentation/Swift/Unicode/Scalar","doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/UTF16View"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Returns the elements of the sequence, sorted."}],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/UTF16View/sorted()","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","title":"sorted()","modules":[{"name":"Swift"}],"externalID":"s:STsSL7ElementRpzrlE6sortedSayABGyF::SYNTHESIZED::s:s7UnicodeO6ScalarV9UTF16ViewV","conformance":{"conformancePrefix":[{"text":"Conforms when","type":"text"}],"constraints":[{"code":"Element","type":"codeVoice"},{"text":" conforms to ","type":