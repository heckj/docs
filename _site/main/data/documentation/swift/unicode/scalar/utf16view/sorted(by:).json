fier","preciseIdentifier":"s:ST7ElementQa","text":"Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"kind":"text","text":" -> ["},{"preciseIdentifier":"s:ST7ElementQa","text":"Element","kind":"typeIdentifier"},{"kind":"text","text":"]"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/UTF16View/sorted(by:)","abstract":[{"type":"text","text":"Returns the elements of the sequence, sorted using the given predicate as"},{"type":"text","text":" "},{"type":"text","text":"the comparison between elements."}],"role":"symbol"},"doc://com.apple.Swift/documentation/Swift/Unicode":{"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Unicode","kind":"identifier"}],"title":"Unicode","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Unicode","type":"topic","url":"/documentation/swift/unicode","abstract":[{"text":"A namespace for Unicode utilities.","type":"text"}],"navigatorTitle":[{"text":"Unicode","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar":{"type":"topic","abstract":[{"text":"A Unicode scalar value.","type":"text"}],"title":"Unicode.Scalar","role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar","url":"/documentation/swift/unicode/scalar","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Scalar"}],"navigatorTitle":[{"kind":"identifier","text":"Scalar"}]},"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/UTF16View":{"identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/Scalar/UTF16View","navigatorTitle":[{"text":"UTF16View","kind":"identifier"}],"kind":"symbol","abstract":[],"type":"topic","url":"/documentation/swift/unicode/scalar/utf16view","role":"s