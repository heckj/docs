:"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult","text":"UnicodeDecodingResult","preciseIdentifier":"s:s21UnicodeDecodingResultO"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol","text":"IteratorProtocol","preciseIdentifier":"s:St"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element","text":"Element","preciseIdentifier":"s:St7ElementQa"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/UInt16","text":"UInt16","preciseIdentifier":"s:s6UInt16V"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"An iterator of code units to be decoded. ","type":"text"},{"code":"input","type":"codeVoice"},{"text":" must be","type":"text"},{"text":" ","type":"text"},{"text":"the same iterator instance in repeated calls to this method. Do not","type":"text"},{"text":" ","type":"text"},{"text":"advance the iterator or any copies of the iterator outside this","type":"text"},{"text":" ","type":"text"},{"text":"method.","type":"text"}]}],"name":"input"}]},{"kind":"content","content":[{"anchor":"return-value","level":2,"type":"heading","text":"Return Value"},{"inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"UnicodeDecodingResult"},{"text":" instance, representing the next","type":"text"},{"text":" ","type":"text"},{"text":"Unicode scalar, an indication of an error, or an indication that the","type":"text"},{"text":" ","type":"text"},{"text":"UTF sequence has been fully decoded.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"To decode a code unit sequence completely, call this method repeatedly","type":"text"},{"text":" ","type":"text"},{"text":"until it returns ","type":"text"},{"type":"codeVoice","code":"UnicodeDecodingResult.emptyInput"},{"text":". Checking that the","type":"text"},{"text":" ","type":"text"},{"text":"iterator was exhausted is not sufficient, because the decoder can store","type":"text"},{"text":" ","type":"text"},{"text":"buffered data from the input iterator.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because of buffering, it is impossible to find the corresponding position","type":"text"},{"text":" ","type":"text"},{"text":"in the iterator for a given returned ","type":"text"},{"type":"codeVoice","code":"Unicode.Scalar"},{"text":" or an error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following example decodes the UTF-16 encoded bytes of a string into an","type":"text"},{"text":" ","type":"text"},{"text":"array of ","type":"text"},{"type":"codeVoice","code":"Unicode.Scalar"},{"text":" instances. This is a demonstration only—if","type":"text"},{"text":" ","type":"text"},{"text":"you need the Unicode scalar representation of a string, use its","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"unicodeScalars"},{"text":" view.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let str = \"✨Unicode✨\"","print(Array(str.utf16))","// Prints \"[10024, 85, 110, 105, 99, 111, 100, 101, 10024]\"","","var codeUnitIterator = str.utf16.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf16Decoder = UTF16()","Decode: while true {","    switch utf16Decoder.decode(&codeUnitIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","// Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unicode/utf16/decode(_:)-swift.method"]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/Unicode/UTF16":{"role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"UTF16"}],"title":"Unicode.UTF16","type":"topic","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/UTF16","url":"/documentation/swift/unicode/utf16","abstract":[],"navigatorTitle":[{"kind":"identifier","text":"UTF16"}]},"doc://com.apple.Swift/documentation/Swift/Unicode/UTF16/decode(_:)-swift.method":{"title":"decode(_:)","abstract":[{"type":"text","text":"Starts or continues decoding a UTF-16 sequence."}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decode"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"I"},{"kind":"text","text":">("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:s7UnicodeO5UTF16O6decodeys0A14DecodingResultOxzStRzs6UInt16V7ElementRtzlF1IL_xmfp","text":"I"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s21UnicodeDecodingResultO","text":"UnicodeDecodingResult"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/UTF16/decode(_:)-swift.method","url":"/documentation/swift/unicode/utf16/decode(_:)-swift.method","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/Unicode":{"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kin