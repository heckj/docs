{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Unicode/UTF16/decode(_:)-swift.method","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decode"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"I"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"input"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"preciseIdentifier":"s:s7UnicodeO5UTF16O6decodeys0A14DecodingResultOxzStRzs6UInt16V7ElementRtzlF1IL_xmfp","kind":"typeIdentifier","text":"I"},{"kind":"text","text":") -> "},{"identifier":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult","preciseIdentifier":"s:s21UnicodeDecodingResultO","kind":"typeIdentifier","text":"UnicodeDecodingResult"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"I","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:St","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol","text":"IteratorProtocol","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"I","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:St7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element","text":"Element","kind":"typeIdentifier"},{"text":" == ","kind":"text"},{"preciseIdentifier":"s:s6UInt16V","identifier":"doc://com.apple.Swift/documentation/Swift/UInt16","text":"UInt16","kind":"typeIdentifier"}]}]},{"kind":"parameters","parameters":[{"name":"input","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An iterator of code units to be decoded. "},{"type":"codeVoice","code":"input"},{"type":"text","text":" must be"},{"type":"text","text":" "},{"type":"text","text":"the same iterator instance in repeated calls to this method. Do not"},{"type":"text","text":" "},{"type":"text","text":"advance the iterator or any copies of the iterator outside this"},{"type":"text","text":" "},{"type":"text","text":"method."}]}]}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"UnicodeDecodingResult"},{"type":"text","text":" instance, representing the next"},{"type":"text","text":" "},{"type":"text","text":"Unicode scalar, an indication of an error, or an indication that the"},{"type":"text","text":" "},{"type":"text","text":"UTF sequence has been fully decoded."}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"To decode a code unit sequence completely, call this method repeatedly","type":"text"},{"text":" ","type":"text"},{"text":"until it returns ","type":"text"},{"code":"UnicodeDecodingResult.emptyInput","type":"codeVoice"},{"text":". Checking that the","type":"text"},{"text":" ","type":"text"},{"text":"iterator was exhausted is not sufficient, because the decoder can store","type":"text"},{"text":" ","type":"text"},{"text":"buffered data from the input iterator.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because of buffering, it is impossible to find the corresponding position"},{"type":"text","text":" "},{"type":"text","text":"in the iterator for a given returned "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" or an error."}]},{"type":"paragraph","inlineContent":[{"text":"The following example decodes the UTF-16 encoded bytes of a string into an","type":"text"},{"text":" ","type":"text"},{"text":"array of ","type":"text"},{"type":"codeVoice","code":"Unicode.Scalar"},{"text":" instances. This is a demonstration only—if","type":"text"},{"text":" ","type":"text"},{"text":"you need the Unicode scalar representation of a string, use its","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"unicodeScalars"},{"text":" view.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let str = \"✨Unicode✨\"","print(Array(str.utf16))","// Prints \"[10024, 85, 110, 105, 99, 111, 100, 101, 10024]\"","","var codeUnitIterator = str.utf16.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf16Decoder = UTF16()","Decode: while true {","    switch utf16Decoder.decode(&codeUnitIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","// Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""]}]}],"metadata":{"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"Swift"}],"externalID":"s:s7UnicodeO5UTF16O6decodeys0A14DecodingResultOxzStRzs6UInt16V7ElementRtzlF","title":"decode(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decode"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"I"},{"kind":"text","text":">("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"I","preciseIdentifier":"s:s7UnicodeO5UTF16O6decodeys0A14DecodingResultOxzStRzs6UInt16V7ElementRtzlF1IL_xmfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"UnicodeDecodingResult","preciseIdentifier":"s:s21UnicodeDecodingResultO"}],"extendedModule":"Swift","role":"symbol"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Unicode","doc://com.apple.Swift/documentation/Swift/Unicode/UTF16"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documenta