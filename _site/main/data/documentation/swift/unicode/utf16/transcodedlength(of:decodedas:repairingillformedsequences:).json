epairingIllFormedSequences"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"entire iterator will be exhausted. Otherwise, iteration will stop if"},{"text":" ","type":"text"},{"text":"an ill-formed sequence is detected.","type":"text"}]}],"name":"input"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The Unicode encoding of ","type":"text"},{"code":"input","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"sourceEncoding"},{"name":"repairingIllFormedSequences","content":[{"inlineContent":[{"text":"Pass ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" to measure the length of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"input"},{"type":"text","text":" even when "},{"code":"input","type":"codeVoice"},{"type":"text","text":" contains ill-formed sequences. Each"},{"type":"text","text":" "},{"type":"text","text":"ill-formed sequence is replaced with a Unicode replacement character"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"\"\\u{FFFD}\""},{"type":"text","text":") and is measured as such. Pass "},{"type":"codeVoice","code":"false"},{"type":"text","text":" to immediately"},{"type":"text","text":" "},{"type":"text","text":"stop measuring "},{"type":"codeVoice","code":"input"},{"type":"text","text":" when an ill-formed sequence is encountered."}],"type":"paragraph"}]}]},{"content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A tuple containing the number of UTF-16 code units required to","type":"text"},{"text":" ","type":"text"},{"text":"encode ","type":"text"},{"code":"input","type":"codeVoice"},{"text":" and a Boolean value that indicates whether the ","type":"text"},{"code":"input","type":"codeVoice"},{"text":" ","type":"text"},{"text":"contained only ASCII characters. If ","type":"text"},{"code":"repair