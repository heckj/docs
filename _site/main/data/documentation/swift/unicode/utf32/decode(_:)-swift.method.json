Swift/documentation/Swift/UnicodeDecodingResult":{"identifier":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnicodeDecodingResult"}],"navigatorTitle":[{"kind":"identifier","text":"UnicodeDecodingResult"}],"type":"topic","url":"/documentation/swift/unicodedecodingresult","title":"UnicodeDecodingResult","abstract":[{"type":"text","text":"The result of one Unicode decoding step."}],"role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element":{"abstract":[{"text":"The type of element traversed by the iterator.","type":"text"}],"title":"Element","required":true,"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element","url":"/documentation/swift/iteratorprotocol/element","type":"topic","fragments":[{"kind":"keyword","text":"associatedtype"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/UInt32":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"UInt32"}],"url":"/documentation/swift/uint32","abstract":[{"type":"text","text":"A 32-bit unsigned integer value"},{"type":"text","text":" "},{"text":"type.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"UInt32"}],"title":"UInt32","identifier":"doc://com.apple.Swift/documentation/Swift/UInt32"},"doc://com.apple.Swift/documentation/Swift/Unicode/UTF32/decode(_:)-swift.method":{"identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/UTF32/decode(_:)-swift.method","abstract":[{"type":"text","text":"Starts or continues decoding a UTF-32 sequence."}],"role":"symbol","title":"decode(_:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"decode","kind":"identifier"},{"text":"<","kind":"te