r":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult","text":"UnicodeDecodingResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"I","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","text":"IteratorProtocol","preciseIdentifier":"s:St","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol"},{"text":", ","kind":"text"},{"text":"I","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Element","preciseIdentifier":"s:St7ElementQa","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element"},{"kind":"text","text":" == "},{"identifier":"doc://com.apple.Swift/documentation/Swift/UInt32","kind":"typeIdentifier","preciseIdentifier":"s:s6UInt32V","text":"UInt32"}]}]},{"kind":"parameters","parameters":[{"name":"input","content":[{"type":"paragraph","inlineContent":[{"text":"An iterator of code units to be decoded. ","type":"text"},{"type":"codeVoice","code":"input"},{"type":"text","text":" must be"},{"text":" ","type":"text"},{"text":"the same iterator instance in repeated calls to this method. Do not","type":"text"},{"text":" ","type":"text"},{"text":"advance the iterator or any copies of the iterator outside this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"method."}]}]}]},{"kind":"content","content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"code":"UnicodeDecodingResult","type":"codeVoice"},{"type":"text","text":" instance, representing the next"},{"text":" ","type":"text"},{"text":"Unicode scalar, an indication of an error, or an indication that the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"UTF sequence has been fully decoded."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To decode a code unit sequence completely, call this method repeatedly"},{"type":"text","text":" "},{"text":"until it returns ","type":"text"},{"code":"UnicodeDecodingResult.emptyInput","type":"codeVoice"},{"text":". Checking that the","type":"text"},{"text":" ","type":"text"},{"text":"iterator was exhausted is not sufficient, because the decoder can store","type":"text"},{"type":"text","text":" "},{"text":"buffered data from the input iterator.","type":"text"}]},{"inlineContent":[{"text":"Because of buffering, it is impossible to find the corresponding position","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in the iterator for a given returned "},{"code":"Unicode.Scalar","type":"codeVoice"},{"text":" or an error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example decodes the UTF-16 encoded bytes of a string"},{"type":"text","text":" "},{"type":"text","text":"into an array of "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" instances. This is a demonstration"},{"type":"text","text":" "},{"type":"text","text":"only—if you need the Unicode scalar representation of a string, use"},{"type":"text","text":" "},{"type":"text","text":"its "},{"type":"codeVoice","code":"unicodeScalars"},{"type":"text","text":" view."}],"type":"paragraph"},{"code":["// UTF-32 representation of \"✨Unicode✨\"","let codeUnits: [UTF32.CodeUnit] =","        [10024, 85, 110, 105, 99, 111, 100, 101, 10024]","","var codeUnitIterator = codeUnits.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf32Decoder = UTF32()","Decode: while true {","    switch utf32Decoder.decode(&codeUnitIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","// Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""],"type":"codeListing","syntax":"swift"}]}],"variants":[{"paths":["/documentation/swift/unicode/utf32/decode(_:)-swift.method"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","sections":[],"references":{"doc://com.apple.Swift/documentation/Swift/UInt32":{"navigatorTitle":[{"text":"UInt32","kind":"identifier"}],"url":"/documentation/swift/uint32","title":"UInt32","abstract":[{"type":"text","text":"A 32-bit unsigned integer value"},{"type":"text","text":" "},{"type":"text","text":"type."}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UInt32","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/UInt32","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/IteratorProtocol":{"identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol","type":"topic","url":"/documentation/swift/iteratorprotocol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"IteratorProtocol"}],"kind":"symbol","abstract":[{"text":"A type that supplies the values of a sequence one at a time.","type":"text"}],"title":"IteratorProtocol","navigatorTitle":[{"kind":"identifier","text":"IteratorProtocol"}]},"doc://com.apple.Swift/documentation/Swift/Unicode":{"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Unicode","kind":"identifier"}],"title":"Unicode","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Unicode","type":"topic","url":"/documentation/swift/unicode","abstract":[{"text":"A namespace for Unicode utilities.","type":"text"}],"navigatorTitle":[{"text":"Unicode","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult","type":"topic","title":"UnicodeDecodingResult