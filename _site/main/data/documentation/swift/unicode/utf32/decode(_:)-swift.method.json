{"abstract":[{"text":"Starts or continues decoding a UTF-32 sequence.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unicode/utf32/decode(_:)-swift.method"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Unicode","doc://com.apple.Swift/documentation/Swift/Unicode/UTF32"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"mutating","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"decode","kind":"identifier"},{"text":"<","kind":"text"},{"text":"I","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"input","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"kind":"text","text":" "},{"preciseIdentifier":"s:s7UnicodeO5UTF32O6decodeys0A14DecodingResultOxzStRzs6UInt32V7ElementRtzlF1IL_xmfp","kind":"typeIdentifier","text":"I"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s21UnicodeDecodingResultO","identifier":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult","kind":"typeIdentifier","text":"UnicodeDecodingResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:St","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol","kind":"typeIdentifier","text":"IteratorProtocol"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":"."},{"preciseIdentifier":"s:St7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element","kind":"typeIdentifier","text":"Element"},{"kind":"text","text":" == "},{"preciseIdentifier":"s:s6UInt32V","identifier":"doc://com.apple.Swift/documentation/Swift/UInt32","kind":"typeIdentifier","text":"UInt32"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An iterator of code units to be decoded. "},{"code":"input","type":"codeVoice"},{"type":"text","text":" must be"},{"type":"text","text":" "},{"type":"text","text":"the same iterator instance in repeated calls to this method. Do not"},{"type":"text","text":" "},{"type":"text","text":"advance the iterator or any copies of the iterator outside this"},{"type":"text","text":" "},{"type":"text","text":"method."}]}],"name":"input"}]},{"kind":"content","content":[{"anchor":"return-value","type":"heading","text":"Return Value","level":2},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"UnicodeDecodingResult"},{"text":" instance, representing the next","type":"text"},{"text":" ","type":"text"},{"text":"Unicode scalar, an indication of an error, or an indication that the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"UTF sequence has been fully decoded."}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"To decode a code unit sequence completely, call this method repeatedly","type":"text"},{"text":" ","type":"text"},{"text":"until it returns ","type":"text"},{"code":"UnicodeDecodingResult.emptyInput","type":"codeVoice"},{"text":". Checking that the","type":"text"},{"text":" ","type":"text"},{"text":"iterator was exhausted is not sufficient, because the decoder can store","type":"text"},{"text":" ","type":"text"},{"text":"buffered data from the input iterator.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because of buffering, it is impossible to find the corresponding position"},{"type":"text","text":" "},{"type":"text","text":"in the iterator for a given returned "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" or an error."}],"type":"paragraph"},{"inlineContent":[{"text":"The following example decodes the UTF-16 encoded bytes of a string","type":"text"},{"text":" ","type":"text"},{"text":"into an array of ","type":"text"},{"code":"Unicode.Scalar","type":"codeVoice"},{"text":" instances. This is a demonstration","type":"text"},{"text":" ","type":"text"},{"text":"only—if you need the Unicode scalar representation of a string, use","type":"text"},{"text":" ","type":"text"},{"text":"its ","type":"text"},{"code":"unicodeScalars","type":"codeVoice"},{"text":" view.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["// UTF-32 representation of \"✨Unicode✨\"","let codeUnits: [UTF32.CodeUnit] =","        [10024, 85, 110, 105, 99, 111, 100, 101, 10024]","","var codeUnitIterator = codeUnits.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf32Decoder = UTF32()","Decode: while true {","    switch utf32Decoder.decode(&codeUnitIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","// Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""]}]}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/Unicode/UTF32/decode(_:)-swift.method","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","metadata":{"role":"symbol","externalID":"s:s7UnicodeO5UTF32O6decodeys0A14DecodingResultOxzStRzs6UInt32V7ElementRtzlF","symbolKind":"method","extendedModule":"Swift","roleHeading":"Instance Method","modules":[{"name":"Swift"}],"title":"decode(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"decode","kind":"identifier"},{"text":"<","kind":"text"},{"text":"I","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:s7UnicodeO