{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unicode/utf8/decode(_:)-swift.method"]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/Unicode/UTF8/decode(_:)-swift.method"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"decode(_:)","roleHeading":"Instance Method","externalID":"s:s7UnicodeO4UTF8O6decodeys0A14DecodingResultOxzStRzs5UInt8V7ElementRtzlF","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decode"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"I"},{"kind":"text","text":">("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:s7UnicodeO4UTF8O6decodeys0A14DecodingResultOxzStRzs5UInt8V7ElementRtzlF1IL_xmfp","text":"I"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s21UnicodeDecodingResultO","text":"UnicodeDecodingResult"}],"symbolKind":"method","modules":[{"name":"Swift"}],"extendedModule":"Swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/Unicode","doc://com.apple.Swift/documentation/Swift/Unicode/UTF8"]]},"sections":[],"kind":"symbol","abstract":[{"text":"Starts or continues decoding a UTF-8 sequence.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decode"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"I"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"input"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:s7UnicodeO4UTF8O6decodeys0A14DecodingResultOxzStRzs5UInt8V7ElementRtzlF1IL_xmfp","text":"I"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s21UnicodeDecodingResultO","identifier":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult","text":"UnicodeDecodingResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:St","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol","text":"IteratorProtocol"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:St7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element","text":"Element"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V","identifier":"doc://com.apple.Swift/documentation/Swift/UInt8","text":"UInt8"}]}]},{"kind":"parameters","parameters":[{"name":"input","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An iterator of code units to be decoded. "},{"code":"input","type":"codeVoice"},{"type":"text","text":" must be"},{"type":"text","text":" "},{"type":"text","text":"the same iterator instance in repeated calls to this method. Do not"},{"type":"text","text":" "},{"type":"text","text":"advance the iterator or any copies of the iterator outside this"},{"type":"text","text":" "},{"type":"text","text":"method."}]}]}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"UnicodeDecodingResult"},{"type":"text","text":" instance, representing the next"},{"type":"text","text":" "},{"type":"text","text":"Unicode scalar, an indication of an error, or an indication that the"},{"type":"text","text":" "},{"type":"text","text":"UTF sequence has been fully decoded."}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"To decode a code unit sequence completely, call this method repeatedly"},{"type":"text","text":" "},{"type":"text","text":"until it returns "},{"type":"codeVoice","code":"UnicodeDecodingResult.emptyInput"},{"type":"text","text":". Checking that the"},{"type":"text","text":" "},{"type":"text","text":"iterator was exhausted is not sufficient, because the decoder can store"},{"type":"text","text":" "},{"type":"text","text":"buffered data from the input iterator."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because of buffering, it is impossible to find the corresponding position"},{"type":"text","text":" "},{"type":"text","text":"in the iterator for a given returned "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" or an error."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example decodes the UTF-8 encoded bytes of a string into an"},{"type":"text","text":" "},{"type":"text","text":"array of "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" instances. This is a demonstration only—if"},{"type":"text","text":" "},{"type":"text","text":"you need the Unicode scalar representation of a string, use its"},{"type":"text","text":" "},{"type":"codeVoice","code":"unicodeScalars"},{"type":"text","text":" view."}],"type":"paragraph"},{"syntax":"swift","code":["let str = \"✨Unicode✨\"","print(Array(str.utf8))","// Prints \"[226, 156, 168, 85, 110, 105, 99, 111, 100, 101, 226, 156, 168]\"","","var bytesIterator = str.utf8.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf8Decoder = UTF8()","Decode: while true {","    switch utf8Decoder.decode(&bytesIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","// Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""],"type":"codeListing"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/UInt8":{"navigatorTitle":[{"text":"UInt8","kind":"identifier"}],"url":"/documentation/swift/uint8","title":"UInt8","abstract":[{"type":"text","text":"An 8-bit unsigned integer value"},{"type":"text","text":" "},{"type":"text","text":"type."}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UInt8","kind":"identifier"}],"identifier":"doc://com.apple.Swift/documentation/Swift/UInt8","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult","type":"topic","title":"UnicodeDecodingResult","kind":"symbol","url":"/documentation/swift/unicodedecodingresult","navigatorTitle":[{"text":"UnicodeDecodingResult","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnicodeDecodingResult","kind":"identifier"}],"abstract":[{"type":"text","text":"The result of one Unicode decoding step."}]},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/Unicode/UTF8/decode(_:)-swift.method":{"identifier":"doc://com.apple.Swift/documentation/Swift/Unicode/UTF8/decode(_:)-swift.method","kind":"symbol","role":"symbol","type":"topic","url":"/documentation/swift/unicode/utf8/decode(_:)-swift.method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decode"},{"kind":"text","text":"<"},{"kind":"genericParame