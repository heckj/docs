ciseIdentifier":"s:s21UnicodeDecodingResultO","identifier":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"I","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"IteratorProtocol","kind":"typeIdentifier","preciseIdentifier":"s:St","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol"},{"text":", ","kind":"text"},{"text":"I","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:St7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element"},{"text":" == ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V","identifier":"doc://com.apple.Swift/documentation/Swift/UInt8"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"input","content":[{"inlineContent":[{"text":"An iterator of code units to be decoded. ","type":"text"},{"type":"codeVoice","code":"input"},{"text":" must be","type":"text"},{"text":" ","type":"text"},{"text":"the same iterator instance in repeated calls to this method. Do not","type":"text"},{"text":" ","type":"text"},{"text":"advance the iterator or any copies of the iterator outside this","type":"text"},{"text":" ","type":"text"},{"text":"method.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"UnicodeDecodingResult","type":"codeVoice"},{"text":" instance, representing the next","type":"text"},{"text":" ","type":"text"},{"text":"Unicode scalar, an indication of an error, or an indication that the","type":"text"},{"text":" ","type":"text"},{"text":"UTF sequence has been fully decoded.","type":"text"}]}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"To decode a code unit sequence completely, call this method repeatedly","type":"text"},{"text":" ","type":"text"},{"text":"until it returns ","type":"text"},{"code":"UnicodeDecodingResult.emptyInput","type":"codeVoice"},{"text":". Checking that the","type":"text"},{"text":" ","type":"text"},{"text":"iterator was exhausted is not sufficient, because the decoder can store","type":"text"},{"text":" ","type":"text"},{"text":"buffered data from the input iterator.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because of buffering, it is impossible to find the corresponding position"},{"type":"text","text":" "},{"type":"text","text":"in the iterator for a given returned "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" or an error."}]},{"type":"paragraph","inlineContent":[{"text":"The following example decodes the UTF-8 encoded bytes of a string into an","type":"text"},{"text":" ","type":"text"},{"text":"array of ","type":"text"},{"code":"Unicode.Scalar","type":"codeVoice"},{"text":" instances. This is a demonstration only—if","type":"text"},{"text":" ","type":"text"},{"text":"you need the Unicode scalar representation of a string, use its","type":"text"},{"text":" ","type":"text"},{"code":"unicodeScalars","type":"codeVoice"},{"text":" view.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let str = \"✨Unicode✨\"","print(Array(str.utf8))","// Prints \"[226, 156, 168, 85, 110, 105, 99, 111, 100, 101, 226, 156, 168]\"","","var bytesIterator = str.utf8.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf8Decoder = UTF8()","Decode: while true {","    switch utf8Decoder.decode(&bytesIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","// Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""]}],"kind":"content"}],"variants":[{"paths":["/documentation/swift/unicode/utf8/decode(_:)-swift.method"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/Unicode":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Unicode"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Unicode","kind":"symbol","title":"Unicode","abstract":[{"text":"A namespace for Unicode utilities.","type":"text"}],"url":"/documentation/swift/unicode","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"text":"Unicode","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element":{"abstract":[{"text":"The type of element traversed by the iterator.","type":"text"}],"title":"Element","required":true,"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element","url":"/documentation/swift/iteratorprotocol/element","type":"topic","fragments":[{"kind":"keyword","text":"associatedtype"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"kind":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/Unicode/UTF8/decode(_:)-swift.method":{"url":"/documentation/swift/unicode/utf8/decode(_:)-swift.method","type":"topic","title":"decode(_:)","kind":"symbol","abstract":[{"type":"text","text":"Starts or continues decoding a UTF-8 sequence."}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decode"},{"kind":"text","text":"<"},{"text":"I","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","