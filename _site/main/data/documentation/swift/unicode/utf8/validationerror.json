"inlineContent":[{"type":"text","text":"E0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"A0..BF"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"80..BF"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"U+1000..U+CFFF"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"E1..EC"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"80..BF"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"80..BF"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"U+D000..U+D7FF"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"ED"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"80..9F"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"80..BF"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"inlineContent":[{"type":"text","text":"U+E000..U+FFFF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"EE..EF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..BF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..BF"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"U+10000..U+3FFFF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"F0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"90..BF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..BF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..BF"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"U+40000..U+FFFFF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"F1..F3"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..BF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..BF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..BF"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"U+100000..U+10FFFF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"F4"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..8F"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..BF"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"80..BF"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"anchor":"Classifying-errors","text":"Classifying errors","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"inlineContent":[{"type":"text","text":"unexpected continuation"}],"type":"emphasis"},{"type":"text","text":" is when a continuation byte ("},{"type":"codeVoice","code":"10xxxxxx"},{"type":"text","text":") occurs"},{"type":"text","text":" "},{"type":"text","text":"in a position that should be the start of a new scalar value. Unexpected"},{"type":"text","text":" "},{"type":"text","text":"continuations can often occur when the input contains arbitrary data"},{"type":"text","text":" "},{"type":"text","text":"instead of textual content. An unexpected continuation at the start of"},{"type":"text","text":" "},{"type":"text","text":"input might mean that the input was not correctly sliced along scalar"},{"type":"text","text":" "},{"type":"text","text":"boundaries or that it does not contain UTF-8."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"inlineContent":[{"type":"text","text":"truncated scalar"}],"type":"emphasis"},{"type":"text","text":" is a multi-byte sequence that is the start of a valid"},{"type":"text","text":" "},{"type":"text","text":"multi-byte scalar but is cut off before ending correctly. A truncated"},{"type":"text","text":" "},{"type":"text","text":"scalar at the end of the input might mean that only part of the entire"},{"type":"text","text":" "},{"type":"text","text":"input was received."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"inlineContent":[{"type":"text","text":"surrogate code point"}],"type":"emphasis"},{"type":"text","text":" ("},{"type":"codeVoice","code":"U+D800..U+DFFF"},{"type":"text","text":") is invalid UTF-8. Surrogate"},{"type":"text","text":" "},{"type":"text","text":"code points are used by UTF-16 to encode scalars in the supplementary"},{"type":"text","text":" "},{"type":"text","text":"planes. Their presence may mean the input was encoded in a different 8-bit"},{"type":"text","text":" "},{"type":"text","text":"encoding, such as CESU-8, WTF-8, or Java’s Modified UTF-8."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"inlineContent":[{"type":"text","text":"invalid non-surrogate code point"}],"type":"emphasis"},{"type":"text","text":" is any code point higher than"},{"type":"text","text":" "},{"type":"codeVoice","code":"U+10FFFF"},{"type":"text","text":". This can often occur when the input is arbitrary data instead"},{"type":"text","text":" "},{"type":"text","text":"of textual content."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"inlineContent":[{"type":"text","text":"overlong encoding"}],"type":"emphasis"},{"type":"text","text":" occurs when a scalar value that could have been"},{"type":"text","text":" "},{"type":"text","text":"encoded using fewer bytes is encoded in a longer byte sequence. Overlong"},{"type":"text","text":" "},{"type":"text","text":"encodings are invalid UTF-8 and can lead to security issues if not"},{"type":"text","text":" "},{"type":"text","text":"correctly detected:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https://nvd.nist.gov/vuln/detail/CVE-2008-2938","isActive":true,"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https://nvd.nist.gov/vuln/detail/CVE-2000-0884","isActive":true,"type":"reference"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An overlong encoding of "},{"type":"codeVoice","code":"NUL"},{"type":"text","text":", "},{"type":"codeVoice","code":"0xC0 0x80"},{"type":"text","text":", is used in Java’s Modified"},{"type":"text","text":" "},{"type":"text","text":"UTF-8 but is invalid UTF-8. Overlong encoding errors often catch attempts"},{"type":"text","text":" "},{"type":"text","text":"to bypass security measures."}]},{"anchor":"Reporting-the-range-of-the-error","text":"Reporting the range of the error","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The range of the error reported follows the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Maximal subpart of an"},{"type":"text","text":" "},{"type":"text","text":"ill-formed subsequence"}]},{"type":"text","text":" algorithm in which each error is either one byte"},{"type":"text","text":" "},{"type":"text","text":"long or ends before the first byte that is disallowed. See “U+FFFD"},{"type":"text","text":" "},{"type":"text","text":"Substitution of Maximal Subparts” in the Unicode Standard. Unicode started"},{"type":"text","text":" "},{"type":"text","text":"recommending this algorithm in version 6 and is adopted by the W3C."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The maximal subpart algorithm will produce a single multi-byte range for a"},{"type":"text","text":" "},{"type":"text","text":"truncated scalar (a multi-byte sequence that is the start of a valid"},{"type":"text","text":" "},{"type":"text","text":"multi-byte scalar but is cut off before ending correctly). For all other"},{"type":"text","text":" "},{"type":"text","text":"errors (including overlong encodings, surrogates, and invalid code"},{"type":"text","text":" "},{"type":"text","text":"points), it will produce an error per byte."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since overlong encodings, surrogates, and invalid code points are erroneous"},{"type":"text","text":" "},{"type":"text","text":"by the second byte (at the latest), the above definition produces the same"},{"type":"text","text":" "},{"type":"text","text":"ranges as defining such a sequence as a truncated scalar error followed by"},{"type":"text","text":" "},{"type":"text","text":"unexpected continuation byte errors. The more semantically-rich"},{"type":"text","text":" "},{"type":"text","text":"classification is reported."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, a surrogate code point sequence "},{"type":"codeVoice","code":"ED A0 80"},{"type":"text","text":" will be reported"},{"type":"text","text":" "},{"type":"text","text":"as three "},{"type":"codeVoice","code":".surrogateCodePointByte"},{"type":"text","text":" errors rather than a "},{"type":"codeVoice","code":".truncatedScalar"},{"type":"text","text":" "},{"type":"text","text":"followed by two "},{"type":"codeVoice","code":".unexpectedContinuationByte"},{"type":"text","text":" errors."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Other commonly reported error ranges can be constructed from this result."},{"type":"text","text":" "},{"type":"text","text":"For example, PEP 383’s error-per-byte can be constructed by mapping over"},{"type":"text","text":" "},{"type":"text","text":"the reported range. Similarly, constructing a single error for the longest"},{"type":"text","text":" "},{"type":"text","text":"invalid byte range can be constructed by joining adjacent error ranges."}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Algorithm"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"61"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"F1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"80"}]}],[{"inlineContent":[{"type":"text","text":"80"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"E1"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"80"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"C2"}]}],[{"inlineContent":[{"type":"text","text":"62"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Longest range"}]}],[{"type":"paragraph","inlineContent":[{"text":"U+61","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"err"}]}],[{"type":"paragraph","inlineContent":[]}],[{"inlineContent":[],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"inlineContent":[],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"U+62"}]}]],[[{"inlineContent":[{"text":"Maximal subpart","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"U+61"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"err"}]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"err"}]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"err"}]}],[{"inlineContent":[{"text":"U+62","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Error per byte"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"U+61"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"err"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"err"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"err"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"err"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"err"}]}],[{"inlineContent":[{"type":"text","text":"err"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"U+62"}],"type":"paragraph"}]]],"header":"row"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unicode/utf8/validationerror"]}],"references":{"https://nvd.nist.gov/vuln/de