sultOqd__zStRd__7ElementQyd__8CodeUnitRtzlF1IL_qd__mfp","kind":"typeIdentifier","text":"I"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s21UnicodeDecodingResultO","identifier":"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult","kind":"typeIdentifier","text":"UnicodeDecodingResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:St","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol","kind":"typeIdentifier","text":"IteratorProtocol"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"preciseIdentifier":"s:s16_UnicodeEncodingP8CodeUnitQa","kind":"typeIdentifier","text":"CodeUnit"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":"."},{"preciseIdentifier":"s:St7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element","kind":"typeIdentifier","text":"Element"}]}],"kind":"declarations"},{"parameters":[{"name":"input","content":[{"inlineContent":[{"type":"text","text":"An iterator of code units to be decoded. "},{"code":"input","type":"codeVoice"},{"type":"text","text":" must be"},{"type":"text","text":" "},{"type":"text","text":"the same iterator instance in repeated calls to this method. Do not"},{"type":"text","text":" "},{"type":"text","text":"advance the iterator or any copies of the iterator outside this"},{"type":"text","text":" "},{"type":"text","text":"method."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"UnicodeDecodingResult"},{"type":"text","text":" instance, representing the next"},{"type":"text","text":" "},{"type":"text","text":"Unicode scalar, an indication of an error, or an indication that the"},{"type":"text","text":" "},{"type":"text","text":"UTF sequence has been fully decoded."}]}],"kind":"content"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"To decode a code unit sequence completely, call this method repeatedly"},{"type":"text","text":" "},{"type":"text","text":"until it returns "},{"type":"codeVoice","code":"UnicodeDecodingResult.emptyInput"},{"type":"text","text":". Checking that the"},{"type":"text","text":" "},{"type":"text","text":"iterator was exhausted is not sufficient, because the decoder can store"},{"type":"text","text":" "},{"type":"text","text":"buffered data from the input iterator."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because of buffering, it is impossible to find the corresponding position"},{"type":"text","text":" "},{"type":"text","text":"in the iterator for a given returned "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" or an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example decodes the UTF-8 encoded bytes of a string into an"},{"type":"text","text":" "},{"type":"text","text":"array of "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" instances:"}]},{"code":["let str = \"✨Unicode✨\"","print(Array(str.utf8))","// Prints \"[226, 156, 168, 85, 110, 105, 99, 111, 100, 101, 226, 156, 168]\"","","var bytesIterator = str.utf8.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf8Decoder = UTF8()","Decode: while true {","    switch utf8Decoder.decode(&bytesIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","// Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""],"type":"codeListing","syntax":"swift"}],"kind":"conten