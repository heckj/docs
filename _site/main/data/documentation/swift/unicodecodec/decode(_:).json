,"preciseIdentifier":"s:St"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"text":"CodeUnit","preciseIdentifier":"s:s16_UnicodeEncodingP8CodeUnitQa","kind":"typeIdentifier"},{"text":" == ","kind":"text"},{"text":"I","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Element","identifier":"doc://com.apple.Swift/documentation/Swift/IteratorProtocol/Element","kind":"typeIdentifier","preciseIdentifier":"s:St7ElementQa"}],"languages":["swift"]}]},{"parameters":[{"name":"input","content":[{"inlineContent":[{"type":"text","text":"An iterator of code units to be decoded. "},{"type":"codeVoice","code":"input"},{"type":"text","text":" must be"},{"type":"text","text":" "},{"type":"text","text":"the same iterator instance in repeated calls to this method. Do not"},{"type":"text","text":" "},{"type":"text","text":"advance the iterator or any copies of the iterator outside this"},{"type":"text","text":" "},{"type":"text","text":"method."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"UnicodeDecodingResult"},{"text":" instance, representing the next","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Unicode scalar, an indication of an error, or an indication that the"},{"type":"text","text":" "},{"type":"text","text":"UTF sequence has been fully decoded."}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To decode a code unit sequence completely, call this method repeatedly"},{"text":" ","type":"text"},{"text":"until it returns ","type":"text"},{"code":"UnicodeDecodingResult.emptyInput","type":"codeVoice"},{"type":"text","text":". Checking that the"},{"type":"text","text":" "},{"type":"text","text":"iterator was exhausted is not sufficient, because the decoder can store"},{"type":"text","text":" "},{"type":"text","text":"buffered data from the input iterator."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because of buffering, it is impossible to find the corresponding position"},{"type":"text","text":" "},{"type":"text","text":"in the iterator for a given returned "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" or an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example decodes the UTF-8 encoded bytes of a string into an"},{"type":"text","text":" "},{"type":"text","text":"array of "},{"code":"Unicode.Scalar","type":"codeVoice"},{"text":" instances:","type":"text"}]},{"type":"codeListing","code":["let str = \"✨Unicode✨\"","print(Array(str.utf8))","// Prints \"[226, 156, 168, 85, 110, 105, 99, 111, 100, 101, 226, 156, 168]\"","","var bytesIterator = str.utf8.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf8Decoder = UTF8()","Decode: while true {","    switch utf8Decoder.decode(&bytesIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","// Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""],"syntax":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnicodeCodec"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unicodecodec/decode(_:)"]}],"sections":[],"abstract":[{"type":"text","text":"Starts or continues decoding a code unit sequence into Unicode scalar"},{"type":"text","text":" "},{"type":"text","text":"values."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/UnicodeCodec/decode(_:)","interfaceLanguage":"swi