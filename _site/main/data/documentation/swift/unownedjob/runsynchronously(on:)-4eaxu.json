{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"Run this job isolated to the passed task executor.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"runSynchronously"},{"kind":"text","text":"("},{"kind":"externalParam","text":"on"},{"kind":"text","text":" "},{"kind":"internalParam","text":"executor"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnownedTaskExecutor","preciseIdentifier":"s:12_Concurrency19UnownedTaskExecutorV","identifier":"doc://com.apple.Swift/documentation/Swift/UnownedTaskExecutor"},{"kind":"text","text":")"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The task executor this job will be run on."}]}],"name":"executor"}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This operation runs the job on the calling thread and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"blocks"}]},{"type":"text","text":" until the job completes."},{"type":"text","text":" "},{"type":"text","text":"The intended use of this method is for an executor to determine when and where it"},{"type":"text","text":" "},{"type":"text","text":"wants to run the job and then call this method on it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The passed in executor reference is used to establish the executor context for the job,"},{"type":"text","text":" "},{"type":"text","text":"and should be the same executor as the one semantically calling the "},{"type":"codeVoice","code":"runSynchronously"},{"type":"text","text":" method."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This operation consumes the job, preventing it accidental use after it has been run."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Converting a "},{"type":"codeVoice","code":"ExecutorJob"},{"type":"text","text":" to an "},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/UnownedJob"},{"type":"text","text":" and invoking ``UnownedJob/runSynchronously(_:)` on it multiple times is undefined behavior,"},{"type":"text","text":" "},{"type":"text","text":"as a job can only ever be run once, and must not be accessed after it has been run."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/UnownedJob/runSynchronously(isolatedTo:taskExecutor:)","type":"reference"}]}],"name":"See Also","style":"note","type":"aside"}],"kind":"content"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/UnownedJob/runSynchronously(on:)-4eaxu"},"metadata":{"externalID":"s:ScJ16runSynchronously2ony12_Concurrency19UnownedTaskExecutorV_tF","title":"runSynchronously(on:)","modules":[{"name":"Swift","relatedModules":[]}],"roleHeading":"Instance Method","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"runSynchronously"},{"kind":"text","text":"("},{"kind":"externalParam","text":"on"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency19UnownedTaskExecutorV","text":"UnownedTaskExecutor"},{"kind":"text","text":")"}],"role":"symbol"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnownedJob"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unownedjob/runsynchronously(on:)-4eaxu"]}],"references":{"doc://com.apple.Swift/documentation/Swift/UnownedJob/runSynchronously(on:)-4eaxu":{"kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/UnownedJob/runSynchronously(on:)-