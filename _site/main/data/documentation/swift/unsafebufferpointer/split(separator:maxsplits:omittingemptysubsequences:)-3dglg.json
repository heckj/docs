":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"split"},{"kind":"text","text":"("},{"kind":"externalParam","text":"separator"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sl7ElementQa","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Element","kind":"typeIdentifier","text":"Element"},{"kind":"text","text":", "},{"kind":"externalParam","text":"maxSplits"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","identifier":"doc://com.apple.Swift/documentation/Swift/Int","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":" = Int.max, "},{"kind":"externalParam","text":"omittingEmptySubsequences"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":" = true) -> ["},{"preciseIdentifier":"s:Sl11SubSequenceQa","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","kind":"typeIdentifier","text":"SubSequence"},{"kind":"text","text":"]"}]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The element that should be split upon."}],"type":"paragraph"}],"name":"separator"},{"content":[{"inlineContent":[{"type":"text","text":"The maximum number of times to split the collection, or"},{"type":"text","text":" "},{"type":"text","text":"one less than the number of subsequences to return. If"},{"type":"text","text":" "},{"type":"codeVoice","code":"maxSplits + 1"},{"type":"text","text":" subsequences are returned, the last one is a suffix"},{"type":"text","text":" "},{"type":"text","text":"of the original collection containing the remaining elements."},{"type":"text","text":" "},{"type":"codeVoice","code":"maxSplits"},{"type":"text","text":" must be greater than or equal to zero. The default value"},{"type":"text","text":" "},{"type":"text","text":"is "},{"type":"codeVoice","co