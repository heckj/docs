"text"},{"text":"instead of assuming that its indices start at a particular value.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This example demonstrates getting a slice from a buffer of strings,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"finding the index of one of the strings in the slice, and then using that"},{"type":"text","text":" "},{"text":"index in the original buffer.","type":"text"}]},{"code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","streets.withUnsafeBufferPointer { buffer in","    let streetSlice = buffer[2..<buffer.endIndex]","    print(Array(streetSlice))","    // Prints \"[\"Channing\", \"Douglas\", \"Evarts\"]\"","    let index = streetSlice.firstIndex(of: \"Evarts\")    // 4","    print(buffer[index!])","    // Prints \"Evarts\"","}"],"syntax":"swift","type":"codeListing"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bounds checks for "},{"code":"bounds","type":"codeVoice"},{"text":" are performed only in debug mode.","type":"text"}]}],"type":"aside","name":"Note"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unsafebufferpointer/subscript(_:)-6ynnu"]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer"]]},"metadata":{"extendedModule":"Swift","fragments":[{"text":"subscript","kind":"keyword"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Range","preciseIdentifier":"s:Sn"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5SliceV","text":"Slice"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SR","text":"UnsafeBufferPointer"},{"kind":"text","text":"<"},{"text":"Eleme