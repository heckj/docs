{"sections":[],"abstract":[{"type":"text","text":"Executes the given closure while temporarily binding the memory referenced"},{"type":"text","text":" "},{"type":"text","text":"by this buffer to the given type."}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer/withMemoryRebound(to:_:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withMemoryRebound"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"E"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Result"},{"kind":"text","text":">("},{"kind":"externalParam","text":"to"},{"kind":"text","text":" "},{"kind":"internalParam","text":"type"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1TL_qd__mfp","text":"T"},{"kind":"text","text":".Type, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"buffer"},{"kind":"text","text":": "},{"identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer","kind":"typeIdentifier","preciseIdentifier":"s:SR","text":"UnsafeBufferPointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1TL_qd__mfp","text":"T"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1EL_qd_0_mfp","text":"E"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF6ResultL_qd_1_mfp","text":"Result"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1EL_qd_0_mfp","text":"E"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF6ResultL_qd_1_mfp","text":"Result"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"E"},{"kind":"text","text":" : "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Error","kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP","text":"Error"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":" : ~Copyable, "},{"kind":"typeIdentifier","text":"Result"},{"kind":"text","text":" : ~Copyable"}]}]},{"kind":"parameters","parameters":[{"name":"type","content":[{"inlineContent":[{"type":"text","text":"The type to temporarily bind the memory referenced by this"},{"type":"text","text":" "},{"type":"text","text":"buffer. The type "},{"type":"codeVoice","code":"T"},{"type":"text","text":" must be layout compatible"},{"type":"text","text":" "},{"type":"text","text":"with the pointer’s "},{"type":"codeVoice","code":"Element"},{"type":"text","text":" type."}],"type":"paragraph"}]},{"name":"body","content":[{"inlineContent":[{"type":"text","text":"A closure that takes a  typed buffer to the"},{"type":"text","text":" "},{"type":"text","text":"same memory as this buffer, only bound to type "},{"type":"codeVoice","code":"T"},{"type":"text","text":". The buffer"},{"type":"text","text":" "},{"type":"text","text":"parameter contains a number of complete instances of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" based"},{"type":"text","text":" "},{"type":"text","text":"on the capacity of the original buffer and the stride of "},{"type":"codeVoice","code":"Element"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The closure’s buffer argument is valid only for the duration of the"},{"type":"text","text":" "},{"type":"text","text":"closure’s execution. If "},{"type":"codeVoice","code":"body"},{"type":"text","text":" has a return value, that value"},{"type":"text","text":" "},{"type":"text","text":"is also used as the return value for the "},{"code":"withMemoryRebound(to:_:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"method."}],"type":"paragraph"}]}]},{"content":[{"level":2,"type":"heading","anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"The return value, if any, of the ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" closure parameter.","type":"text"}]}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use this method when you have a buffer of memory bound to one type and"},{"type":"text","text":" "},{"type":"text","text":"you need to access that memory as a buffer of another type. Accessing"},{"type":"text","text":" "},{"type":"text","text":"memory as type "},{"type":"codeVoice","code":"T"},{"type":"text","text":" requires that the memory be bound to that type. A"},{"type":"text","text":" "},{"type":"text","text":"memory location may only be bound to one type at a time, so accessing"},{"type":"text","text":" "},{"type":"text","text":"the same memory as an unrelated type without first rebinding the memory"},{"type":"text","text":" "},{"type":"text","text":"is undefined."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The number of instances of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" referenced by the rebound buffer may be"},{"type":"text","text":" "},{"type":"text","text":"different than the number of instances of "},{"type":"codeVoice","code":"Element"},{"type":"text","text":" referenced by the"},{"type":"text","text":" "},{"type":"text","text":"original buffer. The number of instances of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" will be calculated"},{"type":"text","text":" "},{"type":"text","text":"at runtime."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any instance of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" within the re-bound region may be initialized or"},{"text":" ","type":"text"},{"text":"uninitialized. Every instance of ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"type":"text","text":" overlapping with a given"},{"text":" ","type":"text"},{"type":"text","text":"instance of "},{"type":"codeVoice","code":"T"},{"text":" should have the same initialization state (i.e.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initialized or uninitialized.) Accessing a "},{"code":"T","type":"codeVoice"},{"text":" whose underlying","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":" storage is in a mixed initialization state shall be"},{"type":"text","text":" "},{"type":"text","text":"undefined behaviour."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because this buffer’s memory is no longer bound to its "},{"type":"codeVoice","code":"Element"},{"type":"text","text":" type"},{"type":"text","text":" "},{"type":"text","text":"while the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure executes, do not access memory using the"},{"type":"text","text":" "},{"type":"text","text":"original buffer from within "},{"type":"codeVoice","code":"body"},{"text":". Instead, use the ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" closure’s","type":"text"},{"type":"text","text":" "},{"text":"buffer argument to access the values in memory as instances of type","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"T"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"After executing ","type":"text"},{"code":"body","type":"codeVoice"},{"text":", this method rebinds memory back to the original","type":"text"},{"text":" ","type":"text"},{"code":"Element","type":"codeVoice"},{"text":" type.","type":"text"}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Only use this method to rebind the buffer’s memory to a type"},{"type":"text","text":" "},{"type":"text","text":"that is layout compatible with the currently bound "},{"type":"codeVoice","code":"Element"},{"type":"text","text":" type."},{"type":"text","text":" "},{"type":"text","text":"The stride of the temporary type ("},{"type":"codeVoice","code":"T"},{"type":"text","text":") may be an integer multiple"},{"type":"text","text":" "},{"type":"text","text":"or a whole fraction of "},{"type":"codeVoice","code":"Element"},{"type":"text","text":"‘s stride."},{"type":"text","text":" "},{"type":"text","text":"To bind a region of memory to a type that does not match these"},{"type":"text","text":" "},{"type":"text","text":"requirements, convert the buffer to a raw buffer and use the"},{"type":"text","text":" "},{"type":"text","text":"raw buffer’s "},{"type":"codeVoice","code":"withMemoryRebound(to:)"},{"type":"text","text":" method."},{"type":"text","text":" "},{"type":"text","text":"If "},{"type":"codeVoice","code":"T"},{"type":"text","text":" and "},{"code":"Element","type":"codeVoice"},{"type":"text","text":" have different alignments, this buffer’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"baseAddress"},{"type":"text","text":" must be aligned with the larger of the two alignments."}]}],"type":"aside"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":[{"paths":["/documentation/swift/unsafebufferpointer/withmemoryrebound(to:_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer"]]},"metadata":{"extendedModule":"Swift","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withMemoryRebound"},{"kind":"text","text":"<"},{"text":"T","kind":"genericParameter"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"E"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Result"},{"kind":"text","text":">("},{"kind":"externalParam","text":"to"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1TL_qd__mfp","text":"T"},{"text":".Type, (","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"buffer","kind":"internalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SR","text":"UnsafeBufferPointer"},{"text":"<","kind":"text"},{"text":"T","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1TL_qd__mfp","kind":"typeIdentifier"},{"text":">) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"text":"E","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1EL_qd_0_mfp","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Result","preciseIdentifier":"s:SRsRi_zrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_SRyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF6ResultL_qd_1_mfp","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"t