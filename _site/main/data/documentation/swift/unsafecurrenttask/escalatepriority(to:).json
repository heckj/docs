{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnsafeCurrentTask"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"escalatePriority","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"newPriority","kind":"internalParam"},{"text":": ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskPriority","text":"TaskPriority","kind":"typeIdentifier","preciseIdentifier":"s:ScP"},{"text":")","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The task which to escalate the priority of"}]}],"name":"task"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The new priority the task should continue executing on"}]}],"name":"newPriority"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"name":"Warning","style":"warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This API should rarely be used, and instead you can rely on","type":"text"},{"text":" ","type":"text"},{"text":"structured concurrency and implicit priority escalation which happens","type":"text"},{"text":" ","type":"text"},{"text":"when a higher priority task awaits on a result of a lower priority task.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"I.e. using "},{"type":"codeVoice","code":"await"},{"type":"text","text":" on the target task usually is the correct way to"},{"type":"text","text":" "},{"type":"text","text":"escalate the target task to the current priority of the calling task,"},{"type":"text","text":" "},{"type":"text","text":"especially because in such setup if the waiting task gets escalated,"},{"type":"text","text":" "},{"typ