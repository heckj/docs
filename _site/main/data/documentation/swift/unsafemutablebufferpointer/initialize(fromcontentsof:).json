{"abstract":[{"text":"Initializes the buffer’s memory with every element of the source.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"initialize"},{"kind":"text","text":"("},{"kind":"externalParam","text":"fromContentsOf"},{"kind":"text","text":" "},{"kind":"internalParam","text":"source"},{"kind":"text","text":": "},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Collection","kind":"typeIdentifier","preciseIdentifier":"s:Sl","identifier":"doc://com.apple.Swift/documentation/Swift/Collection"},{"text":"<","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:Sr7Elementxmfp"},{"text":">) -> ","kind":"text"},{"text":"Index","kind":"typeIdentifier","preciseIdentifier":"s:SrsRi_zrlE5Indexa","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer/Index"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"source","content":[{"inlineContent":[{"type":"text","text":"A collection of elements to be used to"},{"type":"text","text":" "},{"type":"text","text":"initialize the buffer’s storage."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"inlineContent":[{"type":"text","text":"The index one past the last element of the buffer initialized"},{"type":"text","text":" "},{"type":"text","text":"by this function."}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Prior to calling the "},{"type":"codeVoice","code":"initialize(fromContentsOf:)"},{"type":"text","text":" method on a buffer, the"},{"type":"text","text":" "},{"type":"text","text":"memory referenced by the buffer must be uninitialized, or the "},{"type":"codeVoice","code":"Element"},{"type":"text","text":" "},{"type":"text","text":"type must be a trivial type. After the call, the memory referenced by the"},{"type":"text","text":" "},{"type":"text","text":"buffer up to, but not including, the returned index is initialized. The"},{"text":" ","type":"text"},{"text":"buffer must reference enough memory to accommodate ","type":"text"},{"code":"source.count","type":"codeVoice"},{"text":" ","type":"text"},{"text":"elements.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The returned index is the position of the next uninitialized element in"},{"type":"text","text":" "},{"type":"text","text":"the buffer, one past the index of the last element written. If "},{"type":"codeVoice","code":"source"},{"type":"text","text":" "},{"type":"text","text":"contains no elements, the returned index is equal to the buffer’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"startIndex"},{"type":"text","text":". If "},{"type":"codeVoice","code":"source"},{"type":"text","text":" contains as many elements as the buffer can"},{"type":"text","text":" "},{"type":"text","text":"hold, the returned index is equal to the buffer’s "},{"type":"codeVoice","code":"endIndex"},{"type":"text","text":"."}]},{"type":"aside","style":"note","name":"Precondition","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"self.count"},{"text":" >= ","type":"text"},{"type":"codeVoice","code":"source.count"}]}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The memory regions referenced by "},{"code":"source","type":"codeVoice"},{"type":"text","text":" and this buffer"},{"type":"text","text":" "},{"type":"text","text":"must not overlap."}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unsafemutablebufferpointer/initialize(fromcontentsof:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"t