":"codeVoice","code":"self.count"},{"type":"text","text":" >= "},{"type":"codeVoice","code":"source.count"}]}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The memory regions referenced by "},{"type":"codeVoice","code":"source"},{"type":"text","text":" and this buffer"},{"type":"text","text":" "},{"type":"text","text":"may overlap."}]}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unsafemutablebufferpointer/moveinitialize(fromcontentsof:)-1ag7a"]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer"]]},"metadata":{"extendedModule":"Swift","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"moveInitialize"},{"kind":"text","text":"("},{"kind":"externalParam","text":"fromContentsOf"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Slice","preciseIdentifier":"s:s5SliceV"},{"kind":"text","text":"<`Self`"},{"kind":"text","text":">) -> "},{"preciseIdentifier":"s:SrsRi_zrlE5Indexa","kind":"typeIdentifier","text":"Index"}],"symbolKind":"method","externalID":"s:Sr14moveInitialize14fromContentsOfSis5SliceVySryxGG_tF","modules":[{"name":"Swift"}],"title":"moveInitialize(fromContentsOf:)","role":"symbol","roleHeading":"Instance Method"},"references":{"doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer/Index":{"navigatorTitle":[{"kind":"identifier","text":"Index"}],"url":"/documentation/swift/unsafemutablebufferpointer/index","title":"UnsafeMutableBufferPointer.Index","abstract":[],"type":"topic","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"Index"}],"identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer/Index","role":"symbol","kind":"symbol"},"doc://c