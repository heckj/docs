{"sections":[],"abstract":[{"type":"text","text":"Moves every element of an initialized source buffer into the"},{"type":"text","text":" "},{"type":"text","text":"uninitialized memory referenced by this buffer, leaving the source memory"},{"type":"text","text":" "},{"type":"text","text":"uninitialized and this buffer’s memory initialized."}],"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer/moveInitialize(fromContentsOf:)-1ag7a","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"moveInitialize"},{"kind":"text","text":"("},{"kind":"externalParam","text":"fromContentsOf"},{"kind":"text","text":" "},{"kind":"internalParam","text":"source"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Slice","preciseIdentifier":"s:s5SliceV","identifier":"doc://com.apple.Swift/documentation/Swift/Slice"},{"kind":"text","text":"<`Self`"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","text":"Index","preciseIdentifier":"s:SrsRi_zrlE5Indexa","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer/Index"}]}]},{"kind":"parameters","parameters":[{"name":"source","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A buffer containing the values to copy. The memory"},{"type":"text","text":" "},{"type":"text","text":"region underlying "},{"type":"codeVoice","code":"source"},{"type":"text","text":" must be initialized."}]}]}]},{"kind":"content","content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The index one past the last element of the buffer initialized"},{"type":"text","text":" "},{"type":"text","text":"by this function."}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"ty