{"sections":[],"variants":[{"paths":["/documentation/swift/unsafemutablebufferpointer/partition(by:)-33su1"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Reorders the elements of the collection such that all the elements"},{"type":"text","text":" "},{"type":"text","text":"that match the given predicate are after all the elements that don’t"},{"type":"text","text":" "},{"type":"text","text":"match."}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer/partition(by:)-33su1"},"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer"]]},"metadata":{"roleHeading":"Instance Method","extendedModule":"Swift","role":"symbol","externalID":"s:SMsSKRzrlE9partition2by5IndexSlQzSb7ElementSTQzKXE_tKF::SYNTHESIZED::s:Sr","symbolKind":"method","title":"partition(by:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"partition","kind":"identifier"},{"text":"(","kind":"text"},{"text":"by","kind":"externalParam"},{"text":": (","kind":"text"},{"preciseIdentifier":"s:SK7ElementQa","text":"Element","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:SK5IndexQa","text":"Index","kind":"typeIdentifier"}],"conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"availabilityPrefix":[{"type":"text","text":"Available when"}],"constraints":[{"type":"codeVoice","code":"Self"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"BidirectionalCollection"},{"type":"text","text":"."}]},"modules":[{"name":"Swift"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"mutating","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"partition","kind":"identifier"},{"text":"(","kind":"text"},{"text":"by","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"belongsInSecondPartition","kind":"internalParam"},{"text":": (","kind":"text"},{"text":"Element","preciseIdentifier":"s:SK7ElementQa","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/BidirectionalCollection/Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":") ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Index","identifier":"doc://com.apple.Swift/documentation/Swift/BidirectionalCollection/Index","kind":"typeIdentifier","preciseIdentifier":"s:SK5IndexQa"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"belongsInSecondPartition","content":[{"type":"paragraph","inlineContent":[{"text":"A predicate used to partition","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the collection. All elements satisfying this predicate are ordered"},{"type":"text","text":" "},{"type":"text","text":"after all elements not satisfying it."}]}]}]},{"content":[{"text":"Return Value","level":2,"type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"The index of the first element in the reordered collection"},{"type":"text","text":" "},{"type":"text","text":"that matches "},{"type":"codeVoice","code":"belongsInSecondPartition"},{"type":"text","text":". If no elements in the"},{"type":"text","text":" "},{"type":"text","text":"collection match "},{"type":"codeVoice","code":"belongsInSecondPartition"},{"type":"text","text":", the returned index is"},{"type":"text","text":" "},{"type":"text","text":"equal to the collection’s "},{"type":"codeVoice","code":"endIndex"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"After partitioning a collection, there is a pivot index ","type":"text"},{"code":"p","type":"codeVoice"},{"text":" where","type":"text"},{"text":" ","type":"text"},{"text":"no element before ","type":"text"},{"code":"p","type":"codeVoice"},{"text":" satisfies the ","type":"text"},{"code":"belongsInSecondPartition","type":"codeVoice"},{"text":" ","type":"text"},{"text":"predicate and every element at or after ","type":"text"},{"code":"p","type":"codeVoice"},{"text":" satisfies","type":"text"},{"text":" ","type":"text"},{"code":"belongsInSecondPartition","type":"codeVoice"},{"text":". This operation isn’t guaranteed to be","type":"text"},{"text":" ","type":"text"},{"text":"stable, so the relative ordering of elements within the partitions might","type":"text"},{"text":" ","type":"text"},{"text":"change.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In the following example, an array of numbers is partitioned by a","type":"text"},{"text":" ","type":"text"},{"text":"predicate that matches elements greater than 30.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var numbers = [30, 40, 20, 30, 30, 60, 10]","let p = numbers.partition(by: { $0 > 30 })","// p == 5","// numbers == [30, 10, 20, 30, 30, 60, 40]"],"type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"numbers"},{"text":" array is now arranged in two partitions. The first","type":"text"},{"text":" ","type":"text"},{"text":"partition, ","type":"text"},{"type":"codeVoice","code":"numbers[..<p]"},{"text":", is made up of the elements that","type":"text"},{"text":" ","type":"text"},{"text":"are not greater than 30. The second partition, ","type":"text"},{"type":"codeVoice","code":"numbers[p...]"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"is made up of the elements that "},{"type":"emphasis","inlineContent":[{"type":"text","text":"are"}]},{"type":"text","text":" greater than 30."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let first = numbers[..<p]","// first == [30, 10, 20, 30, 30]","let second = numbers[p...]","// second == [60, 40]"]},{"inlineContent":[{"type":"text","text":"Note that the order of elements in both partitions changed."},{"type":"text","text":" "},{"type":"text","text":"That is, "},{"type":"codeVoice","code":"40"},{"type":"text","text":" appears before "},{"code":"60","type":"codeVoice"},{"type":"text","text":" in the original collection,"},{"type":"text","text":" "},{"type":"text","text":"but, after calling "},{"type":"codeVoice","code":"partition(by:)"},{"type":"text","text":", "},{"code":"60","type":"codeVoice"},{"text":" appears before ","type":"text"},{"code":"40","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" is the length of the collection."}]}],"name":"Complexity","type":"aside","style":"note"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/BidirectionalCollection/Element":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/BidirectionalCollection/Element","url":"/documentation/swift/bidirectionalcollection/element","required":true,"kind":"s