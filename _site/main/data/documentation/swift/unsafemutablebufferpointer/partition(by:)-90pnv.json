.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer","role":"symbol","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/Bool":{"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Bool","type":"topic","title":"Bool","kind":"symbol","url":"/documentation/swift/bool","navigatorTitle":[{"kind":"identifier","text":"Bool"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Bool"}],"abstract":[{"text":"A value type whose instances are either ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]},"doc://com.apple.Swift/documentation/Swift/MutableCollection/Index":{"required":true,"abstract":[],"role":"symbol","url":"/documentation/swift/mutablecollection/index","kind":"symbol","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Index"}],"identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Index","type":"topic","title":"Index"},"doc://com.apple.Swift/documentation/Swift/MutableCollection/Element":{"required":true,"abstract":[],"role":"symbol","url":"/documentation/swift/mutablecollection/element","kind":"symbol","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Element"}],"identifier":"doc://com.apple.Swift/documentation/Swift/MutableCollection/Element","type":"topic","title":"Element"},"doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer/partition(by:)-90pnv":{"url":"/documentation/swift/unsafemutablebufferpointer/partition(by:)-90pnv","title":"partition(by:)","abstract":[{"type":"text","text":"Reorders the elements of the collection such that all the elements"},{"type":"text","text":" "},{"type":"text","text":"that match the given predicate are after all the elements that don’t"},{"type":"text","text":" "},{"type":"text","text":"match."