":"text","text":" "},{"text":"executed and ","type":"text"},{"type":"codeVoice","code":"initialResult"},{"text":" is the result of the call to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"reduce(into:_:)"},{"text":".","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"text":"), where ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"text":" is the length of the sequence.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Complexity"}],"kind":"content"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer/reduce(into:_:)"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","metadata":{"externalID":"s:STsE6reduce4into_qd__qd__n_yqd__z_7ElementQztKXEtKlF::SYNTHESIZED::s:Sr","symbolKind":"method","roleHeading":"Instance Method","title":"reduce(into:_:)","role":"symbol","extendedModule":"Swift","modules":[{"name":"Swift"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reduce"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Result"},{"kind":"text","text":">("},{"kind":"externalParam","text":"into"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Result","preciseIdentifier":"s:STsE6reduce4into_qd__qd__n_yqd__z_7ElementQztKXEtKlF6ResultL_qd__mfp"},{"kind":"text","text":", ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"partialResult"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Result","preciseIdentifier":"s:STsE6reduce4into_qd__qd__n_yqd__z_7ElementQztKXEtKlF6ResultL_qd__mfp"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:ST7ElementQa"