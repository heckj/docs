am","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","identifier":"doc://com.apple.Swift/documentation/Swift/Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"pointer"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutablePointer","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:SpsRi_zrlE17withMemoryRebound2to8capacity_qd_1_qd__m_Siqd_1_Spyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1TL_qd__mfp"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"E","preciseIdentifier":"s:SpsRi_zrlE17withMemoryRebound2to8capacity_qd_1_qd__m_Siqd_1_Spyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1EL_qd_0_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Result","preciseIdentifier":"s:SpsRi_zrlE17withMemoryRebound2to8capacity_qd_1_qd__m_Siqd_1_Spyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF6ResultL_qd_1_mfp"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"E","preciseIdentifier":"s:SpsRi_zrlE17withMemoryRebound2to8capacity_qd_1_qd__m_Siqd_1_Spyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1EL_qd_0_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Result","preciseIdentifier":"s:SpsRi_zrlE17withMemoryRebound2to8capacity_qd_1_qd__m_Siqd_1_Spyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF6ResultL_qd_1_mfp"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"E"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Error","text":"Error","preciseIdentifier":"s:s5ErrorP"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":" : ~Copyable, "},{"kind":"typeIdentifier","text":"Result"},{"kind":"text","text":" : ~Copyable"}]}],"kind":"declarations"},{"parameters":[{"name":"type","content":[{"inlineContent":[{"text":"The type to temporarily bind the memory referenced by this","type":"text"},{"text":" ","type":"text"},{"text":"pointer. The type ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" must be layout compatible","type":"text"},{"text":" ","type":"text"},{"text":"with the pointer’s ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"text":" type.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The number of instances of "},{"code":"T","type":"codeVoice"},{"type":"text","text":" in the re-bound region."}],"type":"paragraph"}],"name":"count"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A closure that takes a mutable typed pointer to the","type":"text"},{"text":" ","type":"text"},{"text":"same memory as this pointer, only bound to type ","type":"text"},{"code":"T","type":"codeVoice"},{"text":". The closure’s","type":"text"},{"text":" ","type":"text"},{"text":"pointer argument is valid only for the duration of the closure’s","type":"text"},{"text":" ","type":"text"},{"text":"execution. If ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" has a return value, that value is also used as","type":"text"},{"text":" ","type":"text"},{"text":"the return value for the ","type":"text"},{"code":"withMemoryRebound(to:capacity:_:)","type":"codeVoice"},{"text":" method.","type":"text"}]}],"name":"body"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"inlineContent":[{"text":"The return value, if any, of the ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" closure parameter.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method when you have a pointer to memory bound to one type and"},{"type":"text","text":" "},{"type":"text","text":"you need to access that memory as instances of another type. Accessing"},{"type":"text","text":" "},{"type":"text","text":"memory as a type "},{"type":"codeVoice","code":"T"},{"type":"text","text":" requires that the memory be bound to that type. A"},{"type":"text","text":" "},{"type":"text","text":"memory location may only be bound to one type at a time, so accessing"},{"type":"text","text":" "},{"type":"text","text":"the same memory as an unrelated type without first rebinding the memory"},{"type":"text","text":" "},{"type":"text","text":"is undefined."}]},{"type":"paragraph","inlineContent":[{"text":"The region of memory that starts at this pointer and covers ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" ","type":"text"},{"text":"strides of ","type":"text"},{"type":"codeVoice","code":"T"},{"text":" instances must be bound to ","type":"text"},{"type":"codeVoice","code":"Pointee"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Any instance of ","type":"text"},{"type":"codeVoice","code":"T"},{"text":" within the re-bound region may be initialized or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"uninitialized. Every instance of "},{"code":"Pointee","type":"codeVoice"},{"type":"text","text":" overlapping with a given"},{"type":"text","text":" "},{"type":"text","text":"instance of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" should have the same initialization state (i.e."},{"type":"text","text":" "},{"type":"text","text":"initialized or uninitialized.) Accessing a "},{"type":"codeVoice","code":"T"},{"type":"text","text":" whose underlying"},{"type":"text","text":" "},{"code":"Pointee","type":"codeVoice"},{"type":"text","text":" storage is in a mixed initialization state shall be"},{"type":"text","text":" "},{"text":"undefined behaviour.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The following example temporarily rebinds the memory of a "},{"type":"codeVoice","code":"UInt64"},{"type":"text","text":" "},{"type":"text","text":"pointer to "},{"type":"codeVoice","code":"Int64"},{"type":"text","text":", then modifies the signed integer."}],"type":"paragraph"},{"code":["let uint64Pointer: UnsafeMutablePointer<UInt64> = fetchValue()","uint64Pointer.withMemoryRebound(to: Int64.self, capacity: 1) {","    $0.pointee.negate()","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Because this pointer’s memory is no longer bound to its "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":" type"},{"type":"text","text":" "},{"type":"text","text":"while the "},{"code":"body","type":"codeVoice"},{"type":"text","text":" closure executes, do not access memory using the"},{"text":" ","type":"text"},{"type":"text","text":"original pointer from within "},{"type":"codeVoice","code":"body"},{"type":"text","text":". Instead, use the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure’s"},{"type":"text","text":" "},{"type":"text","text":"pointer argument to access the values in memory as instances of type"},{"type":"text","text":" "},{"type":"codeVoice","code":"T"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"After executing ","type":"text"},{"code":"body","type":"codeVoice"},{"text":", this method rebinds memory back to the original","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":" type."}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Only use this method to rebind the pointer’s memory to a type"},{"type":"text","text":" "},{"type":"text","text":"that is layout compatible with the "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":" type. The stride of the"},{"type":"text","text":" "},{"type":"text","text":"temporary type ("},{"type":"codeVoice","code":"T"},{"type":"text","text":") may be an integer multiple or a whole fraction"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":"’s stride, for example to point to one element of"},{"type":"text","text":" "},{"type":"text","text":"an aggregate."},{"type":"text","text":" "},{"type":"text","text":"To bind a region of memory to a type that does not match these"},{"type":"text","text":" "},{"type":"text","text":"requirements, convert the pointer to a raw pointer and use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"bindMemory(to:)"},{"type":"text","text":" method."},{"type":"text","text":" "},{"type":"text","text":"If "},{"type":"codeVoice","code":"T"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":" have different alignments, this pointer"},{"type":"text","text":" "},{"type":"text","text":"must be aligned with the larger of the two alignments."}],"type":"paragraph"}],"type":"aside"}],"kind":"content"}],"variants":[{"paths":["/documentation/swift/unsafemutablepointer/withmemoryrebound(to:capacity:_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/Error":{"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Error","url":"/documentation/swift/error","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"Error","kind":"identifier"}],"title":"Error","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Error","kind":"identifier"}],"abstract":[{"type":"text","text":"A type representing an error value that can be thrown."}]},"doc://com.apple.Swift/documentation/Swift/Unsaf