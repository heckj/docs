{"type":"text","text":"type that is layout compatible with "},{"type":"codeVoice","code":"T"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The memory written to must not extend beyond the buffer pointer’s memory"},{"type":"text","text":" "},{"type":"text","text":"region—that is, "},{"type":"codeVoice","code":"offset + MemoryLayout<T>.size"},{"type":"text","text":" must be less than or"},{"type":"text","text":" "},{"text":"equal to the buffer pointer’s ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"After calling "},{"type":"codeVoice","code":"storeBytes(of:toByteOffset:as:)"},{"type":"text","text":", the memory is"},{"type":"text","text":" "},{"text":"initialized to the raw bytes of ","type":"text"},{"code":"value","type":"codeVoice"},{"text":". If the memory is bound to a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type "},{"type":"codeVoice","code":"U"},{"type":"text","text":" that is layout compatible with "},{"type":"codeVoice","code":"T"},{"type":"text","text":", then it contains a value of"},{"type":"text","text":" "},{"type":"text","text":"type "},{"type":"codeVoice","code":"U"},{"type":"text","text":". Calling "},{"type":"codeVoice","code":"storeBytes(of:toByteOffset:as:)"},{"type":"text","text":" does not change the"},{"type":"text","text":" "},{"type":"text","text":"bound type of the memory."}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"A trivial type can be copied with just a bit-for-bit copy without","type":"text"},{"text":" ","type":"text"},{"text":"any indirection or reference-counting operations. Generally, native","type":"text"},{"text":" ","type":"text"},{"text":"Swift types that do not contain strong or weak references or other","type":"text"},{"text":" ","type":"text"},{"text":"forms of indirection are trivial, as are imported C structs and enum