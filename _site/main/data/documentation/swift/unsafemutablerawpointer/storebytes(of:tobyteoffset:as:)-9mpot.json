{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawPointer"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"storeBytes"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"kind":"externalParam","text":"of"},{"text":" ","kind":"text"},{"text":"value","kind":"internalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:Sv10storeBytes2of12toByteOffset2asyx_SixmtlF1TL_xmfp"},{"kind":"text","text":", "},{"kind":"externalParam","text":"toByteOffset"},{"kind":"text","text":" "},{"kind":"internalParam","text":"offset"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Int","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":" = 0, "},{"kind":"externalParam","text":"as"},{"kind":"text","text":" "},{"kind":"internalParam","text":"type"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:Sv10storeBytes2of12toByteOffset2asyx_SixmtlF1TL_xmfp"},{"kind":"text","text":".Type)"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The value to store as raw bytes.","type":"text"}]}],"name":"value"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The offset from this pointer, in bytes. ","type":"text"},{"type":"codeVoice","code":"offset"},{"text":" must be","type":"text"},{"text":" ","type":"text"},{"text":"nonnegative. The default is zero.","type":"text"}]}],"name":"offset"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The type of "},{"type":"codeVoice","code":"value"},{"type":"text","text":"."}]}],"name":"type"}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"The type ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" to be stored must be a trivial type. The memory","type":"text"},{"type":"text","text":" "},{"type":"text","text":"must also be uninitialized, initialized to "},{"type":"codeVoice","code":"T"},{"type":"text","text":", or initialized to"},{"type":"text","text":" "},{"type":"text","text":"another trivial type that is layout compatible with "},{"type":"codeVoice","code":"T"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"After calling ","type":"text"},{"type":"codeVoice","code":"storeBytes(of:toByteOffset:as:)"},{"text":", the memory is","type":"text"},{"text":" ","type":"text"},{"text":"initialized to the raw bytes of ","type":"text"},{"type":"codeVoice","code":"value"},{"text":". If the memory is bound to a","type":"text"},{"text":" ","type":"text"},{"text":"type ","type":"text"},{"type":"codeVoice","code":"U"},{"text":" that is layout compatible with ","type":"text"},{"type":"codeVoice","code":"T"},{"text":", then it contains a value of","type":"text"},{"text":" ","type":"text"},{"text":"type ","type":"text"},{"type":"codeVoice","code":"U"},{"text":". Calling ","type":"text"},{"type":"codeVoice","code":"storeBytes(of:toByteOffset:as:)"},{"text":" does not change the","type":"text"},{"text":" ","type":"text"},{"text":"bound type of the memory.","type":"text"}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"text":"A trivial type can be copied with just a bit-for-bit copy without","type":"text"},{"text":" ","type":"text"},{"text":"any indirection or reference-counting operations. Generally, native","type":"text"},{"text":" ","type":"text"},{"text":"Swift types that do not contain strong or weak references or other","type":"text"},{"text":" ","type":"text"},{"text":"forms of indirection are trivial, as are imported C structs and enums.","type":"text"}],"type":"paragraph"}]},{"inlineContent":[{"text":"If you need to store into memory a copy of a value of a type that isn’t","type":"text"},{"text":" ","type":"text"},{"text":"trivial, you cannot use the ","type":"text"},{"code":"storeBytes(of:toByteOffset:as:)","type":"codeVoice"},{"text":" method.","type":"text"},{"text":" ","type":"text"},{"text":"Instead, you must know either initialize the memory or,","type":"text"},{"text":" ","type":"text"},{"text":"if you know the memory was already bound to ","type":"text"},{"code":"type","type":"codeVoice"},{"text":", assign to the memory.","type":"text"},{"text":" ","type":"text"},{"text":"For example, to replace a value stored in a raw pointer ","type":"text"},{"code":"p","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"where ","type":"text"},{"code":"U","type":"codeVoice"},{"text":" is the current type and ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" is the new type, use a typed","type":"text"},{"text":" ","type":"text"},{"text":"pointer to access and deinitialize the current value before initializing","type":"text"},{"text":" ","type":"text"},{"text":"the memory with a new value:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let typedPointer = p.bindMemory(to: U.self, capacity: 1)","typedPointer.deinitialize(count: 1)","p.initializeMemory(as: T.self, repeating: newValue, count: 1)"]}],"kind":"content"}],"abstract":[{"text":"Stores the given value’s bytes into raw memory at the specified offset.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"extendedModule":"Swift","role":"symbol","title":"storeBytes(of:toByteOffset:as:)","symbolKind":"method","modules":[{"name":"Swift"}],"externalID":"s:Sv10storeBytes2of12toByteOffset2asyx_SixmtlF","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"storeBytes"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"kind":"externalParam