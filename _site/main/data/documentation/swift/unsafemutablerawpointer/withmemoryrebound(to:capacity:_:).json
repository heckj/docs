xt"},{"preciseIdentifier":"s:Si","identifier":"doc://com.apple.Swift/documentation/Swift/Int","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"_","kind":"externalParam"},{"kind":"text","text":" "},{"text":"body","kind":"internalParam"},{"kind":"text","text":": ("},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"pointer"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutablePointer","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv17withMemoryRebound2to8capacity_q0_xm_Siq0_SpyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1TL_xmfp","text":"T"},{"text":">) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sv17withMemoryRebound2to8capacity_q0_xm_Siq0_SpyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1EL_q_mfp","text":"E","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sv17withMemoryRebound2to8capacity_q0_xm_Siq0_SpyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF6ResultL_q0_mfp","text":"Result","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sv17withMemoryRebound2to8capacity_q0_xm_Siq0_SpyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1EL_q_mfp","text":"E","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sv17withMemoryRebound2to8capacity_q0_xm_Siq0_SpyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF6ResultL_q0_mfp","text":"Result","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"E","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:s5ErrorP","identifier":"doc://com.apple.Swift/documentation/Swift/Error","text":"Error","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":" : ~Copyable, ","kind":"text"},{"text":"Result","kind":"typeIdentifier"},{"text":" : ~Copyable","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"type","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The type to temporarily bind the memory referenced by this"},{"type":"text","text":" "},{"type":"text","text":"pointer. This pointer must be a multiple of this type’s alignment."}]}]},{"name":"count","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The number of instances of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" in the re-bound region."}]}]},{"name":"body","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure that takes a typed pointer to the"},{"type":"text","text":" "},{"type":"text","text":"same memory as this pointer, only bound to type "},{"type":"codeVoice","code":"T"},{"type":"text","text":". The closure’s"},{"type":"text","text":" "},{"type":"text","text":"pointer argument is valid only for the duration of the closure’s"},{"type":"text","text":" "},{"type":"text","text":"execution. If "},{"type":"codeVoice","code":"body"},{"type":"text","text":" has a return value, that value is also used as"},{"type":"text","text":" "},{"type":"text","text":"the return value for the "},{"type":"codeVoice","code":"withMemoryRebound(to:capacity:_:)"},{"type":"text","text":" method."}]}]}]},{"content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"The return value, if any, of the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure parameter."}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Use this method when you have a pointer to raw memory and you need"},{"type":"text","text":" "},{"type":"text","text":"to access that memory as instances of a given type "},{"type":"codeVoice","code":"T"},{"type":"text","text":". Accessing"},{"type":"text","text":" "},{"type":"text","text":"memory as a type "},{"type":"codeVoice","code":"T"},{"type":"text","text":" requires that the memory be bound to that type. A"},{"type":"text","text":" "},{"type":"text","text":"memory location may only be bound to one type at a time, so accessing"},{"type":"text","text":" "},{"type":"text","text":"the same memory as an unrelated type without first rebinding the memory"},{"type":"text","text":" "},{"type":"text","text":"is undefined."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Any instance of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" within the re-bound region may be initialized or"},{"type":"text","text":" "},{"type":"text","text":"uninitialized. The memory underlying any individual instance of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" "},{"type":"text","text":"must have the same initialization state (i.e.  initialized or"},{"type":"text","text":" "},{"type":"text","text":"uninitialized.) Accessing a "},{"type":"codeVoice","code":"T"},{"type":"text","text":" whose underlying memory"},{"type":"text","text":" "},{"type":"text","text":"is in a mixed initialization state shall be undefined behaviour."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example temporarily rebinds a raw memory pointer"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"Int64"},{"type":"text","text":", then modifies the signed integer."}],"type":"paragraph"},{"type":"codeListing","code":["let pointer: UnsafeMutableRawPointer = fetchValue()","pointer.withMemoryRebound(to: Int64.self, capacity: 1) {","    $0.pointee.negate()","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"After executing "},{"type":"codeVoice","code":"body"},{"type":"text","text":", this method rebinds memory back to its original"},{"type":"text","text":" "},{"type":"text","text":"binding state. This can be unbound memory, or bound to a different type."}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The region of memory starting at this pointer must match the"},{"type":"text","text":" "},{"type":"text","text":"alignment of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" (as reported by "},{"type":"codeVoice","code":"MemoryLayout<T>.alignment"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"That is, "},{"type":"codeVoice","code":"Int(bitPattern: self) % MemoryLayout<T>.alignment"},{"type":"text","text":" "},{"type":"text","text":"must equal zero."}]}]},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The region of memory starting at this pointer may have been"},{"type":"text","text":" "},{"type":"text","text":"bound to a type. If that is the case, then "},{"type":"codeVoice","code":"T"},{"type":"text","text":" must be"},{"type":"text","text":" "},{"type":"text","text":"layout compatible with the type to which the memory has been bound."},{"type":"text","text":" "},{"type":"text","text":"This requirement does not apply if the region of memory"},{"type":"text","text":" "},{"type":"text","text":"has not been bound to any type."}]}]}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawPointer":{"navigatorTitle":[{"kind":"identifier","text":"UnsafeMutableRawPointer"}],"type":"topic","title":"UnsafeMutableRawPointer","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawPointer","kind":"symbol","role":"symbol","abstra