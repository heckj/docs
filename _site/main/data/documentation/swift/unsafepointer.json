{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/UnsafePointer","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Pointee"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Pointee"},{"kind":"text","text":" : ~Copyable"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc://com.apple.Swift/documentation/Swift/using-imported-c-functions-in-swift"]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"You use instances of the ","type":"text"},{"code":"UnsafePointer","type":"codeVoice"},{"text":" type to access data of a","type":"text"},{"text":" ","type":"text"},{"text":"specific type in memory. The type of data that a pointer can access is the","type":"text"},{"text":" ","type":"text"},{"text":"pointer’s ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"text":" type. ","type":"text"},{"code":"UnsafePointer","type":"codeVoice"},{"text":" provides no automated","type":"text"},{"text":" ","type":"text"},{"text":"memory management or alignment guarantees. You are responsible for","type":"text"},{"text":" ","type":"text"},{"text":"handling the life cycle of any memory you work with through unsafe","type":"text"},{"text":" ","type":"text"},{"text":"pointers to avoid leaks or undefined behavior.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Memory that you manually manage can be either ","type":"text"},{"inlineContent":[{"type":"text","text":"untyped"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"bound"}],"type":"emphasis"},{"text":" to a","type":"text"},{"text":" ","type":"text"},{"text":"specific type. You use the ","type":"text"},{"type":"codeVoice","code":"UnsafePointer"},{"text":" type to access and","type":"text"},{"text":" ","type":"text"},{"text":"manage memory that has been bound to a specific type.","type":"text"}]},{"anchor":"Understanding-a-Pointers-Memory-State","type":"heading","text":"Understanding a Pointer’s Memory State","level":1},{"type":"paragraph","inlineContent":[{"type":"text","text":"The memory referenced by an "},{"code":"UnsafePointer","type":"codeVoice"},{"type":"text","text":" instance can be in"},{"type":"text","text":" "},{"type":"text","text":"one of several states. Many pointer operations must only be applied to"},{"type":"text","text":" "},{"type":"text","text":"pointers with memory in a specific state—you must keep track of the"},{"type":"text","text":" "},{"type":"text","text":"state of the memory you are working with and understand the changes to"},{"type":"text","text":" "},{"type":"text","text":"that state that different operations perform. Memory can be untyped and"},{"type":"text","text":" "},{"type":"text","text":"uninitialized, bound to a type and uninitialized, or bound to a type and"},{"type":"text","text":" "},{"type":"text","text":"initialized to a value. Finally, memory that was allocated previously may"},{"type":"text","text":" "},{"type":"text","text":"have been deallocated, leaving existing pointers referencing unallocated"},{"type":"text","text":" "},{"type":"text","text":"memory."}]},{"text":"Uninitialized Memory","anchor":"Uninitialized-Memory","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Memory that has just been allocated through a typed pointer or has been"},{"type":"text","text":" "},{"type":"text","text":"deinitialized is in an "},{"type":"emphasis","inlineContent":[{"text":"uninitialized","type":"text"}]},{"type":"text","text":" state. Uninitialized memory must be"},{"type":"text","text":" "},{"type":"text","text":"initialized before it can be accessed for reading."}],"type":"paragraph"},{"text":"Initialized Memory","anchor":"Initialized-Memory","type":"heading","level":2},{"inlineContent":[{"inlineContent":[{"text":"Initialized","type":"text"}],"type":"emphasis"},{"text":" memory has a value that can be read using a pointer’s","type":"text"},{"text":" ","type":"text"},{"code":"pointee","type":"codeVoice"},{"type":"text","text":" property or through subscript notation. In the following"},{"type":"text","text":" "},{"type":"text","text":"example, "},{"type":"codeVoice","code":"ptr"},{"type":"text","text":" is a pointer to memory initialized with a value of "},{"type":"codeVoice","code":"23"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let ptr: UnsafePointer<Int> = ...","// ptr.pointee == 23","// ptr[0] == 23"]},{"level":1,"type":"heading","text":"Accessing a Pointer’s Memory as a Different Type","anchor":"Accessing-a-Pointers-Memory-as-a-Different-Type"},{"inlineContent":[{"text":"When you access memory through an ","type":"text"},{"code":"UnsafePointer","type":"codeVoice"},{"text":" instance, the","type":"text"},{"text":" ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"text":" type must be consistent with the bound type of the memory. If","type":"text"},{"text":" ","type":"text"},{"text":"you do need to access memory that is bound to one type as a different","type":"text"},{"text":" ","type":"text"},{"text":"type, Swift’s pointer types provide type-safe ways to temporarily or","type":"text"},{"text":" ","type":"text"},{"text":"permanently change the bound type of the memory, or to load typed","type":"text"},{"text":" ","type":"text"},{"text":"instances directly from raw memory.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"An "},{"type":"codeVoice","code":"UnsafePointer<UInt8>"},{"type":"text","text":" instance allocated with eight bytes of"},{"type":"text","text":" "},{"type":"text","text":"memory, "},{"type":"codeVoice","code":"uint8Pointer"},{"type":"text","text":", will be used for the examples below."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let uint8Pointer: UnsafePointer<UInt8> = fetchEightBytes()"]},{"inlineContent":[{"text":"When you only need to temporarily access a pointer’s memory as a different","type":"text"},{"text":" ","type":"text"},{"text":"type, use the ","type":"text"},{"type":"codeVoice","code":"withMemoryRebound(to:capacity:)"},{"type":"text","text":" method. For example, you"},{"type":"text","text":" "},{"type":"text","text":"can use this method to call an API that expects a pointer to a different"},{"type":"text","text":" "},{"type":"text","text":"type that is layout compatible with your pointer’s "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":". The following"},{"type":"text","text":" "},{"type":"text","text":"code temporarily rebinds the memory that "},{"type":"codeVoice","code":"uint8Pointer"},{"type":"text","text":" references from"},{"type":"text","text":" "},{"type":"codeVoice","code":"UInt8"},{"type":"text","text":" to "},{"type":"codeVoice","code":"Int8"},{"type":"text","text":" to call the imported C "},{"type":"codeVoice","code":"strlen"},{"type":"text","text":" function."}],"type":"paragraph"},{"code":["// Imported from C","func strlen(_ __s: UnsafePointer<Int8>!) -> UInt","","let length = uint8Pointer.withMemoryRebound(to: Int8.self, capacity: 8) {","    return strlen($0)","}","// length == 7"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"When you need to permanently rebind memory to a different type, first","type":"text"},{"text":" ","type":"text"},{"text":"obtain a raw pointer to the memory and then call the","type":"text"},{"text":" ","type":"text"},{"code":"bindMemory(to:capacity:)","type":"codeVoice"},{"text":" method on the raw pointer. The following","type":"text"},{"text":" ","type":"text"},{"text":"example binds the memory referenced by ","type":"text"},{"code":"uint8Pointer","type":"codeVoice"},{"text":" to one instance of","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"UInt64","type":"codeVoice"},{"text":" type:","type":"text"}]},{"code":["let uint64Pointer = UnsafeRawPointer(uint8Pointer)","                          .bindMemory(to: UInt64.self, capacity: 1)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After rebinding the memory referenced by "},{"type":"codeVoice","code":"uint8Pointer"},{"type":"text","text":" to "},{"type":"codeVoice","code":"UInt64"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"accessing that pointer’s referenced memory as a "},{"type":"codeVoice","code":"UInt8"},{"type":"text","text":" instance is"},{"type":"text","text":" "},{"type":"text","text":"undefined."}]},{"syntax":"swift","code":["var fullInteger = uint64Pointer.pointee          // OK","var firstByte = uint8Pointer.pointee             // undefined"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Alternatively, you can access the same memory as a different type without"},{"type":"text","text":" "},{"type":"text","text":"rebinding through untyped memory access, so long as the bound type and the"},{"type":"text","text":" "},{"type":"text","text":"destination type are trivial types. Convert your pointer to an"},{"type":"text","text":" "},{"type":"codeVoice","code":"UnsafeRawPointer"},{"type":"text","text":" instance and then use the raw pointer’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"load(fromByteOffset:as:)"},{"type":"text","text":" method to read values."}],"type":"paragraph"},{"syntax":"swift","code":["let rawPointer = UnsafeRawPointer(uint64Pointer)","let fullInteger = rawPointer.load(as: UInt64.self)   // OK","let firstByte = rawPointer.load(as: UInt8.self)      // OK"],"type":"codeListing"},{"text":"Performing Typed Pointer Arithmetic","anchor":"Performing-Typed-Pointer-Arithmetic","type":"heading","level":1},{"inlineContent":[{"type":"text","text":"Pointer arithmetic with a typed pointer is counted in strides of the"},{"type":"text","text":" "},{"type":"text","text":"pointer’s "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":" type. When you add to or subtract from an "},{"type":"codeVoice","code":"UnsafePointer"},{"type":"text","text":" "},{"type":"text","text":"instance, the result is a new pointer of the same type, offset by that"},{"type":"text","text":" "},{"text":"number of instances of the ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"text":" type.","type":"text"}],"type":"paragraph"},{"code":["// 'intPointer' points to memory initialized with [10, 20, 30, 40]","let intPointer: UnsafePointer<Int> = ...","","// Load the first value in memory","let x = intPointer.pointee","// x == 10","","// Load the third value in memory","let offsetPointer = intPointer + 2","let y = offsetPointer.pointee","// y == 30"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use subscript notation to access the value in memory at a"},{"type":"text","text":" "},{"type":"text","text":"specific offset."}]},{"code":["let z = intPointer[2]","// z == 30"],"type":"codeListing","syntax":"swift"},{"anchor":"Implicit-Casting-and-Bridging","type":"heading","text":"Implicit Casting and Bridging","level":1},{"type":"paragraph","inlineContent":[{"type":"text","text":"When calling a function or method with an "},{"code":"UnsafePointer","type":"codeVoice"},{"type":"text","text":" parameter, you can pass"},{"type":"text","text":" "},{"type":"text","text":"an instance of that specific pointer type, pass an instance of a"},{"type":"text","text":" "},{"type":"text","text":"compatible pointer type, or use Swift’s implicit bridging to pass a"},{"type":"text","text":" "},{"type":"text","text":"compatible pointer."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, the "},{"code":"printInt(atAddress:)","type":"codeVoice"},{"type":"text","text":" function in the following code"},{"type":"text","text":" "},{"type":"text","text":"sample expects an "},{"code":"UnsafePointer<Int>","type":"codeVoice"},{"type":"text","text":" instance as its first parameter:"}]},{"code":["func printInt(atAddress p: UnsafePointer<Int>) {","    print(p.pointee)","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As is typical in Swift, you can call the "},{"type":"codeVoice","code":"printInt(atAddress:)"},{"type":"text","text":" function"},{"type":"text","text":" "},{"type":"text","text":"with an "},{"type":"codeVoice","code":"UnsafePointer"},{"text":" instance. This example passes ","type":"text"},{"code":"intPointer","type":"codeVoice"},{"text":", a pointer to","type":"text"},{"text":" ","type":"text"},{"text":"an ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" value, to ","type":"text"},{"code":"print(address:)","type":"codeVoice"},{"text":".","type":"text"}]},{"syntax":"swift","code":["printInt(atAddress: intPointer)","// Prints \"42\""],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Because a mutable typed pointer can be implicitly cast to an immutable"},{"type":"text","text":" "},{"type":"text","text":"pointer with the same "},{"code":"Pointee","type":"codeVoice"},{"type":"text","text":" type when passed as a parameter, you can"},{"type":"text","text":" "},{"type":"text","text":"also call "},{"code":"printInt(atAddress:)","type":"codeVoice"},{"type":"text","text":" with an "},{"code":"UnsafeMutablePointer","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"syntax":"swift","code":["let mutableIntPointer = UnsafeMutablePointer(mutating: intPointer)","printInt(atAddress: mutableIntPointer)","// Prints \"42\""],"type":"codeListing"},{"inlineContent":[{"text":"Alternatively, you can use Swift’s ","type":"text"},{"inlineContent":[{"type":"text","text":"implicit bridging"}],"type":"emphasis"},{"text":" to pass a pointer to","type":"text"},{"text":" ","type":"text"},{"text":"an instance or to the elements of an array. The following example passes a","type":"text"},{"text":" ","type":"text"},{"text":"pointer to the ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" variable by using inout syntax:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var value: Int = 23","printInt(atAddress: &value)","// Prints \"23\""],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"An immutable pointer to the elements of an array is implicitly created when"},{"type":"text","text":" "},{"type":"text","text":"you pass the array as an argument. This example uses implicit bridging to"},{"type":"text","text":" "},{"type":"text","text":"pass a pointer to the elements of "},{"type":"codeVoice","code":"numbers"},{"type":"text","text":" when calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"printInt(atAddress:)"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let numbers = [5, 10, 15, 20]","printInt(atAddress: numbers)","// Prints \"5\""]},{"inlineContent":[{"text":"You can also use inout syntax to pass a mutable pointer to the elements of","type":"text"},{"text":" ","type":"text"},{"text":"an array. Because ","type":"text"},{"type":"codeVoice","code":"printInt(atAddress:)"},{"text":" requires an immutable pointer,","type":"text"},{"text":" ","type":"text"},{"text":"although this is syntactically valid, it isn’t necessary.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var mutableNumbers = numbers","printInt(atAddress: &mutableNumbers)"]},{"inlineContent":[{"text":"No matter which way you call ","type":"text"},{"type":"codeVoice","code":"printInt(atAddress:)"},{"text":", Swift’s type safety","type":"text"},{"text":" ","type":"text"},{"text":"guarantees that you can only pass a pointer to the type required by the","type":"text"},{"text":" ","type":"text"},{"text":"function—in this case, a pointer to an ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":".","type":"text"}],"type":"paragraph"},{"name":"Important","style":"important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"The pointer created through implicit bridging of an instance"},{"type":"text","text":" "},{"type":"text","text":"or of an array’s elements is only valid during the execution of the"},{"text":" ","type":"text"},{"text":"called function. Escaping the pointer to use after the execution of the","type":"text"},{"text":" ","type":"text"},{"text":"function is undefined behavior. In particular, do not use implicit","type":"text"},{"text":" ","type":"text"},{"text":"bridging when calling an ","type":"text"},{"type":"codeVoice","code":"UnsafePointer"},{"text":" initializer.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var number = 5","let numberPointer = UnsafePointer<Int>(&number)","// Accessing 'numberPointer' is undefined behavior."]}]}]}],"variants":[{"paths":["/documentation/swift/unsafepointer"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"identifiers":["doc://com.apple.Swift/documentation/Synchronization/AtomicOptionalRepresentable","doc://com.apple.Swift/documentation/Synchronization/AtomicRepresentable","doc://com.apple.Swift/documentation/Swift/BitwiseCopyable","doc://com.apple.Swift/documentation/Swift/CVarArg","doc://com.apple.Swift/documentation/Swift/Comparable","doc://com.apple.Swift/documentation/Swift/Copyable","doc://com.apple.Swift/documentation/Swift/CustomDebugStringConvertible","doc://com.apple.Swift/documentation/Swift/CustomReflectable","doc://com.apple.Swift/documentation/Swift/Equatable","doc://com.apple.Swift/documentation/Swift/Escapable","doc://com.apple.Swift/documentation/Swift/Hashable","doc://com.apple.Swift/documentation/Swift/Strideable