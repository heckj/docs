entifier":"doc://com.apple.Swift/documentation/Swift/Error"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":" : ~Copyable, "},{"kind":"typeIdentifier","text":"Result"},{"kind":"text","text":" : ~Copyable"}]}]},{"parameters":[{"content":[{"inlineContent":[{"text":"The type to temporarily bind the memory referenced by this","type":"text"},{"text":" ","type":"text"},{"text":"pointer. The type ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" must be layout compatible","type":"text"},{"text":" ","type":"text"},{"text":"with the pointer’s ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"text":" type.","type":"text"}],"type":"paragraph"}],"name":"type"},{"content":[{"inlineContent":[{"text":"The number of instances of ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" in the re-bound region.","type":"text"}],"type":"paragraph"}],"name":"count"},{"content":[{"inlineContent":[{"text":"A closure that takes a typed pointer to the","type":"text"},{"text":" ","type":"text"},{"text":"same memory as this pointer, only bound to type ","type":"text"},{"code":"T","type":"codeVoice"},{"text":". The closure’s","type":"text"},{"text":" ","type":"text"},{"text":"pointer argument is valid only for the duration of the closure’s","type":"text"},{"text":" ","type":"text"},{"text":"execution. If ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" has a return value, that value is also used as","type":"text"},{"text":" ","type":"text"},{"text":"the return value for the ","type":"text"},{"type":"codeVoice","code":"withMemoryRebound(to:capacity:_:)"},{"text":" method.","type":"text"}],"type":"paragraph"}],"name":"body"}],"kind":"parameters"},{"content":[{"anchor":"return-value","level":2,"text":"Return Value","type":"heading"},{"inlineContent":[{"text":"The return value, if any, of the ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" closure parameter.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Use this method when you have a pointer to memory bound to one type and","type":"text"},{"text":" ","type":"text"},{"text":"you need to access that memory as instances of another type. Accessing","type":"text"},{"text":" ","type":"text"},{"text":"memory as a type ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" requires that the memory be bound to that type. A","type":"text"},{"text":" ","type":"text"},{"text":"memory location may only be bound to one type at a time, so accessing","type":"text"},{"text":" ","type":"text"},{"text":"the same memory as an unrelated type without first rebinding the memory","type":"text"},{"text":" ","type":"text"},{"text":"is undefined.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The region of memory that starts at this pointer and covers ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" ","type":"text"},{"text":"strides of ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" instances must be bound to ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Any instance of ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" within the re-bound region may be initialized or","type":"text"},{"text":" ","type":"text"},{"text":"uninitialized. Every instance of ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"text":" overlapping with a given","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instance of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" should have the same initialization state (i.e."},{"type":"text","text":" "},{"text":"initialized or uninitialized.) Accessing a ","type":"text"},{"type":"codeVoice","code":"T"},{"text":" whose underlying","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Pointee"},{"text":" storage is in a mixed initialization state shall be","type":"text"},{"type":"text","text":" "},{"text":"undefined behaviour.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following example temporarily rebinds the memory of a ","type":"text"},{"type":"codeVoice","code":"UInt64"},{"text":" ","type":"text"},{"text":"pointer to ","type":"text"},{"code":"Int64","type":"codeVoice"},{"text":", then accesses a property on the signed integer.","type":"text"}]},{"code":["let uint64Pointer: UnsafePointer<UInt64> = fetchValue()","let isNegative = uint64Pointer.withMemoryRebound(","    to: Int64.self, capacity: 1",") {","    return $0.pointee < 0","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Because this pointer’s memory is no longer bound to its ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"text":" type","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"while the "},{"code":"body","type":"codeVoice"},{"text":" closure executes, do not access memory using the","type":"text"},{"text":" ","type":"text"},{"text":"original pointer from within ","type":"text"},{"code":"body","type":"codeVoice"},{"text":". Instead, use the ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" closure’s","type":"text"},{"text":" ","type":"text"},{"text":"pointer argument to access the values in memory as instances of type","type":"text"},{"text":" ","type":"text"},{"code":"T","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"After executing ","type":"text"},{"code":"body","type":"codeVoice"},{"text":", this method rebinds memory back to the original","type":"text"},{"text":" ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"text":" type.","type":"text"}],"type":"paragraph"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"Only use this method to rebind the pointer’s memory to a type"},{"type":"text","text":" "},{"type":"text","text":"that is layout compatible with the "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":" type. The stride of the"},{"type":"text","text":" "},{"type":"text","text":"temporary type ("},{"type":"codeVoice","code":"T"},{"type":"text","text":") may be an integer multiple or a whole fraction"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":"’s stride, for example to point to one element of"},{"type":"text","text":" "},{"type":"text","text":"an aggregate."},{"type":"text","text":" "},{"type":"text","text":"To bind a region of memory to a type that does not match these"},{"type":"text","text":" "},{"type":"text","text":"requirements, convert the pointer to a raw pointer and use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"bindMemory(to:)"},{"type":"text","text":" method."},{"type":"text","text":" "},{"type":"text","text":"If "},{"type":"codeVoice","code":"T"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":" have different alignments, this pointer"},{"type":"text","text":" "},{"type":"text","text":"must be aligned with the larger of the two alignments."}],"type":"paragraph"}],"type":"aside","name":"Note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unsafepointer/withmemoryrebound(to:capacity:_:)"]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnsafePointer"]]},"references":{"doc://com.apple.Swift/documentation/Swift/UnsafePointer":{"identifier":"doc://com.apple.Swift/documentation/Swift/UnsafePointer","navigatorTitle":[{"text":"UnsafePointer","kind":"identifier"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"A pointer for accessing data of a specific type."}],"url":"/documentation/swift/unsafepointer","role":"symbol","title":"UnsafePointer","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnsafePoint