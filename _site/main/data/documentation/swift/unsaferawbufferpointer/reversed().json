{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reversed"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"ReversedCollection","identifier":"doc://com.apple.Swift/documentation/Swift/ReversedCollection","preciseIdentifier":"s:s18ReversedCollectionV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":">"}],"languages":["swift"]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"You can reverse a collection without allocating new space for its"},{"type":"text","text":" "},{"type":"text","text":"elements by calling this "},{"code":"reversed()","type":"codeVoice"},{"type":"text","text":" method. A "},{"code":"ReversedCollection","type":"codeVoice"},{"type":"text","text":" "},{"text":"instance wraps an underlying collection and provides access to its","type":"text"},{"text":" ","type":"text"},{"text":"elements in reverse order. This example prints the characters of a","type":"text"},{"text":" ","type":"text"},{"text":"string in reverse order:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let word = \"Backwards\"","for char in word.reversed() {","    print(char, terminator: \"\")","}","// Prints \"sdrawkcaB\""]},{"type":"paragraph","inlineContent":[{"text":"If you need a reversed collection of the same type, you may be able to","type":"text"},{"text":" ","type":"text"},{"text":"use the collection’s sequence-based or collection-based initializer. For","type":"text"},{"text":" ","type":"text"},{"text":"example, to get the reversed version of a string, reverse its","type":"text"},{"text":" ","type":"text"},{"text":"characters and initialize a new ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" instance from the result.","type":"text"}]},{"type":"codeListing","syntax":"swift",