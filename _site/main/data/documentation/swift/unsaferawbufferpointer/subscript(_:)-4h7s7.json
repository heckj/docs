{"abstract":[{"type":"text","text":"Accesses the contiguous subrange of the collection’s elements specified"},{"type":"text","text":" "},{"type":"text","text":"by a range expression."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/unsaferawbufferpointer/subscript(_:)-4h7s7"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnsafeRawBufferPointer"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"R","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"r","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"R","kind":"typeIdentifier","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp"},{"text":") -> ","kind":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence","text":"SubSequence","kind":"typeIdentifier","preciseIdentifier":"s:Sl11SubSequenceQa"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"R","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SX","text":"RangeExpression","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression"},{"text":", ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:Sl5IndexQa","text":"Index","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index"},{"text":" == ","kind":"text"},{"text":"R","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:SX5BoundQa","text":"Bound","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/RangeExpression/Bound"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The range expression is converted to a concrete subrange relative to this"},{"type":"text","text":" "},{"type":"text","text":"collection. For example, using a "},{"type":"codeVoice","code":"PartialRangeFrom"},{"type":"text","text":" range expression"},{"type":"text","text":" "},{"type":"text","text":"with an array accesses the subrange from the start of the range"},{"type":"text","text":" "},{"type":"text","text":"expression until the end of the array."}]},{"type":"codeListing","code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2...]","print(streetsSlice)","// [\"Channing\", \"Douglas\", \"Evarts\"]"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The accessed slice uses the same indices for the same elements as the"},{"type":"text","text":" "},{"type":"text","text":"original collection uses. This example searches "},{"code":"streetsSlice","type":"codeVoice"},{"type":"text","text":" for one"},{"type":"text","text":" "},{"type":"text","text":"of the strings in the slice, and then uses that index in the original"},{"type":"text","text":" "},{"type":"text","text":"array."}]},{"syntax":"swift","code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    // 4","print(streets[index!])","// \"Evarts\""],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always use the slice’s "},{"type":"codeVoice","code":"startIndex"},{"type":"text","text":" property instead of assuming that its"},{"type":"text","text":" "},{"type":"text","text":"indices start at a particular value. Attempting to access an element by"},{"type":"text","text":" "},{"type":"text","text":"using an index outside the bounds of the slice’s indices may result in a"},{"type":"text","text":" "},{"type":"text","text":"runtime error, even if that index is valid for the original collection."}]},{"syntax":"swift","code":["print(streetsSlice.startIndex)","// 2","print(streetsSlice[2])","// \"Channing\"","","print(streetsSlice[0])","// error: Index out of bounds"],"type":"codeListing"},{"name":"Complexity","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O(1)"}]}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/UnsafeRawBufferPointer/subscript(_:)-4h7s7"},"sections":[],"kind":"symbol","metadata":{"role":"symbol","externalID":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip::SYNTHESIZED::s:SW","symbolKind":"subscript","extendedModule":"Swift","roleHeading":"Instance Subscript","modules":[{"name":"Swift"}],"title":"subscript(_:)","fragments":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"R","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"SubSequence","preciseIdentifier":"s:Sl11SubSequenceQa"}]},"references":{"doc://com.apple.Swift/documentation/Swift/Collection/Index":{"required":true,"url":"/documentation/swift/collection/index","role":"symbol","title":"Index","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Index","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SL","text":"Comparable","kind":"typeIdentifier"}],"kind":"symbol","type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/Collection/Index","abstract":[{"type":"text","text":"A type that represents a position in the collection."}]},"doc://com.apple.Swift/documentation/Swift/Collection/SubSequence":{"title":"SubSequence","kind":"symbol","abstract":[{"type":"text","text":"A collection representing a contiguous subrange