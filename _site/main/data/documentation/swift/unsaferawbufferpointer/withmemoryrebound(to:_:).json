{"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/UnsafeRawBufferPointer/withMemoryRebound(to:_:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift","doc://com.apple.Swift/documentation/Swift/UnsafeRawBufferPointer"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Executes the given closure while temporarily binding the buffer to"},{"type":"text","text":" "},{"type":"text","text":"instances of type "},{"type":"codeVoice","code":"T"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withMemoryRebound"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"E"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Result"},{"kind":"text","text":">("},{"kind":"externalParam","text":"to"},{"kind":"text","text":" "},{"kind":"internalParam","text":"type"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1TL_xmfp","text":"T"},{"kind":"text","text":".Type, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"buffer"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer","preciseIdentifier":"s:SR","text":"UnsafeBufferPointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1TL_xmfp","text":"T"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1EL_q_mfp","text":"E"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF6ResultL_q0_mfp","text":"Result"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1EL_q_mfp","text":"E"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF6ResultL_q0_mfp","text":"Result"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"E"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Error","preciseIdentifier":"s:s5ErrorP","text":"Error"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":" : ~Copyable, "},{"kind":"typeIdentifier","text":"Result"},{"kind":"text","text":" : ~Copyable"}]}]},{"kind":"parameters","parameters":[{"name":"type","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The type to temporarily bind the memory referenced by this"},{"type":"text","text":" "},{"type":"text","text":"buffer."}]}]},{"name":"body","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure that takes a typed pointer to the"},{"type":"text","text":" "},{"type":"text","text":"same memory as this pointer, only bound to type "},{"code":"T","type":"codeVoice"},{"type":"text","text":". The closure’s"},{"type":"text","text":" "},{"type":"text","text":"pointer argument is valid only for the duration of the closure’s"},{"type":"text","text":" "},{"type":"text","text":"execution. If "},{"code":"body","type":"codeVoice"},{"type":"text","text":" has a return value, that value is also used as"},{"type":"text","text":" "},{"type":"text","text":"the return value for the "},{"code":"withMemoryRebound(to:capacity:_:)","type":"codeVoice"},{"type":"text","text":" method."}]}]}]},{"content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value, if any, of the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure parameter."}]}],"kind":"content"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method when you have a buffer to raw memory and you need"},{"type":"text","text":" "},{"type":"text","text":"to access that memory as instances of a given type "},{"type":"codeVoice","code":"T"},{"type":"text","text":". Accessing"},{"type":"text","text":" "},{"type":"text","text":"memory as a type "},{"type":"codeVoice","code":"T"},{"type":"text","text":" requires that the memory be bound to that type."},{"type":"text","text":" "},{"type":"text","text":"A memory location may only be bound to one type at a time, so accessing"},{"type":"text","text":" "},{"type":"text","text":"the same memory as an unrelated type without first rebinding the memory"},{"type":"text","text":" "},{"type":"text","text":"is undefined."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any instance of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" within the re-bound region may be initialized or"},{"type":"text","text":" "},{"type":"text","text":"uninitialized. The memory underlying any individual instance of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" "},{"type":"text","text":"must have the same initialization state (i.e.  initialized or"},{"type":"text","text":" "},{"type":"text","text":"uninitialized.) Accessing a "},{"type":"codeVoice","code":"T"},{"type":"text","text":" whose underlying memory"},{"type":"text","text":" "},{"type":"text","text":"is in a mixed initialization state shall be undefined behaviour."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the byte count of the original buffer is not a multiple of"},{"type":"text","text":" "},{"type":"text","text":"the stride of "},{"type":"codeVoice","code":"T"},{"type":"text","text":", then the re-bound buffer is shorter"},{"type":"text","text":" "},{"type":"text","text":"than the original buffer."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After executing "},{"type":"codeVoice","code":"body"},{"type":"text","text":", this method rebinds memory back to its original"},{"type":"text","text":" "},{"type":"text","text":"binding state. This can be unbound memory, or bound to a different type."}]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The buffer’s base address must match the"},{"type":"text","text":" "},{"type":"text","text":"alignment of "},{"code":"T","type":"codeVoice"},{"type":"text","text":" (as reported by "},{"code":"MemoryLayout<T>.alignment","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"That is, "},{"code":"Int(bitPattern: self.baseAddress) % MemoryLayout<T>.alignment","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"must equal zero."}]}],"style":"note"},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A raw buffer may represent memory that has been bound to a type."},{"type":"text","text":" "},{"type":"text","text":"If that is the case, then "},{"code":"T","type":"codeVoice"},{"type":"text","text":" must be layout compatible with the"},{"type":"text","text":" "},{"type":"text","text":"type to which the memory has been bound. This requirement does not"},{"type":"text","text":" "},{"type":"text","text":"apply if the raw buffer represents memory that has not been bound"},{"type":"text","text":" "},{"type":"text","text":"to any type."}]}],"style":"note"}],"kind":"content"}],"metadata":{"modules":[{"name":"Swift"}],"externalID":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withMemoryRebound"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"E"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Result"},{"kind":"text","text":">("},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1TL_xmfp"},{"kind":"text","text":".Type, ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"buffer"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeBufferPointer","preciseIdentifier":"s:SR"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1TL_xmfp"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"E","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1EL_q_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Result","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF6ResultL_q0_mfp"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"E","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF1EL_q_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Result","preciseIdentifie