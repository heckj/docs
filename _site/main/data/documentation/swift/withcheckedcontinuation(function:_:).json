 "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String","identifier":"doc://com.apple.Swift/documentation/Swift/String"},{"kind":"text","text":" = "},{"kind":"keyword","text":"#function"},{"kind":"text","text":", "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"body"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:ScC","kind":"typeIdentifier","text":"CheckedContinuation","identifier":"doc://com.apple.Swift/documentation/Swift/CheckedContinuation"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:12_Concurrency23withCheckedContinuation8function_xSS_yScCyxs5NeverOGXEtYalF1TL_xmfp","kind":"typeIdentifier","text":"T"},{"kind":"text","text":", "},{"preciseIdentifier":"s:s5NeverO","kind":"typeIdentifier","text":"Never","identifier":"doc://com.apple.Swift/documentation/Swift/Never"},{"kind":"text","text":">) -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void","identifier":"doc://com.apple.Swift/documentation/Swift/Void"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" -> sending "},{"preciseIdentifier":"s:12_Concurrency23withCheckedContinuation8function_xSS_yScCyxs5NeverOGXEtYalF1TL_xmfp","kind":"typeIdentifier","text":"T"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A string identifying the declaration that is the notional"},{"type":"text","text":" "},{"type":"text","text":"source for the continuation, used to identify the continuation in"},{"type":"text","text":" "},{"type":"text","text":"runtime diagnostics related to misuse of this continuation."}]}],"name":"function"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure that takes a "},{"type":"codeVoice","code":"CheckedContinuation"},{"type":"text","text":" parameter."}]}],"name":"body"}]},{"content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The value continuation is resumed with."}]}],"kind":"content"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The body of the closure executes synchronously on the calling task, and once it returns"},{"text":" ","type":"text"},{"type":"text","text":"the calling task is suspended. It is possible to immediately resume the task, or escape the"},{"type":"text","text":" "},{"text":"continuation in order to complete it afterwards, which will then resume the suspended task.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You must invoke the continuation’s ","type":"text"},{"type":"codeVoice","code":"resume"},{"text":" method exactly once.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Missing to invoke it (eventually) will cause the calling task to remain suspended","type":"text"},{"text":" ","type":"text"},{"text":"indefinitely which will result in the task “hanging” as well as being leaked with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"no possibility to destroy it."}]},{"type":"paragraph","inlineContent":[{"text":"The checked continuation offers detection of misuse, and dropping the last reference","type":"text"},{"type":"text","text":" "},{"text":"to it, without having resumed it will trigger a warning. Resuming a continuation twice","type":"text"},{"type":"text","text":" "},{"text":"is also diagnosed and will cause a crash.","type":"text"}]},{"type":"aside","name":"See Also","content":[{"inlineContent":[{"type":"text","text":""},{"code":"withCheckedThrowingContinuation(function:_:)","type":"codeVoice"}],"type":"paragraph"}],"style":"note"},{"type":"aside","name":"See Also","content":[{"inlineContent":[{"type":"text","text":""},{"code":"withUnsafeContinuation(function:_:)","type":"codeVoice"}],"type":"paragraph"}],"style":"note"},{"type":"aside","name":