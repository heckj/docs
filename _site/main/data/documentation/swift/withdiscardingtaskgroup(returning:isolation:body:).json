{"schemaVersion":{"minor":3,"major":0,"patch":0},"seeAlsoSections":[{"title":"Tasks","anchor":"Tasks","generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/Task","doc://com.apple.Swift/documentation/Swift/TaskGroup","doc://com.apple.Swift/documentation/Swift/withTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","doc://com.apple.Swift/documentation/Swift/withThrowingTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/TaskPriority","doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup","doc://com.apple.Swift/documentation/Swift/withThrowingDiscardingTaskGroup(returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/UnsafeCurrentTask"]}],"variants":[{"paths":["/documentation/swift/withdiscardingtaskgroup(returning:isolation:body:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/withDiscardingTaskGroup(returning:isolation:body:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Starts a new scope that can contain a dynamic number of child tasks."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"@backDeployed(before: macOS 15.0, iOS 18.0, watchOS 11.0, tvOS 18.0, visionOS 2.0)\n"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withDiscardingTaskGroup"},{"kind":"text","text":"<"},{"text":"GroupResult","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"returning"},{"kind":"text","text":" "},{"kind":"internalParam","text":"returnType"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GroupResult","preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp"},{"kind":"text","text":".Type = GroupResult.self, "},{"kind":"externalParam","text":"isolation"},{"kind":"text","text":": "},{"text":"isolated","kind":"keyword"},{"text":" (","kind":"text"},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Actor","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Actor","preciseIdentifier":"s:ScA"},{"text":")? = #isolation, ","kind":"text"},{"text":"body","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"inout","kind":"keyword"},{"kind":"text","text":" "},{"text":"DiscardingTaskGroup","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup","preciseIdentifier":"s:12_Concurrency19DiscardingTaskGroupV"},{"text":") ","kind":"text"},{"kind":"keyword","text":"async"},{"text":" -> ","kind":"text"},{"text":"GroupResult","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"GroupResult","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Unlike a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup"},{"type":"text","text":", the child tasks as well as their results are"},{"text":" ","type":"text"},{"type":"text","text":"discarded as soon as the tasks complete. This prevents the discarding"},{"type":"text","text":" "},{"type":"text","text":"task group from accumulating many results waiting to be consumed, and is"},{"text":" ","type":"text"},{"text":"best applied in situations where the result of a child task is some form","type":"text"},{"type":"text","text":" "},{"text":"of side-effect.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A group ","type":"text"},{"inlineContent":[{"text":"always","type":"text"}],"type":"emphasis"},{"type":"text","text":" waits for all of its child tasks"},{"text":" ","type":"text"},{"text":"to complete before it returns. Even canceled tasks must run until","type":"text"},{"text":" ","type":"text"},{"text":"completion before this function returns.","type":"text"},{"text":" ","type":"text"},{"text":"Canceled child tasks cooperatively react to cancellation and attempt","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to return as early as possible."},{"type":"text","text":" "},{"text":"After this function returns, the task group is always empty.","type":"text"}]},{"inlineContent":[{"text":"It is not possible to explicitly await completion of child-tasks,","type":"text"},{"text":" ","type":"text"},{"text":"however the group will automatically await ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"all","type":"text"}]},{"text":" child task completions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before returning from this function:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["await withDiscardingTaskGroup(...) { group in","  group.addTask { /* slow-task */ }","  // slow-task executes...","}","// guaranteed that slow-task has completed and the group is empty & destroyed"]},{"inlineContent":[{"text":"Refer to ","type":"text"},{"isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","type":"reference"},{"text":" documentation for detailed discussion of semantics shared between all task groups.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Task-Group-Cancellation","level":1,"text":"Task Group Cancellation"},{"inlineContent":[{"text":"You can cancel a task group and all of its child tasks","type":"text"},{"text":" ","type":"text"},{"text":"by calling the ","type":"text"},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup/cancelAll()","isActive":true},{"text":" method on the task group,","type":"text"},{"text":" ","type":"text"},{"text":"or by canceling the task in which the group is running.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you call ","type":"text"},{"type":"codeVoice","code":"addTask(priority:operation:)"},{"text":" to create a new task in a canceled group,","type":"text"},{"type":"text","text":" "},{"text":"that task is immediately canceled after creation.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Alternatively, you can call "},{"type":"codeVoice","code":"asyncUnlessCancelled(priority:operation:)"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"which doesn’t create the task if the group has already been canceled.","type":"text"},{"text":" ","type":"text"},{"text":"Choosing between these two functions","type":"text"},{"text":" ","type":"text"},{"text":"lets you control how to react to cancellation within a group:","type":"text"},{"text":" ","type":"text"},{"text":"some child tasks need to run regardless of cancellation,","type":"text"},{"text":" ","type":"text"},{"text":"but other tasks are better not even being created","type":"text"},{"text":" ","type":"text"},{"text":"when you know they can’t produce useful results.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because the tasks you add to a group with this method are nonthrowing,","type":"text"},{"text":" ","type":"text"},{"text":"those tasks can’t respond to cancellation by throwing ","type":"text"},{"code":"CancellationError","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The tasks must handle cancellation in some other way,","type":"text"},{"text":" ","type":"text"},{"text":"such as returning the work completed so far, returning an empty result, or returning ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"For tasks that need to handle cancellation by throwing an error,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"code":"withThrowingDiscardingTaskGroup(returning:body:)","type":"codeVoice"},{"text":" method instead.","type":"text"}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup"}]}],"type":"aside","name":"See Also"},{"content":[{"inlineContent":[{"text":"","type":"text"},{"code":"withThrowingDiscardingTaskGroup(returning:body:)","type":"codeVoice"}],"type":"paragraph"}],"style":"note","type":"aside","name":"See Also"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"metadata":{"symbolKind":"func","externalID":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF","roleHeading":"Function","title":"withDiscardingTaskGroup(returning:isolation:body:)","modules":[{"relatedModules":[],"name":"Swift"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withDiscardingTaskGroup","kind":"identifier"},{"text":"<","kind":"text"},{"text":"GroupResult","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"returning","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GroupResult","preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp","kind":"typeIdentifier"},{"text":".Type, ","kind":"text"},{"text":"isolation","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"isolated","kind":"keyword"},{"text":" (","kind":"text"},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:ScA","text":"Actor","kind":"typeIdentifier"},{"text":")?, ",