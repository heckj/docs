{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@backDeployed(before: macOS 15.0, iOS 18.0, watchOS 11.0, tvOS 18.0, visionOS 2.0)\n","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"withDiscardingTaskGroup"},{"kind":"text","text":"<"},{"text":"GroupResult","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"returning"},{"kind":"text","text":" "},{"kind":"internalParam","text":"returnType"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp","text":"GroupResult","kind":"typeIdentifier"},{"kind":"text","text":".Type = GroupResult.self, "},{"text":"isolation","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"isolated","kind":"keyword"},{"text":" (","kind":"text"},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:ScA","identifier":"doc://com.apple.Swift/documentation/Swift/Actor","text":"Actor","kind":"typeIdentifier"},{"kind":"text","text":")? = #isolation, "},{"text":"body","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"inout","kind":"keyword"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"DiscardingTaskGroup","preciseIdentifier":"s:12_Concurrency19DiscardingTaskGroupV","identifier":"doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"GroupResult","preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp","text":"GroupResult"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Unlike a "},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true,"type":"reference"},{"type":"text","text":", the child tasks as well as their results are"},{"type":"text","text":" "},{"type":"text","text":"discarded as soon as the tasks complete. This prevents the discarding"},{"type":"text","text":" "},{"type":"text","text":"task group from accumulating many results waiting to be consumed, and is"},{"type":"text","text":" "},{"type":"text","text":"best applied in situations where the result of a child task is some form"},{"type":"text","text":" "},{"type":"text","text":"of side-effect."}],"type":"paragraph"},{"inlineContent":[{"text":"A group ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"always"}]},{"text":" waits for all of its child tasks","type":"text"},{"text":" ","type":"text"},{"text":"to complete before it returns. Even canceled tasks must run until","type":"text"},{"text":" ","type":"text"},{"text":"completion before this function returns.","type":"text"},{"text":" ","type":"text"},{"text":"Canceled child tasks cooperatively react to cancellation and attempt","type":"text"},{"text":" ","type":"text"},{"text":"to return as early as possible.","type":"text"},{"text":" ","type":"text"},{"text":"After this function returns, the task group is always empty.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is not possible to explicitly await completion of child-tasks,"},{"type":"text","text":" "},{"type":"text","text":"however the group will automatically await "},{"inlineContent":[{"type":"text","text":"all"}],"type":"emphasis"},{"text":" child task completions","type":"text"},{"text":" ","type":"text"},{"text":"before returning from this function:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["await withDiscardingTaskGroup(...) { group in","  group.addTask { /* slow-task */ }","  // slow-task executes...","}","// guaranteed that slow-task has completed and the group is empty & destroyed"]},{"inlineContent":[{"type":"text","text":"Refer to "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup"},{"type":"text","text":" documentation for detailed discussion of semantics shared between all task groups."}],"type":"paragraph"},{"text":"Task Group Cancellation","level":1,"type":"heading","anchor":"Task-Group-Cancellation"},{"inlineContent":[{"type":"text","text":"You can cancel a task group and all of its child tasks"},{"type":"text","text":" "},{"text":"by calling the ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup/cancelAll()","type":"reference","isActive":true},{"text":" method on the task group,","type":"text"},{"text":" ","type":"text"},{"text":"or by canceling the task in which the group is running.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you call "},{"type":"codeVoice","code":"addTask(priority:operation:)"},{"type":"text","text":" to create a new task in a canceled group,"},{"type":"text","text":" "},{"type":"text","text":"that task is immediately canceled after creation."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, you can call "},{"type":"codeVoice","code":"asyncUnlessCancelled(priority:operation:)"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which doesn’t create the task if the group has already been canceled."},{"type":"text","text":" "},{"text":"Choosing between these two functions","type":"text"},{"text":" ","type":"text"},{"text":"lets you control how to react to cancellation within a group:","type":"text"},{"text":" ","type":"text"},{"text":"some child tasks need to run regardless of cancellation,","type":"text"},{"text":" ","type":"text"},{"text":"but other tasks are better not even being created","type":"text"},{"text":" ","type":"text"},{"text":"when you know they can’t produce useful results.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the tasks you add to a group with this method are nonthrowing,"},{"type":"text","text":" "},{"type":"text","text":"those tasks can’t respond to cancellation by throwing "},{"code":"CancellationError","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The tasks must handle cancellation in some other way,"},{"type":"text","text":" "},{"type":"text","text":"such as returning the work completed so far, returning an empty result, or returning "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"For tasks that need to handle cancellation by throwing an error,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"withThrowingDiscardingTaskGroup(returning:body:)"},{"type":"text","text":" method instead."}]},{"name":"See Also","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true,"type":"reference"}]}],"type":"aside"},{"name":"See Also","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"withThrowingDiscardingTaskGroup(returning:body:)"}]}],"type":"aside"}]}],"abstract":[{"text":"Starts a new scope that can contain a dynamic number of child tasks.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"withDiscardingTaskGroup(returning:isolation:body:)","role":"symbol","modules":[{"relatedModules":[],"name":"Swift"}],"symbolKind":"func","roleHeading":"Function","fragme