{"metadata":{"externalID":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF","roleHeading":"Function","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withoutActuallyEscaping"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"ClosureType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"ResultType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Failure"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"ClosureType","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp"},{"kind":"text","text":", "},{"kind":"externalParam","text":"do"},{"kind":"text","text":": ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"escapingClosure"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ClosureType","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Failure","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF7FailureL_q0_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"ResultType","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF10ResultTypeL_q_mfp"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Failure","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF7FailureL_q0_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"ResultType","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF10ResultTypeL_q_mfp"}],"modules":[{"name":"Swift"}],"role":"symbol","symbolKind":"func","title":"withoutActuallyEscaping(_:do:)"},"abstract":[{"text":"Allows a nonescaping closure to temporarily be used as if it were allowed","type":"text"},{"text":" ","type":"text"},{"text":"to escape.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/withoutActuallyEscaping(_:do:)"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withoutActuallyEscaping"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"ClosureType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"ResultType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Failure"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"closure"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp","text":"ClosureType"},{"kind":"text","text":", "},{"kind":"externalParam","text":"do"},{"kind":"text","text":" "},{"kind":"internalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"escapingClosure"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp","text":"ClosureType"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF7FailureL_q0_mfp","text":"Failure"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF10ResultTypeL_q_mfp","text":"ResultType"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF7FailureL_q0_mfp","text":"Failure"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF10ResultTypeL_q_mfp","text":"ResultType"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Failure"},{"kind":"text","text":" : "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Error","kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP","text":"Error"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"closure","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A nonescaping closure value that is made escapable for the"},{"type":"text","text":" "},{"type":"text","text":"duration of the execution of the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure. If "},{"type":"codeVoice","code":"body"},{"type":"text","text":" has a"},{"type":"text","text":" "},{"type":"text","text":"return value, that value is also used as the return value for the"},{"type":"text","text":" "},{"type":"codeVoice","code":"withoutActuallyEscaping(_:do:)"},{"type":"text","text":" function."}]}]},{"name":"body","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure that is executed immediately with an escapable copy of"},{"type":"text","text":" "},{"type":"codeVoice","code":"closure"},{"type":"text","text":" as its argument."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The return value, if any, of the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure."}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this function to call an API that takes an escaping closure in"},{"type":"text","text":" "},{"type":"text","text":"a way that doesn’t allow the closure to escape in practice. The examples"},{"type":"text","text":" "},{"type":"text","text":"below demonstrate how to use "},{"type":"codeVoice","code":"withoutActuallyEscaping(_:do:)"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"text","text":"conjunction with two common APIs that use escaping closures: lazy"},{"type":"text","text":" "},{"type":"text","text":"collection views and asynchronous operations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code declares an "},{"type":"codeVoice","code":"allValues(in:match:)"},{"type":"text","text":" function that checks"},{"type":"text","text":" "},{"type":"text","text":"whether all the elements in an array match a predicate. The function won’t"},{"type":"text","text":" "},{"type":"text","text":"compile as written, because a lazy collection’s "},{"type":"codeVoice","code":"filter(_:)"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"requires an escaping closure. The lazy collection isn’t persisted, so the"},{"type":"text","text":" "},{"type":"codeVoice","code":"predicate"},{"type":"text","text":" closure won’t actually escape the body of the function;"},{"type":"text","text":" "},{"type":"text","text":"nevertheless, it can’t be used in this way."}]},{"type":"codeListing","code":["func allValues(in array: [Int], match predicate: (Int) -> Bool) -> Bool {","    return array.lazy.filter { !predicate($0) }.isEmpty","}","// error: closure use of non-escaping parameter 'predicate'..."],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"withoutActuallyEscaping(_:do:)"},{"type":"text","text":" provides a temporarily escapable copy of"},{"type":"text","text":" "},{"type":"codeVoice","code":"predicate"},{"type":"text","text":" that "},{"type":"emphasis","inlineContent":[{"type":"text","text":"can"}]},{"type":"text","text":" be used in a call to the lazy view’s "},{"type":"codeVoice","code":"filter(_:)"},{"type":"text","text":" "},{"type":"text","text":"method. The second version of "},{"type":"codeVoice","code":"allValues(in:match:)"},{"type":"text","text":" compiles without"},{"type":"text","text":" "},{"type":"text","text":"error, with the compiler guaranteeing that the "},{"type":"codeVoice","code":"escapablePredicate"},{"type":"text","text":" "},{"type":"text","text":"closure doesn’t last beyond the call to "},{"type":"codeVoice","code":"withoutActuallyEscaping(_:do:)"},{"type":"text","text":"."}]},{"type":"codeListing","code":["func allValues(in array: [Int], match predicate: (Int) -> Bool) -> Bool {","    return withoutActuallyEscaping(predicate) { escapablePredicate in","        array.lazy.filter { !escapablePredicate($0) }.isEmpty","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Asynchronous calls are another type of API that typically escape their"},{"type":"text","text":" "},{"type":"text","text":"closure arguments. The following code declares a"},{"type":"text","text":" "},{"type":"codeVoice","code":"perform(_:simultaneouslyWith:)"},{"type":"text","text":" function that uses a dispatch queue to"},{"type":"text","text":" "},{"type":"text","text":"execute two closures concurrently."}]},{"type":"codeListing","code":["func perform(_ f: () -> Void, simultaneouslyWith g: () -> Void) {","    let queue = DispatchQueue(label: \"perform\", attributes: .concurrent)","    queue.async(execute: f)","    queue.async(execute: g)","    queue.sync(flags: .barrier) {}","}","// error: passing non-escaping parameter 'f'...","// error: passing non-escaping parameter 'g'..."],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"perform(_:simultaneouslyWith:)"},{"type":"text","text":" function ends with a call to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"sync(flags:execute:)"},{"type":"text","text":" method using the "},{"type":"codeVoice","code":".barrier"},{"type":"text","text":" flag, which forces the"},{"type":"text","text":" "},{"type":"text","text":"function to wait until both closures have completed running before"},{"type":"text","text":" "},{"type":"text","text":"returning. Even though the barrier guarantees that neither closure will"},{"type":"text","text":" "},{"type":"text","text":"escape the function, the "},{"type":"codeVoice","code":"async(execute:)"},{"type":"text","text":" method still requires that the"},{"type":"text","text":" "},{"type":"text","text":"closures passed be marked as "},{"type":"codeVoice","code":"@escaping"},{"type":"text","text":", so the first version of the"},{"type":"text","text":" "},{"type":"text","text":"function does not compile. To resolve these errors, you can use"},{"type":"text","text":" "},{"type":"codeVoice","code":"withoutActuallyEscaping(_:do:)"},{"type":"text","text":" to get copies of "},{"type":"codeVoice","code":"f"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g"},{"type":"text","text":" that can be"},{"type":"text","text":" "},{"type":"text","text":"passed to "},{"type":"codeVoice","code":"async(execute:)"},{"type":"text","text":"."}]},{"type":"codeListing","code":["func perform(_ f: () -> Void, simultaneouslyWith g: () -> Void) {","    withoutActuallyEscaping(f) { escapableF in","        withoutActuallyEscaping(g) { escapableG in","            let queue = DispatchQueue(label: \"perform\", attributes: .concurrent)","            queue.async(execute: escapableF)","            queue.async(execute: escapableG)","            queue.sync(flags: .barrier) {}","        }","    }","}"],"syntax":"swift"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The escapable copy of "},{"type":"codeVoice","code":"closure"},{"type":"text","text":" passed to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" is only valid"},{"type":"text","text":" "},{"type":"text","text":"during the call to "},{"type":"codeVoice","code":"withoutActuallyEscaping(_:do:)"},{"type":"text","text":". It is undefined"},{"type":"text","text":" "},{"type":"text","text":"behavior for the escapable closure to be stored, referenced, or executed"},{"type":"text","text":" "},{"type":"text","text":"after the function returns."}]}],"type":"aside","name":"Important","style":"important"}]}],"variants":[{"paths":["/documentation/swift/withoutactuallyescaping(_:do:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/withoutActuallyEscaping(_:do:)":{"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Allows a nonescaping closure to temporarily be used as if it were allowed"},{"type":"text","text":" "},{"type":"text","text":"to escape."}],"title":"withoutActuallyEscaping(_:do:)","url":"/documentation/swift/withoutactuallyescaping(_:do:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withoutActuallyEscaping"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"ClosureType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"ResultType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Failure"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"ClosureType","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp"},{"kind":"text","text":", "},{"kind":"externalParam","text":"do"},{"kind":"text","text":": ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"escapingClosure"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ClosureType","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Failure","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF7FailureL_q0_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"ResultType","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF10ResultTypeL_q_mfp"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Failure","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF7FailureL_q0_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"ResultType","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF10ResultTypeL_q_mfp"}],"type":"topic","identifier":"doc://com.apple.Swift/documentation/Swift/withoutActuallyEscaping(_:do:)"},"doc://com.apple.Swift/documentation/Swift/Error":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Error","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"A type representing an error value that can be thrown."}],"url":"/documentation/swift/error","identifier":"doc://com.apple.Swift/documentation/Swift/Error","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Error","kind":"identifier"}],"title":"Error"}}}