{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withoutActuallyEscaping"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"ClosureType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"ResultType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Failure"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"closure"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp","kind":"typeIdentifier","text":"ClosureType"},{"kind":"text","text":", "},{"kind":"externalParam","text":"do"},{"kind":"text","text":" "},{"kind":"internalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"escapingClosure"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp","kind":"typeIdentifier","text":"ClosureType"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF7FailureL_q0_mfp","kind":"typeIdentifier","text":"Failure"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF10ResultTypeL_q_mfp","kind":"typeIdentifier","text":"ResultType"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF7FailureL_q0_mfp","kind":"typeIdentifier","text":"Failure"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF10ResultTypeL_q_mfp","kind":"typeIdentifier","text":"ResultType"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Failure"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:s5ErrorP","identifier":"doc://com.apple.Swift/documentation/Swift/Error","kind":"typeIdentifier","text":"Error"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"closure","content":[{"type":"paragraph","inlineContent":[{"text":"A nonescaping closure value that is made escapable for the","type":"text"},{"text":" ","type":"text"},{"text":"duration of the execution of the ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" closure. If ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" has a","type":"text"},{"text":" ","type":"text"},{"text":"return value, that value is also used as the return value for the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"withoutActuallyEscaping(_:do:)"},{"type":"text","text":" function."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A closure that is executed immediately with an escapable copy of"},{"type":"text","text":" "},{"code":"closure","type":"codeVoice"},{"type":"text","text":" as its argument."}],"type":"paragraph"}],"name":"body"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"The return value, if any, of the ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" closure.","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this function to call an API that takes an escaping closure in"},{"type":"text","text":" "},{"type":"text","text":"a way that doesn’t allow the closure to escape in practice. The examples"},{"type":"text","text":" "},{"type":"text","text":"below demonstrate how to use "},{"type":"codeVoice","code":"withoutActuallyEscaping(_:do:)"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"text","text":"conjunction with two common APIs that use escaping closures: lazy"},{"type":"text","text":" "},{"type":"text","text":"collection views and asynchronous operations."}]},{"type":"paragraph","inlineContent":[{"text":"The following code declares an ","type":"text"},{"type":"codeVoice","code":"allValues(in:match:)"},{"text":" function that checks","type":"text"},{"text":" ","type":"text"},{"text":"whether all the elements in an array match a predicate. The function won’t","type":"text"},{"text":" ","type":"text"},{"text":"compile as written, because a lazy collection’s ","type":"text"},{"code":"filter(_:)","type":"codeVoice"},{"text":" method","type":"text"},{"type":"text","text":" "},{"type":"text","text":"requires an escaping closure. The lazy collection isn’t persisted, so the"},{"type":"text","text":" "},{"code":"predicate","type":"codeVoice"},{"type":"text","text":" closure won’t actually escape the body of the function;"},{"type":"text","text":" "},{"type":"text","text":"nevertheless, it can’t be used in this way."}]},{"syntax":"swift","code":["func allValues(in array: [Int], match predicate: (Int) -> Bool) -> Bool {","    return array.lazy.filter { !predicate($0) }.isEmpty","}","// error: closure use of non-escaping parameter 'predicate'..."],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"code":"withoutActuallyEscaping(_:do:)","type":"codeVoice"},{"text":" provides a temporarily escapable copy of","type":"text"},{"text":" ","type":"text"},{"code":"predicate","type":"codeVoice"},{"text":" that ","type":"text"},{"inlineContent":[{"type":"text","text":"can"}],"type":"emphasis"},{"text":" be used in a call to the lazy view’s ","type":"text"},{"code":"filter(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"method. The second version of ","type":"text"},{"code":"allValues(in:match:)","type":"codeVoice"},{"text":" compiles without","type":"text"},{"text":" ","type":"text"},{"text":"error, with the compiler guaranteeing that the ","type":"text"},{"code":"escapablePredicate","type":"codeVoice"},{"text":" ","type":"text"},{"text":"closure doesn’t last beyond the call to ","type":"text"},{"code":"withoutActuallyEscaping(_:do:)","type":"codeVoice"},{"text":".","type":"text"}]},{"syntax":"swift","code":["func allValues(in array: [Int], match predicate: (Int) -> Bool) -> Bool {","    return withoutActuallyEscaping(predicate) { escapablePredicate in","        array.lazy.filter { !escapablePredicate($0) }.isEmpty","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Asynchronous calls are another type of API that typically escape their","type":"text"},{"text":" ","type":"text"},{"text":"closure arguments. The following code declares a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"perform(_:simultaneouslyWith:)"},{"type":"text","text":" function that uses a dispatch queue to"},{"type":"text","text":" "},{"type":"text","text":"execute two closures concurrently."}]},{"code":["func perform(_ f: () -> Void, simultaneouslyWith g: () -> Void) {","    let queue = DispatchQueue(label: \"perform\", attributes: .concurrent)","    queue.async(execute: f)","    queue.async(execute: g)","    queue.sync(flags: .barrier) {}","}","// error: passing non-escaping parameter 'f'...","// error: passing non-escaping parameter 'g'..."],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"perform(_:simultaneouslyWith:)"},{"type":"text","text":" function ends with a call to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"sync(flags:execute:)"},{"type":"text","text":" method using the "},{"type":"codeVoice","code":".barrier"},{"type":"text","text":" flag, which forces the"},{"type":"text","text":" "},{"type":"text","text":"function to wait until both closures have completed running before"},{"type":"text","text":" "},{"type":"text","text":"returning. Even though the barrier guarantees that neither closure will"},{"type":"text","text":" "},{"type":"text","text":"escape the function, the "},{"type":"codeVoice","code":"async(execute:)"},{"type":"text","text":" method still requires that the"},{"type":"text","text":" "},{"type":"text","text":"closures passed be marked as "},{"type":"codeVoice","code":"@escaping"},{"type":"text","text":", so the first version of the"},{"type":"text","text":" "},{"type":"text","text":"function does not compile. To resolve these errors, you can use"},{"type":"text","text":" "},{"type":"codeVoice","code":"withoutActuallyEscaping(_:do:)"},{"type":"text","text":" to get copies of "},{"type":"codeVoice","code":"f"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g"},{"text":" that can be","type":"text"},{"text":" ","type":"text"},{"text":"passed to ","type":"text"},{"code":"async(execute:)","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["func perform(_ f: () -> Void, simultaneouslyWith g: () -> Void) {","    withoutActuallyEscaping(f) { escapableF in","        withoutActuallyEscaping(g) { escapableG in","            let queue = DispatchQueue(label: \"perform\", attributes: .concurrent)","            queue.async(execute: escapableF)","            queue.async(execute: escapableG)","            queue.sync(flags: .barrier) {}","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The escapable copy of ","type":"text"},{"code":"closure","type":"codeVoice"},{"text":" passed to ","type":"text"},{"code":"body","type":"codeVoice"},{"text":" is only valid","type":"text"},{"text":" ","type":"text"},{"text":"during the call to ","type":"text"},{"code":"withoutActuallyEscaping(_:do:)","type":"codeVoice"},{"text":". It is undefined","type":"text"},{"text":" ","type":"text"},{"text":"behavior for the escapable closure to be stored, referenced, or executed","type":"text"},{"text":" ","type":"text"},{"text":"after the function returns.","type":"text"}]}],"type":"aside","style":"important","name":"Important"}]}],"variants":[{"paths":["/documentation/swift/withoutactuallyescaping(_:do:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Allows a nonescaping closure to temporarily be used as if it were allowed"},{"type":"text","text":" "},{"type":"text","text":"to escape."}],"kind":"symbol","identifier":{"url":"doc://com.apple.Swift/documentation/Swift/withoutActuallyEscaping(_:do:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Function","title":"withoutActuallyEscaping(_:do:)","modules":[{"name":"Swift"}],"externalID":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF","symbolKind":"func","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withoutActuallyEscaping"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"ClosureType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"ResultType"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Failure"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp","text":"ClosureType"},{"kind":"text","text":", "},{"kind":"externalParam","text":"do"},{"kind":"text","text":": ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"escapingClosure"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s23withoutActuallyEscaping_2doq_x_q_xq0_YKXEtq0_YKs5ErrorR0_r1_lF11ClosureTypeL_xmfp","text":"ClosureType"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"text":"Failure","kind