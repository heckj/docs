{"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/withTaskCancellationHandler(operation:onCancel:)"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"metadata":{"externalID":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancelxxyYaq_YKYCXE_yyXEtYaq_YKs5ErrorR_r0_lF","role":"symbol","roleHeading":"Function","modules":[{"relatedModules":[],"name":"Swift"}],"title":"withTaskCancellationHandler(operation:onCancel:)","symbolKind":"func","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withTaskCancellationHandler","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Return","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Failure","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"operation","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"nonisolated(nonsending)","kind":"keyword"},{"text":", ","kind":"text"},{"text":"onCancel","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"sending","kind":"keyword"},{"text":" () -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"text":"Failure","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancelxxyYaq_YKYCXE_yyXEtYaq_YKs5ErrorR_r0_lF7FailureL_q_mfp"},{"text":") -> ","kind":"text"},{"text":"Return","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancelxxyYaq_YKYCXE_yyXEtYaq_YKs5ErrorR_r0_lF6ReturnL_xmfp"}]},"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/withtaskcancellationhandler(operation:oncancel:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":"(nonsending) ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withTaskCancellationHandler","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Return","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Failure","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"operation","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"nonisolated(nonsending)","kind":"keyword"},{"text":", ","kind":"text"},{"text":"onCancel","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"handler","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"sending","kind":"keyword"},{"text":" () -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Void","preciseIdentifier":"s:s4Voida"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"text":"Failure","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancelxxyYaq_YKYCXE_yyXEtYaq_YKs5ErrorR_r0_lF7FailureL_q_mfp"},{"text":") -> ","kind":"text"},{"text":"Return","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancelxxyYaq_YKYCXE_yyXEtYaq_YKs5ErrorR_r0_lF6ReturnL_xmfp"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Failure","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Error","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Error","preciseIdentifier":"s:s5ErrorP"}],"languages":["swift"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The operation to perform."}]}],"name":"operation"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure to execute on cancellation."},{"type":"text","text":" "},{"type":"text","text":"If the task is canceled, this closure is called at most once;"},{"type":"text","text":" "},{"type":"text","text":"otherwise, it isn’t called."}]}],"name":"handler"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This differs from the operation cooperatively checking for cancellation"},{"type":"text","text":" "},{"type":"text","text":"and reacting to it in that the cancellation handler is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"always"}]},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"immediately"}]},{"type":"text","text":" invoked when the task is canceled. For example, even if the"},{"type":"text","text":" "},{"type":"text","text":"operation is running code that never checks for cancellation, a cancellation"},{"type":"text","text":" "},{"type":"text","text":"handler still runs and provides a chance to run some cleanup code:"}]},{"code":["await withTaskCancellationHandler {","  var sum = 0","  while condition {","    sum += 1","  }","  return sum","} onCancel: {","  // This onCancel closure might execute concurrently with the operation.","  condition.cancel()","}"],"type":"codeListing","syntax":"swift"},{"text":"Execution order and semantics","anchor":"Execution-order-and-semantics","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"operation"},{"type":"text","text":" closure is always invoked, even when the"},{"type":"text","text":" "},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:)"},{"type":"text","text":" method is called from a task"},{"type":"text","text":" "},{"type":"text","text":"that was already canceled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:)"},{"type":"text","text":" is used in a task that has already been"},{"type":"text","text":" "},{"type":"text","text":"canceled, the cancellation handler will be executed"},{"type":"text","text":" "},{"type":"text","text":"immediately before the "},{"type":"codeVoice","code":"operation"},{"type":"text","text":" closure gets to execute."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This allows the cancellation handler to set some external “canceled” flag"},{"type":"text","text":" "},{"type":"text","text":"that the operation may be "},{"type":"emphasis","inlineContent":[{"type":"text","text":"atomically"}]},{"type":"text","text":" checking for in order to avoid"},{"type":"text","text":" "},{"type":"text","text":"performing any actual work once the operation gets to run."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"operation"},{"type":"text","text":" closure executes on the calling execution context, and doesn’t"},{"type":"text","text":" "},{"type":"text","text":"suspend or change execution context unless code contained within the closure"},{"type":"text","text":" "},{"type":"text","text":"does so. In other words, the potential suspension point of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:)"},{"type":"text","text":" never suspends by itself before"},{"type":"text","text":" "},{"type":"text","text":"executing the operation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If cancellation occurs while the operation is running, the cancellation"},{"type":"text","text":" "},{"type":"text","text":"handler executes "},{"type":"emphasis","inlineContent":[{"type":"text","text":"concurrently"}]},{"type":"text","text":" with the operation."}]},{"text":"Cancellation handlers and locks","anchor":"Cancellation-handlers-and-locks","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cancellation handlers which acquire locks must take care to avoid deadlock."},{"type":"text","text":" "},{"type":"text","text":"The cancellation handler may be invoked while holding internal locks"},{"type":"text","text":" "},{"type":"text","text":"associated with the task or other tasks.  Other operations on the task, such"},{"type":"text","text":" "},{"type":"text","text":"as resuming a continuation, may acquire these same internal locks."},{"type":"text","text":" "},{"type":"text","text":"Therefore, if a cancellation handler must acquire a lock, other code should"},{"type":"text","text":" "},{"type":"text","text":"not cancel tasks or resume continuations while holding that lock."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Execute an operation with a cancellation handler that’s immediately","type":"text"},{"text":" ","type":"text"},{"text":"invoked if the current task is canceled.","type":"text"}],"references":{"doc://com.apple.Swift/documentation/Swift/Void":{"kind":"symbol","navigatorTitle":[{"text":"Void","kind":"identifier"}],"title":"Void","abstract":[{"type":"text","text":"The return type of functions that don’t explicitly specify a return type,"},{"text":" ","type":"text"},{"type":"text","text":"that is, an empty tuple "},{"type":"codeVoice","code":"()"},{"text":".","type":"text"}],"identifier":"doc://com.apple.Swift/documentation/Swift/Void","role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Void","kind":"identifier"}],"url":"/documentation/swift/void","type":"topic"},"doc://com.apple.Swift/documentation/Swift/withTaskCancellationHandler(operation:onCancel:)":{"title":"withTaskCancellationHandler(operation:onCancel:)","kind":"symbol","abstract":[{"type":"text","text":"Execute an operation with a cancellation handler that’s immediately"},{"text":" ","type":"text"},{"text":"invoked if the current task is canceled.","type":"text"}],"url":"/documentation/swift/withtaskcancellationhandler(operation:oncancel:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"withTaskCancellationHandler"},{"text":"<","kind":"text"},{"text":"Return","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Failure","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"operation","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"nonisolated(nonsending)","kind":"keyword"},{"text":", ","kind":"text"},{"text":"onCancel","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"sending","kind":"keyword"},{"text":" () -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancelxxyYaq_YKYCXE_yyXEtYaq_YKs5ErrorR_r0_lF7FailureL_q_mfp","text":"Failure"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancelxxyYaq_YKYCXE_yyXEtYaq_YKs5ErrorR_r0_lF6ReturnL_xmfp","text":"Return"}],"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/withTaskCancellationHandler(operation:onCancel:)"},"doc://com.apple.Swift/documentation/Swift/Error":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Error","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"A type representing an error value that can be thrown."}],"url":"/documentation/swift/error","identifier":"doc://com.apple.Swift/documentation/Swift/Error","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Error","kind":"identifier"}],"title":"Error"},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"}}}