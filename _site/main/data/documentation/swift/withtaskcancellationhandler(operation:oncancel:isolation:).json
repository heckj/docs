{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/withTaskCancellationHandler(operation:onCancel:isolation:)"},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","seeAlsoSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/CancellationError","doc://com.apple.Swift/documentation/Swift/Task/cancel()","doc://com.apple.Swift/documentation/Swift/Task/isCancelled-swift.property","doc://com.apple.Swift/documentation/Swift/Task/isCancelled-swift.type.property","doc://com.apple.Swift/documentation/Swift/Task/checkCancellation()"],"title":"Canceling Tasks","anchor":"Canceling-Tasks"}],"abstract":[{"type":"text","text":"Execute an operation with a cancellation handler that’s immediately"},{"text":" ","type":"text"},{"text":"invoked if the current task is canceled.","type":"text"}],"metadata":{"externalID":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF","symbolKind":"func","role":"symbol","title":"withTaskCancellationHandler(operation:onCancel:isolation:)","roleHeading":"Function","modules":[{"relatedModules":[],"name":"Swift"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withTaskCancellationHandler","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"operation","kind":"externalParam"},{"kind":"text","text":": () "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp","text":"T","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"onCancel","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" () -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":", "},{"text":"isolation","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"isolated","kind":"keyword"},{"text":" (","kind":"text"},{"text":"any","kind":"keyword"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:ScA","text":"Actor"},{"kind":"text","text":")?) "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"text":"rethrows","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp","text":"T","kind":"typeIdentifier"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@backDeployed(before: macOS 15.0, iOS 18.0, watchOS 11.0, tvOS 18.0, visionOS 2.0)\n","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"withTaskCancellationHandler"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"operation","kind":"externalParam"},{"kind":"text","text":": () "},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp","kind":"typeIdentifier","text":"T"},{"kind":"text","text":", "},{"kind":"externalParam","text":"onCancel"},{"kind":"text","text":" "},{"kind":"internalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" () -> "},{"preciseIdentifier":"s:s4Voida","identifier":"doc://com.apple.Swift/documentation/Swift/Void","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":", "},{"kind":"externalParam","text":"isolation"},{"kind":"text","text":": "},{"kind":"keyword","text":"isolated"},{"kind":"text","text":" ("},{"kind":"keyword","text":"any"},{"kind":"text","text":" "},{"preciseIdentifier":"s:ScA","identifier":"doc://com.apple.Swift/documentation/Swift/Actor","kind":"typeIdentifier","text":"Actor"},{"kind":"text","text":")?) "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp","kind":"typeIdentifier","text":"T"}]}]},{"kind":"parameters","parameters":[{"name":"operation","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The operation to perform."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure to execute on cancellation."},{"type":"text","text":" "},{"type":"text","text":"If the task is canceled, this closure is called at most once;"},{"type":"text","text":" "},{"type":"text","text":"otherwise, it isn’t called."}]}],"name":"handler"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The actor that the operation and cancellation handler are isolated to."}]}],"name":"isolation"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"This differs from the operation cooperatively checking for cancellation"},{"type":"text","text":" "},{"type":"text","text":"and reacting to it in that the cancellation handler is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"always"}]},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"immediately"}]},{"type":"text","text":" invoked when the task is canceled. For example, even if the"},{"type":"text","text":" "},{"type":"text","text":"operation is running code that never checks for cancellation, a cancellation"},{"type":"text","text":" "},{"type":"text","text":"handler still runs and provides a chance to run some cleanup code:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["await withTaskCancellationHandler {","  var sum = 0","  while condition {","    sum += 1","  }","  return sum","} onCancel: {","  // This onCancel closure might execute concurrently with the operation.","  condition.cancel()","}"]},{"type":"heading","anchor":"Execution-order-and-semantics","level":3,"text":"Execution order and semantics"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"operation"},{"type":"text","text":" closure is always invoked, even when the"},{"type":"text","text":" "},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:)"},{"type":"text","text":" method is called from a task"},{"type":"text","text":" "},{"type":"text","text":"that was already canceled."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:)"},{"type":"text","text":" is used in a task that has already been"},{"type":"text","text":" "},{"type":"text","text":"canceled, the cancellation handler will be executed"},{"type":"text","text":" "},{"type":"text","text":"immediately before the "},{"type":"codeVoice","code":"operation"},{"type":"text","text":" closure gets to execute."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This allows the cancellation handler to set some external “canceled” flag"},{"type":"text","text":" "},{"type":"text","text":"that the operation may be "},{"inlineContent":[{"type":"text","text":"atomically"}],"type":"emphasis"},{"type":"text","text":" checking for in order to avoid"},{"type":"text","text":" "},{"type":"text","text":"performing any actual work once the operation gets to run."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"operation"},{"type":"text","text":" closure executes on the calling execution context, and doesn’t"},{"type":"text","text":" "},{"type":"text","text":"suspend or change execution context unless code contained within the closure"},{"type":"text","text":" "},{"type":"text","text":"does so. In other words, the potential suspension point of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:)"},{"type":"text","text":" never suspends by itself before"},{"type":"text","text":" "},{"type":"text","text":"executing the operation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If cancellation occurs while the operation is running, the cancellation"},{"type":"text","text":" "},{"type":"text","text":"handler executes "},{"inlineContent":[{"type":"text","text":"concurrently"}],"type":"emphasis"},{"type":"text","text":" with the operation."}]},{"anchor":"Cancellation-handlers-and-locks","level":3,"type":"heading","text":"Cancellation handlers and locks"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cancellation handlers which acquire locks must take care to avoid deadlock."},{"type":"text","text":" "},{"type":"text","text":"The cancellation handler may be invoked while holding internal locks"},{"type":"text","text":" "},{"type":"text","text":"associated with the task or other tasks.  Other operations on the task, such"},{"type":"text","text":" "},{"type":"text","text":"as resuming a continuation, may acquire these same internal locks."},{"type":"text","text":" "},{"type":"text","text":"Therefore, if a cancellation handler must acquire a lock, other code should"},{"type":"text","text":" "},{"type":"text","text":"not cancel tasks or resume continuations while holding that lock."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/withtaskcancellationhandler(operation:oncancel:isolation:)"]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"references":{"doc://com.apple.Swift/documentation/Swift/withTaskCancellationHandler(operatio