{"kind":"symbol","metadata":{"roleHeading":"Function","symbolKind":"func","modules":[{"name":"Swift","relatedModules":[]}],"externalID":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF","title":"withTaskCancellationHandler(operation:onCancel:isolation:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"withTaskCancellationHandler"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"operation"},{"kind":"text","text":": () "},{"kind":"keyword","text":"async"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp","text":"T"},{"text":", ","kind":"text"},{"text":"onCancel","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" () -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"text":", ","kind":"text"},{"text":"isolation","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"keyword","text":"isolated"},{"kind":"text","text":" ("},{"kind":"keyword","text":"any"},{"text":" ","kind":"text"},{"text":"Actor","kind":"typeIdentifier","preciseIdentifier":"s:ScA"},{"text":")?) ","kind":"text"},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp","kind":"typeIdentifier","text":"T"}],"role":"symbol"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"text","text":"@backDeployed(before: macOS 15.0, iOS 18.0, watchOS 11.0, tvOS 18.0, visionOS 2.0)\n"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"withTaskCancellationHandler"},{"kind":"text","text":"<"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"operation"},{"text":": () ","kind":"text"},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"onCancel"},{"kind":"text","text":" "},{"kind":"internalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"attribute","text":"@Sendable"},{"text":" () -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Void"},{"text":", ","kind":"text"},{"text":"isolation","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"keyword","text":"isolated"},{"kind":"text","text":" ("},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Actor","kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Actor","preciseIdentifier":"s:ScA"},{"text":")? = #isolation) ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The operation to perform."}]}],"name":"operation"},{"name":"handler","content":[{"inlineContent":[{"type":"text","text":"A closure to execute on cancellation."},{"text":" ","type":"text"},{"text":"If the task is canceled, this closure is called at most once;","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"otherwise, it isn’t called."}],"type":"paragraph"}]},{"name":"isolation","content":[{"type":"paragraph","inlineContent":[{"text":"The actor that the operation and cancellation handler are isolated to.","type":"text"}]}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This differs from the operation cooperatively checking for cancellation","type":"text"},{"text":" ","type":"text"},{"text":"and reacting to it in that the cancellation handler is ","type":"text"},{"inlineContent":[{"text":"always","type":"text"}],"type":"emphasis"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"immediately"}]},{"type":"text","text":" invoked when the task is canceled. For example, even if the"},{"type":"text","text":" "},{"type":"text","text":"operation is running code that never checks for cancellation, a cancellation"},{"type":"text","text":" "},{"type":"text","text":"handler still runs and provides a chance to run some cleanup code:"}]},{"type":"codeListing","syntax":"swift","code":["await withTaskCancellationHandler {","  var sum = 0","  while condition {","    sum += 1","  }","  return sum","} onCancel: {","  // This onCancel closure might execute concurrently with the operation.","  condition.cancel()","}"]},{"type":"heading","anchor":"Execution-order-and-semantics","text":"Execution order and semantics","level":3},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"operation","type":"codeVoice"},{"text":" closure is always invoked, even when the","type":"text"},{"text":" ","type":"text"},{"code":"withTaskCancellationHandler(operation:onCancel:)","type":"codeVoice"},{"text":" method is called from a task","type":"text"},{"text":" ","type":"text"},{"text":"that was already canceled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"withTaskCancellationHandler(operation:onCancel:)","type":"codeVoice"},{"text":" is used in a task that has already been","type":"text"},{"text":" ","type":"text"},{"text":"canceled, the cancellation handler will be executed","type":"text"},{"text":" ","type":"text"},{"text":"immediately before the ","type":"text"},{"code":"operation","type":"codeVoice"},{"text":" closure gets to execute.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This allows the cancellation handler to set some external “canceled” flag"},{"type":"text","text":" "},{"type":"text","text":"that the operation may be "},{"type":"emphasis","inlineContent":[{"type":"text","text":"atomically"}]},{"type":"text","text":" checking for in order to avoid"},{"type":"text","text":" "},{"type":"text","text":"performing any actual work once the operation gets to run."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"operation","type":"codeVoice"},{"text":" closure executes on the calling execution context, and doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"suspend or change execution context unless code contained within the closure","type":"text"},{"text":" ","type":"text"},{"text":"does so. In other words, the potential suspension point of the","type":"text"},{"text":" ","type":"text"},{"code":"withTaskCancellationHandler(operation:onCancel:)","type":"codeVoice"},{"text":" never suspends by itself before","type":"text"},{"type":"text","text":" "},{"type":"text","text":"executing the operation."}]},{"type":"paragraph","inlineContent":[{"text":"If cancellation occurs while the operation is running, the cancellation","type":"text"},{"text":" ","type":"text"},{"text":"handler executes ","type":"text"},{"inlineContent":[{"type":"text","text":"concurrently"}],"type":"emphasis"},{"text":" with the operation.","type":"text"}]},{"anchor":"Cancellation-handlers-and-locks","level":3,"text":"Cancellation handlers and locks","type":"heading"},{"inlineContent":[{"type":"text","text":"Cancellation handlers which acquire locks must take care to avoid deadlock."},{"type":"text","text":" "},{"type":"text","text":"The cancellation handler may be invoked while holding internal locks"},{"type":"text","text":" "},{"type":"text","text":"associated with the task or other tasks.  Other operations on the task, such"},{"type":"text","text":" "},{"type":"text","text":"as resuming a continuation, may acquire these same internal locks."},{"type":"text","text":" "},{"type":"text","text":"Therefore, if a cancellation handler must acquire a lock, other code should"},{"type":"text","text":" "},{"type":"text","text":"not cancel tasks or resume continuations while holding that lock."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"seeAlsoSections":[{"anchor":"Canceling-Tasks","identifiers":["doc://com.apple.Swift/documentation/Swift/CancellationError","doc://com.apple.Swift/documentation/Swift/Task/cancel()","doc://com.apple.Swift/documentation/Swift/Task/isCancelled-swift.property","doc://com.apple.Swift/documentation/Swift/Task/isCancelled-swift.type.property","doc://com.apple.Swift/documentation/Swift/Task/checkCancellation()"],"generated":true,"title":"Canceling Tasks"}],"sections":[],"abstract":[{"text":"Execute an operation with a cancellation handler that’s immediately","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"invoked if the current task is canceled."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/withtaskcancellationhandler(operation:oncancel:isolation:)"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc://com.apple.Swift/documentation/Swift/withTaskCancellationHandler(operation:onCancel:isolation:)","interfaceLanguage":"swift"},"references":{"doc://com.apple.Swift/documentation/Swift/Task/isCancelled-swift.