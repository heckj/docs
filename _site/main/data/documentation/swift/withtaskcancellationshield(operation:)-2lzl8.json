{"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Swift"]]},"sections":[],"metadata":{"symbolKind":"func","modules":[{"name":"Swift","relatedModules":[]}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withTaskCancellationShield","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Value","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Failure","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"operation","kind":"externalParam"},{"text":": () ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"text":"Failure","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF7FailureL_q_mfp"},{"text":") -> ","kind":"text"},{"text":"Value","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF5ValueL_xmfp"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"text":"Failure","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF7FailureL_q_mfp"},{"text":") -> ","kind":"text"},{"text":"Value","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF5ValueL_xmfp"}],"roleHeading":"Function","title":"withTaskCancellationShield(operation:)","externalID":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF"},"abstract":[{"type":"text","text":"Enters a scope in which a task cancellation shield is active."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withTaskCancellationShield"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Value"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Failure"},{"kind":"text","text":">("},{"kind":"externalParam","text":"operation"},{"kind":"text","text":": () "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF7FailureL_q_mfp","kind":"typeIdentifier","text":"Failure"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF5ValueL_xmfp","kind":"typeIdentifier","text":"Value"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF7FailureL_q_mfp","kind":"typeIdentifier","text":"Failure"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF5ValueL_xmfp","kind":"typeIdentifier","text":"Value"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Failure"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:s5ErrorP","kind":"typeIdentifier","text":"Error","identifier":"doc://com.apple.Swift/documentation/Swift/Error"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cancellation shields are primarily used to ensure some cleanup code will"},{"type":"text","text":" "},{"type":"text","text":"definitely run, even if the context in which the cleanup functions are called from"},{"type":"text","text":" "},{"type":"text","text":"is a cancelled task, and the functions may otherwise return early (due to observing"},{"type":"text","text":" "},{"type":"text","text":"the cancellation of the current task)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, a resource cleanup function might internally check for cancellation,"},{"type":"text","text":" "},{"type":"text","text":"which could cause it to skip important cleanup work:"}]},{"type":"codeListing","code":["let resource = await makeResource()","defer {","  await withTaskCancellationShield {","    await resource.finish() // runs to completion, even if task was cancelled earlier","  }","}","","struct Resource {","  func finish() {","    guard !Task.isCancelled() else { return } // returns early if task was cancelled!","    // real work happens here","  }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"While inside a cancellation shield, "},{"type":"codeVoice","code":"Task.isCancelled"},{"type":"text","text":" returns "},{"type":"codeVoice","code":"false"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"Task.checkCancellation()"},{"type":"text","text":" does not throw, even if the surrounding task"},{"type":"text","text":" "},{"type":"text","text":"has been cancelled. Similarly task cancellation handlers do not trigger"},{"type":"text","text":" "},{"type":"text","text":"while executing in a shielded block of code."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the shield scope exits, the task’s actual"},{"type":"text","text":" "},{"type":"text","text":"cancellation status becomes observable again. Cancellation shields to not"},{"type":"text","text":" "},{"type":"text","text":"prevent the task from becoming cancelled, but only prevent observing the"},{"type":"text","text":" "},{"type":"text","text":"cancellation while executing inside a shielded scope."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cancellation shields also prevent cancellation from propagating to child tasks"},{"type":"text","text":" "},{"type":"text","text":"created within the shielded scope:"}]},{"type":"codeListing","code":["let task = Task {","  withUnsafeCurrentTask { $0?.cancel() } // cancel the task","","  await withTaskCancellationShield {","    // Child tasks created here do NOT observe the parent's cancellation","    // and therefore start as not cancelled. They can be individually cancelled though.","    await withTaskGroup(of: Void.self) { group in","      group.addTask {","        print(Task.isCancelled) // false","      }","      for await _ in group {}","","      group.cancelAll() // explicitly cancelling the group does cancel child tasks of the group","      group.addTask {","        print(Task.isCancelled) // true","      }","    }","  }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that shielding the "},{"type":"codeVoice","code":"addTask"},{"type":"text","text":" call itself does not shield the child task:"}]},{"type":"codeListing","code":["await withTaskGroup(of: Void.self) { group in","  group.cancelAll()","  withTaskCancellationShield {","    group.addTask { print(Task.isCancelled) } // true - child IS cancelled","  }","  group.addTask {","    withTaskCancellationShield { print(Task.isCancelled) } // false - shielded inside child","  }","}"],"syntax":"swift"}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/withtaskcancellationshield(operation:)-2lzl8"]}],"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.Swift/documentation/Swift/withTaskCancellationShield(operation:)-2lzl8"},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/documentation/Swift/withTaskCancellationShield(operation:)-2lzl8":{"abstract":[{"type":"text","text":"Enters a scope in which a task cancellation shield is active."}],"role":"symbol","url":"/documentation/swift/withtaskcancellationshield(operation:)-2lzl8","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withTaskCancellationShield"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Value"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Failure"},{"kind":"text","text":">("},{"kind":"externalParam","text":"operation"},{"kind":"text","text":": () "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Failure","preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF7FailureL_q_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Value","preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF5ValueL_xmfp"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Failure","preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF7FailureL_q_mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Value","preciseIdentifier":"s:12_Concurrency26withTaskCancellationShield9operationxxyq_YKXE_tq_YKs5ErrorR_r0_lF5ValueL_xmfp"}],"identifier":"doc://com.apple.Swift/documentation/Swift/withTaskCancellationShield(operation:)-2lzl8","type":"topic","title":"withTaskCancellationShield(operation:)"},"doc://com.apple.Swift/documentation/Swift/Error":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Error","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"A type representing an error value that can be thrown."}],"url":"/documentation/swift/error","identifier":"doc://com.apple.Swift/documentation/Swift/Error","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Error","kind":"identifier"}],"title":"Error"}}}