{"abstract":[{"text":"Starts a new scope that can contain a dynamic number of child tasks.","type":"text"}],"seeAlsoSections":[{"title":"Tasks","identifiers":["doc://com.apple.Swift/documentation/Swift/Task","doc://com.apple.Swift/documentation/Swift/TaskGroup","doc://com.apple.Swift/documentation/Swift/withTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","doc://com.apple.Swift/documentation/Swift/withThrowingTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/TaskPriority","doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup","doc://com.apple.Swift/documentation/Swift/withDiscardingTaskGroup(returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup","doc://com.apple.Swift/documentation/Swift/UnsafeCurrentTask"],"generated":true,"anchor":"Tasks"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@backDeployed(before: macOS 15.0, iOS 18.0, watchOS 11.0, tvOS 18.0, visionOS 2.0)\n","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withThrowingDiscardingTaskGroup","kind":"identifier"},{"text":"<","kind":"text"},{"text":"GroupResult","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"returning"},{"kind":"text","text":" "},{"kind":"internalParam","text":"returnType"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency31withThrowingDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdeF0Vys5Error_pGzYaKXEtYaKlF0F6ResultL_xmfp","text":"GroupResult"},{"kind":"text","text":".Type = GroupResult.self, "},{"kind":"externalParam","text":"isolation"},{"kind":"text","text":": "},{"kind":"keyword","text":"isolated"},{"kind":"text","text":" ("},{"kind":"keyword","text":"any"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:ScA","text":"Actor","identifier":"doc://com.apple.Swift/documentation/Swift/Actor"},{"kind":"text","text":")? = #isolation, "},{"kind":"externalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27ThrowingDiscardingTaskGroupV","text":"ThrowingDiscardingTaskGroup","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP","text":"Error","identifier":"doc://com.apple.Swift/documentation/Swift/Error"},{"kind":"text","text":">) "},{"text":"async","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency31withThrowingDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdeF0Vys5Error_pGzYaKXEtYaKlF0F6ResultL_xmfp","text":"GroupResult"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:12_Concurrency31withThrowingDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdeF0Vys5Error_pGzYaKXEtYaKlF0F6ResultL_xmfp","text":"GroupResult","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Unlike a "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","isActive":true},{"type":"text","text":", the child tasks as well as their results are"},{"type":"text","text":" "},{"type":"text","text":"discarded as soon as the tasks complete. This prevents the discarding"},{"type":"text","text":" "},{"type":"text","text":"task group from accumulating many results waiting to be consumed, and is"},{"type":"text","text":" "},{"type":"text","text":"best applied in situations where the result of a child task is some form"},{"text":" ","type":"text"},{"text":"of side-effect.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A group ","type":"text"},{"inlineContent":[{"type":"text","text":"always"}],"type":"emphasis"},{"text":" waits for all of its child tasks","type":"text"},{"text":" ","type":"text"},{"text":"to complete before it returns. Even canceled tasks must run until","type":"text"},{"text":" ","type":"text"},{"text":"completion before this function returns.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Canceled child tasks cooperatively react to cancellation and attempt"},{"type":"text","text":" "},{"type":"text","text":"to return as early as possible."},{"type":"text","text":" "},{"text":"After this function returns, the task group is always empty.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is not possible to explicitly await completion of child-tasks,"},{"type":"text","text":" "},{"type":"text","text":"however the group will automatically await "},{"inlineContent":[{"type":"text","text":"all"}],"type":"emphasis"},{"type":"text","text":" child task completions"},{"text":" ","type":"text"},{"text":"before returning from this function:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["try await withThrowingDiscardingTaskGroup(of: Void.self) { group in","  group.addTask { /* slow-task */ }","  // slow-task executes...","}","// guaranteed that slow-task has completed and the group is empty & destroyed"]},{"inlineContent":[{"type":"text","text":"Refer to "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup"},{"type":"text","text":" documentation for detailed discussion of semantics shared between all task groups."}],"type":"paragraph"},{"level":1,"text":"Task Group Cancellation","type":"heading","anchor":"Task-Group-Cancellation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can cancel a task group and all of its child tasks"},{"type":"text","text":" "},{"type":"text","text":"by calling the "},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup/cancelAll()","isActive":true,"type":"reference"},{"type":"text","text":" method on the task group,"},{"type":"text","text":" "},{"type":"text","text":"or by canceling the task in which the group is running."}]},{"type":"paragraph","inlineContent":[{"text":"If you call ","type":"text"},{"code":"addTask(priority:operation:)","type":"codeVoice"},{"text":" to create a new task in a canceled group,","type":"text"},{"text":" ","type":"text"},{"text":"that task is immediately canceled after creation.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, you can call "},{"type":"codeVoice","code":"asyncUnlessCancelled(priority:operation:)"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which doesn’t create the task if the group has already been canceled."},{"type":"text","text":" "},{"text":"Choosing between these two functions","type":"text"},{"text":" ","type":"text"},{"text":"lets you control how to react to cancellation within a group:","type":"text"},{"text":" ","type":"text"},{"text":"some child tasks need to run regardless of cancellation,","type":"text"},{"text":" ","type":"text"},{"text":"but other tasks are better not even being created","type":"text"},{"text":" ","type":"text"},{"text":"when you know they can’t produce useful results.","type":"text"}]},{"anchor":"Error-Handling-and-Implicit-Cancellation","text":"Error Handling and Implicit Cancellation","type":"heading","level":1},{"inlineContent":[{"type":"text","text":"Since it is not possible to explicitly await individual task completions,"},{"text":" ","type":"text"},{"type":"text","text":"it is also not possible to “re-throw” an error thrown by one of the child"},{"type":"text","text":" "},{"text":"tasks using the same pattern as one would in a ","type":"text"},{"isActive":true,"identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["// ThrowingTaskGroup, pattern not applicable to ThrowingDiscardingTaskGroup","try await withThrowingTaskGroup(of: Void.self) { group in","  group.addTask { try boom() }","  try await group.next() // re-throws \"boom\"","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since discarding task groups don’t have access to "},{"type":"codeVoice","code":"next()"},{"type":"text","text":", this pattern"},{"text":" ","type":"text"},{"text":"cannot be used.","type":"text"},{"text":" ","type":"text"},{"text":"Instead,","type":"text"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"inlineContent":[{"text":"throwing discarding task group implicitly cancels itself whenever any","type":"text"},{"type":"text","text":" "},{"text":"of its child tasks throws","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"first error","type":"text"}]},{"type":"text","text":" thrown inside such task group"},{"type":"text","text":" "},{"type":"text","text":"is then retained and thrown"},{"type":"text","text":" "},{"text":"out of the ","type":"text"},{"type":"codeVoice","code":"withThrowingDiscardingTaskGroup"},{"text":" method when it returns.","type":"text"}]},{"syntax":"swift","code":["try await withThrowingDiscardingTaskGroup { group in","  group.addTask { try boom(1) }","  group.addTask { try boom(2, after: .seconds(5)) }","  group.addTask { try boom(3, after: .seconds(5)) }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Generally, this suits the typical use cases of a"},{"type":"text","text":" "},{"type":"text","text":"discarding task group well, however, if you want to prevent specific"},{"type":"text","text":" "},{"type":"text","text":"errors from canceling the group you can catch them inside the child"},{"type":"text","text":" "},{"type":"text","text":"task’s body like this:"}]},{"type":"codeListing","syntax":"swift","code":["try await withThrowingDiscardingTaskGroup { group in","  group.addTask {","    do {","      try boom(1)","    } catch is HarmlessError {","      return","    }","  }","  group.addTask {","    try boom(2, after: .seconds(5))","  }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/swift/withthrowingdiscardingtaskgroup(returning:isolation:body:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"withThrowingDiscardingTaskGroup(returning:isolation:body:)","modules":[{"relatedModules":[],"name":"Swift"}],"roleHeading":"Function","symbolKind":"func","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"withThrowingDiscardingTaskGroup"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"GroupResult"},{"kind":"text","text":">("},{"kind":"externalParam","text":"returning"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GroupResult","preciseIdentifier":"s:12_Concurrency31withThrowingDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdeF0Vys5Error_pGzYaKXEtYaKlF0F6ResultL_xmfp"},{"kind":"text","text":".Type, "},{"kind":"externalParam","text":"isolation"},{"kind":"text","text":": "},{"kind":"keyword","text":"isolated"},{"kind":"text","text":" ("},{"kind":"keyword","text":"any"},{"kind":"text","text":" "},{"text":"Actor","kind":"typeIdentifier","preciseIdentifier":"s:ScA"},{"kind":"text","text":")?, "},{"kind":"externalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"preciseIdentifier":"s:12_Concurrency27ThrowingDiscardingTaskGroupV","kind":"typeIdentifier","text":"ThrowingDiscardingTaskGroup"},{"kind":"text","text":"<"},{