{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"text","text":"@backDeployed(before: macOS 15.0, iOS 18.0, watchOS 11.0, tvOS 18.0, visionOS 2.0)\n"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withThrowingDiscardingTaskGroup"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"GroupResult"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"returning"},{"kind":"text","text":" "},{"text":"returnType","kind":"internalParam"},{"kind":"text","text":": "},{"text":"GroupResult","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency31withThrowingDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdeF0Vys5Error_pGzYaKXEtYaKlF0F6ResultL_xmfp"},{"kind":"text","text":".Type = GroupResult.self, "},{"kind":"externalParam","text":"isolation"},{"kind":"text","text":": "},{"kind":"keyword","text":"isolated"},{"kind":"text","text":" ("},{"text":"any","kind":"keyword"},{"kind":"text","text":" "},{"identifier":"doc://com.apple.Swift/documentation/Swift/Actor","kind":"typeIdentifier","preciseIdentifier":"s:ScA","text":"Actor"},{"kind":"text","text":")? = #isolation, "},{"kind":"externalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup","text":"ThrowingDiscardingTaskGroup","preciseIdentifier":"s:12_Concurrency27ThrowingDiscardingTaskGroupV"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"Error","preciseIdentifier":"s:s5ErrorP","identifier":"doc://com.apple.Swift/documentation/Swift/Error"},{"kind":"text","text":">) "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"GroupResult","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency31withThrowingDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdeF0Vys5Error_pGzYaKXEtYaKlF0F6ResultL_xmfp"},{"kind":"text","text":") "},{"text":"async","kind":"keyword"},{"kind":"text","text":" "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"GroupResult","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency31withThrowingDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdeF0Vys5Error_pGzYaKXEtYaKlF0F6ResultL_xmfp"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Unlike a "},{"identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","type":"reference","isActive":true},{"type":"text","text":", the child tasks as well as their results are"},{"type":"text","text":" "},{"type":"text","text":"discarded as soon as the tasks complete. This prevents the discarding"},{"type":"text","text":" "},{"type":"text","text":"task group from accumulating many results waiting to be consumed, and is"},{"type":"text","text":" "},{"type":"text","text":"best applied in situations where the result of a child task is some form"},{"type":"text","text":" "},{"type":"text","text":"of side-effect."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A group "},{"type":"emphasis","inlineContent":[{"type":"text","text":"always"}]},{"type":"text","text":" waits for all of its child tasks"},{"type":"text","text":" "},{"type":"text","text":"to complete before it returns. Even canceled tasks must run until"},{"type":"text","text":" "},{"type":"text","text":"completion before this function returns."},{"type":"text","text":" "},{"type":"text","text":"Canceled child tasks cooperatively react to cancellation and attempt"},{"type":"text","text":" "},{"type":"text","text":"to return as early as possible."},{"type":"text","text":" "},{"type":"text","text":"After this function returns, the task group is always empty."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is not possible to explicitly await completion of child-tasks,"},{"type":"text","text":" "},{"type":"text","text":"however the group will automatically await "},{"type":"emphasis","inlineContent":[{"type":"text","text":"all"}]},{"type":"text","text":" child task completions"},{"text":" ","type":"text"},{"text":"before returning from this function:","type":"text"}]},{"code":["try await withThrowingDiscardingTaskGroup { group in","  group.addTask { /* slow-task */ }","  // slow-task executes...","}","// guaranteed that slow-task has completed and the group is empty & destroyed"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Refer to ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true,"type":"reference"},{"text":" documentation for detailed discussion of semantics shared between all task groups.","type":"text"}]},{"text":"Task Group Cancellation","level":1,"anchor":"Task-Group-Cancellation","type":"heading"},{"inlineContent":[{"text":"You can cancel a task group and all of its child tasks","type":"text"},{"text":" ","type":"text"},{"text":"by calling the ","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup/cancelAll()","isActive":true,"type":"reference"},{"text":" method on the task group,","type":"text"},{"text":" ","type":"text"},{"text":"or by canceling the task in which the group is running.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you call ","type":"text"},{"code":"addTask(priority:operation:)","type":"codeVoice"},{"text":" to create a new task in a canceled group,","type":"text"},{"text":" ","type":"text"},{"text":"that task is immediately canceled after creation.","type":"text"},{"text":" ","type":"text"},{"text":"Alternatively, you can call ","type":"text"},{"code":"asyncUnlessCancelled(priority:operation:)","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which doesn’t create the task if the group has already been canceled.","type":"text"},{"text":" ","type":"text"},{"text":"Choosing between these two functions","type":"text"},{"text":" ","type":"text"},{"text":"lets you control how to react to cancellation within a group:","type":"text"},{"type":"text","text":" "},{"text":"some child tasks need to run regardless of cancellation,","type":"text"},{"text":" ","type":"text"},{"text":"but other tasks are better not even being created","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when you know they can’t produce useful results."}],"type":"paragraph"},{"anchor":"Error-Handling-and-Implicit-Cancellation","level":1,"type":"heading","text":"Error Handling and Implicit Cancellation"},{"inlineContent":[{"text":"Since it is not possible to explicitly await individual task completions,","type":"text"},{"text":" ","type":"text"},{"text":"it is also not possible to “re-throw” an error thrown by one of the child","type":"text"},{"text":" ","type":"text"},{"text":"tasks using the same pattern as one would in a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["// ThrowingTaskGroup, pattern not applicable to ThrowingDiscardingTaskGroup","try await withThrowingTaskGroup(of: Void.self) { group in","  group.addTask { try boom() }","  try await group.next() // re-throws \"boom\"","}"]},{"inlineContent":[{"text":"Since discarding task groups don’t have access to ","type":"text"},{"code":"next()","type":"codeVoice"},{"text":", this pattern","type":"text"},{"text":" ","type":"text"},{"text":"cannot be used.","type":"text"},{"text":" ","type":"text"},{"text":"Instead,","type":"text"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"inlineContent":[{"text":"throwing discarding task group implicitly cancels itself whenever any","type":"text"},{"text":" ","type":"text"},{"text":"of its child tasks throws","type":"text"}],"type":"emphasis"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"inlineContent":[{"text":"first error","type":"text"}],"type":"emphasis"},{"text":" thrown inside such task group","type":"text"},{"text":" ","type":"text"},{"text":"is then retained and thrown","type":"text"},{"text":" ","type":"text"},{"text":"out of the ","type":"text"},{"code":"withThrowingDiscardingTaskGroup","type":"codeVoice"},{"text":" method when it returns.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["try await withThrowingDiscardingTaskGroup { group in","  group.addTask { try boom(1) }","  group.addTask { try boom(2, after: .seconds(5)) }","  group.addTask { try boom(3, after: .seconds(5)) }","}"]},{"inlineContent":[{"text":"Generally, this suits the typical use cases of a","type":"text"},{"text":" ","type":"text"},{"text":"discarding task group well, however, if you want to prevent specific","type":"text"},{"text":" ","type":"text"},{"text":"errors from canceling the group you can catch them inside the child","type":"text"},{"text":" ","type":"text"},{"text":"task’s body like this:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["try await withThrowingDiscardingTaskGroup { group in","  group.addTask {","    do {","      try boom(1)","    } catch is HarmlessError {","      return","    }","  }","  group.addTask {","    try boom(2, after: .seconds(5))","  }","}"]}]}],"sections":[],"seeAlsoSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Swift/Task","doc://com.apple.Swift/documentation/Swift/TaskGroup","doc://com.apple.Swift/documentation/Swift/withTaskGroup(of:returning:isolation:body:)","doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","doc://com.apple.Swift/documentation/Swift/withThrowingTaskGroup(of:returning:isolation:body:)","doc://com.appl