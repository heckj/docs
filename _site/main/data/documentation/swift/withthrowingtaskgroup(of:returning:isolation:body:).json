ng child tasks."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"@backDeployed(before: macOS 15.0, iOS 18.0, watchOS 11.0, tvOS 18.0, visionOS 2.0)\n"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withThrowingTaskGroup"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"ChildTaskResult"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"GroupResult"},{"kind":"text","text":">("},{"kind":"externalParam","text":"of"},{"kind":"text","text":" "},{"kind":"internalParam","text":"childTaskResultType"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF05ChildD6ResultL_xmfp","text":"ChildTaskResult"},{"kind":"text","text":".Type = ChildTaskResult.self, "},{"kind":"externalParam","text":"returning"},{"kind":"text","text":" "},{"kind":"internalParam","text":"returnType"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF0E6ResultL_q_mfp","text":"GroupResult"},{"kind":"text","text":".Type = GroupResult.self, "},{"kind":"externalParam","text":"isolation"},{"kind":"text","text":": "},{"kind":"keyword","text":"isolated"},{"kind":"text","text":" ("},{"kind":"keyword","text":"any"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:ScA","identifier":"doc://com.apple.Swift/documentation/Swift/Actor","text":"Actor"},{"kind":"text","text":")? = #isolation, "},{"kind":"externalParam","text":"body"},{"kind":"text","text":": ("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:Scg","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","text":"ThrowingTaskGroup"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF05ChildD6ResultL_xmfp","text":"ChildTaskResult"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP","identifier":"doc://com.apple.Swift/documentation/Swift/Error","text":"Error"},{"kind":"text","text":">) "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF0E6ResultL_q_mfp","text":"GroupResult"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"GroupResult","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF0E6ResultL_q_mfp"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"ChildTaskResult"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","text":"Sendable","preciseIdentifier":"s:s8SendableP"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A group "},{"type":"emphasis","inlineContent":[{"type":"text","text":"always"}]},{"type":"text","text":" waits for all of its child tasks"},{"type":"text","text":" "},{"type":"text","text":"to complete before it returns. Even canceled tasks must run until"},{"type":"text","text":" "},{"type":"text","text":"completion before this function returns."},{"type":"text","text":" "},{"type":"text","text":"Canceled child tasks cooperatively react to cancellation and attempt"},{"type":"text","text":" "},{"type":"text","text":"to return as early as possible."},{"type":"text","text":" "},{"type":"text","text":"After this function returns, the task group is always empty."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To collect the results of the group’s child tasks,"},{"type":"text","text":" "},{"type":"text","text":"you can use a "},{"code":"for","type":"codeVoice"},{"type":"text","text":"-"},{"code":"await","type":"codeVoice"},{"type":"text","text":"-"},{"code":"in","type":"codeVoice"},{"type":"text","text":" loop:"}]},{"type":"codeListing","syntax":"swift","code":["var sum = 0","for try await result in group {","    sum += result","}"]},{"inlineContent":[{"type":"text","text":"If you need more control or only a few results,"},{"type":"text","text":" "},{"type":"text","text":"you can call "},{"type":"codeVoice","code":"next()"},{"type":"text","text":" directly:"}],"type":"paragraph"},{"code":["guard let first = try await group.next() else {","    group.cancelAll()","    return 0","}","let second = await group.next() ?? 0","group.cancelAll()","return first + second"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":1,"anchor":"Error-Handling","text":"Error Handling"},{"inlineContent":[{"type":"text","text":"Throwing an error in one of the child tasks of a task group"},{"type":"text","text":" "},{"type":"text","text":"doesn’t immediately cancel the other tasks in that group."},{"type":"text","text":" "},{"type":"text","text":"However,"},{"type":"text","text":" "},{"type":"text","text":"throwing out of the "},{"code":"body","type":"codeVoice"},{"type":"text","text":" of the "},{"code":"withThrowingTaskGroup","type":"codeVoice"},{"type":"text","text":" method does cancel"},{"type":"text","text":" "},{"type":"text","text":"the group, and all of its child tasks."},{"text":" ","type":"text"},{"type":"text","text":"For example,"},{"text":" ","type":"text"},{"type":"text","text":"if you call "},{"code":"next()","type":"codeVoice"},{"type":"text","text":" in the task group and propagate its error,"},{"type":"text","text":" "},{"text":"all other tasks are canceled.","type":"text"},{"type":"text","text":" "},{"text":"For example, in the code below,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"nothing is canceled and the group doesn’t throw an error:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["try await withThrowingTaskGroup(of: Void.self) { group in","    group.addTask { throw SomeError() }","}"]},{"inlineContent":[{"text":"In contrast, this example throws ","type":"text"},{"type":"codeVoice","code":"SomeError"},{"text":" ","type":"text"},{"text":"and cancels all of the tasks in the group:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["try await withThrowingTaskGroup(of: Void.self) { group in","    group.addTask { throw SomeError() }","    try await group.next()","}"]},{"inlineContent":[{"type":"text","text":"An individual task throws its error"},{"type":"text","text":" "},{"type":"text","text":"in the corresponding call to "},{"type":"codeVoice","code":"Group.next()"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"which gives you a chance to handle the individual error","type":"text"},{"type":"text","text":" "},{"text":"or to let the group rethrow the error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Refer to "},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true,"type":"reference"},{"type":"text","text":" documentation for detailed discussion of semantics shared between all task groups."}],"type":"paragraph"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":""},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","type":"reference","isActive":true