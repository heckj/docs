},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ThrowingTaskGroup","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","preciseIdentifier":"s:Scg","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"ChildTaskResult","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF05ChildD6ResultL_xmfp","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Error","identifier":"doc://com.apple.Swift/documentation/Swift/Error","preciseIdentifier":"s:s5ErrorP","kind":"typeIdentifier"},{"text":">) ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"GroupResult","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF0E6ResultL_q_mfp","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"GroupResult","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF0E6ResultL_q_mfp"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"ChildTaskResult"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc://com.apple.Swift/documentation/Swift/Sendable","text":"Sendable","preciseIdentifier":"s:s8SendableP"}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A group "},{"type":"emphasis","inlineContent":[{"type":"text","text":"always"}]},{"type":"text","text":" waits for all of its child tasks"},{"type":"text","text":" "},{"type":"text","text":"to complete before it returns. Even canceled tasks must run until"},{"type":"text","text":" "},{"type":"text","text":"completion before this function returns."},{"type":"text","text":" "},{"type":"text","text":"Canceled child tasks cooperatively react to cancellation and attempt"},{"type":"text","text":" "},{"type":"text","text":"to return as early as possible."},{"type":"text","text":" "},{"type":"text","text":"After this function returns, the task group is always empty."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To collect the results of the group’s child tasks,"},{"type":"text","text":" "},{"type":"text","text":"you can use a "},{"code":"for","type":"codeVoice"},{"type":"text","text":"-"},{"code":"await","type":"codeVoice"},{"type":"text","text":"-"},{"code":"in","type":"codeVoice"},{"type":"text","text":" loop:"}]},{"code":["var sum = 0","for try await result in group {","    sum += result","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need more control or only a few results,"},{"type":"text","text":" "},{"type":"text","text":"you can call "},{"code":"next()","type":"codeVoice"},{"type":"text","text":" directly:"}]},{"code":["guard let first = try await group.next() else {","    group.cancelAll()","    return 0","}","let second = await group.next() ?? 0","group.cancelAll()","return first + second"],"syntax":"swift","type":"codeListing"},{"text":"Error Handling","type":"heading","anchor":"Error-Handling","level":1},{"type":"paragraph","inlineContent":[{"text":"Throwing an error in one of the child tasks of a task group","type":"text"},{"text":" ","type":"text"},{"text":"doesn’t immediately cancel the other tasks in that group.","type":"text"},{"text":" ","type":"text"},{"text":"However,","type":"text"},{"text":" ","type":"text"},{"text":"throwing out of the ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" of the ","type":"text"},{"type":"codeVoice","code":"withThrowingTaskGroup"},{"text":" method does cancel","type":"text"},{"text":" ","type":"text"},{"text":"the group, and all of its child tasks.","type":"text"},{"text":" ","type":"text"},{"text":"For example,","type":"text"},{"text":" ","type":"text"},{"text":"if you call ","type":"text"},{"type":"codeVoice","code":"next()"},{"text":" in the task group and propagate its error,","type":"text"},{"text":" ","type":"text"},{"text":"all other tasks are canceled.","type":"text"},{"text":" ","type":"text"},{"text":"For example, in the code below,","type":"text"},{"text":" ","type":"text"},{"text":"nothing is canceled and the group doesn’t throw an error:","type":"text"}]},{"code":["try await withThrowingTaskGroup(of: Void.self) { group in","    group.addTask { throw SomeError() }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"In contrast, this example throws ","type":"text"},{"code":"SomeError","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and cancels all of the tasks in the group:","type":"text"}],"type":"paragraph"},{"code":["try await withThrowingTaskGroup(of: Void.self) { group in","    group.addTask { throw SomeError() }","    try await group.next()","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"An individual task throws its error","type":"text"},{"text":" ","type":"text"},{"text":"in the corresponding call to ","type":"text"},{"code":"Group.next()","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which gives you a chance to handle the individual error","type":"text"},{"text":" ","type":"text"},{"text":"or to let the group rethrow the error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Refer to "},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","isActive":true},{"type":"text","text":" documentation for detailed discussion of semantics shared between all task groups."}],"type":"paragraph"},{"name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"identifier":"doc://com.apple.Swift/documentation/Swift/TaskGroup","type":"reference","isActive":true}],"type":"paragraph"}],"type":"aside","style":"note"},{"name":"See Also","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingTaskGroup","isActive":true}]}],"type":"aside","style":"note"},{"name":"See Also","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"reference","identifier":"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGroup","isActive":true}]}],"type":"aside","style":"note"}],"kind":"content"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"type":"topic","title":"Swift","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"kind":"symbol","url":"/documentation/swift","role":"collection","identifier":"doc://com.apple.Swift/documentation/Swift"},"doc://com.apple.Swift/documentation/Swift/TaskPriority":{"url":"/documentation/swift/taskpriority","type":"topic","kind":"symbol","title":"TaskPriority","abstract":[{"text":"The priority of a task.","type":"text"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TaskPriority"}],"navigatorTitle":[{"kind":"identifier","text":"TaskPriority"}],"identifier":"doc://com.apple.Swift/documentation/Swift/TaskPriority"},"doc://com.apple.Swift/documentation/Swift/Task":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Task"}],"abstract":[{"type":"text","text":"A unit of asynchronous work."}],"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/Task","type":"topic","kind":"symbol","title":"Task","navigatorTitle":[{"kind":"identifier","text":"Task"}],"url":"/documentation/swift/task"},"doc://com.apple.Swift/documentation/Sw