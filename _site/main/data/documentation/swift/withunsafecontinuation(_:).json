{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":"(nonsending) "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withUnsafeContinuation"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"fn"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"UnsafeContinuation","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeContinuation","preciseIdentifier":"s:Scc"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:12_Concurrency22withUnsafeContinuationyxySccyxs5NeverOGXEYalF1TL_xmfp"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Never","identifier":"doc://com.apple.Swift/documentation/Swift/Never","preciseIdentifier":"s:s5NeverO"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","text":"Void","identifier":"doc://com.apple.Swift/documentation/Swift/Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" -> sending "},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:12_Concurrency22withUnsafeContinuationyxySccyxs5NeverOGXEYalF1TL_xmfp"}]}]},{"parameters":[{"name":"fn","content":[{"inlineContent":[{"type":"text","text":"A closure that takes an "},{"type":"codeVoice","code":"UnsafeContinuation"},{"type":"text","text":" parameter."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The value continuation is resumed with."}]}],"kind":"content"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The body of the closure executes synchronously on the calling task, and once it returns"},{"type":"text","text":" "},{"type":"text","text":"the calling task is suspended. It is possible to immediately resume the task, or escape the"},{"type":"text","text":" "},{"type":"text","text":"continuation in order to complete it afterwards, which will then resume the suspended task."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You must invoke the continuation’s "},{"code":"resume","type":"codeVoice"},{"type":"text","text":" method exactly once."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Missing to invoke it (eventually) will cause the calling task to remain suspended"},{"type":"text","text":" "},{"type":"text","text":"indefinitely which will result in the task “hanging” as well as being leaked with"},{"type":"text","text":" "},{"type":"text","text":"no possibility to destroy it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike the “checked” continuation variant, the "},{"code":"UnsafeContinuation","type":"codeVoice"},{"type":"text","text":" does not"},{"type":"text","text":" "},{"type":"text","text":"detect or diagnose any kind of misuse, so you need to be extra careful to avoid"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"code":"resume","type":"codeVoice"},{"type":"text","text":" twice or forgetting to call resume before letting go of the"},{"type":"text","text":" "},{"type":"text","text":"continuation object."}]},{"name":"See Also","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"withUnsafeThrowingContinuation(function:_:)","type":"codeVoice"}]}]},{"name":"See Also","type":"aside","style":"note","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"withCheckedContinuation(function:_:)","type":"codeVoice"}],"type":"paragraph"}]},{"name":"See Also","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"wi