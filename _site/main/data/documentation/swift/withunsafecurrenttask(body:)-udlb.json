e":"codeVoice"},{"text":" ","type":"text"},{"text":"because an asynchronous function always runs in the context of a task.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The operation is guaranteed to execute on the caller’s isolation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Storing an unsafe reference to a task doesn’t affect the task’s actual life cycle,","type":"text"},{"text":" ","type":"text"},{"text":"and the behavior of accessing an unsafe task reference","type":"text"},{"text":" ","type":"text"},{"text":"outside of the ","type":"text"},{"code":"withUnsafeCurrentTask(body:)","type":"codeVoice"},{"text":" method’s closure is unsafe and undefined behavior.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"There’s no safe way to retrieve a reference to the current task"},{"text":" ","type":"text"},{"text":"and save it for long-term use.","type":"text"},{"text":" ","type":"text"},{"text":"To query the current task without saving a reference to it,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use properties like "},{"code":"currentPriority","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"If you need to store a reference to a task,","type":"text"},{"text":" ","type":"text"},{"text":"create an unstructured task using ","type":"text"},{"type":"codeVoice","code":"Task.detached(priority:operation:)"},{"text":" instead.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["/documentation/swift/withunsafecurrenttask(body:)-udlb"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc://com.apple.Swift/documentation/Swift","type":"topic","url":"/documentation/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"},"doc://com.apple.Swift/docu