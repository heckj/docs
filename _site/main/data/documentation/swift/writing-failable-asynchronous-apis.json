{"kind":"article","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/writing-failable-asynchronous-apis"},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","doc:\/\/com.apple.Swift\/documentation\/Swift\/numbers-and-basic-values","doc:\/\/com.apple.Swift\/documentation\/Swift\/Result"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Vend results as part of an API when you can’t return errors synchronously."}],"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"Swift"}],"title":"Writing Failable Asynchronous APIs"},"seeAlsoSections":[{"generated":true,"title":"Representing a Result","anchor":"Representing-a-Result","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/Result\/success(_:)","doc:\/\/com.apple.Swift\/documentation\/Swift\/Result\/failure(_:)"]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When writing a function, method, or other API that might fail, you use the "},{"type":"codeVoice","code":"throws"},{"type":"text","text":" "},{"type":"text","text":"keyword on the declaration to indicate that the API call can throw an error. However,"},{"type":"text","text":" "},{"type":"text","text":"you can’t use the "},{"type":"codeVoice","code":"throws"},{"type":"text","text":" keyword to model APIs that return asynchronously. Instead,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Result"},{"type":"text","text":" enumeration to capture information about whether an asychronous"},{"type":"text","text":" "},{"type":"text","text":"call succeeds or fails, and use the associated values for the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Result\/success(_:)"},{"type":"text","text":" "},{"type":"text","text":"and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Result\/failure(_:)"},{"type":"text","text":" cases to carry information about the result of the"},{"type":"text","text":" "},{"type":"text","text":"call."}]},{"anchor":"Return-Result-Instances-Asynchronously","type":"heading","level":3,"text":"Return Result Instances Asynchronously"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example models an asynchronous source of random numbers. The "},{"type":"codeVoice","code":"fetchRemoteRandomNumber(completion:)"},{"type":"text","text":" "},{"type":"text","text":"method returns "},{"type":"codeVoice","code":"Void"},{"type":"text","text":" synchronously, and asynchronously calls a completion handler"},{"type":"text","text":" "},{"type":"text","text":"with a "},{"type":"codeVoice","code":"Result<Int, EntropyError>"},{"type":"text","text":" instance that contains either a random result"},{"type":"text","text":" "},{"type":"text","text":"or information about the failure."}]},{"code":["let queue = DispatchQueue(label: \"com.example.queue\")","","enum EntropyError: Error {","    case entropyDepleted","}","","struct AsyncRandomGenerator {","    static let entropyLimit = 5","    var count = 0","","    mutating func fetchRemoteRandomNumber(","        completion: @escaping (Result<Int, EntropyError>) -> Void","    ) {","        let result: Result<Int, EntropyError>","        if count < AsyncRandomGenerator.entropyLimit {","            \/\/ Produce numbers until reaching the entropy limit.","            result = .success(Int.random(in: 1...100))","        } else {","            \/\/ Supply a failure reason when the caller hits the limit.","            result = .failure(.entropyDepleted)","        }","","        count += 1","","        \/\/ Delay to simulate an asynchronous source of entropy.","        queue.asyncAfter(deadline: .now() + 2) {","            completion(result)","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Users of your remote random number generator can decide how to handle both the success"},{"type":"text","text":" "},{"type":"text","text":"and failure cases:"}]},{"code":["var generator = AsyncRandomGenerator()","","\/\/ Request one more number than the limit to trigger a failure.","(0..<AsyncRandomGenerator.entropyLimit + 1).forEach { _ in","    generator.fetchRemoteRandomNumber { result in","        switch result {","        case .success(let number):","            print(number)","        case .failure(let error):","            print(\"Source of randomness failed: \\(error)\")","        }","    }","}","","print(\"Waiting on some numbers.\")","","dispatchMain()","\/* Prints:","success(29)","success(46)","success(85)","success(39)","success(84)","Source of randomness failed: entropyDepleted","*\/"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"paths":["\/documentation\/swift\/writing-failable-asynchronous-apis"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/Result/failure(_:)":{"role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"failure"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:s6ResultOsRi_zRi0_zrlE7Failureq_mfp","text":"Failure"},{"kind":"text","text":")"}],"title":"Result.failure(_:)","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Result\/failure(_:)","type":"topic","url":"\/documentation\/swift\/result\/failure(_:)","abstract":[{"type":"text","text":"A failure, storing a "},{"type":"codeVoice","code":"Failure"},{"type":"text","text":" value."}]},"doc://com.apple.Swift/documentation/Swift/Result":{"navigatorTitle":[{"kind":"identifier","text":"Result"}],"title":"Result","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Result"}],"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Result","type":"topic","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"A value that represents either a success or a failure, including an"},{"type":"text","text":" "},{"type":"text","text":"associated value in each case."}],"url":"\/documentation\/swift\/result"},"doc://com.apple.Swift/documentation/Swift/swift-standard-library":{"type":"topic","abstract":[{"text":"Solve complex problems and write high-performance, readable code.","type":"text"}],"title":"Swift Standard Library","role":"collectionGroup","url":"\/documentation\/swift\/swift-standard-library","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","kind":"article"},"doc://com.apple.Swift/documentation/Swift/numbers-and-basic-values":{"kind":"article","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/numbers-and-basic-values","role":"collectionGroup","type":"topic","url":"\/documentation\/swift\/numbers-and-basic-values","abstract":[{"text":"Model data with numbers, Boolean values, and other fundamental types.","type":"text"}],"title":"Numbers and Basic Values"},"doc://com.apple.Swift/documentation/Swift/Result/success(_:)":{"role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"success"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:s6ResultOsRi_zRi0_zrlE7Successxmfp","text":"Success"},{"kind":"text","text":")"}],"title":"Result.success(_:)","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Result\/success(_:)","type":"topic","url":"\/documentation\/swift\/result\/success(_:)","abstract":[{"type":"text","text":"A success, storing a "},{"type":"codeVoice","code":"Success"},{"type":"text","text":" value."}]},"doc://com.apple.Swift/documentation/Swift":{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","url":"\/documentation\/swift","role":"collection","kind":"symbol","abstract":[{"text":"Build apps using a powerful open language.","type":"text"}],"title":"Swift"}}}