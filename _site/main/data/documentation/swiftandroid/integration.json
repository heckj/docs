        },
        {
          "inlineContent" : [
            {
              "text" : "Add a custom Gradle task to invoke ",
              "type" : "text"
            },
            {
              "code" : "swift build",
              "type" : "codeVoice"
            },
            {
              "text" : " and copy the resulting ",
              "type" : "text"
            },
            {
              "code" : ".so",
              "type" : "codeVoice"
            },
            {
              "text" : " into ",
              "type" : "text"
            },
            {
              "code" : "jniLibs\/",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "tasks.register<Exec>(\"buildSwiftLibrary\") {",
            "    workingDir = file(\"${rootDir}\/swift\")",
            "    commandLine(\"swift\", \"build\",",
            "        \"--swift-sdk\", \"aarch64-unknown-linux-android28\",",
            "        \"-c\", \"release\", \"--static-swift-stdlib\")",
            "}"
          ],
          "syntax" : "kotlin",
          "type" : "codeListing"
        },
        {
          "anchor" : "Swift-Package-Manager",
          "level" : 2,
          "text" : "Swift Package Manager",
          "type" : "heading"
        },
        {
          "code" : [
