  },
  "kind" : "article",
  "metadata" : {
    "modules" : [
      {
        "name" : "Swiftly"
      }
    ],
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Getting started with swiftly"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "To get started with swiftly you can download it from ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/swift.org\/download",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ", and extract the package.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "tabs" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "If you are using Linux then you can download the binary:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "curl -L https:\/\/download.swift.org\/swiftly\/linux\/swiftly-$(uname -m).tar.gz > swiftly.tar.gz",
                    "tar zxf swiftly.tar.gz"
                  ],
                  "syntax" : null,
                  "type" : "codeListing"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "Now run swiftly init to finish the installation:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    ".\/swiftly init"
                  ],
                  "syntax" : null,
                  "type" : "codeListing"
                }
              ],
              "title" : "Linux"
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "On macOS you can either run the pkg installer from the command-line like this or run the package by double-clicking on it (not recommended):",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "curl -L https:\/\/download.swift.org\/swiftly\/darwin\/swiftly.pkg > swiftly.pkg",
                    "installer -pkg swiftly.pkg -target CurrentUserHomeDirectory"
                  ],
                  "syntax" : null,
                  "type" : "codeListing"
                },
                {
                  "inlineContent" : [
                    {
                      "text" : "Once the package is installed, run ",
                      "type" : "text"
                    },
                    {
                      "code" : "swiftly init",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " to finish the installation:",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                },
                {
                  "code" : [
                    "~\/.swiftly\/bin\/swiftly init"
                  ],
                  "syntax" : null,
                  "type" : "codeListing"
                }
              ],
              "title" : "macOS"
            }
          ],
          "type" : "tabNavigator"
        },
        {
          "inlineContent" : [
            {
              "text" : "Swiftly installs itself and downloads the latest available Swift toolchain.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Follow the prompts for any additional steps that may be required.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Once everything is done you can begin using swift.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "$ swift --version",
            "",
            "Swift version 6.0.3 (swift-6.0.3-RELEASE)",
            "...",
            "",
            "$ swift build        # Build with the latest (6.0.3) toolchain"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "You can install (and use) another release toolchain:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "$ swiftly install --use 5.10",
            "",
            "$ swift --version",
            "",
            "Swift version 5.10.1 (swift-5.10.1-RELEASE)",
            "...",
            "",
            "$ swift build    # Build with the 5.10.1 toolchain"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Quickly test your package with the latest nightly snapshot to prepare for the next release:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "$ swiftly install main-snapshot",
            "$ swiftly run swift test +main-snapshot   # Run \"swift test\" with the main-snapshot toolchain",
            "$ swift build                             # Continue to build with my usual toolchain"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Uninstall this toolchain after you’re finished with it:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "$ swiftly uninstall main-snapshot"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "anchor" : "Installing-toolchains-through-an-HTTP-proxy",
          "level" : 2,
          "text" : "Installing toolchains through an HTTP proxy",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Swiftly downloads a list of toolchains from https:\/\/www.swift.org\/ and retrieves them from CDN via https:\/\/download.swift.org.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "If your environment requires a proxy, Swiftly attempts to use the standard environment variables ",
              "type" : "text"
            },
            {
              "code" : "http_proxy",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "HTTP_PROXY",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "https_proxy",
              "type" : "codeVoice"
            },
            {
              "text" : " or ",
              "type" : "text"
            },
            {
              "code" : "HTTPS_PROXY",
              "type" : "codeVoice"
            },
            {
              "text" : " to determine which proxy server to use instead of making a direct connection.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "To download latest nightly snapshot using a proxy:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "$ export https_proxy=http:\/\/proxy:3128",
            "$ swiftly install main-snapshot"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
