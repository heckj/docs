  },
  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/SwiftlyDocs\/documentation\/SwiftlyDocs\/update-toolchain"
  },
  "kind" : "article",
  "metadata" : {
    "modules" : [
      {
        "name" : "Swiftly"
      }
    ],
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Update Swift toolchains"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Update replaces a given toolchain with a later version of that toolchain.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "For a stable release, this means updating to a later patch, minor, or major version.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "For snapshots, swiftly helps you stay up-to-date by updating to the most recently available snapshot.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Swiftly only updates toolchains that it installed.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "If no version is provided, update updates the currently selected toolchain to its latest patch release if a release toolchain, or the latest available snapshot if a snapshot.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "The newly installed version is then activated to use.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swiftly update"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "To update the latest installed release version to the latest available release version, use ",
              "type" : "text"
            },
            {
              "code" : "latest",
              "type" : "codeVoice"
            },
            {
              "text" : " as the version.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Note that this may update the toolchain to the next minor or even major version.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swiftly update latest"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If only a major version is specified, the latest installed toolchain with that major version will be updated to the latest available release of that major version:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swiftly update 5"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If the major and minor version are specified, the latest installed toolchain associated with that major\/minor version will be updated to the latest available patch release for that major\/minor version.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swiftly update 5.3"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Similarly, to update the latest snapshot associated with a specific version, append ",
              "type" : "text"
            },
            {
              "code" : "-snapshot",
              "type" : "codeVoice"
            },
            {
              "text" : " to the version. For example, the following command updates to the latest 5.3 snapshot version:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swiftly update 5.3-snapshot"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "You can also update the latest installed main snapshot to the latest available one by providing ",
              "type" : "text"
            },
            {
              "code" : "main-snapshot",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "swiftly update main-snapshot"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Here you have seen how to use swiftly to update your toolchains to the latest, latest of a particular major\/minor release, and even snapshots.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
