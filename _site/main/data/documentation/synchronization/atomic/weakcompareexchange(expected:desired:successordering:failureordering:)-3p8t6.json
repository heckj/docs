operation performs the following algorithm as a single atomic"},{"text":" ","type":"text"},{"type":"text","text":"transaction:"}]},{"type":"codeListing","syntax":"swift","code":["atomic(self) { currentValue in","  let original = currentValue","  guard original == expected else { return (false, original) }","  currentValue = desired","  return (true, original)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ordering"},{"type":"text","text":" argument specifies the memory ordering to use when the"},{"type":"text","text":" "},{"type":"text","text":"operation manages to update the current value, while "},{"type":"codeVoice","code":"failureOrdering"},{"type":"text","text":" "},{"type":"text","text":"will be used when the operation leaves the value intact."}]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"The weakCompareExchange form may sometimes return false even when","type":"text"},{"text":" ","type":"text"},{"text":"the original and expected values are equal. (Such failures may happen","type":"text"},{"text":" ","type":"text"},{"text":"when some transient condition prevents the underlying operation from","type":"text"},{"text":" ","type":"text"},{"text":"succeeding – such as an incoming interrupt during a","type":"text"},{"text":" ","type":"text"},{"text":"load-link/store-conditional instruction sequence.) This variant is","type":"text"},{"text":" ","type":"text"},{"text":"designed to be called in a loop that only exits when the exchange is","type":"text"},{"text":" ","type":"text"},{"text":"successful; in such loops, using weakCompareExchange may lead to a","type":"text"},{"text":" ","type":"text"},{"text":"performance improvement by eliminating a nested loop in the regular,","type":"text"},{"text":" ","type":"text"},{"text":"“strong”, compareExchange variants.","type":"text"}]}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":