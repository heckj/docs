{"abstract":[{"type":"text","text":"Perform an atomic weak compare and exchange operation on the current"},{"type":"text","text":" "},{"type":"text","text":"value, applying the specified success/failure memory orderings. This"},{"type":"text","text":" "},{"type":"text","text":"compare-exchange variant is allowed to spuriously fail; it is designed to"},{"type":"text","text":" "},{"type":"text","text":"be called in a loop until it indicates a successful exchange has happened."}],"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Synchronization","doc://com.apple.Swift/documentation/Synchronization/Atomic"]]},"metadata":{"externalID":"s:15Synchronization6AtomicVA2A19_Atomic16BitStorageV0B14RepresentationRtzrlE19weakCompareExchange8expected7desired15successOrdering07failureM0Sb9exchanged_x8originaltxn_xnAA0b6UpdateM0VAA0b4LoadM0VtF","symbolKind":"method","title":"weakCompareExchange(expected:desired:successOrdering:failureOrdering:)","conformance":{"availabilityPrefix":[{"type":"text","text":"Available when"}],"constraints":[{"type":"codeVoice","code":"Value"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Value.AtomicRepresentation"},{"type":"text","text":" is "},{"type":"codeVoice","code":"_Atomic16BitStorage"},{"type":"text","text":"."}],"conformancePrefix":[{"type":"text","text":"Conforms when"}]},"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"weakCompareExchange","kind":"identifier"},{"text":"(","kind":"text"},{"text":"expected","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"consuming","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Value","preciseIdentifier":"s:15Synchronization6AtomicVA2A19_Atomic16BitStorageV0B14RepresentationRtzrlE5Valuexmfp","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"desired","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"consuming","kind":"keyword"