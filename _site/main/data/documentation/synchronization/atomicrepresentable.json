{"topicSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Synchronization/AtomicRepresentable/AtomicRepresentation"],"title":"Associated Types","anchor":"Associated-Types"},{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Synchronization/AtomicRepresentable/decodeAtomicRepresentation(_:)","doc://com.apple.Swift/documentation/Synchronization/AtomicRepresentable/encodeAtomicRepresentation(_:)"],"title":"Type Methods","anchor":"Type-Methods"}],"identifier":{"url":"doc://com.apple.Swift/documentation/Synchronization/AtomicRepresentable","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc://com.apple.Swift/documentation/Synchronization"]]},"metadata":{"externalID":"s:15Synchronization19AtomicRepresentableP","role":"symbol","roleHeading":"Protocol","modules":[{"name":"Synchronization"}],"title":"AtomicRepresentable","navigatorTitle":[{"text":"AtomicRepresentable","kind":"identifier"}],"symbolKind":"protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AtomicRepresentable","kind":"identifier"}]},"sections":[],"kind":"symbol","relationshipsSections":[{"identifiers":["doc://com.apple.Swift/documentation/Synchronization/AtomicOptionalRepresentable"],"type":"inheritedBy","title":"Inherited By","kind":"relationships"},{"identifiers":["doc://com.apple.Swift/documentation/Swift/Bool","doc://com.apple.Swift/documentation/Swift/Double","doc://com.apple.Swift/documentation/Swift/Duration","doc://com.apple.Swift/documentation/Swift/Float","doc://com.apple.Swift/documentation/Swift/Float16","doc://com.apple.Swift/documentation/Swift/Int","doc://com.apple.Swift/documentation/Swift/Int128","doc://com.apple.Swift/documentation/Swift/Int16","doc://com.apple.Swift/documentation/Swift/Int32","doc://com.apple.Swift/documentation/Swift/Int64","doc://com.apple.Swift/documentation/Swift/Int8","doc://com.apple.Swift/documentation/Swift/Never","doc://com.apple.Swift/documentation/Swift/ObjectIdentifier","doc://com.apple.Swift/documentation/Swift/OpaquePointer","doc://com.apple.Swift/documentation/Swift/Optional","doc://com.apple.Swift/documentation/Swift/UInt","doc://com.apple.Swift/documentation/Swift/UInt128","doc://com.apple.Swift/documentation/Swift/UInt16","doc://com.apple.Swift/documentation/Swift/UInt32","doc://com.apple.Swift/documentation/Swift/UInt64","doc://com.apple.Swift/documentation/Swift/UInt8","doc://com.apple.Swift/documentation/Swift/Unmanaged","doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer","doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer","doc://com.apple.Swift/documentation/Swift/UnsafeMutablePointer","doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawBufferPointer","doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawPointer","doc://com.apple.Swift/documentation/Swift/UnsafePointer","doc://com.apple.Swift/documentation/Swift/UnsafeRawBufferPointer","doc://com.apple.Swift/documentation/Swift/UnsafeRawPointer","doc://com.apple.Swift/documentation/Synchronization/WordPair"],"type":"conformingTypes","title":"Conforming Types","kind":"relationships"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc://com.apple.Swift/documentation/Synchronization/Atomic","doc://com.apple.Swift/documentation/Synchronization/AtomicLazyReference","doc://com.apple.Swift/documentation/Synchronization/WordPair","doc://com.apple.Swift/documentation/Synchronization/AtomicOptionalRepresentable"],"title":"Atomic Values","anchor":"Atomic-Values"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AtomicRepresentable"}]}]},{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"Types that conform to the "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" protocol can be used as the"},{"type":"text","text":" "},{"type":"codeVoice","code":"Value"},{"type":"text","text":" type parameter with the "},{"type":"codeVoice","code":"Atomic"},{"type":"text","text":" type. Conformances that utilize"},{"type":"text","text":" "},{"type":"text","text":"existing atomic storage representations as their own representation will get"},{"type":"text","text":" "},{"type":"text","text":"the primitive atomic operations available on "},{"type":"codeVoice","code":"Atomic"},{"type":"text","text":" for free. Such"},{"type":"text","text":" "},{"type":"text","text":"operations include "},{"type":"codeVoice","code":"load"},{"type":"text","text":", "},{"type":"codeVoice","code":"store"},{"type":"text","text":", "},{"type":"codeVoice","code":"exchange"},{"type":"text","text":", "},{"type":"codeVoice","code":"compareExchange"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"weakCompareExchange"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"text":"Conforming to the AtomicRepresentable protocol","type":"heading","anchor":"Conforming-to-the-AtomicRepresentable-protocol"},{"inlineContent":[{"type":"text","text":"Conforming your own custom types allow them to be used in the "},{"type":"codeVoice","code":"Atomic"},{"type":"text","text":" type"},{"type":"text","text":" "},{"type":"text","text":"and get access to all of the primitive atomic operations explained above."},{"type":"text","text":" "},{"type":"text","text":"There are two main ways to conform your type to "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Using a predefined "},{"type":"codeVoice","code":"RawRepresentable"},{"type":"text","text":" conformance"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Manually conforming to "},{"type":"codeVoice","code":"AtomicRepresentable"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"If you custom type already conforms to "},{"type":"codeVoice","code":"RawRepresentable"},{"type":"text","text":", then adding the"},{"type":"text","text":" "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" conformance may be really simple! If the "},{"type":"codeVoice","code":"RawValue"},{"type":"text","text":" "},{"type":"text","text":"associated type of your type is already itself an "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"then all you need to do is add the conformance and you’re done!"}],"type":"paragraph"},{"type":"codeListing","code":["enum TrafficLight: UInt8 {","  case red","  case yellow","  case green","}","","extension TrafficLight: AtomicRepresentable {}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"And that’s it! Here, we’re utilizing Swift’s automatic "},{"type":"codeVoice","code":"RawRepresentable"},{"type":"text","text":" "},{"type":"text","text":"conformance synthesis for enums by declaring our “raw value” to be a"},{"type":"text","text":" "},{"type":"codeVoice","code":"UInt8"},{"type":"text","text":". By adding the "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" conformance, we automatically"},{"type":"text","text":" "},{"type":"text","text":"figure out how to do the conformance from the "},{"type":"codeVoice","code":"RawRepresentable"},{"type":"text","text":" "},{"type":"text","text":"implementation and do all of the necessary work for you. However, it is still"},{"type":"text","text":" "},{"type":"text","text":"possible to customize this behavior using the manual method explained below."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Defining your own "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" conformance is pretty simple. All"},{"type":"text","text":" "},{"type":"text","text":"you have to do is decide what atomic storage representation fits best for"},{"type":"text","text":" "},{"type":"text","text":"your type, and create the bidirectional relationship between the two."}],"type":"paragraph"},{"type":"codeListing","code":["// A point in an x-y coordinate system.","struct GridPoint {","  var x: Int","  var y: Int","}","","extension GridPoint: AtomicRepresentable {","  typealias AtomicRepresentation = WordPair.AtomicRepresentation","","  static func encodeAtomicRepresentation(","    _ value: consuming GridPoint","  ) -> AtomicRepresentation {","    let wordPair = WordPair(","      first: UInt(bitPattern: value.x),","      second: UInt(bitPattern: value.y)","    )","","    return WordPair.encodeAtomicRepresentation(wordPair)","  }","","  static func decodeAtomicRepresentation(","    _ representation: consuming AtomicRepresentation","  ) -> GridPoint {","    let wordPair = WordPair.decodeAtomicRepresentation(representation)","","    return GridPoint(","      x: Int(bitPattern: wordPair.first),","      y: Int(bitPattern: wordPair.second)","    )","  }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Here, we’re going to select "},{"type":"codeVoice","code":"WordPair"},{"type":"text","text":"’s atomic storage representation as"},{"type":"text","text":" "},{"type":"text","text":"our own. This is very important because we only get the atomic operations"},{"type":"text","text":" "},{"type":"text","text":"like "},{"type":"codeVoice","code":"load"},{"type":"text","text":" and "},{"type":"codeVoice","code":"store"},{"type":"text","text":" if our representation is one of the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"fundamental"}]},{"type":"text","text":" "},{"type":"text","text":"storage representations. Luckily for us, "},{"type":"codeVoice","code":"WordPair"},{"type":"text","text":" does use one of these"},{"type":"text","text":" "},{"type":"text","text":"types as its storage type."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In addition to selecting what storage representation our type will use, we"},{"type":"text","text":" "},{"type":"text","text":"define two static functions that go from both our custom type to its"},{"type":"text","text":" "},{"type":"text","text":"representation and the representation back to our own type. Because our"},{"type":"text","text":" "},{"type":"text","text":"representation is the same as "},{"type":"codeVoice","code":"WordPair.AtomicRepresentation"},{"type":"text","text":", we will"},{"type":"text","text":" "},{"type":"text","text":"actually go through "},{"type":"codeVoice","code":"WordPair"},{"type":"text","text":"’s "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" conformance to help"},{"type":"text","text":" "},{"type":"text","text":"define our own."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This is all you need to do to conform your custom type to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" protocol. From here, you can use this type in all of"},{"type":"text","text":" "},{"type":"text","text":"the primitive atomic operations like shown below:"}],"type":"paragraph"},{"type":"codeListing","code":["func atomicGridPoint(_ gridPoint: Atomic<GridPoint>) {","  let newGridPoint = GridPoint(x: 123, y: -456)","","  let oldGridPoint1 = gridPoint.load(ordering: .relaxed)","","  gridPoint.store(newGridPoint, ordering: .releasing)","","  let oldGridPoint2 = gridPoint.exchange(","    desired: oldGridPoint1,","    ordering: .acquiringAndReleasing","  )","","  let (exchanged1, oldGridPoint2) = gridPoint.compareExchange(","    expected: oldGridPoint1,","    desired: newGridPoint,","    ordering: .sequentiallyConsistent","  )","","  let (exchanged2, oldGridPoint3) = gridPoint.weakCompareExchange(","    expected: newGridPoint,","    desired: oldGridPoint2,","    ordering: .relaxed","  )","}"],"syntax":"swift"},{"level":2,"text":"List of Fundamental Atomic Representations","type":"heading","anchor":"List-of-Fundamental-Atomic-Representations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When defining your own "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":" conformance, it is critical"},{"type":"text","text":" "},{"type":"text","text":"that your custom type should choose from the following list of types as its"},{"type":"text","text":" "},{"type":"text","text":"own "},{"type":"codeVoice","code":"AtomicRepresentation"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UInt8.AtomicRepresentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UInt16.AtomicRepresentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UInt32.AtomicRepresentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UInt64.AtomicRepresentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UInt.AtomicRepresentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Int8.AtomicRepresentation"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int16.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int32.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int64.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"WordPair.AtomicRepresentation"}]}]}]},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":""},{"code":"Int8.AtomicRepresentation","type":"codeVoice"},{"type":"text","text":" is the same type as"},{"type":"text","text":" "},{"type":"codeVoice","code":"UInt8.AtomicRepresentation"},{"type":"text","text":" and the same is true for all of the same"},{"type":"text","text":" "},{"type":"text","text":"sized integer types. If your type wraps an unsigned integer, you should"},{"type":"text","text":" "},{"type":"text","text":"prefer to use an unsigned integer’s atomic representation instead of a"},{"type":"text","text":" "},{"type":"text","text":"signed ones and vice versa. "},{"type":"codeVoice","code":"Int"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"UInt"},{"text":"’s representation will be","type":"text"},{"type":"text","text":" "},{"text":"64 bits wide on 64 bit systems and 32 bit wide on 32 bit systems. ","type":"text"},{"type":"codeVoice","code":"Int64"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"type":"codeVoice","code":"UInt64"},{"text":" always conform to ","type":"text"},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" on 64 bit systems,"},{"type":"text","text":" "},{"type":"text","text":"but on 32 bit systems they will only conform if the platform supports"},{"type":"text","text":" "},{"type":"text","text":"double wide atomics. "},{"type":"codeVoice","code":"WordPair"},{"text":" will only conform to ","type":"text"},{"type":"codeVoice","code":"AtomicRepresentable"},{"text":" ","type":"text"},{"text":"on platforms that support double wide atomics, but if they do it will be","type":"text"},{"text":" ","type":"text"},{"text":"128 bits wide on 64 bit systems and 64 bits wide on 32 bit systems.","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"paths":["/documentation/synchronization/atomicrepresentable"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"A type that supports atomic operations through a separate atomic storage","type":"text"},{"text":" ","type":"text"},{"text":"representation.","type":"text"}],"references":{"doc://com.ap