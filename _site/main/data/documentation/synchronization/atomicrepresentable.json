m.apple.Swift/documentation/Swift/Duration","doc://com.apple.Swift/documentation/Swift/Float","doc://com.apple.Swift/documentation/Swift/Float16","doc://com.apple.Swift/documentation/Swift/Int","doc://com.apple.Swift/documentation/Swift/Int128","doc://com.apple.Swift/documentation/Swift/Int16","doc://com.apple.Swift/documentation/Swift/Int32","doc://com.apple.Swift/documentation/Swift/Int64","doc://com.apple.Swift/documentation/Swift/Int8","doc://com.apple.Swift/documentation/Swift/Never","doc://com.apple.Swift/documentation/Swift/ObjectIdentifier","doc://com.apple.Swift/documentation/Swift/OpaquePointer","doc://com.apple.Swift/documentation/Swift/Optional","doc://com.apple.Swift/documentation/Swift/UInt","doc://com.apple.Swift/documentation/Swift/UInt128","doc://com.apple.Swift/documentation/Swift/UInt16","doc://com.apple.Swift/documentation/Swift/UInt32","doc://com.apple.Swift/documentation/Swift/UInt64","doc://com.apple.Swift/documentation/Swift/UInt8","doc://com.apple.Swift/documentation/Swift/Unmanaged","doc://com.apple.Swift/documentation/Swift/UnsafeBufferPointer","doc://com.apple.Swift/documentation/Swift/UnsafeMutableBufferPointer","doc://com.apple.Swift/documentation/Swift/UnsafeMutablePointer","doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawBufferPointer","doc://com.apple.Swift/documentation/Swift/UnsafeMutableRawPointer","doc://com.apple.Swift/documentation/Swift/UnsafePointer","doc://com.apple.Swift/documentation/Swift/UnsafeRawBufferPointer","doc://com.apple.Swift/documentation/Swift/UnsafeRawPointer","doc://com.apple.Swift/documentation/Synchronization/WordPair"],"title":"Conforming Types"}],"abstract":[{"text":"A type that supports atomic operations through a separate atomic storage","type":"text"},{"text":" ","type":"text"},{"text":"representation.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AtomicRepresentable"}],"languages":["swift"]}]},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Types that conform to the "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" protocol can be used as the"},{"type":"text","text":" "},{"code":"Value","type":"codeVoice"},{"text":" type parameter with the ","type":"text"},{"code":"Atomic","type":"codeVoice"},{"text":" type. Conformances that utilize","type":"text"},{"text":" ","type":"text"},{"text":"existing atomic storage representations as their own representation will get","type":"text"},{"text":" ","type":"text"},{"text":"the primitive atomic operations available on ","type":"text"},{"code":"Atomic","type":"codeVoice"},{"text":" for free. Such","type":"text"},{"text":" ","type":"text"},{"text":"operations include ","type":"text"},{"code":"load","type":"codeVoice"},{"text":", ","type":"text"},{"code":"store","type":"codeVoice"},{"text":", ","type":"text"},{"code":"exchange","type":"codeVoice"},{"text":", ","type":"text"},{"code":"compareExchange","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"weakCompareExchange","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Conforming to the AtomicRepresentable protocol","anchor":"Conforming-to-the-AtomicRepresentable-protocol","type":"heading","level":2},{"inlineContent":[{"text":"Conforming your own custom types allow them to be used in the ","type":"text"},{"type":"codeVoice","code":"Atomic"},{"text":" type","type":"text"},{"text":" ","type":"text"},{"text":"and get access to all of the primitive atomic operations explained above.","type":"text"},{"text":" ","type":"text"},{"text":"There are two main ways to conform your type to ","type":"text"},{"type":"codeVoice","code":"AtomicRepresentable"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Using a predefined "},{"type":"codeVoice","code":"RawRepresentable"},{"type":"text","text":" conformance"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Manually conforming to "},{"code":"AtomicRepresentable","type":"codeVoice"}]}]}]},{"inlineContent":[{"text":"If you custom type already conforms to ","type":"text"},{"type":"codeVoice","code":"RawRepresentable"},{"text":", then adding the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"AtomicRepresentable"},{"text":" conformance may be really simple! If the ","type":"text"},{"type":"codeVoice","code":"RawValue"},{"text":" ","type":"text"},{"text":"associated type of your type is already itself an ","type":"text"},{"type":"codeVoice","code":"AtomicRepresentable"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"then all you need to do is add the conformance and you’re done!","type":"text"}],"type":"paragraph"},{"code":["enum TrafficLight: UInt8 {","  case red","  case yellow","  case green","}","","extension TrafficLight: AtomicRepresentable {}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"And that’s it! Here, we’re utilizing Swift’s automatic ","type":"text"},{"type":"codeVoice","code":"RawRepresentable"},{"text":" ","type":"text"},{"text":"conformance synthesis for enums by declaring our “raw value” to be a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"UInt8"},{"text":". By adding the ","type":"text"},{"type":"codeVoice","code":"AtomicRepresentable"},{"text":" conformance, we automatically","type":"text"},{"text":" ","type":"text"},{"text":"figure out how to do the conformance from the ","type":"text"},{"type":"codeVoice","code":"RawRepresentable"},{"text":" ","type":"text"},{"text":"implementation and do all of the necessary work for you. However, it is still","type":"text"},{"text":" ","type":"text"},{"text":"possible to customize this behavior using the manual method explained below.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Defining your own "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" conformance is pretty simple. All"},{"type":"text","text":" "},{"type":"text","text":"you have to do is decide what atomic storage representation fits best for"},{"type":"text","text":" "},{"type":"text","text":"your type, and create the bidirectional relationship between the two."}]},{"type":"codeListing","syntax":"swift","code":["// A point in an x-y coordinate system.","struct GridPoint {","  var x: Int","  var y: Int","}","","extension GridPoint: AtomicRepresentable {","  typealias AtomicRepresentation = WordPair.AtomicRepresentation","","  static func encodeAtomicRepresentation(","    _ value: consuming GridPoint","  ) -> AtomicRepresentation {","    let wordPair = WordPair(","      first: UInt(bitPattern: value.x),","      second: UInt(bitPattern: value.y)","    )","","    return WordPair.encodeAtomicRepresentation(wordPair)","  }","","  static func decodeAtomicRepresentation(","    _ representation: consuming AtomicRepresentation","  ) -> GridPoint {","    let wordPair = WordPair.decodeAtomicRepresentation(representation)","","    return GridPoint(","      x: Int(bitPattern: wordPair.first),","      y: Int(bitPattern: wordPair.second)","    )","  }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here, we’re going to select "},{"type":"codeVoice","code":"WordPair"},{"type":"text","text":"’s atomic storage representation as"},{"type":"text","text":" "},{"type":"text","text":"our own. This is very important because we only get the atomic operations"},{"type":"text","text":" "},{"type":"text","text":"like "},{"type":"codeVoice","code":"load"},{"type":"text","text":" and "},{"type":"codeVoice","code":"store"},{"type":"text","text":" if our representation is one of the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"fundamental"}]},{"type":"text","text":" "},{"type":"text","text":"storage representations. Luckily for us, "},{"type":"codeVoice","code":"WordPair"},{"type":"text","text":" does use one of these"},{"type":"text","text":" "},{"type":"text","text":"types as its storage type."}]},{"type":"paragraph","inlineContent":[{"text":"In addition to selecting what storage representation our type will use, we","type":"text"},{"text":" ","type":"text"},{"text":"define two static functions that go from both our custom type to its","type":"text"},{"text":" ","type":"text"},{"text":"representation and the representation back to our own type. Because our","type":"text"},{"text":" ","type":"text"},{"text":"representation is the same as ","type":"text"},{"code":"WordPair.AtomicRepresentation","type":"codeVoice"},{"text":", we will","type":"text"},{"text":" ","type":"text"},{"text":"actually go through ","type":"text"},{"code":"WordPair","type":"codeVoice"},{"text":"’s ","type":"text"},{"code":"AtomicRepresentable","type":"codeVoice"},{"text":" conformance to help","type":"text"},{"text":" ","type":"text"},{"text":"define our own.","type":"text"}]},{"inlineContent":[{"text":"This is all you need to do to conform your custom type to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"AtomicRepresentable"},{"text":" protocol. From here, you can use this type in all of","type":"text"},{"text":" ","type":"text"},{"text":"the primitive atomic operations like shown below:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func atomicGridPoint(_ gridPoint: Atomic<GridPoint>) {","  let newGridPoint = GridPoint(x: 123, y: -456)","","  let oldGridPoint1 = gridPoint.load(ordering: .relaxed)","","  gridPoint.store(newGridPoint, ordering: .releasing)","","  let oldGridPoint2 = gridPoint.exchange(","    desired: oldGridPoint1,","    ordering: .acquiringAndReleasing","  )","","  let (exchanged1, oldGridPoint2) = gridPoint.compareExchange(","    expected: oldGridPoint1,","    desired: newGridPoint,","    ordering: .sequentiallyConsistent","  )","","  let (exchanged2, oldGridPoint3) = gridPoint.weakCompareExchange(","    expected: newGridPoint,","    desired: oldGridPoint2,","    ordering: .relaxed","  )","}"]},{"text":"List of Fundamental Atomic Representations","type":"heading","anchor":"List-of-Fundamental-Atomic-Representations","level":2},{"inlineContent":[{"type":"text","text":"When defining your own "},{"code":"AtomicRepresentable","type":"codeVoice"},{"text":" conformance, it is critical","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that your custom type should choose from the following list of types as its"},{"type":"text","text":" "},{"text":"own ","type":"text"},{"type":"codeVoice","code":"AtomicRepresentation"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UInt8.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UInt16.AtomicRepresentation","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"code":"UInt32.AtomicRepresentation","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UInt64.AtomicRepresentation","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UInt.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Int8.AtomicRepresentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Int16.AtomicRepresentation","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int32.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Int64.AtomicRepresentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Int.AtomicRepresentation","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"WordPair.AtomicRepresentation"}]}]}],"type":"unorderedList"},{"name":"Note","type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"Int8.AtomicRepresentation"},{"type":"text","text":" is the same type as"},{"type":"text","text":" "},{"code":"UInt8.AtomicRepresentation","type":"codeVoice"},{"text":" and the same is true for all of the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"sized integer types. If your type wraps an unsigned integer, you should"},{"type":"text","text":" "},{"type":"text","text":"prefer to use an unsigned integer’s atomic representation instead of a"},{"type":"text","text":" "},{"text":"signed ones and vice versa. ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"UInt"},{"text":"’s representation will be","type":"text"},{"text":" ","type":"text"},{"text":"64 bits wide on 64 bit systems and 32 bit wide on 32 bit systems. ","type":"text"},{"code":"Int64","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"and "},{"type":"codeVoice","code":"UInt64"},{"type":"text","text":" always conform to "},{"type":"codeVoice","code":"AtomicRepresentable"},{"type":"text","text":" on 64 bit systems,"},{"type":"text","text":" "},{"type":"text","text":"but on 32 bit systems they will only conform if the platform supports"},{"text":" ","type":"text"},{"text":"double wide atomics. ","type":"text"},{"type":"codeVoice","code":"WordPair"},{"text":" will only conform to ","type":"text"},{"code":"AtomicRepresentable","type":"codeVoice"},{"text":" ","type":"text"},{"text":"on platforms that support double wide atomics, but if they do it will be","type":"text"},{"text":" ","type":"text"},{"text":"128 bits wide on 64 bit systems and 64 bits wide on 32 bit systems.","type":"text"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.apple.Swift/documentation/Swift/UnsafeRawBufferPointer":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnsafeRawBufferPointer","kind":"identifier"}],"abstract":[{"type":"text","text":"A  nonowning collection interface to the bytes in a"},{"type":"text","text":" "},{"type":"text","text":"region of memory."}],"role":"symbol","identifier":"doc://com.apple.Swift/documentation/Swift/UnsafeRawBufferPointer","type":"topic","kind":"symbol","title":"UnsafeRawBufferPointer","navigatorTitle":[{"text":"UnsafeRawBufferPointer","kind":"identifier"}],"url":"/documentation/swift/unsaferawbufferpointer"},"doc://com.apple.Swift/documentation/Synchronization/AtomicRepresentable/encodeAtomicRepresentation(_:)":{"required":true,"url":"/documentation/synchronization/atomicrepresentable/encodeatomicrepresentation(_:)","role":"symbol","title":"encodeAtomicRepresentation(_:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"encodeAtomicRepresentation","kind":"identifier"},{"text":"(","kind":"text"},{"text":"consuming","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"AtomicRepresentation","kind":"typeIdentifier","preciseIdentifier":"s:15Synchronization19AtomicRepresentableP0B14RepresentationQa"}],"type":"topic","kind":"symbol","identifier":"doc://com.apple.Swift/documentation/Synchronization/AtomicRepresentable/encodeAtomicRepresentation(_:)","abstract":[{"text":"Destroys a value of ","type":"text"},{"type":"codeVoice","code":"Self"},{"text":" and prepares an ","type":"text"},{"type":"codeVoice","code":"AtomicRepresentation"},{"text":" storage","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type to be used for atomic operations."}]},"doc://com.apple.Swift/documentation/Synchronization/AtomicRepresentable/decodeAtomicRepresentation(_:)":{"role":"symbol","title":"decodeAto