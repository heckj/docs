    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "When you attach an image to a test, you can pass an instance of this type to",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/org.swift.testing\/documentation\/Testing\/Attachment\/record(_:named:as:sourceLocation:)",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " so that the testing",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "library knows the image format you’d like to use. If you don’t pass an",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "instance of this type, the testing library infers which format to use based",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "on the attachment’s preferred name.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The testing library always supports the PNG and JPEG image formats. The set",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "of additional supported image formats is platform-specific:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "On Apple platforms, you can use ",
                      "type" : "text"
                    },
                    {
                      "identifier" : "https:\/\/developer.apple.com\/documentation\/imageio\/cgimagedestinationcopytypeidentifiers()",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "from the ",
                      "type" : "text"
                    },
                    {
                      "identifier" : "https:\/\/developer.apple.com\/documentation\/imageio",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "to determine which formats are supported.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "On Windows, you can use ",
                      "type" : "text"
                    },
                    {
                      "identifier" : "https:\/\/learn.microsoft.com\/en-us\/windows\/win32\/api\/wincodec\/nf-wincodec-iwicimagingfactory-createcomponentenumerator",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : " ",
                      "type" : "text"
                    },
                    {
                      "text" : "to enumerate the available image encoders.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        }
      ],
      "kind" : "content"
    }
