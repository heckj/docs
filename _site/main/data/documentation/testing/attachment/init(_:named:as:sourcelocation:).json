            },
            {
              "text" : "pass ",
              "type" : "text"
            },
            {
              "code" : "nil",
              "type" : "codeVoice"
            },
            {
              "text" : ", then the image format that the testing library uses depends on",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "the path extension you specify in ",
              "type" : "text"
            },
            {
              "code" : "preferredName",
              "type" : "codeVoice"
            },
            {
              "text" : ", if any. If you do not",
