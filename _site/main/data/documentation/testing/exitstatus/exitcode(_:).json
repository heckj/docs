        },
        {
          "inlineContent" : [
            {
              "text" : "The C programming language defines two standard exit codes, ",
              "type" : "text"
            },
            {
              "code" : "EXIT_SUCCESS",
              "type" : "codeVoice"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "and ",
              "type" : "text"
            },
            {
              "code" : "EXIT_FAILURE",
              "type" : "codeVoice"
            },
            {
              "text" : ". Platforms may additionally define their own",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "non-standard exit codes:",
              "type" : "text"
