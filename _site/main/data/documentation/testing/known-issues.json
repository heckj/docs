    "title" : "Known issues"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "Overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The testing library provides several functions named ",
              "type" : "text"
            },
            {
              "code" : "withKnownIssue()",
              "type" : "codeVoice"
            },
            {
              "text" : " that",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "you can use to mark issues as known. Use them to inform the testing library that",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "a test should not be marked as failing if only known issues are recorded.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Mark-an-expectation-failure-as-known",
          "level" : 3,
          "text" : "Mark an expectation failure as known",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Consider a test function with a single expectation:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Test func grillHeating() throws {",
            "  var foodTruck = FoodTruck()",
            "  try foodTruck.startGrill()",
            "  #expect(foodTruck.grill.isHeating) \/\/ ❌ Expectation failed",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If the value of the ",
              "type" : "text"
            },
            {
              "code" : "isHeating",
              "type" : "codeVoice"
            },
            {
              "text" : " property is ",
              "type" : "text"
            },
            {
              "code" : "false",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "#expect",
              "type" : "codeVoice"
            },
            {
              "text" : " will record an",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "issue. If you cannot fix the underlying problem, you can surround the failing",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "code in a closure passed to ",
              "type" : "text"
            },
            {
              "code" : "withKnownIssue()",
              "type" : "codeVoice"
            },
            {
              "text" : ":",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Test func grillHeating() throws {",
            "  var foodTruck = FoodTruck()",
            "  try foodTruck.startGrill()",
            "  withKnownIssue(\"Propane tank is empty\") {",
            "    #expect(foodTruck.grill.isHeating) \/\/ Known issue",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "The issue recorded by ",
              "type" : "text"
            },
            {
              "code" : "#expect",
              "type" : "codeVoice"
            },
            {
              "text" : " will then be considered “known” and the test",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "will not be marked as a failure. You may include an optional comment to explain",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "the problem or provide context.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Mark-a-thrown-error-as-known",
          "level" : 3,
          "text" : "Mark a thrown error as known",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "If an ",
              "type" : "text"
            },
            {
              "code" : "Error",
              "type" : "codeVoice"
            },
            {
              "text" : " is caught by the closure passed to ",
              "type" : "text"
            },
            {
              "code" : "withKnownIssue()",
              "type" : "codeVoice"
            },
            {
              "text" : ", the issue",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "representing that caught error will be marked as known. Continuing the previous",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "example, suppose the problem is that the ",
              "type" : "text"
            },
            {
              "code" : "startGrill()",
              "type" : "codeVoice"
            },
            {
              "text" : " function is throwing an",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "error. You can apply ",
              "type" : "text"
            },
            {
              "code" : "withKnownIssue()",
              "type" : "codeVoice"
            },
            {
              "text" : " to this situation as well:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Test func grillHeating() {",
            "  var foodTruck = FoodTruck()",
            "  withKnownIssue {",
            "    try foodTruck.startGrill() \/\/ Known issue",
            "    #expect(foodTruck.grill.isHeating)",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Because all errors thrown from the closure are caught and interpreted as known",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "issues, the ",
              "type" : "text"
            },
            {
              "code" : "withKnownIssue()",
              "type" : "codeVoice"
            },
            {
              "text" : " function is not throwing. Consequently, any",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "subsequent code which depends on the throwing call having succeeded (such as the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "#expect",
              "type" : "codeVoice"
            },
            {
              "text" : " after ",
              "type" : "text"
            },
            {
              "code" : "startGrill()",
              "type" : "codeVoice"
            },
            {
              "text" : ") must be included in the closure to avoid",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "additional issues.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "",
                  "type" : "text"
                },
                {
                  "code" : "withKnownIssue()",
                  "type" : "codeVoice"
                },
                {
                  "text" : " is recommended instead of ",
                  "type" : "text"
                },
                {
                  "code" : "#expect(throws:)",
                  "type" : "codeVoice"
                },
                {
                  "text" : " for any",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "error which is considered a known issue so that the test status and results",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "will reflect the situation more accurately.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Note",
          "style" : "note",
          "type" : "aside"
        },
        {
          "anchor" : "Match-a-specific-issue",
          "level" : 3,
          "text" : "Match a specific issue",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "By default, ",
              "type" : "text"
            },
            {
              "code" : "withKnownIssue()",
              "type" : "codeVoice"
            },
            {
              "text" : " considers all issues recorded while invoking the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "body closure known. If multiple issues may be recorded, you can pass a trailing",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "closure labeled ",
              "type" : "text"
            },
            {
              "code" : "matching:",
              "type" : "codeVoice"
            },
            {
              "text" : " which will be called once for each recorded issue",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "to determine whether it should be treated as known:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Test func batteryLevel() throws {",
            "  var foodTruck = FoodTruck()",
            "  try withKnownIssue {",
            "    let batteryLevel = try #require(foodTruck.batteryLevel) \/\/ Known",
            "    #expect(batteryLevel >= 0.8) \/\/ Not considered known",
            "  } matching: { issue in",
            "    guard case .expectationFailed(let expectation) = issue.kind else {",
            "      return false",
            "    }",
            "    return expectation.isRequired",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "anchor" : "Resolve-a-known-issue",
          "level" : 3,
          "text" : "Resolve a known issue",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "If there are no issues recorded while calling ",
              "type" : "text"
            },
            {
              "code" : "function",
              "type" : "codeVoice"
            },
            {
              "text" : ", ",
              "type" : "text"
            },
            {
              "code" : "withKnownIssue()",
              "type" : "codeVoice"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "will record a distinct issue about the lack of any issues having been recorded.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "This notifies you that the underlying problem may have been resolved so that you",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "can investigate and consider removing ",
              "type" : "text"
            },
            {
              "code" : "withKnownIssue()",
              "type" : "codeVoice"
            },
            {
              "text" : " if it’s no longer",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "necessary.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Handle-a-nondeterministic-failure",
          "level" : 3,
          "text" : "Handle a nondeterministic failure",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "If ",
              "type" : "text"
            },
            {
              "code" : "withKnownIssue()",
              "type" : "codeVoice"
            },
            {
              "text" : " sometimes succeeds but other times records an issue",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "indicating there were no known issues, this may indicate a nondeterministic",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "failure or a “flaky” test.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The first step in resolving a nondeterministic test failure is to analyze the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "code being tested and determine the source of the unpredictable behavior. If",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "you discover a bug such as a race condition, the ideal resolution is to fix",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "the underlying problem so that the code always behaves consistently even if",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "it continues to exhibit the known issue.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "If the underlying problem only occurs in certain circumstances, consider",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "including a precondition. For example, if the grill only fails to heat when",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "there’s no propane, you can pass a trailing closure labeled ",
              "type" : "text"
            },
            {
              "code" : "when:",
              "type" : "codeVoice"
            },
            {
              "text" : " which",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "determines whether issues recorded in the body closure should be considered",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "known:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Test func grillHeating() throws {",
            "  var foodTruck = FoodTruck()",
            "  try foodTruck.startGrill()",
            "  withKnownIssue {",
            "    \/\/ Only considered known when hasPropane == false",
            "    #expect(foodTruck.grill.isHeating)",
            "  } when: {",
            "    !hasPropane",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "If the underlying problem is unpredictable and fails at random, you can pass",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "isIntermittent: true",
              "type" : "codeVoice"
            },
            {
              "text" : " to let the testing library know that it will not always",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "occur. Then, the testing library will not record an issue when zero known issues",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "are recorded:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "@Test func grillHeating() throws {",
            "  var foodTruck = FoodTruck()",
            "  try foodTruck.startGrill()",
            "  withKnownIssue(isIntermittent: true) {",
            "    #expect(foodTruck.grill.isHeating)",
            "  }",
            "}"
          ],
          "syntax" : "swift",
          "type" : "codeListing"
        }
      ],
      "kind" : "content"
    }
