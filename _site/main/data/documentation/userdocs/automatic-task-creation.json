{
  "abstract" : [
    {
      "text" : "Add tasks for common operations with your Package.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/userdocs\/documentation\/userdocs"
      ]
    ]
  },
  "identifier" : {
    "interfaceLanguage" : "swift",
    "url" : "doc:\/\/userdocs\/documentation\/userdocs\/automatic-task-creation"
  },
  "kind" : "article",
  "metadata" : {
    "role" : "article",
    "roleHeading" : "Article",
    "title" : "Automatic Task Creation"
  },
  "primaryContentSections" : [
    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "For workspaces that contain a ",
              "type" : "text"
            },
            {
              "code" : "Package.swift",
              "type" : "codeVoice"
            },
            {
              "text" : " file, the Swift extension adds the following tasks:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "text" : "Build All",
                          "type" : "text"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : ": Build all targets in the Package.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "text" : "Build Debug <Executable>",
                          "type" : "text"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : ": Each executable product in a Package.swift get a task for building a debug build.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "text" : "Build Release <Executable>",
                          "type" : "text"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : ": Each executable product in a Package.swift get a task for building a release build.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Tasks use workflows common to all VS Code extensions. For more information see ",
                  "type" : "text"
                },
                {
                  "identifier" : "https:\/\/code.visualstudio.com\/docs\/editor\/tasks",
                  "isActive" : true,
                  "type" : "reference"
                },
                {
                  "text" : ".",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "💡 Tip",
          "style" : "note",
          "type" : "aside"
        },
        {
          "inlineContent" : [
            {
              "text" : "These tasks are available via the commands ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "Terminal ▸ Run Task…",
                  "type" : "text"
                }
              ],
              "type" : "strong"
            },
            {
              "text" : " and ",
              "type" : "text"
            },
            {
              "inlineContent" : [
                {
                  "text" : "Terminal ▸ Run Build Task…",
                  "type" : "text"
                }
              ],
              "type" : "strong"
            },
            {
              "text" : " in the command palette.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Create-tasks-for-library-targets",
          "level" : 2,
          "text" : "Create tasks for library targets",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "By default build tasks are only automatically created for executable products. If you set the ",
              "type" : "text"
            },
            {
              "code" : "swift.createTasksForLibraryProducts",
              "type" : "codeVoice"
            },
            {
              "text" : " setting to true, then additional tasks will be created:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "text" : "Build Debug <Library>",
                          "type" : "text"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : ": Each library product in a Package.swift get a task for building a debug build.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "text" : "Build Release <Library>",
                          "type" : "text"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : ": Each library product in a Package.swift get a task for building a release build.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Tasks will not be created for automatic library products, as you cannot specify a ",
                  "type" : "text"
                },
                {
                  "code" : "--product",
                  "type" : "codeVoice"
                },
                {
                  "text" : " option for automatic products when building. For more information see the ",
                  "type" : "text"
                },
                {
                  "identifier" : "https:\/\/docs.swift.org\/package-manager\/PackageDescription\/PackageDescription.html#product",
                  "isActive" : true,
                  "type" : "reference"
                },
                {
                  "text" : ".",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "⚠️ Important",
          "style" : "note",
          "type" : "aside"
        }
      ],
      "kind" : "content"
    }
  ],
