        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "code" : "Create New Project...",
                          "type" : "codeVoice"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : " - Create a new Swift project using a template. This opens a dialog to guide you through creating a new project structure.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "code" : "Create New Swift File...",
                          "type" : "codeVoice"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : " - Create a new ",
                      "type" : "text"
                    },
                    {
                      "code" : ".swift",
                      "type" : "codeVoice"
                    },
                    {
                      "text" : " file in the current workspace.",
                      "type" : "text"
