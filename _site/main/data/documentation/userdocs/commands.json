              "content" : [
                {
                  "inlineContent" : [
                    {
                      "inlineContent" : [
                        {
                          "code" : "Install Swiftly Toolchain...",
                          "type" : "codeVoice"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : " - Install a Swift toolchain using Swiftly. Shows a list of available stable Swift releases that can be downloaded and installed. Requires Swiftly to be installed first.",
                      "type" : "text"
                    }
