          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The Swift toolchain provides DocC, which compiles documentation for your Swift package. You can distribute compiled documentation to developers, or host the content. It’s what this project used to make its documentation! You can learn more about DocC by reading ",
              "type" : "text"
            },
            {
              "identifier" : "https:\/\/www.swift.org\/documentation\/docc\/",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "View a side-by-side live preview of your documentation as you edit it with the Swift extension for VS Code.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Access this feature using the Preview Swift Documentation button at the top right of an editor, or by invoking ",
              "type" : "text"
            },
            {
              "code" : "Swift: Preview Documentation",
              "type" : "codeVoice"
            },
            {
              "text" : " in the command palette.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "This opens up a new editor pane with your rendered documentation:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "identifier" : "docc-live-preview.gif",
              "type" : "image"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "This feature is only available when using a Swift toolchain 6.2 or higher running on macOS or Linux.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Note",
          "style" : "note",
          "type" : "aside"
        }
