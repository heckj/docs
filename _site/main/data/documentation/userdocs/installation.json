          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The Swift extension is supported on macOS, Linux, and Windows. To set it up:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Install Swift from the ",
                      "type" : "text"
                    },
                    {
                      "identifier" : "https:\/\/www.swift.org\/install",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : ".",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Install ",
                      "type" : "text"
                    },
                    {
                      "identifier" : "https:\/\/code.visualstudio.com\/Download",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : ".",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Install the Swift extension from the ",
                      "type" : "text"
                    },
                    {
                      "identifier" : "https:\/\/marketplace.visualstudio.com\/items?itemName=swiftlang.swift-vscode",
                      "isActive" : true,
                      "type" : "reference"
                    },
                    {
                      "text" : ".",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "orderedList"
        },
        {
          "inlineContent" : [
            {
              "text" : "Once your machine is ready, you can start writing Swift code:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "items" : [
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Use the ",
                      "type" : "text"
                    },
                    {
                      "inlineContent" : [
                        {
                          "code" : "Swift: Create New Project...",
                          "type" : "codeVoice"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : " command from the command palette to initialize a new project.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            },
            {
              "content" : [
                {
                  "inlineContent" : [
                    {
                      "text" : "Navigate to ",
                      "type" : "text"
                    },
                    {
                      "inlineContent" : [
                        {
                          "code" : "File > Open Folder",
                          "type" : "codeVoice"
                        }
                      ],
                      "type" : "strong"
                    },
                    {
                      "text" : " in the menu bar to open an existing project on your machine.",
                      "type" : "text"
                    }
                  ],
                  "type" : "paragraph"
                }
              ]
            }
          ],
          "type" : "unorderedList"
        }
      ],
      "kind" : "content"
    }
