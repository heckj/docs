{
  "abstract" : [
    {
      "text" : "On macOS, iOS, and Linux, the ",
      "type" : "text"
    },
    {
      "code" : "libdispatch",
      "type" : "codeVoice"
    },
    {
      "text" : "-based executor is used by default, but ",
      "type" : "text"
    },
    {
      "code" : "libdispatch",
      "type" : "codeVoice"
    },
    {
      "text" : " is not supported in a single-threaded WebAssembly environment.",
      "type" : "text"
    },
    {
      "text" : " ",
      "type" : "text"
    },
    {
      "text" : "However, there are still two global task executors available in Swift for Wasm.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/WasmGuide\/documentation\/WasmGuide"
      ],
