{
  "abstract" : [
    {
      "text" : "WebAssembly modules often need to interact with their host environment.",
      "type" : "text"
    },
    {
      "text" : " ",
      "type" : "text"
    },
    {
      "text" : "This guide demonstrates how to build a Swift guest module that both exports",
      "type" : "text"
    },
    {
      "text" : " ",
      "type" : "text"
    },
    {
      "text" : "functions to the host and imports functions from it, using ",
      "type" : "text"
    },
    {
      "code" : "WasmKit",
      "type" : "codeVoice"
    },
    {
      "text" : " as the host application.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
    "paths" : [
      [
        "doc:\/\/WasmGuide\/documentation\/WasmGuide"
      ],
