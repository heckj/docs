{
  "abstract" : [
    {
      "text" : "Swift for WebAssembly supports both ",
      "type" : "text"
    },
    {
      "code" : "swift-testing",
      "type" : "codeVoice"
    },
    {
      "text" : " and ",
      "type" : "text"
    },
    {
      "code" : "XCTest",
      "type" : "codeVoice"
    },
    {
      "text" : " for writing test suites. Your project needs to have a",
      "type" : "text"
    },
    {
      "text" : " ",
      "type" : "text"
    },
    {
      "code" : "Package.swift",
      "type" : "codeVoice"
    },
    {
      "text" : " package manifest with test targets configured.",
      "type" : "text"
    }
  ],
  "hierarchy" : {
